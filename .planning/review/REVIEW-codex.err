   347	        private static double ReadBeDouble(byte[] b)
   348	        {
   349	            var fp = new byte[8];
   350	            for (int i = 0; i < 8; i++) fp[i] = BitConverter.IsLittleEndian ? b[7 - i] : b[i];
   351	            return BitConverter.ToDouble(fp, 0);
   352	        }
