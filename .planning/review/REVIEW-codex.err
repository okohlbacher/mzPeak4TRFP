   220	        public override void Write(IRawDataPlus raw, int firstScanNumber, int lastScanNumber)
   221	        {
   222	            if (!raw.HasMsData)
   223	            {
   224	                throw new RawFileParserException("No MS data in RAW file, no output will be produced");
   225	            }
