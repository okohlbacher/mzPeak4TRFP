  1663	        // Maps each MSn child's own ordinal (source_index) to its precursor_index (parent ordinal, null
  1664	        // when the parent was not emitted) and its selected-ion intensity (null when not read).
  1665	        private static (Dictionary<ulong, ulong?> precursorIndex, Dictionary<ulong, float?> selIntensity)
  1666	            ReadMsnChildMaps(byte[] metaBytes)
  1667	        {
  1668	            using (var ms = new MemoryStream(metaBytes))
  1669	            using (var reader = ParquetReader.CreateAsync(ms).Result)
  1670	            {
  1671	                var schema = reader.Schema;
  1672	                var rg = reader.OpenRowGroupReader(0);
  1673	
  1674	                var preSrc = rg.ReadColumnAsync(Leaf(schema, "precursor/source_index")).Result;
  1675	                var preIdx = rg.ReadColumnAsync(Leaf(schema, "precursor/precursor_index")).Result;
  1676	                var siSrc = rg.ReadColumnAsync(Leaf(schema, "selected_ion/source_index")).Result;
  1677	                var siInt = rg.ReadColumnAsync(Leaf(schema,
  1678	                    "selected_ion/MS_1000042_intensity_unit_MS_1000131")).Result;
  1679	
  1680	                var precursorIndex = ZipNullable<ulong>(preSrc.Data, preIdx.Data);
  1681	                var selIntensity = ZipNullable<float>(siSrc.Data, siInt.Data);
  1682	                return (precursorIndex, selIntensity);
  1683	            }
  1684	        }
  1685	
  1686	        // Pairs a nullable source_index column (one defined value per MSn row, null on the padded tail)
  1687	        // with a value column that holds a value only where present, producing source_index -> value?
  1688	        // (null where the value itself is absent). Rows whose source_index is null are skipped.
  1689	        private static Dictionary<ulong, T?> ZipNullable<T>(Array keys, Array values) where T : struct
  1690	        {
  1691	            var map = new Dictionary<ulong, T?>();
  1692	            for (int i = 0; i < keys.Length; i++)
  1693	            {
  1694	                var key = keys.GetValue(i);
  1695	                if (key == null) continue;
  1696	                var v = values.GetValue(i);
  1697	                map[(ulong)key] = v == null ? (T?)null : (T)v;
  1698	            }
  1699	            return map;
  1700	        }
