   905	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   906	            var dir = Convert(input, out var archive);
   907	            var jsonPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".json");
   908	            try
