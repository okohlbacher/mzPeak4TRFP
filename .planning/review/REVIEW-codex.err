files=[\"spectra_metadata.parquet\",\"spectra_data.parquet\",\"spectra_peaks.parquet\",\"chromatograms_metadata.parquet\",\"chromatograms_data.parquet\"]
def read_bytes(root, name):
    if root.is_dir(): return (root/name).read_bytes()
    with zipfile.ZipFile(root) as z: return z.read(name)
for root in roots:
    print(\"===\", root.name)
    if root.is_dir():
        names=sorted(p.name for p in root.iterdir())
    else:
