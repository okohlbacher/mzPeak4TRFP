   595	
   596	        // Every MS_/UO_/IMS_ CV code embedded in any column name across the metadata schema, as the
   597	        // validator's cv_list_declared rule collects them.
   598	        private static HashSet<string> CollectedCvCodes(byte[] metaBytes)
   599	        {
   600	            var codes = new HashSet<string>();
   601	            using (var ms = new MemoryStream(metaBytes))
   602	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   603	            {
   604	                foreach (var d in reader.Schema.GetDataFields())
   605	                {
   606	                    foreach (System.Text.RegularExpressions.Match mch in
   607	                        System.Text.RegularExpressions.Regex.Matches(d.Path.ToString(), @"(MS|UO|IMS)_\d+"))
   608	                    {
   609	                        codes.Add(mch.Groups[1].Value);
   610	                    }
   611	                }
   612	            }
   613	            return codes;
   614	        }
