   218	        /// <summary>
   219	        /// Calculate the precursor peak intensity (similar to modern MSConvert).
   220	        /// Sum intensities of all peaks in the isolation window.
   221	        /// </summary>
   222	        /// <param name="rawFile">the RAW file object</param>
   223	        /// <param name="precursorScanNumber">the precursor scan number</param>
   224	        /// <param name="precursorMass">the precursor mass</param>
   225	        /// <param name="isolationWidth">the isolation width</param>
   226	        /// <param name="useProfile">profile/centroid switch</param>
   227	        protected static double CalculatePrecursorPeakIntensity(IRawDataPlus rawFile, int precursorScanNumber,
   228	            double precursorMass, double? isolationWidth, bool useProfile)
   229	        {
   230	            double precursorIntensity = 0;
   231	            double halfWidth = isolationWidth is null || isolationWidth == 0 ? 0 : DefaultIsolationWindowLowerOffset; // that is how it is made in MSConvert (why?)
   232	
   233	            double[] masses;
   234	            double[] intensities;
   235	
   236	            // Get the mz-array from RAW file or cache
   237	            if (precursorCache.ContainsKey(precursorScanNumber))
   238	            {
   239	                masses = precursorCache[precursorScanNumber].Masses;
   240	                intensities = precursorCache[precursorScanNumber].Intensities;
   241	            }
   242	            else
   243	            {
   244	                Scan scan = Scan.FromFile(rawFile, precursorScanNumber);
   245	
   246	                if (useProfile) //get the profile data
   247	                {
   248	                    masses = scan.SegmentedScan.Positions;
   249	                    intensities = scan.SegmentedScan.Intensities;
   250	                }
   251	                else
   252	                {
   253	                    if (scan.HasCentroidStream) //use centroids if possible
   254	                    {
   255	                        masses = scan.CentroidScan.Masses;
   256	                        intensities = scan.CentroidScan.Intensities;
   257	                    }
   258	                    else
   259	                    {
   260	                        var scanEvent = rawFile.GetScanEventForScanNumber(precursorScanNumber);
   261	                        if (scan.SegmentedScan.PositionCount > 0)
   262	                        {
   263	                            var centroidedScan = scanEvent.ScanData == ScanDataType.Profile //only centroid profile spectra
   264	                                ? Scan.ToCentroid(scan).SegmentedScan
   265	                                : scan.SegmentedScan;
   266	
   267	                            masses = centroidedScan.Positions;
   268	                            intensities = centroidedScan.Intensities;
   269	                        }
   270	                        else
   271	                        {
   272	                            masses = Array.Empty<double>();
   273	                            intensities = Array.Empty<double>();
   274	                        }
   275	                    }
   276	                }
   277	
   278	                //save to cache
   279	                precursorCache.Add(precursorScanNumber, new MZArray { Masses = masses, Intensities = intensities });
   280	            }
   281	
   282	            var index = masses.FastBinarySearch(precursorMass - halfWidth); //set index to the first peak inside isolation window
   283	
   284	            while (index > 0 && index < masses.Length && masses[index] < precursorMass + halfWidth) //negative index means value was not found
   285	            {
   286	                precursorIntensity += intensities[index];
   287	                index++;
   288	            }
   289	
   290	            return precursorIntensity;
   291	        }
