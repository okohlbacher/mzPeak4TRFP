  1472	            var present = new List<string>();
  1473	            for (int i = 0; i < n; i++)
  1474	            {
  1475	                if (i >= m) rows.Add(MzPeakParquet.Absent());
  1476	                else if (values[i] != null) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i]); }
  1477	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
