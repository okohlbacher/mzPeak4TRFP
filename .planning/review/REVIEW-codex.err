   104	        private static ChromFacet ReadChromFacet(byte[] bytes)
   105	        {
   106	            using (var ms = new MemoryStream(bytes))
   107	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   108	            {
   109	                var schema = reader.Schema;
   110	                var rg = reader.OpenRowGroupReader(0);
   111	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/chromatogram_index")).Result.Data
   112	                    .Cast<ulong>().ToArray();
   113	                var time = rg.ReadColumnAsync(Leaf(schema, "point/time")).Result.Data
   114	                    .Cast<double>().ToArray();
   115	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
   116	                    .Cast<float>().ToArray();
   117	                var lvl = rg.ReadColumnAsync(Leaf(schema, "point/ms_level")).Result.Data
   118	                    .Cast<long>().ToArray();
   119	                var meta = reader.CustomMetadata;
   120	                return new ChromFacet
   121	                {
   122	                    ChromatogramIndex = idx,
   123	                    Time = time,
   124	                    Intensity = inten,
   125	                    MsLevel = lvl,
   126	                    TicSource = meta["chromatogram_tic_source"],
   127	                    PointCount = int.Parse(meta["chromatogram_data_point_count"])
   128	                };
   129	            }
   130	        }
   131	
   132	        // Runs a pyarrow snippet against an arbitrary parquet entry of the archive (the {PARQUET}
   133	        // token is replaced with the temp file path), returning the printed JSON object.
   134	        private static JObject PyArrowEntry(string archive, string entry, string snippet)
   135	        {
   136	            var python = ResolvePython();
   137	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   138	
   139	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   140	            File.WriteAllBytes(path, ReadEntry(archive, entry));
   141	            try
   142	            {
   143	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   144	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   145	                {
   146	                    RedirectStandardOutput = true,
   147	                    RedirectStandardError = true,
   148	                    UseShellExecute = false
   149	                };
   150	                using (var proc = Process.Start(psi))
   151	                {
   152	                    var stdout = proc.StandardOutput.ReadToEnd();
   153	                    var stderr = proc.StandardError.ReadToEnd();
   154	                    proc.WaitForExit();
   155	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   156	                    return JObject.Parse(stdout.Trim());
   157	                }
   158	            }
   159	            finally
   160	            {
   161	                File.Delete(path);
   162	            }
   163	        }
