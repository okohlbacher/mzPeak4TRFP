   565	        [Test]
   566	        public void Footer_ArrayIndex_Lock()
   567	        {
   568	            var root = RepoRoot();
   569	            if (root == null) Assert.Ignore("reference archive not found");
   570	            var chunked = Convert(false, out var cdir);
   571	            var pointed = Convert(true, out var pdir);
   572	            try
   573	            {
   574	                var footerSnippet =
   575	                    "import pyarrow.parquet as pq, json\n" +
   576	                    "m = pq.read_metadata(r'{PARQUET}').metadata\n" +
   577	                    "print(m[b'spectrum_array_index'].decode())\n";
   578	
   579	                var ours = PyArrow(chunked, "spectra_data.parquet", footerSnippet);
   580	                Assert.That((string)ours["prefix"], Is.EqualTo("chunk"));
   581	                var entries = (JArray)ours["entries"];
   582	                Assert.That(entries.Select(e => (string)e["buffer_format"]).ToArray(),
   583	                    Is.EqualTo(new[] { "chunk_start", "chunk_end", "chunk_values", "chunk_encoding", "chunk_secondary" }));
   584	
   585	                var refArchive = Path.Combine(root, ReferenceChunkedArchive);
   586	                var refFooter = PyArrow(refArchive, "spectra_data.parquet", footerSnippet);
   587	                var refEntries = (JArray)refFooter["entries"];
   588	                var refTransforms = refEntries.Select(e => (string)e["transform"]).ToArray();
   589	                Assert.That(entries.Select(e => (string)e["transform"]).ToArray(), Is.EqualTo(refTransforms),
   590	                    "transform CURIEs match the reference footer verbatim");
   591	
   592	                // m/z entries carry sorting_rank 0; the intensity entry omits it.
   593	                for (int i = 0; i < 4; i++)
   594	                    Assert.That((int)entries[i]["sorting_rank"], Is.EqualTo(0), $"m/z entry {i} sorting_rank 0");
   595	                Assert.That(entries[4]["sorting_rank"].Type, Is.EqualTo(JTokenType.Null),
   596	                    "intensity entry omits sorting_rank");
   597	
   598	                var pointFooter = PyArrow(pointed, "spectra_data.parquet", footerSnippet);
   599	                Assert.That((string)pointFooter["prefix"], Is.EqualTo("point"),
   600	                    "--point mode retains the v1 point array_index");
   601	                Assert.That(((JArray)pointFooter["entries"]).Select(e => (string)e["buffer_format"]).ToArray(),
   602	                    Is.EqualTo(new[] { "point", "point" }));
   603	            }
   604	            finally { Directory.Delete(cdir, true); Directory.Delete(pdir, true); }
   605	        }
   606	
   607	        [Test]
   608	        public void BitwiseMultiset_Chunked_Equals_Point()
   609	        {
   610	            var chunked = Convert(false, out var cdir);
   611	            var pointed = Convert(true, out var pdir);
   612	            try
   613	            {
   614	                // Decode chunked m/z with the null-aware delta decode, build per-spectrum BITWISE keys
   615	                // (DoubleToInt64Bits / SingleToInt32Bits), and compare the multisets to the point facet.
   616	                var decodeSnippet =
   617	                    "import pyarrow.parquet as pq, json, struct\n" +
   618	                    "from collections import defaultdict\n" +
   619	                    "def dd(start, arr):\n" +
   620	                    "    buf=[]; last=start\n" +
   621	                    "    if not arr: return [start]\n" +
   622	                    "    if arr[0] is None:\n" +
   623	                    "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   624	                    "        last=None\n" +
   625	                    "    else: buf.append(start)\n" +
   626	                    "    for it in arr:\n" +
   627	                    "        if it is not None:\n" +
   628	                    "            if last is not None: last=it+last; buf.append(last)\n" +
   629	                    "            else: buf.append(it); last=it\n" +
   630	                    "        else: buf.append(None); last=None\n" +
   631	                    "    return buf\n" +
   632	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   633	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   634	                    "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   635	                    "d=defaultdict(list)\n" +
   636	                    "for i in range(len(si)):\n" +
   637	                    "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
   638	                    "    for m,it in zip(dmz, inn[i]):\n" +
   639	                    "        if m is None or it is None: continue\n" +
   640	                    "        d[si[i]].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   641	                    "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   642	                var chunkKeys = PyArrow(chunked, "spectra_data.parquet", decodeSnippet);
   643	
   644	                var pointSnippet =
   645	                    "import pyarrow.parquet as pq, json, struct\n" +
   646	                    "from collections import defaultdict\n" +
   647	                    "t = pq.read_table(r'{PARQUET}').column('point').combine_chunks()\n" +
   648	                    "si=t.field('spectrum_index').to_pylist(); mz=t.field('mz').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   649	                    "d=defaultdict(list)\n" +
   650	                    "for s,m,it in zip(si,mz,inn):\n" +
   651	                    "    d[s].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   652	                    "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   653	                var pointKeys = PyArrow(pointed, "spectra_data.parquet", pointSnippet);
   654	
   655	                Assert.That(chunkKeys.Properties().Select(p => p.Name).OrderBy(x => x),
   656	                    Is.EqualTo(pointKeys.Properties().Select(p => p.Name).OrderBy(x => x)),
   657	                    "same spectrum_index set");
   658	
   659	                int mzMismatch = 0, intMismatch = 0;
   660	                foreach (var prop in chunkKeys.Properties())
   661	                {
   662	                    var c = ((JArray)prop.Value).Select(a => ((long)a[0], (int)a[1])).OrderBy(x => x).ToArray();
   663	                    var p = ((JArray)pointKeys[prop.Name]).Select(a => ((long)a[0], (int)a[1])).OrderBy(x => x).ToArray();
   664	                    Assert.That(c.Length, Is.EqualTo(p.Length), $"spectrum {prop.Name} point count");
   665	                    var cMz = c.Select(x => x.Item1).ToArray(); var pMz = p.Select(x => x.Item1).ToArray();
   666	                    var cIn = c.Select(x => x.Item2).OrderBy(x => x).ToArray();
   667	                    var pIn = p.Select(x => x.Item2).OrderBy(x => x).ToArray();
   668	                    if (!cMz.SequenceEqual(pMz)) mzMismatch++;
   669	                    if (!cIn.SequenceEqual(pIn)) intMismatch++;
   670	                }
   671	                // Intensity is never delta-encoded -> must be bitwise-identical.
   672	                Assert.That(intMismatch, Is.EqualTo(0), "intensity is bitwise-identical chunked vs point");
   673	                // Empirical finding (recorded in SUMMARY): f64 delta encode+reconstruct is bit-exact on real
   674	                // Thermo m/z, so the m/z multiset matches bitwise with zero tolerance (exact / L1).
   675	                Assert.That(mzMismatch, Is.EqualTo(0),
   676	                    "m/z is BITWISE-identical chunked vs point (delta round-trip is bit-exact on Thermo m/z)");
   677	            }
   678	            finally { Directory.Delete(cdir, true); Directory.Delete(pdir, true); }
   679	        }
   680	
   681	        // The chunk decode snippet shared by the bitwise-equivalence locks: null-aware delta decode of
   682	        // every chunk row across ALL row groups (pyarrow read_table merges row groups), emitting a
   683	        // per-spectrum map of sorted [mz_bits, intensity_bits] pairs with null pairs dropped.
   684	        private const string ChunkDecodeSnippet =
   685	            "import pyarrow.parquet as pq, json, struct\n" +
   686	            "from collections import defaultdict\n" +
   687	            "def dd(start, arr):\n" +
   688	            "    buf=[]; last=start\n" +
   689	            "    if not arr: return [start]\n" +
   690	            "    if arr[0] is None:\n" +
   691	            "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   692	            "        last=None\n" +
   693	            "    else: buf.append(start)\n" +
   694	            "    for it in arr:\n" +
   695	            "        if it is not None:\n" +
   696	            "            if last is not None: last=it+last; buf.append(last)\n" +
   697	            "            else: buf.append(it); last=it\n" +
   698	            "        else: buf.append(None); last=None\n" +
   699	            "    return buf\n" +
   700	            "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   701	            "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   702	            "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   703	            "d=defaultdict(list)\n" +
   704	            "for i in range(len(si)):\n" +
   705	            "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
   706	            "    for m,it in zip(dmz, inn[i]):\n" +
   707	            "        if m is None or it is None: continue\n" +
   708	            "        d[si[i]].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   709	            "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   710	
   711	        private static int RowGroupCount(string archive, string entry)
   712	        {
   713	            using (var ms = new MemoryStream(ReadEntry(archive, entry)))
   714	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   715	                return reader.RowGroupCount;
   716	        }
   717	
   718	        [Test]
   719	        public void ChunkFacet_MultiRowGroup_Equals_SingleRowGroup()
   720	        {
   721	            // Single-row-group chunked run (production cap): one row group for small.RAW.
   722	            var single = Convert(false, out var sdir);
   723	            try
   724	            {
   725	                Assert.That(RowGroupCount(single, "spectra_data.parquet"), Is.EqualTo(1),
   726	                    "production cap yields a single chunk row group for small.RAW");
   727	                var singleKeys = PyArrow(single, "spectra_data.parquet", ChunkDecodeSnippet);
   728	
   729	                // Lowered-cap chunked run through the REAL writer flush path: forces >=2 chunk row groups.
   730	                string mdir = null, multi = null;
   731	                try
   732	                {
   733	                    MzPeakSpectrumWriter.TestRowGroupRowCap = 8;
   734	                    multi = Convert(false, out mdir);
   735	                    Assert.That(RowGroupCount(multi, "spectra_data.parquet"), Is.GreaterThan(1),
   736	                        "lowered cap must drive the chunk list-column flush path into multiple row groups");
   737	
   738	                    var multiKeys = PyArrow(multi, "spectra_data.parquet", ChunkDecodeSnippet);
   739	
   740	                    Assert.That(multiKeys.Properties().Select(p => p.Name).OrderBy(x => x),
   741	                        Is.EqualTo(singleKeys.Properties().Select(p => p.Name).OrderBy(x => x)),
   742	                        "same spectrum_index set across caps");
   743	
   744	                    foreach (var prop in singleKeys.Properties())
   745	                    {
   746	                        var s = ((JArray)prop.Value).Select(a => ((long)a[0], (int)a[1]))
   747	                            .OrderBy(x => x).ToArray();
   748	                        var m = ((JArray)multiKeys[prop.Name]).Select(a => ((long)a[0], (int)a[1]))
   749	                            .OrderBy(x => x).ToArray();
   750	                        Assert.That(m, Is.EqualTo(s),
   751	                            $"spectrum {prop.Name}: (mz,intensity) multiset BITWISE-identical across caps");
   752	                    }
   753	                }
   754	                finally
   755	                {
   756	                    MzPeakSpectrumWriter.TestRowGroupRowCap = null;
   757	                    if (mdir != null) Directory.Delete(mdir, true);
   758	                }
   759	            }
   760	            finally { Directory.Delete(sdir, true); }

