   211	        [Test]
   212	        public void Numpress_V3_ReferenceRow0_FixedPoint_And_AnchoredBound()
   213	        {
   214	            var root = RepoRoot();
   215	            if (root == null) Assert.Ignore("reference numpress archive not found");
   216	            var refArchive = Path.Combine(root, "refs/mzPeak/small.numpress.mzpeak");
   217	            if (!File.Exists(refArchive)) Assert.Ignore("small.numpress.mzpeak not present");
   218	
   219	            var snippet =
   220	                "import pyarrow.parquet as pq, json, struct\n" +
   221	                "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   222	                "nb=t.field('mz_numpress_linear_bytes').to_pylist()\n" +
   223	                "cs=t.field('mz_chunk_start').to_pylist(); ce=t.field('mz_chunk_end').to_pylist()\n" +
   224	                "row=bytes(nb[0])\n" +
   225	                "print(json.dumps({'bytes':[int(x) for x in row],'start':cs[0],'end':ce[0]}))\n";
   226	            var row0 = PyArrow(refArchive, "spectra_data.parquet", snippet);
   227	            var bytes = ((JArray)row0["bytes"]).Select(x => (byte)(int)x).ToArray();
   228	            double start = (double)row0["start"];
   229	            double end = (double)row0["end"];
   230	
   231	            double fp = ReadBeDouble(bytes);
   232	            Assert.That(fp, Is.EqualTo(10599266.0), "reference row-0 fixed point");
   233	
   234	            var dec = MSNumpress.DecodeLinear(bytes);
   235	            var aligned = AnchorAlign(dec, start, end);
   236	            Assert.That(aligned.Length, Is.GreaterThan(0));
   237	            Assert.That(Math.Abs(aligned[0] - start), Is.LessThanOrEqualTo(0.5 / fp),
   238	                "anchored decode start within 0.5/fp of mz_chunk_start");
   239	            Assert.That(Math.Abs(aligned[aligned.Length - 1] - end), Is.LessThanOrEqualTo(0.5 / fp),
   240	                "anchored decode end within 0.5/fp of mz_chunk_end");
   241	        }
