   729	        private void BuildPrecursor(IRawDataPlus raw, int scanNumber, IScanEvent scanEvent,
   730	            IScanFilter scanFilter, ScanTrailer trailer, IDictionary<int, ulong> scanNumberToOrdinal,
   731	            string filterKey, Record rec)
   732	        {
   733	            rec.IsMsn = true;
   734	
   735	            // Parent scan via Master Scan Number trailer, falling back to the scan-string parent the
   736	            // mzML path derives. Map the parent scan number to its emitted ordinal; if the parent was
   737	            // filtered out / not emitted, keep the precursor entry but leave precursor_index null.
   738	            int parentScan;
   739	            var master = trailer.AsPositiveInt("Master Scan Number:");
   740	            if (master.HasValue) parentScan = master.Value;
   741	            else parentScan = GetParentFromScanString(filterKey);
   742	
   743	            if (parentScan > 0 && scanNumberToOrdinal.TryGetValue(parentScan, out var p))
   744	            {
   745	                rec.PrecursorIndex = p;
   746	                rec.PrecursorId = ConstructSpectrumTitle((int)Device.MS, 1, parentScan);
   747	            }
   748	
   749	            var reaction = GetReaction(scanEvent, scanNumber);
   750	            if (reaction == null) return;
   751	
   752	            double? isolationWidth = reaction.IsolationWidth;
   753	            if (isolationWidth < 0) isolationWidth = null;
   754	
   755	            rec.IsolationTarget = (float)reaction.PrecursorMass;
   756	            if (isolationWidth != null)
   757	            {
   758	                var offset = isolationWidth.Value / 2 + reaction.IsolationWidthOffset;
   759	                rec.IsolationLowerOffset = (float)(isolationWidth.Value - offset);
   760	                rec.IsolationUpperOffset = (float)offset;
   761	            }
   762	
   763	            if (OntologyMapping.DissociationTypes.TryGetValue(reaction.ActivationType, out var diss))
   764	            {
   765	                rec.ActivationParams.Add(new Param { Accession = diss.accession, Name = diss.name });
   766	            }
   767	
   768	            if (reaction.CollisionEnergyValid)
   769	            {
   770	                rec.ActivationParams.Add(new Param
   771	                {
   772	                    Accession = "MS:1000045",
   773	                    Name = "collision energy",
   774	                    Float = reaction.CollisionEnergy,
   775	                    Unit = "UO:0000266"
   776	                });
   777	            }
   778	
   779	            int? charge = trailer.AsPositiveInt("Charge State:");
   780	            double? monoisotopicMz = trailer.AsDouble("Monoisotopic M/Z:");
   781	            rec.SelectedIonMz = CalculateSelectedIonMz(reaction, monoisotopicMz, isolationWidth);
   782	            rec.ChargeState = charge;
   783	
   784	            // Selected-ion intensity is read FROM the parent spectrum, so it is only meaningful when
   785	            // the parent was actually emitted (a committed ordinal). A parent that was skipped/filtered
   786	            // out or whose read fails must never force this otherwise-readable child to fail: gate on
   787	            // the parent ordinal being known, and treat any parent-read error as "intensity unknown".
   788	            if (rec.SelectedIonMz > ZeroDelta && rec.PrecursorIndex.HasValue)
   789	            {
   790	                try
   791	                {
   792	                    rec.SelectedIonIntensity = (float)CalculatePrecursorPeakIntensity(raw, parentScan,
   793	                        reaction.PrecursorMass, isolationWidth,
   794	                        ParseInput.NoPeakPicking.Contains(rec.MsLevel - 1));
   795	                }
   796	                catch (Exception ex)
   797	                {
   798	                    Log.Warn($"Scan #{scanNumber}: parent #{parentScan} intensity unreadable, " +
   799	                             $"selected-ion intensity left null: {ex.Message}");
   800	                }
   801	            }
   802	        }
   803	
   804	        private static void AddStored(ZipArchive zip, string name, byte[] bytes)
   805	        {
   806	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   807	            using (var s = entry.Open())
   808	            {
   809	                s.Write(bytes, 0, bytes.Length);
   810	            }
   811	        }
   812	
   813	        // Streams a finished temp-file facet into a STORED zip entry via a 64 KB bounded CopyTo, never
   814	        // reading the whole facet into a byte[].
   815	        private static void AddStoredFromFile(ZipArchive zip, string name, string tempPath)
   816	        {
   817	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   818	            using (var es = entry.Open())
   819	            using (var src = File.OpenRead(tempPath))
   820	                src.CopyTo(es, 1 << 16);
   821	        }
   822	
   823	        private static StructField PointStructField() =>
   824	            new StructField("point",
   825	                new DataField<ulong>("spectrum_index"),
   826	                new DataField<double>("mz"),
   827	                new DataField<float>("intensity"));
   828	
   829	        // The 6-field chunk struct of the spectra_data chunk layout. mz_chunk_values / intensity are
   830	        // nullable-item lists (the writer emits no nulls; the type stays null-aware for read parity).
   831	        private static StructField ChunkStructField() => ChunkStructField(false);
   832	
   833	        // The chunk struct. In delta mode it is the 6-field reference struct. In numpress mode a 7th
   834	        // field (mz_numpress_linear_bytes, large_list<uint8 not null>) carries the encoded m/z while
   835	        // mz_chunk_values is emitted NULL on every row.
   836	        private static StructField ChunkStructField(bool numpress)
   837	        {
   838	            if (!numpress)
   839	                return new StructField("chunk",
   840	                    new DataField<ulong>("spectrum_index"),
   841	                    new DataField<double>("mz_chunk_start"),
   842	                    new DataField<double>("mz_chunk_end"),
   843	                    new ListField("mz_chunk_values", new DataField<double>("item", true)),
   844	                    new DataField<string>("chunk_encoding"),
   845	                    new ListField("intensity", new DataField<float>("item", true)));
   846	
   847	            return new StructField("chunk",
   848	                new DataField<ulong>("spectrum_index"),
   849	                new DataField<double>("mz_chunk_start"),
   850	                new DataField<double>("mz_chunk_end"),
   851	                new ListField("mz_chunk_values", new DataField<double>("item", true)),
   852	                new DataField<string>("chunk_encoding"),
   853	                new ListField("intensity", new DataField<float>("item", true)),
   854	                new ListField("mz_numpress_linear_bytes", new DataField<byte>("item")));
   855	        }
