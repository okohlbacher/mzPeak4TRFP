    74	            var inten = Enumerable.Range(0, n).Select(i => (float)(i + 1)).ToArray();
    75	
    76	            var rt = RoundTrip(mz, inten, 50.0);
    77	            Assert.That(rt.Count, Is.EqualTo(n));
    78	            foreach (var p in rt)
    79	                Assert.That(MzBits(p.mz), Is.EqualTo(MzBits(345.678901234)),
    80	                    "every repeated m/z reconstructs bit-exactly (delta 0.0)");
    81	        }
