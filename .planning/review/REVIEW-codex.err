   869	        // The spectra_data facet contract shared by the point and chunk layouts: append a scan's
   870	        // (mz,intensity) arrays, expose the running data-point count and temp path, and close with the
   871	        // footer KV. The Write() path selects the implementation by the layout flag.
   872	        private interface ISpectraDataFacet : IDisposable
   873	        {
   874	            string TempPath { get; }
   875	            long PointCount { get; }
   876	            void Append(ulong ordinal, double[] mz, float[] intensity);
   877	            void Close(IReadOnlyDictionary<string, string> finalMetadata);
   878	        }
   879	
   880	        // A point-facet (spectra_data / spectra_peaks) streamed to a seekable temp file in bounded row
   881	        // groups. Staging buffers accumulate per scan and flush at the cap; the final residual buffer is
   882	        // flushed by Close, which also attaches the footer KV before disposing the writer.
   883	        private sealed class PointFacetStream : IDisposable, ISpectraDataFacet
   884	        {
   885	            public string TempPath { get; }
   886	            private readonly ParquetSchema _schema;
   887	            private readonly DataField _idx, _mz, _int;
   888	            private readonly int _cap;
   889	            private readonly long _byteCap;
   890	            private long _bufferedBytes;
   891	            private FileStream _sink;
   892	            private MzPeakParquet.Handle _handle;
   893	            private readonly List<ulong> _bIdx = new List<ulong>();
   894	            private readonly List<double> _bMz = new List<double>();
   895	            private readonly List<float> _bInt = new List<float>();
   896	
   897	            // Approximate uncompressed bytes per point row: u64 spectrum_index + f64 mz + f32 intensity.
   898	            private const int PointRowBytes = 8 + 8 + 4;
   899	
   900	            public long PointCount { get; private set; }
   901	
   902	            public PointFacetStream(int cap, long byteCap)
   903	            {
   904	                _cap = cap;
   905	                _byteCap = byteCap;
   906	                TempPath = Path.GetTempFileName();
   907	                _schema = new ParquetSchema(PointStructField());
   908	                _idx = Leaf(_schema, "point/spectrum_index");
   909	                _mz = Leaf(_schema, "point/mz");
   910	                _int = Leaf(_schema, "point/intensity");
   911	                try
   912	                {
   913	                    _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
   914	                    _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
   915	                }
   916	                catch
   917	                {
   918	                    // Self-clean a partially-opened facet: the caller never receives a reference to dispose,
   919	                    // so release the sink and delete the temp file here before the exception propagates.
   920	                    _handle?.Dispose();
   921	                    _sink?.Dispose();
   922	                    TryDelete(TempPath);
   923	                    throw;
   924	                }
   925	            }
   926	
   927	            // The row + byte caps are HARD upper bounds on the in-memory buffer: a single scan's points
   928	            // are split across as many row groups as needed (a scan MAY span row groups in the point
   929	            // layout), filling the remaining capacity, flushing at whichever cap is reached first, then
   930	            // continuing with the same ordinal.
   931	            public void Append(ulong ordinal, double[] mz, float[] intensity)
   932	            {
   933	                int i = 0;
   934	                while (i < mz.Length)
   935	                {
   936	                    int byteRoom = _bufferedBytes >= _byteCap
   937	                        ? 0
   938	                        : (int)Math.Min(int.MaxValue, (_byteCap - _bufferedBytes) / PointRowBytes);
   939	                    int room = Math.Min(_cap - _bIdx.Count, byteRoom);
   940	                    int take = Math.Min(Math.Max(room, 1), mz.Length - i);
   941	                    for (int j = 0; j < take; j++, i++)
   942	                    {
   943	                        _bIdx.Add(ordinal); _bMz.Add(mz[i]); _bInt.Add(intensity[i]);
   944	                    }
   945	                    _bufferedBytes += (long)take * PointRowBytes;
   946	                    if (_bIdx.Count >= _cap || _bufferedBytes >= _byteCap) Flush();
   947	                }
   948	                PointCount += mz.Length;
   949	            }
   950	
   951	            private void Flush()
   952	            {
   953	                if (_bIdx.Count == 0) return;
   954	                var cols = new Dictionary<DataField, (Array, int[], int[])>
   955	                {
   956	                    [_idx] = (_bIdx.ToArray(), null, null),
   957	                    [_mz] = (_bMz.ToArray(), null, null),
   958	                    [_int] = (_bInt.ToArray(), null, null)
   959	                };
   960	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
   961	                _bIdx.Clear(); _bMz.Clear(); _bInt.Clear();
   962	                _bufferedBytes = 0;
   963	            }
   964	
   965	            // Finalize order: flush residual buffer -> CloseAsync(final KV) disposes the writer -> dispose
   966	            // the temp FileStream. After this returns the temp file is fully on disk.
   967	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
   968	            {
   969	                Flush();
   970	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
   971	                _handle = null;
   972	                _sink.Dispose();
   973	                _sink = null;
   974	            }
   975	
   976	            public void Dispose()
   977	            {
   978	                _handle?.Dispose();
   979	                _sink?.Dispose();
   980	            }

 succeeded in 0ms:
   980	            }
   981	        }
   982	
   983	        // A chunked spectra_data facet streamed to a seekable temp file. One chunk struct row per
   984	        // non-empty m/z window per scan: scalar spectrum_index/start/end/encoding plus the two
   985	        // nullable-item lists (mz_chunk_values delta-encoded, intensity verbatim). The row-group cap counts
   986	        // chunk ROWS, not points; a scan contributes as many rows as it has windows.
   987	        private sealed class ChunkFacetStream : IDisposable, ISpectraDataFacet
   988	        {
   989	            public string TempPath { get; }
   990	            private readonly ParquetSchema _schema;
   991	            private readonly DataField _idx, _start, _end, _enc, _mzItem, _intItem, _npkItem;
   992	            private readonly ListField _mzList;
   993	            private readonly int _cap;
   994	            private readonly long _byteCap;
   995	            private long _bufferedBytes;
   996	            private readonly double _chunkSize;
   997	            private readonly bool _numpress;
   998	            private FileStream _sink;
   999	            private MzPeakParquet.Handle _handle;
  1000	
  1001	            private readonly List<ulong> _bIdx = new List<ulong>();
  1002	            private readonly List<double> _bStart = new List<double>();
  1003	            private readonly List<double> _bEnd = new List<double>();
  1004	            private readonly List<string> _bEnc = new List<string>();
  1005	            private readonly List<MzPeakParquet.LeafRow> _mzRows = new List<MzPeakParquet.LeafRow>();
  1006	            private readonly List<double> _mzVals = new List<double>();
  1007	            private readonly List<MzPeakParquet.LeafRow> _intRows = new List<MzPeakParquet.LeafRow>();
  1008	            private readonly List<float> _intVals = new List<float>();
  1009	            private readonly List<MzPeakParquet.LeafRow> _npkRows = new List<MzPeakParquet.LeafRow>();
  1010	            private readonly List<byte> _npkVals = new List<byte>();
  1011	
  1012	            // Approximate uncompressed bytes for a chunk row: the four scalars (~40 B with the encoding
  1013	            // string) + 8 B per delta-encoded m/z value + 4 B per intensity + 1 B per numpress byte.
  1014	            private const int ChunkRowOverheadBytes = 40;
  1015	
  1016	            public long PointCount { get; private set; }
  1017	
  1018	            public ChunkFacetStream(int cap, long byteCap, double chunkSize, bool numpress)
  1019	            {
  1020	                _cap = cap;
  1021	                _byteCap = byteCap;
  1022	                _chunkSize = chunkSize;
  1023	                _numpress = numpress;
  1024	                TempPath = Path.GetTempFileName();
  1025	                _schema = new ParquetSchema(ChunkStructField(numpress));
  1026	                _idx = Leaf(_schema, "chunk/spectrum_index");
  1027	                _start = Leaf(_schema, "chunk/mz_chunk_start");
  1028	                _end = Leaf(_schema, "chunk/mz_chunk_end");
  1029	                _enc = Leaf(_schema, "chunk/chunk_encoding");
  1030	                _mzItem = Leaf(_schema, "chunk/mz_chunk_values/list/item");
  1031	                _mzList = (ListField)FindField(_schema, "chunk/mz_chunk_values");
  1032	                _intItem = Leaf(_schema, "chunk/intensity/list/item");
  1033	                _npkItem = numpress ? Leaf(_schema, "chunk/mz_numpress_linear_bytes/list/item") : null;
  1034	                try
  1035	                {
  1036	                    _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
  1037	                    _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
  1038	                }
  1039	                catch
  1040	                {
  1041	                    _handle?.Dispose();
  1042	                    _sink?.Dispose();
  1043	                    TryDelete(TempPath);
  1044	                    throw;
  1045	                }
  1046	            }
  1047	
  1048	            // Builds one chunk row per non-empty window. Empty scans contribute no row.
  1049	            public void Append(ulong ordinal, double[] mz, float[] intensity)
  1050	            {
  1051	                foreach (var (s, e) in MzPeakChunkCodec.Chunk(mz, _chunkSize))
  1052	                {
  1053	                    int k = e - s;
  1054	                    long rowBytes = ChunkRowOverheadBytes + 4L * k;
  1055	
  1056	                    if (_numpress)
  1057	                    {
  1058	                        var win = new double[k];
  1059	                        for (int i = 0; i < k; i++) win[i] = mz[i + s];
  1060	
  1061	                        _bIdx.Add(ordinal);
  1062	                        _bStart.Add(win[0]);
  1063	                        _bEnd.Add(win[k - 1]);
  1064	                        _bEnc.Add(NumpressLinearCurie);
  1065	
  1066	                        // mz_chunk_values is NULL on every numpress row (parent present, list null).
  1067	                        _mzRows.Add(MzPeakParquet.NullList(_mzList));
  1068	
  1069	                        var bytes = MSNumpress.EncodeLinear(win);
  1070	                        var nLevels = new int[bytes.Length];
  1071	                        var nHas = new bool[bytes.Length];
  1072	                        for (int i = 0; i < bytes.Length; i++)
  1073	                        {
  1074	                            nLevels[i] = _npkItem.MaxDefinitionLevel; nHas[i] = true;
  1075	                            _npkVals.Add(bytes[i]);
  1076	                        }
  1077	                        _npkRows.Add(MzPeakParquet.ListOf(nLevels, nHas));
  1078	                        rowBytes += bytes.Length;
  1079	                    }
  1080	                    else
  1081	                    {
  1082	                        var slice = new double?[k];
  1083	                        for (int i = s; i < e; i++) slice[i - s] = mz[i];
  1084	                        MzPeakChunkCodec.DeltaEncode(slice, out var start, out var end, out var values);
  1085	
  1086	                        _bIdx.Add(ordinal);
  1087	                        _bStart.Add(start);
  1088	                        _bEnd.Add(end);
  1089	                        _bEnc.Add(ChunkEncodingCurie);
  1090	
  1091	                        if (values.Length == 0)
  1092	                        {
  1093	                            _mzRows.Add(MzPeakParquet.EmptyList(_mzList));
  1094	                        }
  1095	                        else
  1096	                        {
  1097	                            var levels = new int[values.Length];
  1098	                            var has = new bool[values.Length];
  1099	                            for (int i = 0; i < values.Length; i++)
  1100	                            {
  1101	                                levels[i] = _mzItem.MaxDefinitionLevel; has[i] = true;
  1102	                                _mzVals.Add(values[i].Value);
  1103	                            }
  1104	                            _mzRows.Add(MzPeakParquet.ListOf(levels, has));
  1105	                        }
  1106	                        rowBytes += 8L * values.Length;
  1107	                    }
  1108	
  1109	                    var iLevels = new int[k];
  1110	                    var iHas = new bool[k];
  1111	                    for (int i = 0; i < k; i++)
  1112	                    {
  1113	                        iLevels[i] = _intItem.MaxDefinitionLevel; iHas[i] = true;
  1114	                        _intVals.Add(intensity[s + i]);
  1115	                    }
  1116	                    _intRows.Add(MzPeakParquet.ListOf(iLevels, iHas));
  1117	
  1118	                    PointCount += k;
  1119	                    _bufferedBytes += rowBytes;
  1120	                    if (_bIdx.Count >= _cap || _bufferedBytes >= _byteCap) Flush();
  1121	                }
  1122	            }
  1123	
  1124	            private void Flush()
  1125	            {
  1126	                if (_bIdx.Count == 0) return;
  1127	                var present = _bIdx.Select(_ => true).ToArray();
  1128	                var (idxDef, _i) = MzPeakParquet.NestedLevels(_idx, present.Select(_ => MzPeakParquet.Present(_idx)).ToArray());
  1129	                var (startDef, _s) = MzPeakParquet.NestedLevels(_start, present.Select(_ => MzPeakParquet.Present(_start)).ToArray());
  1130	                var (endDef, _e) = MzPeakParquet.NestedLevels(_end, present.Select(_ => MzPeakParquet.Present(_end)).ToArray());
  1131	                var (encDef, _c) = MzPeakParquet.NestedLevels(_enc, present.Select(_ => MzPeakParquet.Present(_enc)).ToArray());
  1132	                var (mzDef, mzRep) = MzPeakParquet.NestedLevels(_mzItem, _mzRows);
  1133	                var (intDef, intRep) = MzPeakParquet.NestedLevels(_intItem, _intRows);
  1134	
  1135	                var cols = new Dictionary<DataField, (Array, int[], int[])>
  1136	                {
  1137	                    [_idx] = (_bIdx.ToArray(), idxDef, null),
  1138	                    [_start] = (_bStart.ToArray(), startDef, null),
  1139	                    [_end] = (_bEnd.ToArray(), endDef, null),
  1140	                    [_enc] = (_bEnc.ToArray(), encDef, null),
  1141	                    [_mzItem] = (_mzVals.ToArray(), mzDef, mzRep),
  1142	                    [_intItem] = (_intVals.ToArray(), intDef, intRep)
  1143	                };
  1144	                if (_numpress)
  1145	                {
  1146	                    var (npkDef, npkRep) = MzPeakParquet.NestedLevels(_npkItem, _npkRows);
  1147	                    cols[_npkItem] = (_npkVals.ToArray(), npkDef, npkRep);
  1148	                }
  1149	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
  1150	
  1151	                _bIdx.Clear(); _bStart.Clear(); _bEnd.Clear(); _bEnc.Clear();
  1152	                _mzRows.Clear(); _mzVals.Clear(); _intRows.Clear(); _intVals.Clear();
  1153	                _npkRows.Clear(); _npkVals.Clear();
  1154	                _bufferedBytes = 0;
  1155	            }
  1156	
  1157	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
  1158	            {
  1159	                Flush();
  1160	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
  1161	                _handle = null;
  1162	                _sink.Dispose();
  1163	                _sink = null;
  1164	            }
  1165	
  1166	            public void Dispose()
  1167	            {
  1168	                _handle?.Dispose();
  1169	                _sink?.Dispose();
  1170	            }
  1171	        }
