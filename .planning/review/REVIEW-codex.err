   476	        private static string ResolvePython()
   477	        {
   478	            foreach (var cand in new[] { "python3", "python" })
   479	            {
   480	                try
   481	                {
   482	                    var psi = new ProcessStartInfo(cand, "-c \"import pyarrow\"")
   483	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   484	                    using (var p = Process.Start(psi)) { p.WaitForExit(); if (p.ExitCode == 0) return cand; }
   485	                }
   486	                catch { }
   487	            }
   488	            return null;
   489	        }
   490	
   491	        private static string ResolveValidator()
   492	        {
   493	            try
   494	            {
   495	                var psi = new ProcessStartInfo("mzpeak-validate", "--help")
   496	                { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   497	                using (var p = Process.Start(psi)) { p.WaitForExit(); return "mzpeak-validate"; }
   498	            }
   499	            catch { return null; }
   500	        }
   501	
   502	        // Runs a pyarrow snippet against a named parquet entry of an archive ({PARQUET} token) and returns
   503	        // the printed JSON object. Ignores when python/pyarrow is unavailable.
   504	        private static JObject PyArrow(string archive, string entry, string snippet)
   505	        {
   506	            var python = ResolvePython();
   507	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   508	
   509	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   510	            File.WriteAllBytes(path, ReadEntry(archive, entry));
   511	            try
   512	            {
   513	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   514	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   515	                { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   516	                using (var proc = Process.Start(psi))
   517	                {
   518	                    var stdout = proc.StandardOutput.ReadToEnd();
   519	                    var stderr = proc.StandardError.ReadToEnd();
   520	                    proc.WaitForExit();
   521	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   522	                    return JObject.Parse(stdout.Trim());
   523	                }
   524	            }
   525	            finally { File.Delete(path); }
   526	        }
