   974	        [Test]
   975	        public void Numpress_L2_Bound_And_Intensity_BitExact_vs_Lossless()
   976	        {
   977	            var numpress = Convert(DataMode.Numpress, out var ndir);
   978	            var lossless = Convert(DataMode.Lossless, out var ldir);
   979	            try
   980	            {
   981	                // Decode numpress m/z per chunk via OUR C# anchor-aligned codec (pyarrow only supplies the
   982	                // raw bytes / anchors / intensity). Compare positionally to --lossless (Phase-2 bit-exact).
   983	                var npSnippet =
   984	                    "import pyarrow.parquet as pq, json, struct\n" +
   985	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   986	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   987	                    "ce=t.field('mz_chunk_end').to_pylist(); nb=t.field('mz_numpress_linear_bytes').to_pylist()\n" +
   988	                    "inn=t.field('intensity').to_pylist()\n" +
   989	                    "rows=[]\n" +
   990	                    "for i in range(len(si)):\n" +
   991	                    "    rows.append({'si':si[i],'cs':cs[i],'ce':ce[i],'nb':[int(x) for x in bytes(nb[i])],\n" +
   992	                    "                 'int':[struct.unpack('<i',struct.pack('<f',float(x)))[0] for x in inn[i]]})\n" +
   993	                    "print(json.dumps(rows))\n";
   994	                var npRows = PyArrowArray(numpress, "spectra_data.parquet", npSnippet);
   995	
   996	                var lossSnippet =
   997	                    "import pyarrow.parquet as pq, json, struct\n" +
   998	                    "def dd(start, arr):\n" +
   999	                    "    buf=[]; last=start\n" +
  1000	                    "    if not arr: return [start]\n" +
  1001	                    "    if arr[0] is None:\n" +
  1002	                    "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
  1003	                    "        last=None\n" +
  1004	                    "    else: buf.append(start)\n" +
  1005	                    "    for it in arr:\n" +
  1006	                    "        if it is not None:\n" +
  1007	                    "            if last is not None: last=it+last; buf.append(last)\n" +
  1008	                    "            else: buf.append(it); last=it\n" +
  1009	                    "        else: buf.append(None); last=None\n" +
  1010	                    "    return buf\n" +
  1011	                    "from collections import defaultdict\n" +
  1012	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
  1013	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
  1014	                    "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
  1015	                    "mz=defaultdict(list); it=defaultdict(list)\n" +
  1016	                    "for i in range(len(si)):\n" +
  1017	                    "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
  1018	                    "    for m,v in zip(dmz, inn[i]):\n" +
  1019	                    "        if m is None or v is None: continue\n" +
  1020	                    "        mz[si[i]].append(m); it[si[i]].append(struct.unpack('<i',struct.pack('<f',float(v)))[0])\n" +
  1021	                    "print(json.dumps({'mz':{str(k):v for k,v in mz.items()},'it':{str(k):v for k,v in it.items()}}))\n";
  1022	                var loss = PyArrow(lossless, "spectra_data.parquet", lossSnippet);
  1023	                var lossMz = (JObject)loss["mz"];
  1024	                var lossIt = (JObject)loss["it"];
  1025	
  1026	                // Anti-vacuity: at least one chunk row.
  1027	                Assert.That(npRows.Count, Is.GreaterThan(0), "numpress has at least one chunk row");
  1028	
  1029	                long pointCount = ArchivePointCount(numpress);
  1030	
  1031	                var npMz = new Dictionary<string, List<double>>();
  1032	                var npBound = new Dictionary<string, List<double>>();
  1033	                var npIt = new Dictionary<string, List<int>>();
  1034	                long totalCompared = 0;
  1035	
  1036	                foreach (var row in npRows)
  1037	                {
  1038	                    double cs = (double)row["cs"], ce = (double)row["ce"];
  1039	                    var bytes = ((JArray)row["nb"]).Select(x => (byte)(int)x).ToArray();
  1040	                    var inten = ((JArray)row["int"]).Select(x => (int)x).ToList();
  1041	
  1042	                    double fp = NpFixedPoint(bytes);
  1043	                    Assert.That(double.IsFinite(fp) && fp > 0.0, Is.True, "per-chunk fp finite and > 0");
  1044	
  1045	                    var dec = MzPeakChunkCodec.NumpressDecode(cs, ce, bytes);

