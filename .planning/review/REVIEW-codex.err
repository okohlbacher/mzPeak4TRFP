   439	        private enum DataMode { Numpress, Lossless, Point }
   440	
   441	        // Phase-2 delta-chunk (--lossless) conversion; point=true selects the v1 point layout.
   442	        private static string Convert(bool point, out string dir) =>
   443	            Convert(point ? DataMode.Point : DataMode.Lossless, out dir);
   444	
   445	        private static string Convert(DataMode mode, out string dir)
   446	        {
   447	            dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
   448	            Directory.CreateDirectory(dir);
   449	            var input = new ParseInput(TestRawFile, null, dir, OutputFormat.MzPeak)
   450	            {
   451	                MzPeakPointLayout = mode == DataMode.Point,
   452	                MzPeakNumpress = mode == DataMode.Numpress
   453	            };
   454	            RawFileParser.Parse(input);
   455	            Assert.That(input.Errors, Is.EqualTo(0));
   456	            var archive = Path.Combine(dir, "small.mzpeak");
   457	            Assert.That(File.Exists(archive));
   458	            return archive;
   459	        }
   460	
   461	        private static byte[] ReadEntry(string archive, string name)
   462	        {
   463	            using (var zip = ZipFile.OpenRead(archive))
   464	            {
   465	                var entry = zip.GetEntry(name);
   466	                if (entry == null) return null;
   467	                using (var s = entry.Open())
   468	                using (var ms = new MemoryStream())
   469	                {
   470	                    s.CopyTo(ms);
   471	                    return ms.ToArray();
   472	                }
   473	            }
   474	        }
