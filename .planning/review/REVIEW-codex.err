  1259	        private byte[] BuildMetadataFacet(List<Record> records)
  1260	        {
  1261	            int n = records.Count;
  1262	
  1263	            var spectrum = BuildSpectrumField();
  1264	            var scan = BuildScanField();
  1265	            var precursor = BuildPrecursorField();
  1266	            var selectedIon = BuildSelectedIonField();
  1267	            var schema = new ParquetSchema(spectrum, scan, precursor, selectedIon);
  1268	
  1269	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
  1270	            var presentAll = records.Select(_ => true).ToArray();
  1271	
  1272	            // precursor / selected_ion are independent tables: the k-th MSn (ascending ordinal) sits
  1273	            // at row k, null-padded on rows M..N-1.
  1274	            var msnRecords = records.Where(r => r.IsMsn).OrderBy(r => r.Ordinal).ToList();
  1275	
  1276	            // spectrum facet (present on all N rows)
  1277	            AddScalar(cols, schema, "spectrum/index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1278	            AddScalar(cols, schema, "spectrum/id", records.Select(r => r.Id).ToArray(), presentAll);
