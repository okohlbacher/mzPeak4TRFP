/bin/zsh -lc "python3.11 -c 'exec(\"\"\"
import io, json, zipfile
from pathlib import Path
import pyarrow.parquet as pq
roots=[Path(\"refs/mzPeak/small.unpacked.mzpeak\"), Path(\"refs/mzPeak/small.chunked.mzpeak\"), Path(\"refs/mzPeak/small.numpress.mzpeak\")]
files=[\"spectra_metadata.parquet\",\"spectra_data.parquet\",\"spectra_peaks.parquet\",\"chromatograms_metadata.parquet\",\"chromatograms_data.parquet\"]
def rb(root,name):
    if root.is_dir(): return (root/name).read_bytes()
    with zipfile.ZipFile(root) as z: return z.read(name)
def walk(field,p=\"\"):
    path=f\"{p}/{field.name}\" if p else field.name
    print(\"FIELD\", path, field.type, \"nullable\", field.nullable, \"md\", {k.decode():v.decode() for k,v in (field.metadata or {}).items()})
    typ=field.type
    if hasattr(typ,\"num_fields\"):
        for i in range(typ.num_fields): walk(typ.field(i), path)
for root in roots:
    print(\"===\", root.name)
    names=set(p.name for p in root.iterdir()) if root.is_dir() else set(zipfile.ZipFile(root).namelist())
    for name in files:
        if name not in names: continue
        pf=pq.ParquetFile(io.BytesIO(rb(root,name)))
        print(\"---\", name, \"rows\", pf.metadata.num_rows, \"rowgroups\", pf.metadata.num_row_groups)
        for f in pf.schema_arrow:
            walk(f)
        md={k.decode():v.decode(errors=\"replace\") for k,v in (pf.metadata.metadata or {}).items() if k "'!= b"ARROW:schema"}
        print("KV", json.dumps({k: (v[:300]+"..." if len(v)>300 else v) for k,v in md.items()}, sort_keys=True))
