   869	        [Test]
   870	        public void Validator_Chunked_And_Point_ZeroErrors()
   871	        {
   872	            var validator = ResolveValidator();
   873	            if (validator == null) Assert.Ignore("mzpeak-validate not available");
   874	
   875	            foreach (var point in new[] { false, true })
   876	            {
   877	                var archive = Convert(point, out var dir);
   878	                var jsonPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".json");
   879	                try
   880	                {
   881	                    var psi = new ProcessStartInfo(validator, $"\"{archive}\" --json \"{jsonPath}\"")
   882	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   883	                    using (var p = Process.Start(psi))
   884	                    { p.StandardOutput.ReadToEnd(); p.StandardError.ReadToEnd(); p.WaitForExit(); }
   885	
   886	                    Assert.That(File.Exists(jsonPath), "validator must emit a JSON report");
   887	                    var report = JObject.Parse(File.ReadAllText(jsonPath));
   888	                    var errors = ((JArray)report["findings"])
   889	                        .Where(f => (string)f["level"] == "error")
   890	                        .Select(f => (string)f["ruleId"]).ToArray();
   891	                    Assert.That(errors, Is.Empty,
   892	                        $"{(point ? "--point" : "chunked")} archive must validate 0 errors: {string.Join(",", errors)}");
   893	                }
   894	                finally
   895	                {
   896	                    if (File.Exists(jsonPath)) File.Delete(jsonPath);
   897	                    Directory.Delete(dir, true);
   898	                }
   899	            }
   900	        }
   901	
   902	        [Test]
   903	        public void Size_Chunked_Smaller_Than_Point()
   904	        {
   905	            var chunked = Convert(false, out var cdir);
   906	            var pointed = Convert(true, out var pdir);
   907	            try
   908	            {
   909	                long chunkSize = ReadEntry(chunked, "spectra_data.parquet").Length;
   910	                long pointSize = ReadEntry(pointed, "spectra_data.parquet").Length;
   911	                Assert.That(chunkSize, Is.LessThan(pointSize),
   912	                    $"chunked spectra_data ({chunkSize}) must be smaller than point ({pointSize})");
   913	            }
   914	            finally { Directory.Delete(cdir, true); Directory.Delete(pdir, true); }
   915	        }
