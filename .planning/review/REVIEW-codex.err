   110	            var outp = new double[hi - lo];
   111	            Array.Copy(dec, lo, outp, 0, hi - lo);
   112	            return outp;
   113	        }
   114	
   115	        // Partition a sorted, non-decreasing m/z axis into [start,end) intervals each spanning <= width from
   116	        // the interval's own first m/z. Mirrors null_chunk_every_k: threshold advances by width, a boundary
   117	        // length-1 chunk is rolled into the adjacent chunk, the final residual is always emitted. An empty
   118	        // input yields zero intervals (no chunk row). A single-point spectrum yields one length-1 interval.
   119	        // Throws ArgumentException on non-monotonic (descending) input; the codec assumes ascending order.
   120	        public static List<(int start, int end)> Chunk(double[] mz, double width)
   121	        {
   122	            // A non-finite or non-positive width never advances the threshold and would loop forever;
   123	            // reject it up front so the partition loop is always guaranteed to terminate.
   124	            if (!(width > 0.0) || double.IsInfinity(width))
   125	                throw new ArgumentOutOfRangeException(nameof(width), width,
   126	                    "Chunk width must be a finite value greater than 0.");
   127	
   128	            var result = new List<(int, int)>();
   129	            if (mz == null || mz.Length == 0) return result;
   130	
   131	            for (int i = 1; i < mz.Length; i++)
   132	                if (mz[i] < mz[i - 1])
   133	                    throw new ArgumentException("Chunk requires non-decreasing m/z input.", nameof(mz));
   134	
   135	            int n = mz.Length;
   136	            int offset = 0;
   137	            double threshold = mz[0] + width;
   138	            for (int i = 1; i < n; i++)
   139	            {
   140	                if (mz[i] > threshold)
   141	                {
   142	                    if (i - offset != 1)
   143	                    {
   144	                        result.Add((offset, i));
   145	                        offset = i;
   146	                    }
   147	                    while (threshold < mz[i]) threshold += width;
   148	                }
   149	            }
   150	            result.Add((offset, n));
   151	            return result;
   152	        }
   153	    }
   154	}

