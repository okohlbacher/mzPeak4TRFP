  1490	                .Select(i => (a.SpectrumIndex[i], a.Mz[i], a.Intensity[i]))
  1491	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ThenBy(x => x.Item3).ToArray();
  1492	            var tb = Enumerable.Range(0, b.Mz.Length)
  1493	                .Select(i => (b.SpectrumIndex[i], b.Mz[i], b.Intensity[i]))
  1494	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ThenBy(x => x.Item3).ToArray();
  1495	            Assert.That(tb, Is.EqualTo(ta), "(spectrum_index, mz, intensity) multiset identical across caps");
