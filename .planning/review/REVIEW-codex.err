   468	        // Footer KV for a streamed point facet (spectra_data / spectra_peaks), identical to the v1
   469	        // single-row-group facet's metadata.
   470	        private static Dictionary<string, string> PointFooter(int spectrumCount, long pointCount) =>
   471	            new Dictionary<string, string>
   472	            {
   473	                ["spectrum_count"] = spectrumCount.ToString(),
   474	                ["spectrum_data_point_count"] = pointCount.ToString(),
   475	                ["spectrum_array_index"] = SpectrumArrayIndex
   476	            };
   477	
   478	        // Footer KV for the chunked spectra_data facet: same count keys as the point facet, with the chunk
   479	        // spectrum_array_index instead of the point one.
   480	        private static Dictionary<string, string> ChunkFooter(int spectrumCount, long pointCount, bool numpress) =>
   481	            new Dictionary<string, string>
   482	            {
   483	                ["spectrum_count"] = spectrumCount.ToString(),
   484	                ["spectrum_data_point_count"] = pointCount.ToString(),
   485	                ["spectrum_array_index"] = numpress ? NumpressSpectrumArrayIndex : ChunkedSpectrumArrayIndex
   486	            };
   487	
   488	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   489	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   490	        // index sort is applied only when an ascending violation is detected, never dropping or
   491	        // merging equal-m/z points.
   492	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   493	        {
   494	            var n = masses?.Length ?? 0;
   495	            var mz = new double[n];
   496	            var inten = new float[n];
   497	            bool ascending = true;
   498	            for (int i = 0; i < n; i++)
   499	            {
   500	                mz[i] = masses[i];
   501	                inten[i] = (float)intensities[i];
   502	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   503	            }
   504	
   505	            if (ascending) return (mz, inten);
   506	
   507	            var order = new int[n];
   508	            for (int i = 0; i < n; i++) order[i] = i;
   509	            Array.Sort(order, (a, b) =>
   510	            {
   511	                int c = masses[a].CompareTo(masses[b]);
   512	                return c != 0 ? c : a.CompareTo(b);
   513	            });
   514	            var sortedMz = new double[n];
   515	            var sortedInten = new float[n];
   516	            for (int i = 0; i < n; i++)
   517	            {
   518	                sortedMz[i] = masses[order[i]];
   519	                sortedInten[i] = (float)intensities[order[i]];
   520	            }
   521	            return (sortedMz, sortedInten);
   522	        }
