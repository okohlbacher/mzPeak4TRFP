  1448	            var rows = present.Select(p => p ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1449	            var (def, _r) = MzPeakParquet.NestedLevels(leaf, rows);
  1450	            cols[leaf] = (values, def, null);
  1451	        }
