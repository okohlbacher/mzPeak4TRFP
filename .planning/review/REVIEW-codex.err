   403	        [Test]
   404	        public void Metadata_Scan_And_Spectrum_Facets_Shape_And_Values()
   405	        {
   406	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   407	            var dir = Convert(input, out var archive);
   408	            try
   409	            {
   410	                var snippet =
   411	                    "import pyarrow.parquet as pq, json\n" +
   412	                    "t = pq.read_table(r'{PARQUET}')\n" +
   413	                    "d = t.to_pylist()\n" +
   414	                    "N = len(d)\n" +
   415	                    "sp = [f.name for f in t.schema.field('spectrum').type]\n" +
   416	                    "sc = [f.name for f in t.schema.field('scan').type]\n" +
   417	                    "out = {}\n" +
   418	                    "out['rows'] = N\n" +
   419	                    "out['spectrum_fields'] = sp\n" +
   420	                    "out['scan_fields'] = sc\n" +
   421	                    "out['scan_link_ok'] = all(d[i]['scan']['source_index']==i and d[i]['scan']['scan_index']==i for i in range(N))\n" +
   422	                    "out['polarities'] = sorted(set(int(d[i]['spectrum']['MS_1000465_scan_polarity']) for i in range(N)))\n" +
   423	                    "out['reprs'] = sorted(set(d[i]['spectrum']['MS_1000525_spectrum_representation'] for i in range(N)))\n" +
   424	                    "out['types'] = sorted(set(d[i]['spectrum']['MS_1000559_spectrum_type'] for i in range(N)))\n" +
   425	                    "out['ndp_all_present'] = all(d[i]['spectrum']['MS_1003060_number_of_data_points'] is not None for i in range(N))\n" +
   426	                    "out['npk_present'] = sum(1 for i in range(N) if d[i]['spectrum']['MS_1003059_number_of_peaks'] is not None)\n" +
   427	                    "out['npk_null'] = sum(1 for i in range(N) if d[i]['spectrum']['MS_1003059_number_of_peaks'] is None)\n" +
   428	                    "out['npk_zero'] = any(d[i]['spectrum']['MS_1003059_number_of_peaks']==0 for i in range(N) if d[i]['spectrum']['MS_1003059_number_of_peaks'] is not None)\n" +
   429	                    "out['sw_path'] = str(t.schema.field('scan').type.field('scan_windows').type)\n" +
   430	                    "out['param_path'] = str(t.schema.field('spectrum').type.field('parameters').type)\n" +
   431	                    "out['polarity_type'] = str(t.schema.field('spectrum').type.field('MS_1000465_scan_polarity').type)\n" +
   432	                    "out['scan_start_type'] = str(t.schema.field('scan').type.field('MS_1000016_scan_start_time_unit_UO_0000031').type)\n" +
   433	                    "out['cfg_refs'] = sorted(set(int(d[i]['scan']['instrument_configuration_ref']) for i in range(N)))\n" +
   434	                    "print(json.dumps(out))\n";
   435	                var o = PyArrowMetadata(archive, snippet);
   436	
   437	                Assert.That((int)o["rows"], Is.EqualTo(48));
   438	                Assert.That((bool)o["scan_link_ok"], Is.True);
   439	
   440	                var spectrumFields = o["spectrum_fields"].Select(x => (string)x).ToArray();
   441	                Assert.That(spectrumFields, Does.Contain("MS_1000511_ms_level"));
   442	                Assert.That(spectrumFields, Does.Contain("MS_1000465_scan_polarity"));
   443	                Assert.That(spectrumFields, Does.Contain("MS_1000525_spectrum_representation"));
   444	                Assert.That(spectrumFields, Does.Contain("MS_1000559_spectrum_type"));
   445	                Assert.That(spectrumFields, Does.Contain("MS_1000528_lowest_observed_mz_unit_MS_1000040"));
   446	                Assert.That(spectrumFields, Does.Contain("MS_1000527_highest_observed_mz_unit_MS_1000040"));
   447	                Assert.That(spectrumFields, Does.Contain("MS_1003060_number_of_data_points"));
   448	                Assert.That(spectrumFields, Does.Contain("MS_1003059_number_of_peaks"));
   449	                Assert.That(spectrumFields, Does.Contain("MS_1000504_base_peak_mz_unit_MS_1000040"));
   450	                Assert.That(spectrumFields, Does.Contain("MS_1000505_base_peak_intensity_unit_MS_1000131"));
   451	                Assert.That(spectrumFields, Does.Contain("MS_1000285_total_ion_current_unit_MS_1000131"));
   452	
   453	                var scanFields = o["scan_fields"].Select(x => (string)x).ToArray();
   454	                Assert.That(scanFields, Does.Contain("source_index"));
   455	                Assert.That(scanFields, Does.Contain("scan_index"));
   456	                Assert.That(scanFields, Does.Contain("MS_1000016_scan_start_time_unit_UO_0000031"));
   457	                Assert.That(scanFields, Does.Contain("MS_1000512_filter_string"));
   458	                Assert.That(scanFields, Does.Contain("MS_1000927_ion_injection_time_unit_UO_0000028"));
   459	                Assert.That(scanFields, Does.Contain("instrument_configuration_ref"));
   460	
   461	                // polarity int8 sign in {-1,1}; representation/type CURIE strings.
   462	                Assert.That(o["polarity_type"].ToString(), Is.EqualTo("int8"));
   463	                foreach (var p in o["polarities"]) Assert.That(Math.Abs((int)p), Is.EqualTo(1));
   464	                foreach (var r in o["reprs"]) Assert.That((string)r, Does.Match(@"^MS:\d+$"));
   465	                foreach (var ty in o["types"]) Assert.That((string)ty, Does.Match(@"^MS:\d+$"));
   466	
   467	                // scan_start_time raw float32 minutes.
   468	                Assert.That(o["scan_start_type"].ToString(), Is.EqualTo("float"));
   469	
   470	                // count discipline: data_points always present; peaks NULL where unwritten, never 0.
   471	                Assert.That((bool)o["ndp_all_present"], Is.True);
   472	                Assert.That((int)o["npk_present"], Is.GreaterThan(0));
   473	                Assert.That((int)o["npk_null"], Is.GreaterThan(0));
   474	                Assert.That((bool)o["npk_zero"], Is.False, "number_of_peaks must be NULL, never 0, when no peaks written");
   475	
   476	                // list element named item: paths contain "item:".
   477	                Assert.That(o["sw_path"].ToString(), Does.Contain("item:"));
   478	                Assert.That(o["param_path"].ToString(), Does.Contain("item:"));
   479	
   480	                // two distinct analyzers -> config refs {0,1}.
   481	                Assert.That(o["cfg_refs"].Select(x => (int)x).ToArray(), Is.EqualTo(new[] { 0, 1 }));
   482	            }
   483	            finally
   484	            {
   485	                Directory.Delete(dir, true);
   486	            }
   487	        }
