    30	        // Row-count flush cap for the streamed data facets, a secondary guard against unbounded buffers
    31	        // when individual rows are tiny. Point rows are ~20 bytes; fat chunk rows (lists of m/z values +
    32	        // numpress bytes + intensities) are bounded primarily by RowGroupByteCap below.
    33	        private const int RowGroupRowCap = 1_048_576;
    34	
    35	        // Primary flush cap: approximate uncompressed bytes accumulated in the current row-group buffer.
    36	        // Chunk rows carry variable-length lists, so a row-count cap alone produces a single multi-hundred-
    37	        // megabyte row group on large inputs that standard readers cannot load. Flushing at a healthy
    38	        // Parquet row-group size keeps every row group readable.
    39	        private const long RowGroupByteCap = 64L * 1024 * 1024;
    40	
    41	        // Optional override of the streamed row-count flush cap. When set, the streamed flush path uses
    42	        // this value instead of RowGroupRowCap, lowering the per-row-group bound so a small input still
    43	        // emits multiple row groups through the writer. Left null in normal operation.
    44	        internal static int? TestRowGroupRowCap;
    45	
    46	        // Optional override of the streamed byte flush cap, lowered by tests so a small input crosses the
    47	        // byte budget and emits multiple row groups. Left null in normal operation.
    48	        internal static long? TestRowGroupByteCap;
    49	
    50	        private int Cap => TestRowGroupRowCap ?? RowGroupRowCap;
    51	        private long ByteCap => TestRowGroupByteCap ?? RowGroupByteCap;
