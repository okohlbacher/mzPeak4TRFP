   857	        private static StructField ChromDataStructField() =>
   858	            new StructField("point",
   859	                new DataField<ulong>("chromatogram_index"),
   860	                new DataField<double>("time"),
   861	                new DataField<float>("intensity"),
   862	                new DataField<long>("ms_level"));
