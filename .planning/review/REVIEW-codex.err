  1552	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
  1553	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1554	            string listPath, int n, List<List<Param>> perRow)
  1555	        {
  1556	            int m = perRow.Count;
  1557	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
  1558	            var padded = new List<List<Param>>();
  1559	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
  1560	            AddParamList(cols, schema, listPath, padded, structPresent);
  1561	        }
  1562	
  1563	        private void AddParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1564	            string listPath, List<List<Param>> perRow, bool[] structPresent)
  1565	        {
  1566	            var list = (ListField)FindField(schema, listPath);
  1567	            var accLeaf = Leaf(schema, listPath + "/list/item/accession");
  1568	            var nameLeaf = Leaf(schema, listPath + "/list/item/name");
  1569	            var unitLeaf = Leaf(schema, listPath + "/list/item/unit");
  1570	            var intLeaf = Leaf(schema, listPath + "/list/item/value/integer");
  1571	            var fltLeaf = Leaf(schema, listPath + "/list/item/value/float");
  1572	            var strLeaf = Leaf(schema, listPath + "/list/item/value/string");
  1573	            var boolLeaf = Leaf(schema, listPath + "/list/item/value/boolean");
  1574	
  1575	            var accRows = new List<MzPeakParquet.LeafRow>();
  1576	            var nameRows = new List<MzPeakParquet.LeafRow>();
  1577	            var unitRows = new List<MzPeakParquet.LeafRow>();
  1578	            var intRows = new List<MzPeakParquet.LeafRow>();
  1579	            var fltRows = new List<MzPeakParquet.LeafRow>();
  1580	            var strRows = new List<MzPeakParquet.LeafRow>();
  1581	            var boolRows = new List<MzPeakParquet.LeafRow>();
  1582	
  1583	            var accVals = new List<string>();
  1584	            var nameVals = new List<string>();
  1585	            var unitVals = new List<string>();
  1586	            var intVals = new List<long>();
  1587	            var fltVals = new List<double>();
  1588	            var strVals = new List<string>();
  1589	            var boolVals = new List<bool>();
  1590	
  1591	            for (int row = 0; row < perRow.Count; row++)
  1592	            {
  1593	                if (!structPresent[row])
  1594	                {
  1595	                    accRows.Add(MzPeakParquet.NullList()); nameRows.Add(MzPeakParquet.NullList());
  1596	                    unitRows.Add(MzPeakParquet.NullList()); intRows.Add(MzPeakParquet.NullList());
  1597	                    fltRows.Add(MzPeakParquet.NullList()); strRows.Add(MzPeakParquet.NullList());
  1598	                    boolRows.Add(MzPeakParquet.NullList());
  1599	                    continue;
  1600	                }
  1601	
  1602	                var items = perRow[row];
  1603	                if (items.Count == 0)
  1604	                {
  1605	                    accRows.Add(MzPeakParquet.EmptyList(list)); nameRows.Add(MzPeakParquet.EmptyList(list));
  1606	                    unitRows.Add(MzPeakParquet.EmptyList(list)); intRows.Add(MzPeakParquet.EmptyList(list));
  1607	                    fltRows.Add(MzPeakParquet.EmptyList(list)); strRows.Add(MzPeakParquet.EmptyList(list));
  1608	                    boolRows.Add(MzPeakParquet.EmptyList(list));
  1609	                    continue;
  1610	                }
  1611	
  1612	                foreach (var it in items) { CollectPrefix(it.Accession); CollectPrefix(it.Unit); }
  1613	                AddListLeaf(accRows, accVals, accLeaf, items, p => p.Accession);
  1614	                AddListLeaf(nameRows, nameVals, nameLeaf, items, p => p.Name);
  1615	                AddListLeaf(unitRows, unitVals, unitLeaf, items, p => p.Unit);
  1616	                AddListLeafNumStruct(intRows, intVals, intLeaf, items, p => p.Integer);
  1617	                AddListLeafNumStruct(fltRows, fltVals, fltLeaf, items, p => p.Float);
  1618	                AddListLeaf(strRows, strVals, strLeaf, items, p => p.String);
  1619	                AddListLeafNumStruct(boolRows, boolVals, boolLeaf, items, p => p.Boolean);
  1620	            }
  1621	
  1622	            Emit(cols, accLeaf, accVals.ToArray(), accRows);
  1623	            Emit(cols, nameLeaf, nameVals.ToArray(), nameRows);
  1624	            Emit(cols, unitLeaf, unitVals.ToArray(), unitRows);
  1625	            Emit(cols, intLeaf, intVals.ToArray(), intRows);
  1626	            Emit(cols, fltLeaf, fltVals.ToArray(), fltRows);
  1627	            Emit(cols, strLeaf, strVals.ToArray(), strRows);
  1628	            Emit(cols, boolLeaf, boolVals.ToArray(), boolRows);
  1629	        }
  1630	
  1631	        private static void AddListLeaf(List<MzPeakParquet.LeafRow> rows, List<string> vals, DataField leaf,
  1632	            List<Param> items, Func<Param, string> sel)
  1633	        {
  1634	            var levels = new int[items.Count];
  1635	            var has = new bool[items.Count];
  1636	            for (int i = 0; i < items.Count; i++)
  1637	            {
  1638	                var v = sel(items[i]);
  1639	                if (v != null) { vals.Add(v); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1640	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1641	            }
  1642	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1643	        }
  1644	
  1645	        private static void AddListLeafNumStruct<T>(List<MzPeakParquet.LeafRow> rows, List<T> vals, DataField leaf,
  1646	            List<Param> items, Func<Param, T?> sel) where T : struct
  1647	        {
  1648	            var levels = new int[items.Count];
  1649	            var has = new bool[items.Count];
  1650	            for (int i = 0; i < items.Count; i++)
  1651	            {
  1652	                var v = sel(items[i]);
  1653	                if (v.HasValue) { vals.Add(v.Value); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1654	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1655	            }
  1656	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1657	        }
  1658	
  1659	        private static void Emit(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf,
  1660	            Array values, List<MzPeakParquet.LeafRow> rows)
  1661	        {
  1662	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
  1663	            cols[leaf] = (values, def, rep);
  1664	        }
