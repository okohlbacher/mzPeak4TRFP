  1999	        private static DataField Leaf(ParquetSchema schema, string path)
  2000	        {
  2001	            foreach (var d in schema.GetDataFields())
  2002	                if (d.Path.ToString() == path) return d;
  2003	            throw new RawFileParserException($"Leaf not found: {path}");
  2004	        }
  2005	    }
