  1162	        // Positions sorted but Intensities in acquisition order (the two arrays are not index-paired and
  1163	        // their nonzero counts differ from the writer's realigned output), so re-deriving the exact
  1164	        // per-point intensity pairing from the SegmentedScan alone would require re-implementing the
  1165	        // reader's internal realignment. The differential suite (MzPeakDifferentialTests) compares
  1166	        // intensities value-for-value only over the reference-profile spectra. To avoid overclaiming
  1167	        // beyond that scope, this test asserts L2 here as a structural invariant for every emitted
  1168	        // spectrum (intensity is f32, finite, and the per-spectrum point count equals
  1169	        // number_of_data_points) and additionally runs an independent intensity check against an mzML
  1170	        // re-export of the same RAW for every spectrum that has a clean point-for-point correspondence,
  1171	        // so the value-equality claim rests on a source not derived from our archive.
  1172	        [Test]
  1173	        public void RoundTrip_L1_Mz_BitExact_Vs_IndependentRawRead_L2_Intensity_F32_Structural()
  1174	        {
  1175	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1176	            var dir = Convert(input, out var archive);
  1177	            try
  1178	            {
  1179	                using (var ms = new MemoryStream(ReadEntry(archive, "spectra_data.parquet")))
  1180	                using (var reader = ParquetReader.CreateAsync(ms).Result)
  1181	                {
  1182	                    Assert.That(Leaf(reader.Schema, "point/mz").ClrType, Is.EqualTo(typeof(double)), "m/z f64");
  1183	                    Assert.That(Leaf(reader.Schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)), "intensity f32");
  1184	                }
  1185	
  1186	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
  1187	                var ourMz = new Dictionary<ulong, List<double>>();
  1188	                var ourInt = new Dictionary<ulong, List<float>>();
  1189	                for (int i = 0; i < data.SpectrumIndex.Length; i++)
  1190	                {
  1191	                    var o = data.SpectrumIndex[i];
  1192	                    if (!ourMz.ContainsKey(o)) { ourMz[o] = new List<double>(); ourInt[o] = new List<float>(); }
  1193	                    ourMz[o].Add(data.Mz[i]);
  1194	                    ourInt[o].Add(data.Intensity[i]);
  1195	                }
  1196	
  1197	                var meta = PyArrowEntry(archive, "spectra_metadata.parquet",
  1198	                    "import pyarrow.parquet as pq, json\n" +
  1199	                    "t = pq.read_table(r'{PARQUET}')\n" +
  1200	                    "d = t.to_pylist()\n" +
  1201	                    "out = {'ndp':[int(d[i]['spectrum']['MS_1003060_number_of_data_points']) for i in range(len(d))]}\n" +
  1202	                    "print(json.dumps(out))\n");
  1203	                var ndp = meta["ndp"].Select(x => (int)x).ToArray();
  1204	                int n = ndp.Length;
  1205	
  1206	                using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
  1207	                {
  1208	                    raw.SelectInstrument(Device.MS, 1);
  1209	                    int first = raw.RunHeaderEx.FirstSpectrum;
  1210	                    int last = raw.RunHeaderEx.LastSpectrum;
  1211	                    var ordinalScan = new List<int>();
  1212	                    for (int scan = first; scan <= last; scan++)
  1213	                    {
  1214	                        var sf = raw.GetFilterForScanNumber(scan);
  1215	                        int lvl = (int)sf.MSOrder;
  1216	                        if (lvl > input.MaxLevel || !input.MsLevel.Contains(lvl)) continue;
  1217	                        var seg = Scan.FromFile(raw, scan).SegmentedScan;
  1218	                        if (seg.Positions == null || seg.Positions.Length == 0) continue;
  1219	                        ordinalScan.Add(scan);
  1220	                    }
  1221	
  1222	                    Assert.That(ordinalScan.Count, Is.EqualTo(n),
  1223	                        "ordinal->scan mapping must cover every emitted spectrum");
  1224	
  1225	                    for (ulong ord = 0; ord < (ulong)n; ord++)
  1226	                    {
  1227	                        int scan = ordinalScan[(int)ord];
  1228	                        var seg = Scan.FromFile(raw, scan).SegmentedScan;
  1229	                        // Source m/z, ascending (positions are returned sorted); independent of our archive.
  1230	                        var srcMz = (double[])seg.Positions.Clone();
  1231	                        Array.Sort(srcMz);
  1232	
  1233	                        var aMz = ourMz[ord].ToArray();
  1234	                        var aInt = ourInt[ord].ToArray();
  1235	
  1236	                        Assert.That(aMz.Length, Is.EqualTo(srcMz.Length),
  1237	                            $"ordinal {ord}: our m/z count must equal independent source count");
  1238	                        Assert.That(aMz.Length, Is.EqualTo(ndp[(int)ord]),
  1239	                            $"ordinal {ord}: count must equal number_of_data_points");
  1240	
  1241	                        for (int k = 0; k < aMz.Length; k++)
  1242	                        {
  1243	                            // L1: m/z bit-exact f64 vs the independently re-read source array.
  1244	                            Assert.That(aMz[k], Is.EqualTo(srcMz[k]),
  1245	                                $"ordinal {ord} m/z[{k}] not bit-exact vs independent source");
  1246	                            if (k > 0)
  1247	                                Assert.That(aMz[k], Is.GreaterThanOrEqualTo(aMz[k - 1]),
  1248	                                    $"ordinal {ord} m/z non-decreasing at {k}");
  1249	                            // L2 structural invariant: intensity is finite f32 for every emitted point.
  1250	                            Assert.That(float.IsFinite(aInt[k]), Is.True, $"ordinal {ord} intensity[{k}] finite");
  1251	                        }
  1252	                    }
  1253	                }
  1254	
  1255	                // Independent intensity check for the spectra the differential suite does NOT cover by
  1256	                // value: re-export the same RAW to a profile mzML (a source not derived from our archive)
  1257	                // and compare its decoded intensity arrays, narrowed to f32, against our spectra_data for
  1258	                // every spectrum whose m/z arrays correspond point-for-point. Spectra without a clean
  1259	                // correspondence are reported as structural-only and are not claimed value-equal.
  1260	                AssertIntensityMatchesIndependentMzml(dir, archive, ourMz, ourInt);
  1261	            }
  1262	            finally
  1263	            {
  1264	                Directory.Delete(dir, true);
  1265	            }
  1266	        }
  1267	
  1268	        // Re-exports the test RAW to a profile mzML in-process, decodes its binaryDataArrays in Python
  1269	        // (honoring each array's own 32/64-bit + zlib CV flags), and asserts that, for every emitted
  1270	        // spectrum with a bit-exact m/z correspondence, our f32-narrowed spectra_data intensities equal
  1271	        // the mzML intensities narrowed to f32. The mzML is an independent re-derivation of the RAW, so
  1272	        // matching intensities certify L2 value-equality beyond the differential suite's profile subset.
  1273	        private static void AssertIntensityMatchesIndependentMzml(string dir, string archive,
  1274	            Dictionary<ulong, List<double>> ourMz, Dictionary<ulong, List<float>> ourInt)
  1275	        {
  1276	            var python = ResolvePython();
  1277	            if (python == null) Assert.Ignore("python3 not available");
  1278	
  1279	            var mzml = Path.Combine(dir, "small.indep.profile.mzML");
  1280	            var mzmlInput = new ParseInput(TestRawFile, null, dir, OutputFormat.MzML)
  1281	            {
  1282	                NoPeakPicking = ParseInput.AllLevels
  1283	            };
  1284	            RawFileParser.Parse(mzmlInput);
  1285	            // TRFP names the mzML output after the RAW stem; relocate it to the deterministic path.
  1286	            var produced = Path.Combine(dir, "small.mzML");
  1287	            if (File.Exists(produced) && !File.Exists(mzml)) File.Move(produced, mzml);
  1288	            Assert.That(File.Exists(mzml), "independent profile mzML must exist");
  1289	
  1290	            // Decode the mzML into ordered per-spectrum (mz, intensity) f64 arrays. Index order in the
  1291	            // mzML matches our ordinal order (same scan-range filter, same source), so we compare by
  1292	            // position and only where the m/z arrays correspond exactly.
  1293	            var script = Path.Combine(dir, "decode_mzml.py");
  1294	            File.WriteAllText(script, DecodeMzmlScript);
  1295	            var psi = new ProcessStartInfo(python, $"\"{script}\" \"{mzml}\"")
  1296	            {
  1297	                RedirectStandardOutput = true,
  1298	                RedirectStandardError = true,
  1299	                UseShellExecute = false
  1300	            };
  1301	            string stdout, stderr;
  1302	            using (var proc = Process.Start(psi))
  1303	            {
  1304	                stdout = proc.StandardOutput.ReadToEnd();
  1305	                stderr = proc.StandardError.ReadToEnd();
  1306	                proc.WaitForExit();
  1307	                Assert.That(proc.ExitCode, Is.EqualTo(0), $"mzML decode failed: {stderr}");
  1308	            }
  1309	
  1310	            var spectra = (JArray)JObject.Parse(stdout.Trim())["spectra"];
  1311	            int compared = 0, structuralOnly = 0;
  1312	            for (int i = 0; i < spectra.Count; i++)
  1313	            {
  1314	                var ord = (ulong)i;
  1315	                if (!ourMz.ContainsKey(ord)) { structuralOnly++; continue; }
  1316	                var refMz = ((JArray)spectra[i]["mz"]).Select(x => (double)x).ToArray();
  1317	                var refInt = ((JArray)spectra[i]["intensity"]).Select(x => (double)x).ToArray();
  1318	                var aMz = ourMz[ord];
  1319	                var aInt = ourInt[ord];
  1320	
  1321	                // Only claim value-equality where the two m/z arrays correspond point-for-point.
  1322	                bool corresponds = refMz.Length == aMz.Count;
  1323	                for (int k = 0; corresponds && k < refMz.Length; k++)
  1324	                    if (refMz[k] != aMz[k]) corresponds = false;
  1325	
  1326	                if (!corresponds) { structuralOnly++; continue; }
  1327	
  1328	                compared++;
  1329	                for (int k = 0; k < refInt.Length; k++)
  1330	                {
  1331	                    // Both sides narrowed to f32: our archive stores f32, the mzML carries f64 that the
  1332	                    // writer would have narrowed identically.
  1333	                    Assert.That(aInt[k], Is.EqualTo((float)refInt[k]),
  1334	                        $"ordinal {ord} intensity[{k}] must equal the independent mzML intensity (f32)");
  1335	                }
  1336	            }
  1337	
  1338	            Assert.That(compared, Is.GreaterThan(0),
  1339	                "at least one emitted spectrum must have a bit-exact m/z correspondence to compare by value");
  1340	            TestContext.Out.WriteLine(
  1341	                $"independent intensity check: {compared} spectra value-equal, {structuralOnly} structural-only");
  1342	        }
  1343	
  1344	        // Standard-library mzML decoder: yields per-spectrum (mz, intensity) f64 arrays, decoding each
  1345	        // binaryDataArray per its own precision (32/64-bit float) and compression (zlib/none) CV flags.
  1346	        private const string DecodeMzmlScript =
  1347	            "import sys, json, base64, zlib, struct\n" +
  1348	            "import xml.etree.ElementTree as ET\n" +
  1349	            "path = sys.argv[1]\n" +
  1350	            "ns = {'m': 'http://psi.hupo.org/ms/mzml'}\n" +
  1351	            "tree = ET.parse(path); root = tree.getroot()\n" +
  1352	            "def localname(t):\n" +
  1353	            "    return t.rsplit('}', 1)[-1]\n" +
  1354	            "def decode_array(bda):\n" +
  1355	            "    accs = set()\n" +
  1356	            "    for cv in bda:\n" +
  1357	            "        if localname(cv.tag) == 'cvParam': accs.add(cv.get('accession'))\n" +
  1358	            "    bits = 64 if 'MS:1000523' in accs else (32 if 'MS:1000521' in accs else 64)\n" +
  1359	            "    zipped = 'MS:1000574' in accs\n" +
  1360	            "    is_mz = 'MS:1000514' in accs\n" +

 succeeded in 0ms:
   620	        {
   621	            if (node is JObject obj)
   622	            {
   623	                foreach (var prop in obj.Properties())
   624	                {
   625	                    if ((prop.Name == "accession" || prop.Name == "unit") &&
   626	                        prop.Value.Type == JTokenType.String)
   627	                    {
   628	                        var mch = System.Text.RegularExpressions.Regex.Match(
   629	                            (string)prop.Value, @"^(MS|UO|IMS):\d+$");
   630	                        if (mch.Success) into.Add(mch.Groups[1].Value);
   631	                    }
   632	                    CollectCuriePrefixes(prop.Value, into);
   633	                }
   634	            }
   635	            else if (node is JArray arr)
   636	            {
   637	                foreach (var item in arr) CollectCuriePrefixes(item, into);
   638	            }
   639	        }
   640	
   641	        // The authoritative collected set: every CURIE prefix used in any metadata block, gathered from
   642	        // BOTH the schema column names AND recursively from every accession/unit in the JSON metadata.
   643	        private static HashSet<string> CollectAllCvPrefixes(byte[] metaBytes, JObject metadataBlocks)
   644	        {
   645	            var codes = CollectedCvCodes(metaBytes);
   646	            CollectCuriePrefixes(metadataBlocks, codes);
   647	            return codes;
   648	        }
   649	
   650	        private static Dictionary<string, string> FooterKv(byte[] metaBytes)
   651	        {
   652	            using (var ms = new MemoryStream(metaBytes))
   653	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   654	            {
   655	                return new Dictionary<string, string>(reader.CustomMetadata);
   656	            }
   657	        }
   658	
   659	        [Test]
   660	        public void Metadata_ListLeaf_Paths_Are_Canonical_Item_And_CvValues()
   661	        {
   662	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   663	            var dir = Convert(input, out var archive);
   664	            try
   665	            {
   666	                var metaBytes = ReadEntry(archive, "spectra_metadata.parquet");
   667	                using (var ms = new MemoryStream(metaBytes))
   668	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   669	                {
   670	                    var paths = reader.Schema.GetDataFields().Select(d => d.Path.ToString()).ToHashSet();
   671	
   672	                    // Canonical list-element leaf path is ".../list/item/...", not a flat column.
   673	                    Assert.That(paths.Any(p => p.StartsWith("spectrum/parameters/list/item/")), Is.True,
   674	                        "spectrum.parameters leaves sit under .../list/item/");
   675	                    Assert.That(paths, Does.Contain(
   676	                        "scan/scan_windows/list/item/MS_1000501_scan_window_lower_limit_unit_MS_1000040"));
   677	                    Assert.That(paths, Does.Contain(
   678	                        "scan/scan_windows/list/item/MS_1000500_scan_window_upper_limit_unit_MS_1000040"));
   679	                    Assert.That(paths.Any(p => p.StartsWith("precursor/activation/parameters/list/item/")), Is.True);
   680	                    Assert.That(paths, Does.Contain(
   681	                        "selected_ion/MS_1000744_selected_ion_mz_unit_MS_1000040"));
   682	                    Assert.That(paths, Does.Contain("selected_ion/MS_1000041_charge_state"));
   683	                    Assert.That(paths, Does.Contain(
   684	                        "precursor/isolation_window/MS_1000827_isolation_window_target_mz"),
   685	                        "isolation_window_target_mz carries no unit suffix");
   686	
   687	                    // Ground-truth selected_ion carries ion-mobility columns and a parameters list even
   688	                    // when the source has no mobility values; the struct shape must match exactly.
   689	                    Assert.That(paths, Does.Contain("selected_ion/ion_mobility_value"));
   690	                    Assert.That(paths, Does.Contain("selected_ion/ion_mobility_type"));
   691	                    Assert.That(paths.Any(p => p.StartsWith("selected_ion/parameters/list/item/")), Is.True,
   692	                        "selected_ion.parameters leaves sit under .../list/item/");
   693	                }
   694	
   695	                // CV values: selected_ion_mz finite/positive on MSn rows; charge_state null on small.RAW.
   696	                var snippet =
   697	                    "import pyarrow.parquet as pq, json\n" +
   698	                    "t = pq.read_table(r'{PARQUET}')\n" +
   699	                    "d = t.to_pylist()\n" +
   700	                    "N = len(d)\n" +
   701	                    "M = sum(1 for i in range(N) if d[i]['selected_ion'] is not None and d[i]['selected_ion']['source_index'] is not None)\n" +
   702	                    "out = {}\n" +
   703	                    "out['sel_mz_pos'] = all(d[i]['selected_ion']['MS_1000744_selected_ion_mz_unit_MS_1000040'] > 0 for i in range(M))\n" +
   704	                    "out['charge_all_null'] = all(d[i]['selected_ion']['MS_1000041_charge_state'] is None for i in range(M))\n" +
   705	                    "out['iso_target_pos'] = all(d[i]['precursor']['isolation_window']['MS_1000827_isolation_window_target_mz'] > 0 for i in range(M))\n" +
   706	                    "out['im_value_null'] = all(d[i]['selected_ion']['ion_mobility_value'] is None for i in range(M))\n" +
   707	                    "out['im_type_null'] = all(d[i]['selected_ion']['ion_mobility_type'] is None for i in range(M))\n" +
   708	                    "out['sel_params_empty'] = all(d[i]['selected_ion']['parameters'] == [] for i in range(M))\n" +
   709	                    "print(json.dumps(out))\n";
   710	                var o = PyArrowMetadata(archive, snippet);
   711	                Assert.That((bool)o["sel_mz_pos"], Is.True, "selected_ion_mz positive on every MSn row");
   712	                Assert.That((bool)o["charge_all_null"], Is.True, "small.RAW has no Charge State trailer");
   713	                Assert.That((bool)o["iso_target_pos"], Is.True, "isolation target positive on every MSn row");
   714	                Assert.That((bool)o["im_value_null"], Is.True, "ion_mobility_value null on every MSn row");
   715	                Assert.That((bool)o["im_type_null"], Is.True, "ion_mobility_type null on every MSn row");
   716	                Assert.That((bool)o["sel_params_empty"], Is.True, "selected_ion.parameters empty on every MSn row");
   717	            }
   718	            finally
   719	            {
   720	                Directory.Delete(dir, true);
   721	            }
   722	        }
   723	
   724	        [Test]
   725	        public void Metadata_NumberOfPeaks_Matches_PerOrdinal_Peaks_Facet()
   726	        {
   727	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   728	            var dir = Convert(input, out var archive);
   729	            try
   730	            {
   731	                var peaks = ReadPointFacet(ReadEntry(archive, "spectra_peaks.parquet"));
   732	                var perOrdinal = peaks.SpectrumIndex
   733	                    .GroupBy(x => x)
   734	                    .ToDictionary(g => g.Key, g => (long)g.Count());
   735	
   736	                var snippet =
   737	                    "import pyarrow.parquet as pq, json\n" +
   738	                    "t = pq.read_table(r'{PARQUET}')\n" +
   739	                    "d = t.to_pylist()\n" +
   740	                    "N = len(d)\n" +
   741	                    "out = {'npk': {str(i): d[i]['spectrum']['MS_1003059_number_of_peaks'] for i in range(N)}}\n" +
   742	                    "print(json.dumps(out))\n";
   743	                var o = PyArrowMetadata(archive, snippet);
   744	                var npk = (JObject)o["npk"];
   745	
   746	                foreach (var kv in npk)
   747	                {
   748	                    ulong ord = ulong.Parse(kv.Key);
   749	                    if (kv.Value.Type == JTokenType.Null)
   750	                    {
   751	                        Assert.That(perOrdinal.ContainsKey(ord), Is.False,
   752	                            $"ordinal {ord} has null number_of_peaks but peaks were written");
   753	                    }
   754	                    else
   755	                    {
   756	                        Assert.That(perOrdinal.TryGetValue(ord, out var cnt) && cnt == (long)kv.Value, Is.True,
   757	                            $"ordinal {ord} number_of_peaks must equal its spectra_peaks point count");
   758	                    }
   759	                }
   760	            }
   761	            finally
   762	            {
   763	                Directory.Delete(dir, true);
   764	            }
   765	        }
