 succeeded in 0ms:
     1	#!/usr/bin/env python3.11
     2	"""End-to-end corpus test: for every Thermo RAW that has a reference mzPeak in the
     3	mzML2mzPeak corpus, convert RAW -> mzPeak with TRFP, validate it, and compare it to the
     4	reference. Resumable, smallest-first, bounded concurrency, per-file timeout, temp cleanup.
     5	
     6	  python3.11 tools/e2e/run_corpus_e2e.py [--workers N] [--timeout SEC] [--max-gb G] [--limit K]
     7	
     8	Writes tools/e2e/out/results.json (resume state) + a stamped report.md. Re-running skips
     9	pairs already recorded. Exit 0 if all PASS, 1 if any non-PASS, 2 on harness error.
    10	"""
    11	import os, sys, json, time, subprocess, tempfile, argparse, shutil
    12	from concurrent.futures import ThreadPoolExecutor, as_completed
    13	
    14	HERE = os.path.dirname(os.path.abspath(__file__))
    15	REPO = os.path.abspath(os.path.join(HERE, "..", ".."))
    16	PAIRS = os.path.join(HERE, "corpus_pairs.json")
    17	OUTDIR = os.path.join(HERE, "out")
    18	RESULTS = os.path.join(OUTDIR, "results.json")
    19	DLL = os.path.join(REPO, "ThermoRawFileParser/bin/Release/net8.0/ThermoRawFileParser.dll")
    20	ENV = {**os.environ, "DOTNET_ROLL_FORWARD": "LatestMajor", "DOTNET_ROLL_FORWARD_TO_PRERELEASE": "1"}
    21	
    22	def convert(raw, out, timeout):
    23	    cmd = ["dotnet", DLL, "-i", raw, "-b", out, "-f", "mzpeak"]   # native (AnyCPU 8.0.37)
    24	    t = time.time()
    25	    p = subprocess.run(cmd, env=ENV, capture_output=True, text=True, timeout=timeout)
    26	    return p.returncode == 0 and os.path.exists(out), round(time.time() - t, 1), p.stdout + p.stderr
    27	
    28	def validate(mzp, timeout):
    29	    try:
    30	        p = subprocess.run(["mzpeak-validate", mzp], capture_output=True, text=True, timeout=timeout)
    31	        line = next((l for l in p.stdout.splitlines() if "validation:" in l), p.stdout[:120])
    32	        return ("PASS" in line), line.strip()
    33	    except Exception as e:
    34	        return False, f"validator-error: {e}"
    35	
    36	def compare(ours, ref, timeout):
    37	    try:
    38	        p = subprocess.run(["python3.11", os.path.join(HERE, "compare_mzpeak.py"), ours, ref],
    39	                           capture_output=True, text=True, timeout=timeout)
    40	        return json.loads(p.stdout.strip().splitlines()[-1])
    41	    except Exception as e:
    42	        return {"verdict": "ERROR", "error": f"{type(e).__name__}: {e}"}
    43	
    44	def run_one(pair, timeout):
    45	    raw, ref = pair["raw"], pair["ref_mzpeak"]
    46	    name = os.path.basename(raw)
    47	    rec = {"raw": raw, "ref": ref, "name": name, "raw_mb": pair.get("raw_mb"), "match": pair.get("match")}
    48	    tmpd = tempfile.mkdtemp(prefix="e2e_")
    49	    out = os.path.join(tmpd, "ours.mzpeak")
    50	    try:
    51	        ok, secs, log = convert(raw, out, timeout)
    52	        rec["convert_secs"] = secs
    53	        if not ok:
    54	            rec.update(status="CONVERT_FAIL", detail=log[-400:]); return rec
    55	        vok, vline = validate(out, max(120, timeout // 4))
    56	        rec["validate"] = vline
    57	        cmp = compare(out, ref, max(300, timeout // 2))
    58	        rec["compare"] = cmp
    59	        if cmp.get("verdict") == "PASS" and vok:
    60	            rec["status"] = "PASS"
    61	        elif cmp.get("verdict") == "ERROR":
    62	            rec["status"] = "COMPARE_ERROR"
    63	        elif not vok:
    64	            rec["status"] = "VALIDATE_FAIL"
    65	        else:
    66	            rec["status"] = "DIFF"
    67	        return rec
    68	    except subprocess.TimeoutExpired:
    69	        rec.update(status="TIMEOUT", detail=f">{timeout}s"); return rec
    70	    except Exception as e:
    71	        rec.update(status="ERROR", detail=f"{type(e).__name__}: {e}"); return rec
    72	    finally:
    73	        shutil.rmtree(tmpd, ignore_errors=True)
    74	
    75	def main():
    76	    ap = argparse.ArgumentParser()
    77	    ap.add_argument("--workers", type=int, default=3)
    78	    ap.add_argument("--timeout", type=int, default=1800)
    79	    ap.add_argument("--max-gb", type=float, default=None, help="skip RAW larger than this many GB")
    80	    ap.add_argument("--limit", type=int, default=None, help="only run the first K (smallest) pairs")
    81	    a = ap.parse_args()
    82	    os.makedirs(OUTDIR, exist_ok=True)
    83	    if not os.path.exists(DLL):
    84	        print("ERROR: x64 Release DLL not built:", DLL); sys.exit(2)
    85	    pairs = json.load(open(PAIRS))
    86	    pairs.sort(key=lambda p: p.get("raw_mb") or 0)            # smallest first
    87	    if a.max_gb is not None:
    88	        pairs = [p for p in pairs if (p.get("raw_mb") or 0) / 1024 <= a.max_gb]
    89	    if a.limit:
    90	        pairs = pairs[:a.limit]
    91	    done = {}
    92	    if os.path.exists(RESULTS):
    93	        done = {r["raw"]: r for r in json.load(open(RESULTS))}
    94	    todo = [p for p in pairs if p["raw"] not in done]
    95	    print(f"corpus pairs: {len(pairs)}  already done: {len(pairs)-len(todo)}  to run: {len(todo)}  "
    96	          f"workers={a.workers} timeout={a.timeout}s", flush=True)
    97	    results = list(done.values())
    98	    def flush():
    99	        json.dump(results, open(RESULTS, "w"), indent=2)
   100	    with ThreadPoolExecutor(max_workers=a.workers) as ex:
   101	        futs = {ex.submit(run_one, p, a.timeout): p for p in todo}
   102	        for i, f in enumerate(as_completed(futs), 1):
   103	            r = f.result(); results.append(r); flush()
   104	            c = r.get("compare", {})
   105	            extra = f" exact={c.get('exact_frac')} refContained={c.get('ref_contained_frac')} spectra={c.get('ref_spectra')}" if c else ""
   106	            print(f"[{i}/{len(todo)}] {r['status']:13s} {r.get('raw_mb'):>7}MB {r['name']}"
   107	                  f"  ({r.get('convert_secs','?')}s){extra}", flush=True)
   108	    write_report(results)
   109	    bad = [r for r in results if r["status"] != "PASS"]
   110	    print(f"\nDONE. PASS {len(results)-len(bad)}/{len(results)}. report: {os.path.join(OUTDIR,'report.md')}")
   111	    sys.exit(0 if not bad else 1)
   112	
   113	def write_report(results):
   114	    import collections
   115	    by = collections.Counter(r["status"] for r in results)
   116	    lines = ["# mzPeak E2E corpus comparison (TRFP vs mzML2mzPeak reference)", ""]
   117	    lines.append(f"Pairs run: **{len(results)}** · " + " · ".join(f"{k}: {v}" for k, v in sorted(by.items())))
   118	    lines += ["", "| status | file | RAW MB | spectra | exact% | ref-contained% | convert s | validate |",
   119	              "|---|---|--:|--:|--:|--:|--:|---|"]
   120	    for r in sorted(results, key=lambda r: (r["status"] != "PASS", -(r.get("raw_mb") or 0))):
   121	        c = r.get("compare", {}) or {}
   122	        lines.append(f"| {r['status']} | {r['name']} | {r.get('raw_mb','')} | {c.get('ref_spectra','')} | "
   123	                     f"{c.get('exact_frac','')} | {c.get('ref_contained_frac','')} | {r.get('convert_secs','')} | "
   124	                     f"{(r.get('validate','') or '')[:34]} |")
   125	    nonpass = [r for r in results if r["status"] != "PASS"]
   126	    if nonpass:
   127	        lines += ["", "## Non-PASS detail", ""]
   128	        for r in nonpass:
   129	            lines.append(f"- **{r['name']}** [{r['status']}] — {r.get('detail','')}  compare={json.dumps(r.get('compare',{}))[:300]}")
   130	    open(os.path.join(OUTDIR, "report.md"), "w").write("\n".join(lines) + "\n")
   131	
   132	if __name__ == "__main__":
   133	    main()

