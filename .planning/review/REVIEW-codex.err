  1702	        [Test]
  1703	        public void FailedParent_DoesNotPoison_LaterChild_PrecursorResolution()
  1704	        {
  1705	            // Part A — staging isolation: a post-key read failure on an MS1 must consume no ordinal and no
  1706	            // precursor-map entry. Skip scan 8 (an MS1) through the real Write loop and assert the output
  1707	            // stays dense and every precursor_index still points at a real emitted ordinal.
  1708	            var dirA = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
  1709	            Directory.CreateDirectory(dirA);
  1710	            try
  1711	            {
  1712	                var archive = WriteWithInjection(dirA, failScan: 8, dropParentBeforeChild: null);
  1713	
  1714	                var data = ReadAllRowGroups(ReadEntry(archive, "spectra_data.parquet"));
  1715	                var metaIdx = ReadMetadataIndices(ReadEntry(archive, "spectra_metadata.parquet"));
  1716	
  1717	                Assert.That(data.SpectrumCount, Is.EqualTo(metaIdx.Length),
  1718	                    "metadata rows == data spectrum_count after the skip");
  1719	                Assert.That(metaIdx.OrderBy(x => x).ToArray(),
  1720	                    Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()),
  1721	                    "ordinals dense 0..N-1 despite the skipped scan");
  1722	                Assert.That(data.SpectrumCount, Is.EqualTo(V1SpectrumCount - 1),
  1723	                    "exactly one scan was skipped");
  1724	
  1725	                var (pre, _) = ReadMsnChildMaps(ReadEntry(archive, "spectra_metadata.parquet"));
  1726	                foreach (var v in pre.Values.Where(v => v.HasValue))
  1727	                    Assert.That(v.Value, Is.LessThan((ulong)data.SpectrumCount),
  1728	                        "no precursor_index may dangle past the emitted set");
  1729	            }
  1730	            finally
  1731	            {
  1732	                Directory.Delete(dirA, true);
  1733	            }
  1734	
  1735	            // Part B — the C1 isolation guard: drive the real Write loop so that, at the moment an MSn child
  1736	            // builds its precursor, its resolved parent has a positive scan number but no emitted ordinal
  1737	            // (read-but-not-committed). The child must end with NO precursor_index and NO selected-ion
  1738	            // intensity — it must not read intensity through the absent parent. Before the C1 fix the
