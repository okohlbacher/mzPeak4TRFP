   591	        private byte[] BuildChromatogramMetadataFacet(int n)
   592	        {
   593	            var chromatogram = BuildChromatogramField();
   594	            var precursor = BuildPrecursorField();
   595	            var selectedIon = BuildSelectedIonField();
   596	            var schema = new ParquetSchema(chromatogram, precursor, selectedIon);
   597	
   598	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
   599	            var present = new[] { true };
   600	
   601	            AddScalar(cols, schema, "chromatogram/index", new ulong[] { 0UL }, present);
   602	            AddScalar(cols, schema, "chromatogram/id", new[] { "TIC" }, present);
   603	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1000465", "scan_polarity"),
   604	                new sbyte[] { 0 }, present);
   605	            CollectPrefix("MS:1000235");
   606	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1000626", "chromatogram_type"),
   607	                new[] { "MS:1000235" }, present);
   608	
   609	            var dprLeaf = Leaf(schema, "chromatogram/data_processing_ref");
   610	            var dprRows = new[] { MzPeakParquet.AtLevel(dprLeaf.MaxDefinitionLevel - 1, false) };
   611	            var (dprDef, _) = MzPeakParquet.NestedLevels(dprLeaf, dprRows);
   612	            cols[dprLeaf] = (new string[0], dprDef, null);
   613	
   614	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1003060", "number_of_data_points"),
   615	                new ulong[] { (ulong)n }, present);
   616	
   617	            AddEmptyList(cols, schema, "chromatogram/parameters");
   618	            AddEmptyAuxList(cols, schema, "chromatogram/auxiliary_arrays");
   619	            AddScalar(cols, schema, "chromatogram/number_of_auxiliary_arrays", new uint[] { 0u }, present);
   620	

