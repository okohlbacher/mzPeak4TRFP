  1666	        private void AddScanWindows(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1667	            List<Record> records)
  1668	        {
  1669	            var lowerLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"));
  1670	            var upperLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"));
  1671	
  1672	            var lowerRows = new List<MzPeakParquet.LeafRow>();
  1673	            var upperRows = new List<MzPeakParquet.LeafRow>();
  1674	            var lowerVals = new List<float>();
  1675	            var upperVals = new List<float>();
  1676	
  1677	            for (int row = 0; row < records.Count; row++)
  1678	            {
  1679	                lowerRows.Add(MzPeakParquet.ListOf(new[] { lowerLeaf.MaxDefinitionLevel }, new[] { true }));
  1680	                upperRows.Add(MzPeakParquet.ListOf(new[] { upperLeaf.MaxDefinitionLevel }, new[] { true }));
  1681	                lowerVals.Add(records[row].WindowLower);
  1682	                upperVals.Add(records[row].WindowUpper);
  1683	            }
  1684	
  1685	            Emit(cols, lowerLeaf, lowerVals.ToArray(), lowerRows);
  1686	            Emit(cols, upperLeaf, upperVals.ToArray(), upperRows);
  1687	        }
  1688	
  1689	        private static Field FindField(ParquetSchema schema, string path)
  1690	        {
  1691	            var parts = path.Split('/');
  1692	            Field current = schema.Fields.First(f => f.Name == parts[0]);
  1693	            for (int i = 1; i < parts.Length; i++)
  1694	            {
  1695	                current = ((StructField)current).Fields.First(f => f.Name == parts[i]);
  1696	            }
  1697	            return current;
  1698	        }
