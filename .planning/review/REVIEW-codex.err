   357	        private static double[] AnchorAlign(double[] dec, double start, double end)
   358	        {
   359	            int lo = 0, hi = dec.Length;
   360	            if (hi - lo >= 2 && Math.Abs(dec[lo] - start) > Math.Abs(dec[lo + 1] - start)) lo++;

