     1	#!/usr/bin/env python3.11
     2	"""Compare two mzPeak archives semantically: ours (TRFP) vs a reference (mzML2mzPeak corpus).
     3	
     4	Aligns spectra by nativeID, unions each spectrum's signal across spectra_data + spectra_peaks
     5	(decoding point, delta-chunk, and numpress-linear chunk layouts), and reports per-spectrum
     6	(m/z, intensity) multiset agreement plus ms_level / polarity / RT agreement.
     7	
     8	Usage:  compare_mzpeak.py OURS.mzpeak REFERENCE.mzpeak [--mz-dp 5] [--json]
     9	Exit 0 = equivalent within tolerance, 1 = differences, 2 = engine error.
    10	"""
    11	import sys, json, zipfile, io, struct, collections, argparse
    12	
    13	def _read(zp, name):
    14	    import pyarrow.parquet as pq
    15	    if name not in zp.namelist():
    16	        return None
    17	    return pq.read_table(io.BytesIO(zp.read(name))).to_pylist()
    18	
    19	def _rows(zp, name):
    20	    """Memory-bounded row iterator for large facets (avoids materializing the whole facet)."""
    21	    import pyarrow.parquet as pq
    22	    if name not in zp.namelist():
    23	        return
    24	    pf = pq.ParquetFile(io.BytesIO(zp.read(name)))
    25	    for b in pf.iter_batches(batch_size=65536):
    26	        for r in b.to_pylist():
    27	            yield r
    28	
    29	def _f32(x):
    30	    return struct.unpack("f", struct.pack("f", float(x)))[0]
    31	
    32	def _np_decode(buf, kind):
    33	    import pynumpress, numpy as np
    34	    b = bytes(buf)
    35	    if kind == "linear" and len(b) <= 16:
    36	        # pynumpress 0.0.9 rejects short (<=2-value) linear streams; decode them per canonical:
    37	        # 8-byte BE fixed point, then up to two 4-byte LE int32 values.
    38	        fp = struct.unpack(">d", b[0:8])[0]
    39	        out = []
    40	        if len(b) >= 12:
    41	            out.append(struct.unpack("<i", b[8:12])[0] / fp)
    42	        if len(b) >= 16:
    43	            out.append(struct.unpack("<i", b[12:16])[0] / fp)
    44	        return out
    45	    a = np.frombuffer(b, dtype=np.uint8)
    46	    return list((pynumpress.decode_linear if kind == "linear" else pynumpress.decode_slof)(a))
    47	
    48	def _chunk_mz(c):
    49	    """m/z values for one chunk row: numpress-linear bytes, else delta from start, else absolute."""
    50	    npb = c.get("mz_numpress_linear_bytes")
    51	    if npb:                                            # numpress-linear (CURIE MS:1002312)
    52	        return _np_decode(npb, "linear")
    53	    vals = c.get("mz_chunk_values")
    54	    start = c.get("mz_chunk_start")
    55	    if vals:                                           # delta: start + consecutive (non-null) deltas
    56	        out, mz = ([start] if start is not None else []), start
    57	        for d in vals:
    58	            if d is None:                              # null-marked (zero-stripped) — Phase 4
    59	                continue
    60	            mz += d
    61	            out.append(mz)
    62	        return out
    63	    return [start] if start is not None else []
    64	
    65	def _chunk_intensity(c):
    66	    """intensity values for one chunk row: plain list, else SLOF bytes (reference)."""
    67	    inten = c.get("intensity")
    68	    if inten:
    69	        return [x for x in inten if x is not None]
    70	    slof = c.get("intensity_numpress_slof_bytes")
    71	    if slof:                                           # reference Numpress-SLOF intensity (MS:1002314)
    72	        return _np_decode(slof, "slof")
    73	    return []
    74	
    75	def _decode_chunk_row(c):
    76	    """Yield (mz, intensity) for one chunk row across point/delta/numpress (linear m/z, SLOF intensity)."""
    77	    mzs = _chunk_mz(c)
    78	    inten = _chunk_intensity(c)
    79	    if len(mzs) == len(inten) + 1:                   # pynumpress decode can prepend a phantom anchor
    80	        mzs = mzs[1:]
    81	    elif len(inten) == len(mzs) + 1:
    82	        inten = inten[1:]
    83	    for i in range(min(len(mzs), len(inten))):
    84	        yield float(mzs[i]), inten[i]
    85	
    86	def _signal_by_index(rows_data, rows_peaks):
    87	    """index -> Counter[(mz_key, f32_intensity)] over nonzero points, unioning data + peaks."""
    88	    sig = collections.defaultdict(collections.Counter)
    89	    raw = collections.defaultdict(list)   # index -> [(mz,intensity)]
    90	    if rows_data:
    91	        for r in rows_data:
    92	            if "point" in r and r["point"] is not None:
    93	                p = r["point"]
    94	                raw[p["spectrum_index"]].append((p["mz"], p["intensity"]))
    95	            elif "chunk" in r and r["chunk"] is not None:
    96	                c = r["chunk"]
    97	                raw[c["spectrum_index"]].extend(_decode_chunk_row(c))
    98	    if rows_peaks:
    99	        for r in rows_peaks:
   100	            if r.get("point") is not None:
   101	                p = r["point"]
   102	                raw[p["spectrum_index"]].append((p["mz"], p["intensity"]))
   103	            elif r.get("chunk") is not None:
   104	                c = r["chunk"]
   105	                raw[c["spectrum_index"]].extend(_decode_chunk_row(c))
   106	    return raw
   107	
   108	def _meta(rows):
   109	    """index -> dict(id, ms_level, polarity, rt); only spectrum struct rows."""
   110	    out = {}
   111	    for r in rows or []:
   112	        s = r.get("spectrum")
   113	        if not s:
   114	            continue
   115	        out[s["index"]] = {
   116	            "id": s.get("id"),
   117	            "ms_level": s.get("MS_1000511_ms_level"),
   118	            "polarity": s.get("MS_1000465_scan_polarity"),
   119	            "rt": s.get("time"),
   120	        }
   121	    return out
   122	
   123	def _key_counter(pairs, mz_dp):
   124	    c = collections.Counter()
   125	    for mz, it in pairs:
   126	        if it == 0:
   127	            continue
   128	        c[(round(float(mz), mz_dp), _f32(it))] += 1
   129	    return c
   130	
   131	def compare(ours_path, ref_path, mz_dp=5):
   132	    zo, zr = zipfile.ZipFile(ours_path), zipfile.ZipFile(ref_path)
   133	    om, rm = _meta(_read(zo, "spectra_metadata.parquet")), _meta(_read(zr, "spectra_metadata.parquet"))
   134	    osig = _signal_by_index(_rows(zo, "spectra_data.parquet"), _rows(zo, "spectra_peaks.parquet"))
   135	    rsig = _signal_by_index(_rows(zr, "spectra_data.parquet"), _rows(zr, "spectra_peaks.parquet"))
   136	
   137	    # align by nativeID where present, else by index
   138	    def id2idx(m):
   139	        return {v["id"]: i for i, v in m.items() if v.get("id")}
   140	    oi, ri = id2idx(om), id2idx(rm)
   141	    use_id = len(oi) == len(om) and len(ri) == len(rm) and len(om) and len(rm)
   142	    if use_id:
   143	        shared = sorted(set(oi) & set(ri))
   144	        pairs = [(oi[k], ri[k]) for k in shared]
   145	        align = "nativeID"
   146	    else:
   147	        shared = sorted(set(om) & set(rm))
   148	        pairs = [(i, i) for i in shared]
   149	        align = "index"
   150	
   151	    n_exact = n_mz = n_ref_subset = 0
   152	    ms_ok = pol_ok = rt_ok = 0
   153	    mism = []
   154	    for oidx, ridx in pairs:
   155	        oc = _key_counter(osig.get(oidx, []), mz_dp)
   156	        rc = _key_counter(rsig.get(ridx, []), mz_dp)
   157	        if oc == rc:
   158	            n_exact += 1
   159	        oc_mz = collections.Counter(k[0] for k in oc.elements())
   160	        rc_mz = collections.Counter(k[0] for k in rc.elements())
   161	        if oc_mz == rc_mz:
   162	            n_mz += 1
   163	        if not (rc - oc):           # ref multiset contained in ours (we may emit profile too)
   164	            n_ref_subset += 1
   165	        elif len(mism) < 5:
   166	            mism.append({"ours_idx": oidx, "ref_idx": ridx,
   167	                         "ours_pts": sum(oc.values()), "ref_pts": sum(rc.values())})
   168	        omd, rmd = om.get(oidx, {}), rm.get(ridx, {})
   169	        if omd.get("ms_level") == rmd.get("ms_level"): ms_ok += 1
   170	        if omd.get("polarity") is None or rmd.get("polarity") is None or omd["polarity"] == rmd["polarity"]: pol_ok += 1
   171	        if omd.get("rt") is not None and rmd.get("rt") is not None and abs(omd["rt"] - rmd["rt"]) < 1e-3: rt_ok += 1
   172	
   173	    n = len(pairs)
   174	    out = {
   175	        "ours_spectra": len(om), "ref_spectra": len(rm),
   176	        "spectrum_count_ok": len(om) == len(rm),
   177	        "aligned_by": align, "aligned_spectra": n,
   178	        "exact_multiset": n_exact, "exact_frac": round(n_exact / n, 4) if n else None,
   179	        "mz_set_match": n_mz, "mz_frac": round(n_mz / n, 4) if n else None,
   180	        "ref_contained_in_ours": n_ref_subset, "ref_contained_frac": round(n_ref_subset / n, 4) if n else None,
   181	        "ms_level_match": ms_ok, "polarity_match": pol_ok, "rt_match": rt_ok,
   182	        "mismatch_examples": mism,
   183	    }
   184	    # verdict: same spectrum set, and every reference spectrum's signal reproduced in ours
   185	    out["verdict"] = "PASS" if (out["spectrum_count_ok"] and n and n_ref_subset == n
   186	                                and ms_ok == n and rt_ok == n) else "DIFF"
   187	    return out
   188	
   189	def main():
   190	    ap = argparse.ArgumentParser()
   191	    ap.add_argument("ours"); ap.add_argument("ref")
   192	    ap.add_argument("--mz-dp", type=int, default=5)
   193	    ap.add_argument("--json", action="store_true")
   194	    a = ap.parse_args()
   195	    try:
   196	        r = compare(a.ours, a.ref, a.mz_dp)
   197	    except Exception as e:
   198	        print(json.dumps({"verdict": "ERROR", "error": f"{type(e).__name__}: {e}"}))
   199	        sys.exit(2)
   200	    print(json.dumps(r, indent=2) if a.json else json.dumps(r))
   201	    sys.exit(0 if r["verdict"] == "PASS" else 1)
   202	
   203	if __name__ == "__main__":
