   371	        // Reads and builds everything for one scan into per-scan locals, touching NO shared/streaming
   372	        // state. Returns null for an out-of-range or empty scan (a clean skip); returns the staged scan on
   373	        // success. Any read/build failure throws and is handled by the caller as an error-counted skip, so
   374	        // a failed scan never commits an ordinal, rows, or a precursor-map entry.
   375	        private StagedScan StageScan(IRawDataPlus raw, int scanNumber, ulong ordinal,
   376	            IDictionary<int, ulong> scanNumberToOrdinal)
   377	        {
