   428	        private static string RepoRoot()
   429	        {
   430	            var d = new DirectoryInfo(AppDomain.CurrentDomain.BaseDirectory);
   431	            while (d != null && !File.Exists(Path.Combine(d.FullName, ReferenceChunkedArchive)))
   432	                d = d.Parent;
   433	            return d?.FullName;
