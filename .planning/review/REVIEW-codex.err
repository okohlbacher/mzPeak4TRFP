   528	        [Test]
   529	        public void SchemaDiff_vs_Reference()
   530	        {
   531	            var root = RepoRoot();
   532	            if (root == null) Assert.Ignore("reference archive not found");
   533	            var archive = Convert(false, out var dir);
   534	            try
   535	            {
   536	                var refArchive = Path.Combine(root, ReferenceChunkedArchive);
   537	                var snippet =
   538	                    "import pyarrow.parquet as pq, json\n" +
   539	                    "f = pq.read_table(r'{PARQUET}').schema.field('chunk').type\n" +
   540	                    "out = {'names':[f.field(i).name for i in range(f.num_fields)],\n" +
   541	                    "       'mz_item':str(f.field(3).type.value_field.type),\n" +
   542	                    "       'int_item':str(f.field(5).type.value_field.type)}\n" +
   543	                    "print(json.dumps(out))\n";
   544	                var ours = PyArrow(archive, "spectra_data.parquet", snippet);
   545	                var refs = PyArrow(refArchive, "spectra_data.parquet", snippet);
   546	
   547	                Assert.That(ours["names"].Select(x => (string)x).ToArray(),
   548	                    Is.EqualTo(refs["names"].Select(x => (string)x).ToArray()),
   549	                    "chunk field names match the reference");
   550	                Assert.That((string)ours["mz_item"], Is.EqualTo("double"));
   551	                Assert.That((string)ours["int_item"], Is.EqualTo("float"));
   552	                Assert.That((string)refs["mz_item"], Is.EqualTo("double"));
   553	                Assert.That((string)refs["int_item"], Is.EqualTo("float"));
   554	
   555	                var encSnippet =
   556	                    "import pyarrow.parquet as pq, json\n" +
   557	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   558	                    "print(json.dumps({'enc':sorted(set(t.field('chunk_encoding').to_pylist()))}))\n";
   559	                var ourEnc = PyArrow(archive, "spectra_data.parquet", encSnippet)["enc"].Select(x => (string)x).ToArray();
   560	                Assert.That(ourEnc, Is.EqualTo(new[] { "MS:1003089" }), "chunk_encoding is the reference delta CURIE");
   561	            }
   562	            finally { Directory.Delete(dir, true); }
   563	        }
