   524	        private void CaptureTic(IRawDataPlus raw, List<Record> records, List<double> time,
   525	            List<float> intensity, List<long> msLevel)
   526	        {
   527	            ChromatogramSignal[] trace;
   528	            try
   529	            {
   530	                raw.SelectInstrument(Device.MS, 1);
   531	                var settings = new ChromatogramTraceSettings(TraceType.TIC);
   532	                var data = raw.GetChromatogramData(new IChromatogramSettings[] { settings }, -1, -1);
   533	                trace = ChromatogramSignal.FromChromatogramData(data);
   534	            }
   535	            catch (Exception ex)
   536	            {
   537	                Log.Warn($"Device TIC trace unavailable, falling back to summed TIC: {ex.Message}");
   538	                trace = Array.Empty<ChromatogramSignal>();
   539	            }
   540	
   541	            if (trace.Length == 0)
   542	            {
   543	                foreach (var r in records)
   544	                {
   545	                    time.Add(r.Time);
   546	                    intensity.Add(r.TotalIonCurrent);
   547	                    msLevel.Add(r.MsLevel);
   548	                }
   549	                _chromFromDeviceTrace = false;
   550	                return;
   551	            }
   552	
   553	            var signal = trace[0];
   554	            if (signal.Times.Count == records.Count)
   555	            {
   556	                for (int i = 0; i < records.Count; i++)
   557	                {
   558	                    time.Add(signal.Times[i]);
   559	                    intensity.Add((float)signal.Intensities[i]);
   560	                    msLevel.Add(records[i].MsLevel);
   561	                }
   562	                _chromFromDeviceTrace = true;
   563	                return;
   564	            }
   565	
   566	            var byScan = new Dictionary<int, (double time, double intensity)>();
   567	            for (int k = 0; k < signal.Scans.Count; k++)
   568	            {
   569	                byScan[signal.Scans[k]] = (signal.Times[k], signal.Intensities[k]);
   570	            }
   571	
   572	            bool allDevice = true;
   573	            foreach (var r in records)
   574	            {
   575	                if (byScan.TryGetValue(r.ScanNumber, out var sample))
   576	                {
   577	                    time.Add(sample.time);
   578	                    intensity.Add((float)sample.intensity);
   579	                }
   580	                else
   581	                {
   582	                    time.Add(r.Time);
   583	                    intensity.Add(r.TotalIonCurrent);
   584	                    allDevice = false;
   585	                }
   586	                msLevel.Add(r.MsLevel);
   587	            }
   588	            _chromFromDeviceTrace = allDevice;
   589	        }
