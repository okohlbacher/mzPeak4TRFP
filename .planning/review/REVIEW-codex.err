  1458	            var leaf = Leaf(schema, path);
  1459	            int m = values.Length;
  1460	            var rows = Enumerable.Range(0, n)
  1461	                .Select(i => i < m ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1462	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1463	            cols[leaf] = (values, def, null);
  1464	        }
