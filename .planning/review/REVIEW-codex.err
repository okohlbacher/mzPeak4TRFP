   917	        // --- Numpress (default) integration locks ---
   918	
   919	        [Test]
   920	        public void Numpress_Schema_Footer_NullValues_Encoding()
   921	        {
   922	            var archive = Convert(DataMode.Numpress, out var dir);
   923	            try
   924	            {
   925	                var snippet =
   926	                    "import pyarrow.parquet as pq, json\n" +
   927	                    "t = pq.read_table(r'{PARQUET}')\n" +
   928	                    "ct = t.schema.field('chunk').type\n" +
   929	                    "col = t.column('chunk').combine_chunks()\n" +
   930	                    "cv = col.field('mz_chunk_values').to_pylist()\n" +
   931	                    "out = {'names':[ct.field(i).name for i in range(ct.num_fields)],\n" +
   932	                    "       'enc':sorted(set(col.field('chunk_encoding').to_pylist())),\n" +
   933	                    "       'cv_null':sum(1 for x in cv if x is None),\n" +
   934	                    "       'cv_present_empty':sum(1 for x in cv if x is not None and len(x)==0),\n" +
   935	                    "       'rows':len(cv),\n" +
   936	                    "       'npk_item':str(ct.field(6).type.value_field.type)}\n" +
   937	                    "print(json.dumps(out))\n";
   938	                var o = PyArrow(archive, "spectra_data.parquet", snippet);
   939	                var names = o["names"].Select(x => (string)x).ToArray();
   940	                Assert.That(names, Is.EqualTo(new[]
   941	                {
   942	                    "spectrum_index", "mz_chunk_start", "mz_chunk_end", "mz_chunk_values",
   943	                    "chunk_encoding", "intensity", "mz_numpress_linear_bytes"
   944	                }), "numpress chunk struct has 7 fields incl mz_numpress_linear_bytes");
   945	                Assert.That(o["enc"].Select(x => (string)x).ToArray(), Is.EqualTo(new[] { "MS:1002312" }),
   946	                    "chunk_encoding == MS:1002312");
   947	                Assert.That((int)o["cv_null"], Is.EqualTo((int)o["rows"]),
   948	                    "mz_chunk_values null_count == row count");
   949	                Assert.That((int)o["cv_present_empty"], Is.EqualTo(0),
   950	                    "mz_chunk_values has ZERO present/empty lists (genuinely null, not zero-length)");
   951	                Assert.That((string)o["npk_item"], Is.EqualTo("uint8"), "numpress bytes item is uint8");
   952	
   953	                var footerSnippet =
   954	                    "import pyarrow.parquet as pq, json\n" +
   955	                    "m = pq.read_metadata(r'{PARQUET}').metadata\n" +
   956	                    "print(m[b'spectrum_array_index'].decode())\n";
   957	                var f = PyArrow(archive, "spectra_data.parquet", footerSnippet);
   958	                Assert.That((string)f["prefix"], Is.EqualTo("chunk"));
   959	                var entries = (JArray)f["entries"];
   960	                Assert.That(entries.Select(e => (string)e["buffer_format"]).ToArray(),
   961	                    Is.EqualTo(new[] { "chunk_start", "chunk_end", "chunk_values", "chunk_encoding", "chunk_secondary", "chunk_transform" }));
   962	                var npk = entries.First(e => (string)e["path"] == "chunk.mz_numpress_linear_bytes");
   963	                Assert.That((string)npk["buffer_format"], Is.EqualTo("chunk_transform"));
   964	                Assert.That((string)npk["transform"], Is.EqualTo("MS:1002312"));
   965	                Assert.That((int)npk["sorting_rank"], Is.EqualTo(0));
   966	                var inten = entries.First(e => (string)e["path"] == "chunk.intensity");
   967	                Assert.That((string)inten["buffer_format"], Is.EqualTo("chunk_secondary"));
   968	                Assert.That((string)inten["transform"], Is.EqualTo("MS:1003902"));
   969	                Assert.That(inten["sorting_rank"].Type, Is.EqualTo(JTokenType.Null), "intensity entry unchanged");
   970	            }
   971	            finally { Directory.Delete(dir, true); }
   972	        }
