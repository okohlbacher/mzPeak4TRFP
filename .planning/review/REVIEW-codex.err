  1700	        private static byte[] WriteFacet(ParquetSchema schema, IReadOnlyDictionary<string, string> meta,
  1701	            IDictionary<DataField, (Array, int[], int[])> cols)
  1702	        {
  1703	            using (var ms = new MemoryStream())
  1704	            {
  1705	                MzPeakParquet.WriteAsync(ms, schema, meta, cols).GetAwaiter().GetResult();
  1706	                return ms.ToArray();
  1707	            }
