   489	        [Test]
   490	        public void Metadata_Precursor_And_SelectedIon_NullPadded_And_Linked()
   491	        {
   492	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   493	            var dir = Convert(input, out var archive);
   494	            try
   495	            {
   496	                var snippet =
   497	                    "import pyarrow.parquet as pq, json\n" +
   498	                    "t = pq.read_table(r'{PARQUET}')\n" +
   499	                    "d = t.to_pylist()\n" +
   500	                    "N = len(d)\n" +
   501	                    "pp = [d[i]['precursor'] is not None and d[i]['precursor']['source_index'] is not None for i in range(N)]\n" +
   502	                    "M = sum(pp)\n" +
   503	                    "out = {}\n" +
   504	                    "out['N'] = N\nout['M'] = M\n" +
   505	                    "out['msn_ordinals'] = sorted(int(d[i]['spectrum']['index']) for i in range(N) if d[i]['spectrum']['MS_1000511_ms_level'] >= 2)\n" +
   506	                    "out['msn_count'] = sum(1 for i in range(N) if d[i]['spectrum']['MS_1000511_ms_level'] >= 2)\n" +
   507	                    "out['prec_pattern'] = ''.join('1' if x else '0' for x in pp)\n" +
   508	                    "out['srcs'] = [d[i]['precursor']['source_index'] for i in range(M)]\n" +
   509	                    "out['pidx'] = [d[i]['precursor']['precursor_index'] for i in range(M)]\n" +
   510	                    "out['no_swap'] = all(d[i]['precursor']['source_index']!=d[i]['precursor']['precursor_index'] for i in range(M) if d[i]['precursor']['precursor_index'] is not None)\n" +
   511	                    "out['sel_src_mirror'] = all(d[i]['selected_ion']['source_index']==d[i]['precursor']['source_index'] for i in range(M))\n" +
   512	                    "out['sel_pidx_mirror'] = all((d[i]['selected_ion']['precursor_index'] is None) == (d[i]['precursor']['precursor_index'] is None) and (d[i]['precursor']['precursor_index'] is None or d[i]['selected_ion']['precursor_index']==d[i]['precursor']['precursor_index']) for i in range(M))\n" +
   513	                    "out['sel_null_tail'] = all(d[i]['selected_ion'] is None or d[i]['selected_ion']['source_index'] is None for i in range(M, N))\n" +
   514	                    "out['prec_null_tail'] = all(d[i]['precursor'] is None or d[i]['precursor']['source_index'] is None for i in range(M, N))\n" +
   515	                    "ap = d[0]['precursor']['activation']['parameters']\n" +
   516	                    "out['row0_act_acc'] = [e['accession'] for e in ap]\n" +
   517	                    "out['row0_ce_unit'] = [e['unit'] for e in ap if e['accession']=='MS:1000045']\n" +
   518	                    "out['ms1_ordinals'] = sorted(set(i for i in range(N) if d[i]['spectrum']['MS_1000511_ms_level']==1))\n" +
   519	                    "print(json.dumps(out))\n";
   520	                var o = PyArrowMetadata(archive, snippet);
   521	
   522	                int n = (int)o["N"], m = (int)o["M"];
   523	                Assert.That(m, Is.EqualTo((int)o["msn_count"]), "precursor count == MSn spectrum count");
   524	                Assert.That((string)o["prec_pattern"], Is.EqualTo(new string('1', m) + new string('0', n - m)),
   525	                    "precursor present on rows 0..M-1, null on M..N-1");
   526	                Assert.That((bool)o["prec_null_tail"], Is.True);
   527	                Assert.That((bool)o["sel_null_tail"], Is.True);
   528	
   529	                var srcs = o["srcs"].Select(x => (ulong)x).ToArray();
   530	                Assert.That(srcs, Is.EqualTo(srcs.OrderBy(x => x).ToArray()), "MSn ordinals ascending");
   531	
   532	                // EXACT set equality: the precursor source_index set IS the MSn-ordinal set derived from
   533	                // spectrum.ms_level >= 2 -- no extra precursor rows, none missing.
   534	                var msnOrdinals = o["msn_ordinals"].Select(x => (ulong)x).ToHashSet();
   535	                Assert.That(srcs.ToHashSet(), Is.EquivalentTo(msnOrdinals),
   536	                    "precursor.source_index set must equal the ms_level>=2 ordinal set exactly");
   537	
   538	                Assert.That((bool)o["no_swap"], Is.True, "precursor_index != source_index");
   539	                Assert.That((bool)o["sel_src_mirror"], Is.True,
   540	                    "selected_ion.source_index == precursor.source_index per row");
   541	                Assert.That((bool)o["sel_pidx_mirror"], Is.True,
   542	                    "selected_ion.precursor_index mirrors precursor.precursor_index per row (null-for-null)");
   543	
   544	                var ms1 = o["ms1_ordinals"].Select(x => (ulong)x).ToHashSet();
   545	                foreach (var pi in o["pidx"])
   546	                {
   547	                    if (pi.Type == JTokenType.Null) continue;
   548	                    Assert.That(ms1, Does.Contain((ulong)pi), "precursor_index must be an MS1 ordinal");
   549	                }
   550	
   551	                Assert.That(o["row0_act_acc"].Select(x => (string)x).ToArray(), Does.Contain("MS:1000133"),
   552	                    "small.RAW activation is CID MS:1000133");
   553	                Assert.That(o["row0_ce_unit"].Select(x => (string)x).ToArray(), Does.Contain("UO:0000266"),
   554	                    "collision energy carries unit UO:0000266");
   555	            }
   556	            finally
   557	            {
   558	                Directory.Delete(dir, true);
   559	            }
   560	        }
