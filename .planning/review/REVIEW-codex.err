  1625	        // Runs the production MzPeakSpectrumWriter.Write loop against small.RAW into a temp directory.
  1626	        // failScan: throw AFTER that scan's filter key is staged (a real post-key read failure).
  1627	        // dropParentBeforeChild: just before that child's precursor is built, drop its resolved parent's
  1628	        //   ordinal from the live map — a parent that was read but never emitted, so the child must not read
  1629	        //   a selected-ion intensity through it. Returns the archive path.
  1630	        private static string WriteWithInjection(string dir, int? failScan, int? dropParentBeforeChild)
  1631	        {
  1632	            var input = new ParseInput(TestRawFile, null, dir, OutputFormat.MzPeak)
  1633	            {
  1634	                MzPeakPointLayout = true
  1635	            };
  1636	            var writer = new MzPeakSpectrumWriter(input);
  1637	            if (failScan.HasValue)
  1638	            {
  1639	                writer.AfterFilterKeyStaged = scan =>
  1640	                {
  1641	                    if (scan == failScan.Value)
  1642	                        throw new InvalidOperationException($"injected read failure on scan {scan}");
  1643	                };
  1644	            }
  1645	            if (dropParentBeforeChild.HasValue)
  1646	            {
  1647	                writer.BeforeBuildPrecursor = (scan, scanToOrdinal) =>
  1648	                {
  1649	                    if (scan != dropParentBeforeChild.Value) return;
  1650	                    // Strip every emitted parent so this child cannot resolve a precursor_index, while its
  1651	                    // parent scan number is still positive — exactly the read-but-not-emitted condition.
  1652	                    scanToOrdinal.Clear();
  1653	                };
  1654	            }
  1655	            using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
  1656	            {
  1657	                raw.SelectInstrument(Device.MS, 1);
  1658	                writer.Write(raw, raw.RunHeaderEx.FirstSpectrum, raw.RunHeaderEx.LastSpectrum);
  1659	            }
  1660	            return Path.Combine(dir, "small.mzpeak");
  1661	        }
