   213	                new DataField<string>("data_type", true),
   214	                new DataField<string>("compression", true),
   215	                new DataField<string>("unit", true),
   216	                new ListField("parameters", MzPeakParquet.BuildParamField("item")),
   217	                new DataField<string>("data_processing_ref", true));
   218	        }
   219	    }
   220	}

