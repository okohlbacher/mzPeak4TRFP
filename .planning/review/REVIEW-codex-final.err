   165	                new DataField<ulong>("scan_index", true),
   166	                new DataField<float>(Cv(MzPeakCv.ScanStartTime, "scan_start_time", MzPeakCv.MinuteUnit), true),
   167	                new DataField<uint>(Cv(MzPeakCv.PresetScanConfiguration, "preset_scan_configuration"), true),
   168	                new DataField<string>(Cv(MzPeakCv.FilterString, "filter_string"), true),
   169	                new DataField<float>(Cv(MzPeakCv.IonInjectionTime, "ion_injection_time", MzPeakCv.MillisecondUnit), true),
   170	                new DataField<double>("ion_mobility_value", true),
   171	                new DataField<string>("ion_mobility_type", true),
   172	                new DataField<uint>("instrument_configuration_ref", true),
   173	                new DataField<string>("spectrum_reference", true),
   174	                new ListField("parameters", MzPeakParquet.BuildParamField("item")),
   175	                new ListField("scan_windows", window));
