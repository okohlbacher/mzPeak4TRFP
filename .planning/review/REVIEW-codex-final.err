   201	                new DataField<int>(Cv(MzPeakCv.ChargeState, "charge_state"), true),
   202	                new DataField<float>(Cv(MzPeakCv.SelectedIonIntensity, "intensity", MzPeakCv.CountsUnit), true),
   203	                new DataField<double>("ion_mobility_value", true),
   204	                new DataField<string>("ion_mobility_type", true),
   205	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
   206	        }
   207	
   208	        private StructField BuildAuxArrayField(string name)
   209	        {
   210	            return new StructField(name,
