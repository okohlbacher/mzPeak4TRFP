    22	
    23	        // Reads and builds everything for one scan into per-scan locals, touching NO shared/streaming
    24	        // state. Returns null for an out-of-range or empty scan (a clean skip); returns the staged scan on
    25	        // success. Any read/build failure throws and is handled by the caller as an error-counted skip, so
    26	        // a failed scan never commits an ordinal, rows, or a precursor-map entry.
    27	        private StagedScan StageScan(IRawDataPlus raw, int scanNumber, ulong ordinal,
    28	            IDictionary<int, ulong> scanNumberToOrdinal)
    29	        {
    30	            var scanFilter = raw.GetFilterForScanNumber(scanNumber);
    31	            int level = (int)scanFilter.MSOrder;
    32	            if (level > ParseInput.MaxLevel || !ParseInput.MsLevel.Contains(level)) return null;
    33	
    34	            var scanEvent = raw.GetScanEventForScanNumber(scanNumber);
    35	            var mzData = ReadMZData(raw, scanEvent, scanNumber, false, false, false);
    36	
    37	            var (mz, inten) = OrderedPairs(mzData.masses, mzData.intensities);
    38	
    39	            double[] peakMz = null;
    40	            float[] peakInten = null;
    41	            ulong? peakCount = null;
    42	            if (scanEvent.ScanData == ScanDataType.Profile && Scan.FromFile(raw, scanNumber).HasCentroidStream)
    43	            {
    44	                var peakData = ReadMZData(raw, scanEvent, scanNumber, true, false, false);
    45	                var (pMz, pInten) = OrderedPairs(peakData.masses, peakData.intensities);
    46	                if (pMz.Length > 0)
    47	                {
    48	                    peakMz = pMz;
    49	                    peakInten = pInten;
    50	                    peakCount = (ulong)pMz.Length;
    51	                }
    52	            }
    53	
    54	            var scanStats = raw.GetScanStatsForScanNumber(scanNumber);
    55	            var trailer = new ScanTrailer(raw.GetTrailerExtraInformation(scanNumber));
    56	
    57	            // Mirror the mzML parent-derivation bookkeeping: map each scan's filter prefix to its scan
    58	            // number so an MSn child can resolve its parent via the scan string.
    59	            var filterMatch = level == 1
    60	                ? null
    61	                : (level == 2
    62	                    ? _filterStringIsolationMzPattern.Match(scanEvent.ToString())
    63	                    : _filterStringParentMzPattern.Match(scanEvent.ToString()));
    64	            var filterKey = level == 1 ? "" : (filterMatch != null && filterMatch.Success ? filterMatch.Groups[1].Value : "");
    65	
    66	            // The filter key is staged but nothing has committed yet. A failure raised here is
    67	            // indistinguishable from a real post-key read failure and must leave no trace of this scan.
    68	            AfterFilterKeyStaged?.Invoke(scanNumber);
    69	
    70	            var rec = new MzPeakRecord
    71	            {
    72	                Ordinal = ordinal,
    73	                ScanNumber = scanNumber,
    74	                MsLevel = level,
    75	                Id = ConstructSpectrumTitle((int)Device.MS, 1, scanNumber),
    76	                Time = raw.RetentionTimeFromScanNumber(scanNumber),
    77	                Polarity = scanFilter.Polarity == PolarityType.Negative
    78	                    ? (sbyte?)-1
    79	                    : (scanFilter.Polarity == PolarityType.Positive ? (sbyte?)1 : null),
    80	                Representation = mzData.isCentroided ? MzPeakCv.CentroidSpectrum : MzPeakCv.ProfileSpectrum,
    81	                SpectrumType = level == 1 ? MzPeakCv.Ms1Spectrum : MzPeakCv.MsnSpectrum,
    82	                LowestMz = mz.Length > 0 ? (double?)mz[0] : null,
    83	                HighestMz = mz.Length > 0 ? (double?)mz[mz.Length - 1] : null,
    84	                BasePeakMz = mzData.basePeakMass,
    85	                BasePeakIntensity = mzData.basePeakIntensity.HasValue ? (float?)mzData.basePeakIntensity.Value : null,
    86	                TotalIonCurrent = (float)scanStats.TIC,
    87	                DataPointCount = (ulong)mz.Length,
    88	                PeakCount = peakCount,
    89	                ScanStartTime = (float)raw.RetentionTimeFromScanNumber(scanNumber),
    90	                PresetScanConfiguration = null,
    91	                FilterString = scanEvent.ToString(),
    92	                IonInjectionTime = trailer.AsDouble("Ion Injection Time (ms):").HasValue
    93	                    ? (float?)(float)trailer.AsDouble("Ion Injection Time (ms):").Value : null,
    94	                InstrumentConfigRef = AnalyzerIndex(scanFilter.MassAnalyzer, scanFilter.IonizationMode),
    95	                WindowLower = (float)scanStats.LowMass,
    96	                WindowUpper = (float)scanStats.HighMass
    97	            };
    98	
    99	            if (level >= 2)
   100	            {
   101	                BeforeBuildPrecursor?.Invoke(scanNumber, scanNumberToOrdinal);
   102	                BuildPrecursor(raw, scanNumber, scanEvent, scanFilter, trailer, scanNumberToOrdinal,
   103	                    filterKey, rec);
   104	            }
   105	
   106	            return new StagedScan
   107	            {
   108	                Mz = mz,
   109	                Inten = inten,
   110	                PeakMz = peakMz,
   111	                PeakInten = peakInten,
   112	                Rec = rec,
   113	                FilterKey = filterKey
   114	            };
   115	        }
   116	
   117	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   118	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   119	        // index sort is applied only when an ascending violation is detected, never dropping or
   120	        // merging equal-m/z points.
   121	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   122	        {
   123	            var n = masses?.Length ?? 0;
   124	            var mz = new double[n];
   125	            var inten = new float[n];
   126	            bool ascending = true;
   127	            for (int i = 0; i < n; i++)
   128	            {
   129	                mz[i] = masses[i];
   130	                inten[i] = (float)intensities[i];
   131	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   132	            }
   133	
   134	            if (ascending) return (mz, inten);
   135	
   136	            var order = new int[n];
   137	            for (int i = 0; i < n; i++) order[i] = i;
   138	            Array.Sort(order, (a, b) =>
   139	            {
   140	                int c = masses[a].CompareTo(masses[b]);
   141	                return c != 0 ? c : a.CompareTo(b);
   142	            });
   143	            var sortedMz = new double[n];
   144	            var sortedInten = new float[n];
   145	            for (int i = 0; i < n; i++)
   146	            {
   147	                sortedMz[i] = masses[order[i]];
   148	                sortedInten[i] = (float)intensities[order[i]];
   149	            }
   150	            return (sortedMz, sortedInten);
   151	        }
   152	
   153	        private void CaptureTic(IRawDataPlus raw, List<MzPeakRecord> records, List<double> time,
   154	            List<float> intensity, List<long> msLevel)
   155	        {
   156	            ChromatogramSignal[] trace;
   157	            if (TestForceSummedTic)
   158	            {
   159	                trace = Array.Empty<ChromatogramSignal>();
   160	            }
   161	            else
   162	            {
   163	                try
   164	                {
   165	                    raw.SelectInstrument(Device.MS, 1);
   166	                    var settings = new ChromatogramTraceSettings(TraceType.TIC);
   167	                    var data = raw.GetChromatogramData(new IChromatogramSettings[] { settings }, -1, -1);
   168	                    trace = ChromatogramSignal.FromChromatogramData(data);
   169	                }
   170	                catch (Exception ex)
   171	                {
   172	                    Log.Warn($"Device TIC trace unavailable, falling back to summed TIC: {ex.Message}");
   173	                    trace = Array.Empty<ChromatogramSignal>();
   174	                }
   175	            }
   176	
   177	            if (trace.Length == 0)
   178	            {
   179	                foreach (var r in records)
   180	                {
   181	                    time.Add(r.Time);
   182	                    intensity.Add(r.TotalIonCurrent);
   183	                    msLevel.Add(r.MsLevel);
   184	                }
   185	                _chromFromDeviceTrace = false;
   186	                return;
   187	            }
   188	
   189	            var signal = trace[0];
   190	            if (signal.Times.Count == records.Count)
   191	            {
   192	                for (int i = 0; i < records.Count; i++)
   193	                {
   194	                    time.Add(signal.Times[i]);
   195	                    intensity.Add((float)signal.Intensities[i]);
   196	                    msLevel.Add(records[i].MsLevel);
   197	                }
   198	                _chromFromDeviceTrace = true;
   199	                return;
   200	            }
   201	
   202	            var byScan = new Dictionary<int, (double time, double intensity)>();
   203	            for (int k = 0; k < signal.Scans.Count; k++)
   204	            {
   205	                byScan[signal.Scans[k]] = (signal.Times[k], signal.Intensities[k]);
   206	            }
   207	
   208	            bool allDevice = true;
   209	            foreach (var r in records)
   210	            {
   211	                if (byScan.TryGetValue(r.ScanNumber, out var sample))
   212	                {
   213	                    time.Add(sample.time);
   214	                    intensity.Add((float)sample.intensity);
   215	                }
   216	                else
   217	                {
   218	                    time.Add(r.Time);
   219	                    intensity.Add(r.TotalIonCurrent);
   220	                    allDevice = false;
   221	                }
   222	                msLevel.Add(r.MsLevel);
   223	            }
   224	            _chromFromDeviceTrace = allDevice;
   225	        }
   226	
   227	        private uint AnalyzerIndex(MassAnalyzerType analyzer, IonizationModeType ionization)
   228	        {
   229	            int idx = _analyzerOrder.IndexOf(analyzer);
   230	            if (idx < 0)
   231	            {
   232	                _analyzerOrder.Add(analyzer);
   233	                _ionizationOrder.Add(ionization);
   234	                idx = _analyzerOrder.Count - 1;
   235	            }
   236	            return (uint)idx;
   237	        }
