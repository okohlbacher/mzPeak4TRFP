   157	        private StructField BuildScanField()
   158	        {
   159	            var window = new StructField("item",
   160	                new DataField<float>(Cv(MzPeakCv.ScanWindowLowerLimit, "scan_window_lower_limit", MzPeakCv.MzUnit), true),
   161	                new DataField<float>(Cv(MzPeakCv.ScanWindowUpperLimit, "scan_window_upper_limit", MzPeakCv.MzUnit), true),
   162	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
