   183	                new DataField<float>(Cv(MzPeakCv.IsolationWindowUpperOffset, "isolation_window_upper_offset", MzPeakCv.MzUnit), true),
   184	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
   185	            var activation = new StructField("activation",
   186	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
   187	            return new StructField("precursor",
