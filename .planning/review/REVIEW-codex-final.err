   103	            MzPeakColumns.AddMsnScalar(cols, schema, "selected_ion/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   104	            MzPeakColumns.AddMsnPrecursorIndex(cols, schema, "selected_ion/precursor_index", n, msnRecords);
