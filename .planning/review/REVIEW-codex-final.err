   296	            // Selected-ion intensity is read FROM the parent spectrum, so it is only meaningful when
   297	            // the parent was actually emitted (a committed ordinal). A parent that was skipped/filtered
   298	            // out or whose read fails must never force this otherwise-readable child to fail: gate on
   299	            // the parent ordinal being known, and treat any parent-read error as "intensity unknown".
   300	            if (rec.SelectedIonMz > ZeroDelta && rec.PrecursorIndex.HasValue)
   301	            {
   302	                try
