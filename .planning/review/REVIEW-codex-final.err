   239	        private void BuildPrecursor(IRawDataPlus raw, int scanNumber, IScanEvent scanEvent,
   240	            IScanFilter scanFilter, ScanTrailer trailer, IDictionary<int, ulong> scanNumberToOrdinal,
   241	            string filterKey, MzPeakRecord rec)
   242	        {
   243	            rec.IsMsn = true;
   244	
   245	            // Parent scan via Master Scan Number trailer, falling back to the scan-string parent the
   246	            // mzML path derives. Map the parent scan number to its emitted ordinal; if the parent was
   247	            // filtered out / not emitted, keep the precursor entry but leave precursor_index null.
   248	            int parentScan;
   249	            var master = trailer.AsPositiveInt("Master Scan Number:");
   250	            if (master.HasValue) parentScan = master.Value;
   251	            else parentScan = GetParentFromScanString(filterKey);
   252	
   253	            if (parentScan > 0 && scanNumberToOrdinal.TryGetValue(parentScan, out var p))
   254	            {
   255	                rec.PrecursorIndex = p;
   256	                rec.PrecursorId = ConstructSpectrumTitle((int)Device.MS, 1, parentScan);
   257	            }
