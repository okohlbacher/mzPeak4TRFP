     9	namespace ThermoRawFileParser.Writer
    10	{
    11	    public partial class MzPeakSpectrumWriter
    12	    {
    13	        // Everything staged from a single scan, held in locals until the scan fully succeeds. A read/build
    14	        // failure discards the whole struct: no ordinal, no rows, no precursor-map entry are committed.
    15	        private sealed class StagedScan
    16	        {
    17	            public double[] Mz, PeakMz;
    18	            public float[] Inten, PeakInten;
    19	            public MzPeakRecord Rec;
