   305	                        reaction.PrecursorMass, isolationWidth,
   306	                        ParseInput.NoPeakPicking.Contains(rec.MsLevel - 1));
   307	                }
   308	                catch (Exception ex)
   309	                {
   310	                    Log.Warn($"Scan #{scanNumber}: parent #{parentScan} intensity unreadable, " +

