   259	            var reaction = GetReaction(scanEvent, scanNumber);
   260	            if (reaction == null) return;
   261	            rec.HasReaction = true;
   262	
   263	            double? isolationWidth = reaction.IsolationWidth;
   264	            if (isolationWidth < 0) isolationWidth = null;
   265	
   266	            rec.IsolationTarget = (float)reaction.PrecursorMass;
   267	            if (isolationWidth != null)
   268	            {
   269	                var offset = isolationWidth.Value / 2 + reaction.IsolationWidthOffset;
   270	                rec.IsolationLowerOffset = (float)(isolationWidth.Value - offset);
   271	                rec.IsolationUpperOffset = (float)offset;
   272	            }
   273	
   274	            if (OntologyMapping.DissociationTypes.TryGetValue(reaction.ActivationType, out var diss))
   275	            {
   276	                rec.ActivationParams.Add(new MzPeakParam { Accession = diss.accession, Name = diss.name });
   277	            }
   278	
   279	            if (reaction.CollisionEnergyValid)
   280	            {
   281	                rec.ActivationParams.Add(new MzPeakParam
   282	                {
   283	                    Accession = MzPeakCv.CollisionEnergy,
   284	                    Name = "collision energy",
   285	                    Float = reaction.CollisionEnergy,
   286	                    Unit = MzPeakCv.ElectronvoltUnit
   287	                });
   288	            }
   289	
   290	            int? charge = trailer.AsPositiveInt("Charge State:");
   291	            if (TestChargeOverride != null) charge = TestChargeOverride(scanNumber);
   292	            double? monoisotopicMz = trailer.AsDouble("Monoisotopic M/Z:");
   293	            rec.SelectedIonMz = CalculateSelectedIonMz(reaction, monoisotopicMz, isolationWidth);
   294	            rec.ChargeState = charge;
