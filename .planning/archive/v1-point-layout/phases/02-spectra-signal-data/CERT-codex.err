    82	            var spectrum = new StructField("spectrum",
    83	                new DataField<ulong>("index"), mzRange, paramsList);
    84	            var scan = new StructField("scan",
    85	                new DataField<ulong>("source_index"), new DataField<float>("rt"));
    86	            var schema = new ParquetSchema(spectrum, scan);
    87	
    88	            var cols = new Dictionary<DataField, (Array, int[], int[])>
    89	            {
    90	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 10, 11 }, new[] { 1, 0, 1 }, null),
    91	                [Leaf(schema, "spectrum/mz_range/lo")] = (new[] { 100.5, 50.0 }, new[] { 2, 0, 2 }, null),
    92	                [Leaf(schema, "spectrum/mz_range/hi")] = (new[] { 2000.0, 60.0 }, new[] { 2, 0, 2 }, null),
    93	                [Leaf(schema, "spectrum/parameters/list/item/name")] =
    94	                    (new[] { "a", "b" }, new[] { 5, 5, 0, 2 }, new[] { 0, 1, 0, 0 }),
    95	                [Leaf(schema, "spectrum/parameters/list/item/val")] =
    96	                    (new[] { 1.5 }, new[] { 5, 4, 0, 2 }, new[] { 0, 1, 0, 0 }),
    97	                [Leaf(schema, "scan/source_index")] = (new ulong[] { 10 }, new[] { 0, 1, 0 }, null),
    98	                [Leaf(schema, "scan/rt")] = (new[] { 1.23f }, new[] { 0, 1, 0 }, null)
    99	            };
   100	
   101	            var ms = new MemoryStream();
   102	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string> { ["k"] = "v" },
   103	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   104	
   105	            ms.Position = 0;
   106	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   107	            {
   108	                var rg = reader.OpenRowGroupReader(0);
   109	
   110	                // On read, Data holds only the defined values; nulls live in DefinitionLevels.
   111	                var indexCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result;
   112	                Assert.That(indexCol.Data, Is.EqualTo(new ulong[] { 10, 11 }));
   113	                Assert.That(indexCol.DefinitionLevels, Is.EqualTo(new[] { 1, 0, 1 }));
   114	
   115	                var loCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/mz_range/lo")).Result;
   116	                Assert.That(loCol.Data, Is.EqualTo(new[] { 100.5, 50.0 }));
   117	                Assert.That(loCol.DefinitionLevels, Is.EqualTo(new[] { 2, 0, 2 }));
   118	
   119	                var scanCol = rg.ReadColumnAsync(Leaf(schema, "scan/source_index")).Result;
   120	                Assert.That(scanCol.Data, Is.EqualTo(new ulong[] { 10 }));
   121	                Assert.That(scanCol.DefinitionLevels, Is.EqualTo(new[] { 0, 1, 0 }));
   122	
   123	                // list-of-struct: 2 items in row0 (second val null), empty list in row2.
   124	                // String leaves read back with nulls embedded inline; def levels are the lock.
   125	                var nameCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/parameters/list/item/name")).Result;
   126	                Assert.That(nameCol.Data, Is.EqualTo(new[] { "a", "b", null, null }));
   127	                Assert.That(nameCol.DefinitionLevels, Is.EqualTo(new[] { 5, 5, 0, 2 }));
   128	                Assert.That(nameCol.RepetitionLevels, Is.EqualTo(new[] { 0, 1, 0, 0 }));
   129	
   130	                // val is an explicitly-nullable leaf; it reads back with nulls embedded inline.
   131	                var valCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/parameters/list/item/val")).Result;
   132	                Assert.That(valCol.Data, Is.EqualTo(new double?[] { 1.5, null, null, null }));
   133	                Assert.That(valCol.DefinitionLevels, Is.EqualTo(new[] { 5, 4, 0, 2 }));
   134	            }
   135	        }
   136	
   137	        [Test]
   138	        public void RoundTrip_Param_NullableAccessionUnitString()
   139	        {
   140	            var spectrum = new StructField("spectrum", MzPeakParquet.BuildParamField("p"));
   141	            var schema = new ParquetSchema(spectrum);
   142	
   143	            // Union-as-struct discipline: each PARAM row populates EXACTLY ONE of the four value
   144	            // leaves; the other three are null. Row0 populates integer; row1 populates string.
   145	            // value/* leaves: maxDef=4 (4=non-null, 3=null). accession/name/unit: maxDef=3 (3=non-null, 2=null).
   146	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   147	            {
   148	                [Leaf(schema, "spectrum/p/value/integer")] = (new long[] { 7 }, new[] { 4, 3 }, null),
   149	                [Leaf(schema, "spectrum/p/value/float")] = (new double[0], new[] { 3, 3 }, null),
   150	                [Leaf(schema, "spectrum/p/value/string")] = (new[] { "hello" }, new[] { 3, 4 }, null),
   151	                [Leaf(schema, "spectrum/p/value/boolean")] = (new bool[0], new[] { 3, 3 }, null),
   152	                [Leaf(schema, "spectrum/p/accession")] = (new[] { "MS:1000511" }, new[] { 3, 2 }, null),
   153	                [Leaf(schema, "spectrum/p/name")] = (new[] { "ms level", "intensity" }, new[] { 3, 3 }, null),
   154	                [Leaf(schema, "spectrum/p/unit")] = (new[] { "UO:0000031" }, new[] { 3, 2 }, null)
   155	            };
   156	
   157	            var ms = new MemoryStream();
   158	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string>(),
   159	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   160	
   161	            ms.Position = 0;
   162	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   163	            {
   164	                var rg = reader.OpenRowGroupReader(0);
   165	
   166	                // integer: row0 populated (def 4), row1 null (def 3).
   167	                var integer = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/integer")).Result;
   168	                Assert.That(integer.Data, Is.EqualTo(new long?[] { 7, null }));
   169	                Assert.That(integer.DefinitionLevels, Is.EqualTo(new[] { 4, 3 }));
   170	
   171	                // string: row0 null (def 3), row1 populated (def 4).
   172	                var str = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/string")).Result;
   173	                Assert.That(str.Data, Is.EqualTo(new[] { null, "hello" }));
   174	                Assert.That(str.DefinitionLevels, Is.EqualTo(new[] { 3, 4 }));
   175	
   176	                // float never populated: both rows null (def 3).
   177	                var fl = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/float")).Result;
   178	                Assert.That(fl.DefinitionLevels, Is.EqualTo(new[] { 3, 3 }));
   179	
   180	                // boolean never populated: both rows null (def 3).
   181	                var boolean = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/boolean")).Result;
   182	                Assert.That(boolean.DefinitionLevels, Is.EqualTo(new[] { 3, 3 }));
   183	
   184	                // accession: row0 present (def 3), row1 null (def 2).
   185	                var acc = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/accession")).Result;
   186	                Assert.That(acc.Data, Is.EqualTo(new[] { "MS:1000511", null }));
   187	                Assert.That(acc.DefinitionLevels, Is.EqualTo(new[] { 3, 2 }));
   188	
   189	                var unit = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/unit")).Result;
   190	                Assert.That(unit.Data, Is.EqualTo(new[] { "UO:0000031", null }));
   191	                Assert.That(unit.DefinitionLevels, Is.EqualTo(new[] { 3, 2 }));
   192	
   193	                // name populated on both rows.
   194	                var name = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/name")).Result;
   195	                Assert.That(name.Data, Is.EqualTo(new[] { "ms level", "intensity" }));
   196	            }
   197	        }
