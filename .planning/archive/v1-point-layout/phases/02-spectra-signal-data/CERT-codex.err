   141	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   142	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   143	        // index sort is applied only when an ascending violation is detected, never dropping or
   144	        // merging equal-m/z points.
   145	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   146	        {
   147	            var n = masses?.Length ?? 0;
   148	            var mz = new double[n];
   149	            var inten = new float[n];
   150	            bool ascending = true;
   151	            for (int i = 0; i < n; i++)
   152	            {
   153	                mz[i] = masses[i];
   154	                inten[i] = (float)intensities[i];
   155	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   156	            }
   157	
   158	            if (ascending) return (mz, inten);
   159	
   160	            var order = new int[n];
   161	            for (int i = 0; i < n; i++) order[i] = i;
   162	            Array.Sort(order, (a, b) =>
   163	            {
   164	                int c = masses[a].CompareTo(masses[b]);
   165	                return c != 0 ? c : a.CompareTo(b);
   166	            });
   167	            var sortedMz = new double[n];
   168	            var sortedInten = new float[n];
   169	            for (int i = 0; i < n; i++)
   170	            {
   171	                sortedMz[i] = masses[order[i]];
   172	                sortedInten[i] = (float)intensities[order[i]];
   173	            }
   174	            return (sortedMz, sortedInten);
   175	        }
