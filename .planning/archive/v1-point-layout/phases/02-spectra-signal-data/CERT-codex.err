   416	        [Test]
   417	        public void TestParquetCentroid()
   418	        {
   419	            // Get temp path for writing the test output
   420	            var tempFilePath = Path.GetTempPath();
   421	
   422	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
   423	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.Parquet);
   424	
   425	            RawFileParser.Parse(parseInput);
   426	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   427	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   428	
   429	            // Actual test
   430	            var parquetFilePath = Path.Combine(tempFilePath, "small.mzparquet");
   431	
   432	            Assert.That(File.Exists(parquetFilePath));
   433	            using (var parquetReader = ParquetReader.CreateAsync(parquetFilePath).Result)
   434	            {
   435	                var groupReader = parquetReader.OpenRowGroupReader(0);
   436	                var schema = parquetReader.Schema;
   437	                var scanColumn = groupReader.ReadColumnAsync(schema.FindDataField("scan")).Result;
   438	
   439	                Assert.That(scanColumn.NumValues, Is.EqualTo(48520));
   440	                Assert.That(scanColumn.Statistics.DistinctCount, Is.EqualTo(48));
   441	                Assert.That((from int p in scanColumn.Data where p == 22 select p).Count(), Is.EqualTo(1632));
   442	            }
   443	
   444	            File.Delete(parquetFilePath);
   445	        }
