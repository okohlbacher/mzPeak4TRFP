    30	        private static string Convert(ParseInput parseInput, out string archive)
    31	        {
    32	            var dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    33	            Directory.CreateDirectory(dir);
    34	            parseInput.OutputDirectory = dir;
    35	            RawFileParser.Parse(parseInput);
    36	            Assert.That(parseInput.Errors, Is.EqualTo(0));
    37	            archive = Path.Combine(dir, "small.mzpeak");
    38	            Assert.That(File.Exists(archive));
    39	            return dir;
    40	        }
    41	
    42	        private static byte[] ReadEntry(string archive, string name)
    43	        {
    44	            using (var zip = ZipFile.OpenRead(archive))
    45	            {
    46	                var entry = zip.GetEntry(name);
    47	                if (entry == null) return null;
    48	                using (var s = entry.Open())
    49	                using (var ms = new MemoryStream())
    50	                {
    51	                    s.CopyTo(ms);
    52	                    return ms.ToArray();
    53	                }
    54	            }
    55	        }
    56	
    57	        private static Facet ReadPointFacet(byte[] bytes)
    58	        {
    59	            using (var ms = new MemoryStream(bytes))
    60	            using (var reader = ParquetReader.CreateAsync(ms).Result)
    61	            {
    62	                var schema = reader.Schema;
    63	                var rg = reader.OpenRowGroupReader(0);
    64	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data
    65	                    .Cast<ulong>().ToArray();
    66	                var mz = rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data
    67	                    .Cast<double>().ToArray();
    68	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
    69	                    .Cast<float>().ToArray();
    70	                var meta = reader.CustomMetadata;
    71	                return new Facet
    72	                {
    73	                    SpectrumIndex = idx,
    74	                    Mz = mz,
    75	                    Intensity = inten,
    76	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
    77	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
    78	                };
    79	            }
    80	        }
    81	
    82	        private static DataField Leaf(ParquetSchema schema, string path)
    83	        {
    84	            return schema.GetDataFields().First(d => d.Path.ToString() == path);
    85	        }
