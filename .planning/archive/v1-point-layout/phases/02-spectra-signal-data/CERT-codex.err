   115	        {
   116	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   117	            var dir = Convert(input, out var archive);
   118	            try
   119	            {
   120	                using (var ms = new MemoryStream(ReadEntry(archive, "spectra_data.parquet")))
   121	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   122	                {
   123	                    var schema = reader.Schema;
   124	                    Assert.That(Leaf(schema, "point/mz").ClrType, Is.EqualTo(typeof(double)));
   125	                    Assert.That(Leaf(schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)));
