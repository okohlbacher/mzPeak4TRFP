   210	        [Test]
   211	        public void Peaks_When_Present_Are_Listed_With_DataKind_Peaks()
   212	        {
   213	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   214	            var dir = Convert(input, out var archive);
   215	            try
   216	            {
