    49	        [Test]
    50	        public void Column_DefRepLevels_MatchCheatSheet()
    51	        {
    52	            var paramItem = new StructField("item",
    53	                new DataField<string>("name"),
    54	                new DataField<double>("val", true));
    55	            var paramsList = new ListField("parameters", paramItem);
