    59	        [Test]
    60	        public void TestExtensionsFull()
    61	        {
    62	            // Get temp path for writing the test files
    63	            var tempFilePath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    64	            Directory.CreateDirectory(tempFilePath);
    65	
    66	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
    67	            var parseInput = new ParseInput();
    68	            parseInput.RawFilePath = testRawFile;
    69	
    70	            List<OutputFormat> formats = new List<OutputFormat>();
    71	            string userInput;
    72	            string expectedOutput;
    73	
    74	            foreach (string line in File.ReadLines(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/ExtensionTest.tsv")).Skip(1))
    75	            {
    76	                string[] words = line.Split('\t');
    77	
    78	                switch (words[0].ToLower())
    79	                {
    80	                    case "mgf": formats = new List<OutputFormat> { OutputFormat.MGF }; break;
    81	                    case "mzml": formats = new List<OutputFormat> { OutputFormat.MzML, OutputFormat.IndexMzML }; break;
    82	                }
    83	
    84	                switch (words[1].ToLower())
    85	                {
    86	                    case "true": parseInput.Gzip = true; break;
    87	                    default: parseInput.Gzip = false; break;
    88	                }
    89	
    90	                userInput = words[2];
    91	                expectedOutput = words[3];
    92	
    93	                parseInput.OutputFile = Path.Combine(tempFilePath, userInput);
    94	
    95	                foreach (var format in formats)
    96	                {
    97	                    parseInput.OutputFormat = format;
    98	                    RawFileParser.Parse(parseInput);
    99	                    Assert.That(File.Exists(Path.Combine(tempFilePath, expectedOutput)));
   100	                    File.Delete(Path.Combine(tempFilePath, expectedOutput));
   101	                }
   102	
   103	            }
   104	
   105	            Directory.Delete(tempFilePath, true);
   106	        }
