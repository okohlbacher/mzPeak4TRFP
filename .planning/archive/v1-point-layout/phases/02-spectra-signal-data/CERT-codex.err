   135	        [Test]
   136	        public void MsLevelFilter_Excludes_FilteredOut_Spectra()
   137	        {
   138	            var fullInput = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   139	            var fullDir = Convert(fullInput, out var fullArchive);
   140	            int fullSpectra, fullRows;
   141	            try
   142	            {
   143	                var f = ReadPointFacet(ReadEntry(fullArchive, "spectra_data.parquet"));
   144	                fullSpectra = f.SpectrumCount;
   145	                fullRows = f.PointCount;
   146	            }
   147	            finally
   148	            {
   149	                Directory.Delete(fullDir, true);
   150	            }
   151	
   152	            var ms2Input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak)
   153	            {
   154	                MsLevel = new HashSet<int> { 2 }
   155	            };
   156	            var ms2Dir = Convert(ms2Input, out var ms2Archive);
   157	            try
   158	            {
   159	                var f = ReadPointFacet(ReadEntry(ms2Archive, "spectra_data.parquet"));
   160	                Assert.That(f.SpectrumCount, Is.GreaterThan(0));
   161	                Assert.That(f.SpectrumCount, Is.LessThan(fullSpectra),
   162	                    "MS2-only run must contain fewer spectra than the unfiltered run");
   163	                Assert.That(f.PointCount, Is.LessThan(fullRows),
   164	                    "MS2-only run must contain fewer rows than the unfiltered run");
   165	
   166	                var meta = ReadEntry(ms2Archive, "spectra_metadata.parquet");
   167	                var mf = ReadMetadataIndices(meta);
   168	                Assert.That(mf.Length, Is.EqualTo(f.SpectrumCount));
   169	            }
   170	            finally
   171	            {
   172	                Directory.Delete(ms2Dir, true);
   173	            }
   174	        }
   175	
   176	        private static ulong[] ReadMetadataIndices(byte[] bytes)
   177	        {
   178	            using (var ms = new MemoryStream(bytes))
   179	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   180	            {
   181	                var schema = reader.Schema;
   182	                var rg = reader.OpenRowGroupReader(0);
   183	                return rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result.Data
   184	                    .Cast<ulong>().ToArray();
   185	            }
   186	        }
