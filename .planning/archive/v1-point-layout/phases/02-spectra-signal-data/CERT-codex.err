refs/_findings/mzpeak_groundtruth_schema.md:67:MS_1000927_ion_injection_time_unit_UO_0000028: float
refs/_findings/mzpeak_groundtruth_schema.md:74:    MS_1000501_scan_window_lower_limit_unit_MS_1000040: float,
refs/_findings/mzpeak_groundtruth_schema.md:75:    MS_1000500_scan_window_upper_limit_unit_MS_1000040: float,
refs/_findings/mzpeak_groundtruth_schema.md:85:    MS_1000827_isolation_window_target_mz: float,
refs/_findings/mzpeak_groundtruth_schema.md:86:    MS_1000828_isolation_window_lower_offset: float,
refs/_findings/mzpeak_groundtruth_schema.md:87:    MS_1000829_isolation_window_upper_offset: float,
refs/_findings/mzpeak_groundtruth_schema.md:98:MS_1000042_intensity_unit_MS_1000131: float
