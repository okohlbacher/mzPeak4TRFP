   188	        [Test]
   189	        public void Metadata_Covers_Identical_SpectrumSet_As_Data()
   190	        {
   191	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   192	            var dir = Convert(input, out var archive);
   193	            try
   194	            {
   195	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   196	                var metaIdx = ReadMetadataIndices(ReadEntry(archive, "spectra_metadata.parquet"));
   197	
   198	                int distinct = data.SpectrumIndex.Distinct().Count();
   199	                Assert.That(metaIdx.Length, Is.EqualTo(data.SpectrumCount));
   200	                Assert.That(distinct, Is.EqualTo(data.SpectrumCount));
   201	                Assert.That(metaIdx.OrderBy(x => x).ToArray(),
   202	                    Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()));
   203	            }
   204	            finally
   205	            {
   206	                Directory.Delete(dir, true);
   207	            }
   208	        }
