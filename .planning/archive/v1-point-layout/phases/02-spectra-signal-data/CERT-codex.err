   401	                var selectedMz = Double.Parse(precursor.cvParam.Where(cv => cv.accession == "MS:1000744").First().value);
   402	                Assert.That(selectedMz - 604.7592 < 0.001);
   403	
   404	                var selectedZ = int.Parse(precursor.cvParam.Where(cv => cv.accession == "MS:1000041").First().value);
   405	                Assert.That(selectedZ, Is.EqualTo(2));
   406	
   407	                var selectedI = Double.Parse(precursor.cvParam.Where(cv => cv.accession == "MS:1000042").First().value);
   408	                Assert.That(selectedI - 17044 < 1);
