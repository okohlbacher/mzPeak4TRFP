    87	        [Test]
    88	        public void SpectraData_Ascending_And_MultisetPreserved()
    89	        {
    90	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
    91	            var dir = Convert(input, out var archive);
    92	            try
    93	            {
    94	                var facet = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
    95	
    96	                Assert.That(facet.Mz.Length, Is.EqualTo(facet.PointCount));
    97	                Assert.That(facet.Mz.Length, Is.EqualTo(facet.SpectrumIndex.Length));
    98	                Assert.That(facet.Intensity.Length, Is.EqualTo(facet.PointCount));
    99	
   100	                for (int i = 1; i < facet.SpectrumIndex.Length; i++)
   101	                {
   102	                    if (facet.SpectrumIndex[i] == facet.SpectrumIndex[i - 1])
   103	                        Assert.That(facet.Mz[i], Is.GreaterThanOrEqualTo(facet.Mz[i - 1]),
   104	                            $"spectrum {facet.SpectrumIndex[i]} not non-decreasing at {i}");
   105	                }
   106	            }
   107	            finally
   108	            {
   109	                Directory.Delete(dir, true);
   110	            }
   111	        }
   112	
   113	        [Test]
