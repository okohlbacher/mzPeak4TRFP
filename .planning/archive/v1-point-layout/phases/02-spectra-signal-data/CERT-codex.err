   241	        public void OrderedPairs_Preserves_Duplicate_Mz_In_Input_Order()
   242	        {
   243	            var masses = new[] { 100.0, 100.0, 100.0, 200.0 };
   244	            var intensities = new[] { 11.0, 22.0, 33.0, 44.0 };
   245	
   246	            var (mz, inten) = MzPeakSpectrumWriter.OrderedPairs(masses, intensities);
