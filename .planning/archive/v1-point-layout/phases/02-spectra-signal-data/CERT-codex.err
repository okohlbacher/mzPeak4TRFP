   118	
   119	            foreach (var ext in extensions)
   120	            {
   121	                if (result.ToLower().EndsWith(ext.ToLower()))
   122	                    result = result.Substring(0, result.Length - ext.Length);
   123	
   124	                tail = ext + tail;
   125	                result = result.TrimEnd('.');
   126	            }
   127	
   128	            return result + tail;
   129	        }
