   912	                    .ToHashSet();
   913	
   914	                // The pre-existing reference-archive failures; our writer introduces none of them.
   915	                var allowlist = new HashSet<string> { "index_schema_valid", "cv_list_declared" };
   916	
   917	                Assert.That(errorIds, Does.Not.Contain("columns_spectra_metadata"),
   918	                    "scan-facet error must be cleared");
   919	                Assert.That(errorIds, Does.Not.Contain("cv_list_declared"),
   920	                    "cv_list_declared must be cleared by the generated cv_list");
   921	                var newErrors = errorIds.Except(allowlist).ToArray();
   922	                Assert.That(newErrors, Is.Empty,
   923	                    $"no new ERROR id beyond the pre-existing allowlist: {string.Join(",", newErrors)}");
   924	            }
   925	            finally
   926	            {
   927	                if (File.Exists(jsonPath)) File.Delete(jsonPath);
   928	                Directory.Delete(dir, true);
   929	            }
   930	        }
