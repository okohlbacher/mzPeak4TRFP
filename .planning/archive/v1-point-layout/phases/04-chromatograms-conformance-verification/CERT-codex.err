   925	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
   926	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   927	            string listPath, int n, List<List<Param>> perRow)
   928	        {
   929	            int m = perRow.Count;
   930	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
   931	            var padded = new List<List<Param>>();
   932	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
   933	            AddParamList(cols, schema, listPath, padded, structPresent);
   934	        }
