   701	
   702	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000504", "base_peak_mz", "MS:1000040"),
   703	                records.Select(r => r.BasePeakMz).ToArray(), presentAll);
   704	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000505", "base_peak_intensity", "MS:1000131"),
   705	                records.Select(r => r.BasePeakIntensity).ToArray(), presentAll);
   706	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000285", "total_ion_current", "MS:1000131"),
   707	                records.Select(r => r.TotalIonCurrent).ToArray(), presentAll);
   708	
   709	            AddParamList(cols, schema, "spectrum/parameters", records.Select(r => r.SpectrumParams).ToList(), presentAll);
   710	
   711	            // scan facet (present on all N rows)
   712	            AddScalar(cols, schema, "scan/source_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
   713	            AddScalar(cols, schema, "scan/scan_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
   714	            AddScalar(cols, schema, "scan/" + Cv("MS:1000016", "scan_start_time", "UO:0000031"),
   715	                records.Select(r => r.ScanStartTime).ToArray(), presentAll);
   716	            AddScalar(cols, schema, "scan/" + Cv("MS:1000512", "filter_string"),
   717	                records.Select(r => r.FilterString).ToArray(), presentAll);
   718	            AddScalar(cols, schema, "scan/" + Cv("MS:1000927", "ion_injection_time", "UO:0000028"),
   719	                records.Select(r => r.IonInjectionTime).ToArray(), presentAll);
   720	            AddScalar(cols, schema, "scan/instrument_configuration_ref",
   721	                records.Select(r => r.InstrumentConfigRef).ToArray(), presentAll);
   722	            AddScanWindows(cols, schema, records);
   723	
   724	            // precursor facet (present on rows 0..M-1, null on M..N-1)
   725	            AddMsnScalar(cols, schema, "precursor/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   726	            AddMsnPrecursorIndex(cols, schema, "precursor/precursor_index", n, msnRecords);
   727	            AddMsnString(cols, schema, "precursor/precursor_id", n, msnRecords.Select(r => r.PrecursorId).ToArray());
   728	            AddMsnScalar(cols, schema, "precursor/isolation_window/" + Cv("MS:1000827", "isolation_window_target_mz"),
   729	                n, msnRecords.Select(r => r.IsolationTarget).ToArray());
   730	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"),
   731	                n, msnRecords.Select(r => r.IsolationLowerOffset).ToArray());
   732	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"),
   733	                n, msnRecords.Select(r => r.IsolationUpperOffset).ToArray());
   734	            AddMsnParamList(cols, schema, "precursor/isolation_window/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
   735	            AddMsnParamList(cols, schema, "precursor/activation/parameters", n, msnRecords.Select(r => r.ActivationParams).ToList());
   736	
   737	            // selected_ion facet (present on rows 0..M-1, null on M..N-1)
   738	            AddMsnScalar(cols, schema, "selected_ion/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   739	            AddMsnPrecursorIndex(cols, schema, "selected_ion/precursor_index", n, msnRecords);
   740	            AddMsnScalar(cols, schema, "selected_ion/" + Cv("MS:1000744", "selected_ion_mz", "MS:1000040"),
   741	                n, msnRecords.Select(r => r.SelectedIonMz).ToArray());
   742	            AddMsnNullableInt(cols, schema, "selected_ion/" + Cv("MS:1000041", "charge_state"),
   743	                n, msnRecords.Select(r => r.ChargeState).ToArray());
   744	            AddMsnNullableFloat(cols, schema, "selected_ion/" + Cv("MS:1000042", "intensity", "MS:1000131"),
   745	                n, msnRecords.Select(r => r.SelectedIonIntensity).ToArray());
   746	
   747	            var custom = new Dictionary<string, string>
   748	            {
   749	                ["spectrum_count"] = n.ToString(),
   750	                ["spectrum_data_point_count"] = "0",
   751	                ["spectrum_array_index"] = SpectrumArrayIndex
   752	            };
   753	            AddMetadataBlocks(custom, records);
   754	
   755	            return WriteFacet(schema, custom, cols);
   756	        }
