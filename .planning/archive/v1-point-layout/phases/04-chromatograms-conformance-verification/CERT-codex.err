    46	        private static byte[] ReadEntry(string archive, string name)
    47	        {
    48	            using (var zip = ZipFile.OpenRead(archive))
    49	            {
    50	                var entry = zip.GetEntry(name);
    51	                if (entry == null) return null;
    52	                using (var s = entry.Open())
    53	                using (var ms = new MemoryStream())
    54	                {
    55	                    s.CopyTo(ms);
    56	                    return ms.ToArray();
    57	                }
    58	            }
    59	        }
