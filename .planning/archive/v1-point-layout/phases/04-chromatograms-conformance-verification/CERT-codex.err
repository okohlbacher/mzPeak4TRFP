   668	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
   669	            var presentAll = records.Select(_ => true).ToArray();
   670	
   671	            // precursor / selected_ion are independent tables: the k-th MSn (ascending ordinal) sits
   672	            // at row k, null-padded on rows M..N-1.
   673	            var msnRecords = records.Where(r => r.IsMsn).OrderBy(r => r.Ordinal).ToList();
