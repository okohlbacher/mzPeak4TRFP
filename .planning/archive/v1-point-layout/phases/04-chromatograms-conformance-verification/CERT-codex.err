   689	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000527", "highest_observed_mz", "MS:1000040"),
   690	                records.Select(r => r.HighestMz).ToArray(), presentAll);
   691	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1003060", "number_of_data_points"),
