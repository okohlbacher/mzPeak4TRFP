   956	            var accVals = new List<string>();
   957	            var nameVals = new List<string>();
   958	            var unitVals = new List<string>();
   959	            var intVals = new List<long>();
   960	            var fltVals = new List<double>();
   961	            var strVals = new List<string>();
   962	            var boolVals = new List<bool>();
   963	
   964	            for (int row = 0; row < perRow.Count; row++)
   965	            {
   966	                if (!structPresent[row])
   967	                {
   968	                    accRows.Add(MzPeakParquet.NullList()); nameRows.Add(MzPeakParquet.NullList());
   969	                    unitRows.Add(MzPeakParquet.NullList()); intRows.Add(MzPeakParquet.NullList());
   970	                    fltRows.Add(MzPeakParquet.NullList()); strRows.Add(MzPeakParquet.NullList());
   971	                    boolRows.Add(MzPeakParquet.NullList());
