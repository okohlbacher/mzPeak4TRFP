   592	
   593	        // Every MS_/UO_/IMS_ CV code embedded in any column name across the metadata schema, as the
   594	        // validator's cv_list_declared rule collects them.
   595	        private static HashSet<string> CollectedCvCodes(byte[] metaBytes)
   596	        {
   597	            var codes = new HashSet<string>();
   598	            using (var ms = new MemoryStream(metaBytes))
   599	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   600	            {
   601	                foreach (var d in reader.Schema.GetDataFields())
   602	                {
   603	                    foreach (System.Text.RegularExpressions.Match mch in
   604	                        System.Text.RegularExpressions.Regex.Matches(d.Path.ToString(), @"(MS|UO|IMS)_\d+"))
   605	                    {
   606	                        codes.Add(mch.Groups[1].Value);
   607	                    }
   608	                }
   609	            }
   610	            return codes;
   611	        }
   612	
   613	        // Recursively walk an arbitrary JSON tree and collect the ontology prefix of every CURIE that
   614	        // appears as a value of an "accession" or "unit" key (e.g. "MS:1000133" -> "MS"). This reaches
   615	        // every PARAM list element, component, file_description, run, and nested block alike.
   616	        private static void CollectCuriePrefixes(JToken node, HashSet<string> into)
   617	        {
   618	            if (node is JObject obj)
   619	            {
   620	                foreach (var prop in obj.Properties())
   621	                {
   622	                    if ((prop.Name == "accession" || prop.Name == "unit") &&
   623	                        prop.Value.Type == JTokenType.String)
   624	                    {
   625	                        var mch = System.Text.RegularExpressions.Regex.Match(
   626	                            (string)prop.Value, @"^(MS|UO|IMS):\d+$");
   627	                        if (mch.Success) into.Add(mch.Groups[1].Value);
   628	                    }
   629	                    CollectCuriePrefixes(prop.Value, into);
   630	                }
   631	            }
   632	            else if (node is JArray arr)
   633	            {
   634	                foreach (var item in arr) CollectCuriePrefixes(item, into);
   635	            }
   636	        }
   637	
   638	        // The authoritative collected set: every CURIE prefix used in any metadata block, gathered from
   639	        // BOTH the schema column names AND recursively from every accession/unit in the JSON metadata.
   640	        private static HashSet<string> CollectAllCvPrefixes(byte[] metaBytes, JObject metadataBlocks)
   641	        {
   642	            var codes = CollectedCvCodes(metaBytes);
   643	            CollectCuriePrefixes(metadataBlocks, codes);
   644	            return codes;
   645	        }
   646	
   647	        private static Dictionary<string, string> FooterKv(byte[] metaBytes)
   648	        {
   649	            using (var ms = new MemoryStream(metaBytes))
   650	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   651	            {
   652	                return new Dictionary<string, string>(reader.CustomMetadata);
   653	            }
   654	        }
