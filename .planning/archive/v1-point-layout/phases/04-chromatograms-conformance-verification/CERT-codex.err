   989	        [Test]
   990	        public void Chromatogram_Metadata_Facet_Shape_And_Values()
   991	        {
   992	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   993	            var dir = Convert(input, out var archive);
   994	            try
   995	            {
   996	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   997	                int n = data.SpectrumCount;
   998	
   999	                var snippet =
  1000	                    "import pyarrow.parquet as pq, json\n" +
  1001	                    "t = pq.read_table(r'{PARQUET}')\n" +
  1002	                    "d = t.to_pylist()\n" +
  1003	                    "c = d[0]['chromatogram']\n" +
  1004	                    "ct = t.schema.field('chromatogram').type\n" +
  1005	                    "aux = ct.field('auxiliary_arrays').type.value_type\n" +
  1006	                    "out = {}\n" +
  1007	                    "out['rows'] = len(d)\n" +
  1008	                    "out['id'] = c['id']\n" +
  1009	                    "out['type'] = c['MS_1000626_chromatogram_type']\n" +
  1010	                    "out['pol'] = int(c['MS_1000465_scan_polarity'])\n" +
  1011	                    "out['pol_type'] = str(ct.field('MS_1000465_scan_polarity').type)\n" +
  1012	                    "out['ndp'] = c['MS_1003060_number_of_data_points']\n" +
  1013	                    "out['dpr_null'] = c['data_processing_ref'] is None\n" +
  1014	                    "out['params_empty'] = c['parameters'] == []\n" +
  1015	                    "out['aux_empty'] = c['auxiliary_arrays'] == []\n" +
  1016	                    "out['naux'] = int(c['number_of_auxiliary_arrays'])\n" +
  1017	                    "out['aux_fields'] = [f.name for f in aux]\n" +
  1018	                    "out['prec_in_schema'] = 'precursor' in [f.name for f in t.schema]\n" +
  1019	                    "out['seli_in_schema'] = 'selected_ion' in [f.name for f in t.schema]\n" +
  1020	                    "out['prec_null'] = d[0]['precursor'] is None or d[0]['precursor']['source_index'] is None\n" +
  1021	                    "out['seli_null'] = d[0]['selected_ion'] is None or d[0]['selected_ion']['source_index'] is None\n" +
  1022	                    "print(json.dumps(out))\n";
  1023	                var o = PyArrowEntry(archive, "chromatograms_metadata.parquet", snippet);
  1024	
  1025	                Assert.That((int)o["rows"], Is.EqualTo(1), "exactly one chromatogram row");
  1026	                Assert.That((string)o["id"], Is.EqualTo("TIC"));
  1027	                Assert.That((string)o["type"], Is.EqualTo("MS:1000235"));
  1028	                Assert.That((int)o["pol"], Is.EqualTo(0));
  1029	                Assert.That((string)o["pol_type"], Is.EqualTo("int8"));
  1030	                Assert.That((long)o["ndp"], Is.EqualTo((long)n));
  1031	                Assert.That((bool)o["dpr_null"], Is.True);
  1032	                Assert.That((bool)o["params_empty"], Is.True);
  1033	                Assert.That((bool)o["aux_empty"], Is.True);
  1034	                Assert.That((int)o["naux"], Is.EqualTo(0));
  1035	
  1036	                var auxFields = o["aux_fields"].Select(x => (string)x).ToArray();
  1037	                foreach (var f in new[] { "data", "name", "data_type", "compression", "unit", "parameters", "data_processing_ref" })
  1038	                    Assert.That(auxFields, Does.Contain(f), $"AUX_ARRAY element exposes {f}");
  1039	
  1040	                Assert.That((bool)o["prec_in_schema"], Is.True);
  1041	                Assert.That((bool)o["seli_in_schema"], Is.True);
  1042	                Assert.That((bool)o["prec_null"], Is.True, "precursor present-but-null on the row");
  1043	                Assert.That((bool)o["seli_null"], Is.True, "selected_ion present-but-null on the row");
  1044	            }
  1045	            finally
  1046	            {
  1047	                Directory.Delete(dir, true);
  1048	            }
  1049	        }
