   658	        private byte[] BuildMetadataFacet(List<Record> records)
   659	        {
   660	            int n = records.Count;
   661	
   662	            var spectrum = BuildSpectrumField();
   663	            var scan = BuildScanField();
   664	            var precursor = BuildPrecursorField();
   665	            var selectedIon = BuildSelectedIonField();
   666	            var schema = new ParquetSchema(spectrum, scan, precursor, selectedIon);
