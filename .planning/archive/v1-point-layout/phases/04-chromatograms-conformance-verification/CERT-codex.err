  1096	
  1097	        // L1 is an independent value check: our spectra_data m/z (f64) is compared bit-exact, per
  1098	        // spectrum, against the m/z array re-read directly from small.RAW (Scan.FromFile().SegmentedScan
  1099	        // .Positions) -- the source is NOT derived from our archive. The Thermo SegmentedScan returns
  1100	        // Positions sorted but Intensities in acquisition order (the two arrays are not index-paired and
  1101	        // their nonzero counts differ from the writer's realigned output), so re-deriving the exact
  1102	        // per-point intensity pairing here would require re-implementing the reader's internal
  1103	        // realignment. L2 value-equality is therefore certified by VER-02 against the independent mzdata
  1104	        // reference (MzPeakDifferentialTests); here L2 is the honest structural invariant: intensity is
  1105	        // f32, finite, and the per-spectrum point count equals number_of_data_points.
  1106	        [Test]
  1107	        public void RoundTrip_L1_Mz_BitExact_Vs_IndependentRawRead_L2_Intensity_F32_Structural()
  1108	        {
  1109	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1110	            var dir = Convert(input, out var archive);
  1111	            try
  1112	            {
  1113	                using (var ms = new MemoryStream(ReadEntry(archive, "spectra_data.parquet")))
  1114	                using (var reader = ParquetReader.CreateAsync(ms).Result)
  1115	                {
  1116	                    Assert.That(Leaf(reader.Schema, "point/mz").ClrType, Is.EqualTo(typeof(double)), "m/z f64");
  1117	                    Assert.That(Leaf(reader.Schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)), "intensity f32");
  1118	                }
  1119	
  1120	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
  1121	                var ourMz = new Dictionary<ulong, List<double>>();
  1122	                var ourInt = new Dictionary<ulong, List<float>>();
  1123	                for (int i = 0; i < data.SpectrumIndex.Length; i++)
  1124	                {
  1125	                    var o = data.SpectrumIndex[i];
  1126	                    if (!ourMz.ContainsKey(o)) { ourMz[o] = new List<double>(); ourInt[o] = new List<float>(); }
  1127	                    ourMz[o].Add(data.Mz[i]);
  1128	                    ourInt[o].Add(data.Intensity[i]);
  1129	                }
  1130	
  1131	                var meta = PyArrowEntry(archive, "spectra_metadata.parquet",
  1132	                    "import pyarrow.parquet as pq, json\n" +
  1133	                    "t = pq.read_table(r'{PARQUET}')\n" +
  1134	                    "d = t.to_pylist()\n" +
  1135	                    "out = {'ndp':[int(d[i]['spectrum']['MS_1003060_number_of_data_points']) for i in range(len(d))]}\n" +
  1136	                    "print(json.dumps(out))\n");
  1137	                var ndp = meta["ndp"].Select(x => (int)x).ToArray();
  1138	                int n = ndp.Length;
  1139	
  1140	                using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
  1141	                {
  1142	                    raw.SelectInstrument(Device.MS, 1);
  1143	                    int first = raw.RunHeaderEx.FirstSpectrum;
  1144	                    int last = raw.RunHeaderEx.LastSpectrum;
  1145	                    var ordinalScan = new List<int>();
  1146	                    for (int scan = first; scan <= last; scan++)
  1147	                    {
  1148	                        var sf = raw.GetFilterForScanNumber(scan);
  1149	                        int lvl = (int)sf.MSOrder;
  1150	                        if (lvl > input.MaxLevel || !input.MsLevel.Contains(lvl)) continue;
  1151	                        var seg = Scan.FromFile(raw, scan).SegmentedScan;
  1152	                        if (seg.Positions == null || seg.Positions.Length == 0) continue;
  1153	                        ordinalScan.Add(scan);
  1154	                    }
  1155	
  1156	                    Assert.That(ordinalScan.Count, Is.EqualTo(n),
  1157	                        "ordinal->scan mapping must cover every emitted spectrum");
  1158	
  1159	                    for (ulong ord = 0; ord < (ulong)n; ord++)
  1160	                    {

exec
/bin/zsh -lc "nl -ba ThermoRawFileParser/ThermoRawFileParserTest/MzPeakWriterTests.cs | sed -n '360,760p'" in /Users/kohlbach/Claude/mzPeak4TRFR
 succeeded in 0ms:
   360	                    }
   361	                }
   362	                catch { }
   363	            }
   364	            return null;
   365	        }
   366	
   367	        // Writes the metadata parquet to a temp file and runs a python pyarrow snippet that prints
   368	        // a single JSON object to stdout. The snippet sees the file path via the {PARQUET} token.
   369	        private static JObject PyArrowMetadata(string archive, string snippet)
   370	        {
   371	            var python = ResolvePython();
   372	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   373	
   374	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   375	            File.WriteAllBytes(path, ReadEntry(archive, "spectra_metadata.parquet"));
   376	            try
   377	            {
   378	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   379	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   380	                {
   381	                    RedirectStandardOutput = true,
   382	                    RedirectStandardError = true,
   383	                    UseShellExecute = false
   384	                };
   385	                using (var proc = Process.Start(psi))
   386	                {
   387	                    var stdout = proc.StandardOutput.ReadToEnd();
   388	                    var stderr = proc.StandardError.ReadToEnd();
   389	                    proc.WaitForExit();
   390	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   391	                    return JObject.Parse(stdout.Trim());
   392	                }
   393	            }
   394	            finally
   395	            {
   396	                File.Delete(path);
   397	            }
   398	        }
