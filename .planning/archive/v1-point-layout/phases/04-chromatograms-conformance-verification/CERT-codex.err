   932	        [Test]
   933	        public void Chromatogram_Data_Facet_Shape_And_PerScan_Alignment()
   934	        {
   935	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   936	            var dir = Convert(input, out var archive);
   937	            try
   938	            {
   939	                using (var ms = new MemoryStream(ReadEntry(archive, "chromatograms_data.parquet")))
   940	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   941	                {
   942	                    var schema = reader.Schema;
   943	                    Assert.That(Leaf(schema, "point/chromatogram_index").ClrType, Is.EqualTo(typeof(ulong)));
   944	                    Assert.That(Leaf(schema, "point/time").ClrType, Is.EqualTo(typeof(double)));
   945	                    Assert.That(Leaf(schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)));
   946	                    Assert.That(Leaf(schema, "point/ms_level").ClrType, Is.EqualTo(typeof(long)));
   947	                }
   948	
   949	                var chrom = ReadChromFacet(ReadEntry(archive, "chromatograms_data.parquet"));
   950	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   951	                int n = data.SpectrumCount;
   952	
   953	                Assert.That(chrom.Time.Length, Is.EqualTo(n), "one TIC point per emitted scan");
   954	                Assert.That(chrom.TicSource, Is.EqualTo("device"),
   955	                    "default conversion must take the device-trace path, not the summed fallback");
   956	                Assert.That(chrom.ChromatogramIndex.All(x => x == 0UL), Is.True, "single chromatogram, index all 0");
   957	                var levels = chrom.MsLevel.Distinct().OrderBy(x => x).ToArray();
   958	                Assert.That(levels, Is.EqualTo(new long[] { 1, 2 }), "ms_level multiset {1,2}, never 0");
   959	
   960	                // Per-scan spectrum (time, ms_level) read from spectra_metadata, aligned by ordinal.
   961	                var snippet =
   962	                    "import pyarrow.parquet as pq, json\n" +
   963	                    "t = pq.read_table(r'{PARQUET}')\n" +
   964	                    "d = t.to_pylist()\n" +
   965	                    "out = {'time':[d[i]['spectrum']['time'] for i in range(len(d))],\n" +
   966	                    "       'lvl':[int(d[i]['spectrum']['MS_1000511_ms_level']) for i in range(len(d))]}\n" +
   967	                    "print(json.dumps(out))\n";
   968	                var o = PyArrowEntry(archive, "spectra_metadata.parquet", snippet);
   969	                var sTime = o["time"].Select(x => (double)x).ToArray();
   970	                var sLvl = o["lvl"].Select(x => (long)x).ToArray();
   971	
   972	                Assert.That(sTime.Length, Is.EqualTo(n));
   973	                for (int i = 0; i < n; i++)
   974	                {
   975	                    Assert.That(chrom.Time[i], Is.EqualTo(sTime[i]).Within(1e-6),
   976	                        $"TIC time[{i}] must equal spectrum time");
   977	                    Assert.That(chrom.MsLevel[i], Is.EqualTo(sLvl[i]),
   978	                        $"TIC ms_level[{i}] must equal spectrum ms_level");
   979	                }
   980	                for (int i = 1; i < n; i++)
   981	                    Assert.That(chrom.Time[i], Is.GreaterThanOrEqualTo(chrom.Time[i - 1]), "time non-decreasing");
   982	            }
   983	            finally
   984	            {
   985	                Directory.Delete(dir, true);
   986	            }
   987	        }
