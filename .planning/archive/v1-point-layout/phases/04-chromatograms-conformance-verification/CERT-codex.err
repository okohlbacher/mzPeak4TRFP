   827	        private void CollectPrefix(string curie)
   828	        {
   829	            if (string.IsNullOrEmpty(curie)) return;
   830	            var i = curie.IndexOf(':');
   831	            if (i > 0) _cvPrefixes.Add(curie.Substring(0, i));
   832	        }
