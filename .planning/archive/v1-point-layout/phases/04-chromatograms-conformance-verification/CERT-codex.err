  1039	        private void AddScanWindows(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1040	            List<Record> records)
  1041	        {
  1042	            var lowerLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"));
  1043	            var upperLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"));
  1044	
  1045	            var lowerRows = new List<MzPeakParquet.LeafRow>();
  1046	            var upperRows = new List<MzPeakParquet.LeafRow>();
  1047	            var lowerVals = new List<float>();
  1048	            var upperVals = new List<float>();
  1049	
  1050	            for (int row = 0; row < records.Count; row++)
  1051	            {
  1052	                lowerRows.Add(MzPeakParquet.ListOf(new[] { lowerLeaf.MaxDefinitionLevel }, new[] { true }));
  1053	                upperRows.Add(MzPeakParquet.ListOf(new[] { upperLeaf.MaxDefinitionLevel }, new[] { true }));
  1054	                lowerVals.Add(records[row].WindowLower);
  1055	                upperVals.Add(records[row].WindowUpper);
  1056	            }
  1057	
  1058	            Emit(cols, lowerLeaf, lowerVals.ToArray(), lowerRows);
  1059	            Emit(cols, upperLeaf, upperVals.ToArray(), upperRows);
  1060	        }
  1061	
  1062	        private static Field FindField(ParquetSchema schema, string path)
  1063	        {
  1064	            var parts = path.Split('/');
  1065	            Field current = schema.Fields.First(f => f.Name == parts[0]);
  1066	            for (int i = 1; i < parts.Length; i++)
  1067	            {
  1068	                current = ((StructField)current).Fields.First(f => f.Name == parts[i]);
  1069	            }
  1070	            return current;
  1071	        }
  1072	
  1073	        private static byte[] WriteFacet(ParquetSchema schema, IReadOnlyDictionary<string, string> meta,
  1074	            IDictionary<DataField, (Array, int[], int[])> cols)
  1075	        {
  1076	            using (var ms = new MemoryStream())
  1077	            {
  1078	                MzPeakParquet.WriteAsync(ms, schema, meta, cols).GetAwaiter().GetResult();
  1079	                return ms.ToArray();
  1080	            }
  1081	        }
  1082	
  1083	        // File-level metadata blocks shared verbatim between the parquet footer KV and the index
  1084	        // metadata{}. Built once after all CV-named columns/params are emitted so the generated
  1085	        // cv_list covers exactly the collected CV-prefix set.
  1086	        private JObject _metadataBlocks;
  1087	
  1088	        private void AddMetadataBlocks(IDictionary<string, string> custom, List<Record> records)
  1089	        {
  1090	            var instruments = BuildInstrumentConfigurations();
  1091	            var software = BuildSoftwareList();
  1092	            var dataProcessing = BuildDataProcessingList();
  1093	            var fileDescription = BuildFileDescription(records);
  1094	            var run = BuildRun();
  1095	
  1096	            // cv_list is generated LAST: every accession/unit routed through Cv() or a param helper
  1097	            // has been recorded in _cvPrefixes by this point.
  1098	            var cvList = BuildCvList();
  1099	
  1100	            _metadataBlocks = new JObject
  1101	            {
  1102	                ["version"] = MzPeakVersion,
  1103	                ["cv_list"] = cvList,
  1104	                ["file_description"] = fileDescription,
  1105	                ["instrument_configuration_list"] = instruments,
  1106	                ["software_list"] = software,
  1107	                ["data_processing_method_list"] = dataProcessing,
  1108	                ["run"] = run,
  1109	                ["sample_list"] = new JArray(),
  1110	                ["scan_settings_list"] = new JArray()
  1111	            };
  1112	
  1113	            custom["cv_list"] = Compact(cvList);
  1114	            custom["file_description"] = Compact(fileDescription);
  1115	            custom["instrument_configuration_list"] = Compact(instruments);
  1116	            custom["software_list"] = Compact(software);
  1117	            custom["data_processing_method_list"] = Compact(dataProcessing);
  1118	            custom["run"] = Compact(run);
  1119	            custom["sample_list"] = "[]";
  1120	            custom["scan_settings_list"] = "[]";
  1121	        }
  1122	
  1123	        private static string Compact(JToken token) =>
  1124	            token.ToString(Newtonsoft.Json.Formatting.None);
  1125	
  1126	        private JArray BuildCvList()
  1127	        {
  1128	            var defs = new Dictionary<string, (string version, string fullName, string uri)>
  1129	            {
  1130	                ["MS"] = (MsCvVersion, "PSI-MS controlled vocabulary",
  1131	                    "https://raw.githubusercontent.com/HUPO-PSI/psi-ms-CV/master/psi-ms.obo"),
  1132	                ["UO"] = (UoCvVersion, "Unit Ontology", "http://purl.obolibrary.org/obo/uo.obo")
  1133	            };
  1134	
  1135	            var list = new JArray();
  1136	            foreach (var prefix in _cvPrefixes.OrderBy(p => p))
  1137	            {
  1138	                defs.TryGetValue(prefix, out var d);
  1139	                list.Add(new JObject
  1140	                {
  1141	                    ["id"] = prefix,
  1142	                    ["version"] = d.version ?? "unknown",
  1143	                    ["full_name"] = d.fullName ?? prefix,
  1144	                    ["uri"] = d.uri ?? ""
  1145	                });
  1146	            }
  1147	            return list;
  1148	        }
  1149	
  1150	        private JArray BuildInstrumentConfigurations()
  1151	        {
  1152	            OntologyMapping.UpdateFTMSDefinition(_instrumentModel);
  1153	            var model = OntologyMapping.GetInstrumentModel(_instrumentModel);
  1154	            var detectors = OntologyMapping.GetDetectors(model.accession);
  1155	
  1156	            var list = new JArray();
  1157	            for (int i = 0; i < _analyzerOrder.Count; i++)
  1158	            {
  1159	                var ionization = OntologyMapping.IonizationTypes.TryGetValue(_ionizationOrder[i], out var ion)
  1160	                    ? ion
  1161	                    : OntologyMapping.IonizationTypes[IonizationModeType.Any];
  1162	                var analyzer = OntologyMapping.MassAnalyzerTypes[_analyzerOrder[i]];
  1163	                var detector = i < detectors.Count ? detectors[i] : OntologyMapping.GetDetectors("default")[0];
  1164	
  1165	                var configParams = new JArray
  1166	                {
  1167	                    CvParam(model.accession, model.name, model.value),
  1168	                    CvParam("MS:1000529", "instrument serial number", _instrumentSerial)
  1169	                };
  1170	                var components = new JArray
  1171	                {
  1172	                    Component("ionsource", 1, ionization),
  1173	                    Component("analyzer", 2, analyzer),
  1174	                    Component("detector", 3, detector)
  1175	                };
  1176	                list.Add(new JObject
  1177	                {
  1178	                    ["id"] = i,
  1179	                    ["software_reference"] = "ThermoRawFileParser",
  1180	                    ["parameters"] = configParams,
  1181	                    ["components"] = components
  1182	                });
  1183	            }
  1184	            return list;
  1185	        }
  1186	
  1187	        private JObject Component(string type, int order, CVParamType cv)
  1188	        {
  1189	            return new JObject
  1190	            {
  1191	                ["component_type"] = type,
  1192	                ["order"] = order,
  1193	                ["parameters"] = new JArray { CvParam(cv.accession, cv.name, cv.value) }
  1194	            };
  1195	        }
