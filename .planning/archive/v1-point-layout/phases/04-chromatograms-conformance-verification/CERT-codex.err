  1004	        private static void AddListLeaf(List<MzPeakParquet.LeafRow> rows, List<string> vals, DataField leaf,
  1005	            List<Param> items, Func<Param, string> sel)
  1006	        {
  1007	            var levels = new int[items.Count];
  1008	            var has = new bool[items.Count];
  1009	            for (int i = 0; i < items.Count; i++)
  1010	            {
  1011	                var v = sel(items[i]);
  1012	                if (v != null) { vals.Add(v); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1013	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1014	            }
  1015	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1016	        }
  1017	
  1018	        private static void AddListLeafNumStruct<T>(List<MzPeakParquet.LeafRow> rows, List<T> vals, DataField leaf,
  1019	            List<Param> items, Func<Param, T?> sel) where T : struct
  1020	        {
  1021	            var levels = new int[items.Count];
  1022	            var has = new bool[items.Count];
  1023	            for (int i = 0; i < items.Count; i++)
  1024	            {
  1025	                var v = sel(items[i]);
  1026	                if (v.HasValue) { vals.Add(v.Value); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1027	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1028	            }
  1029	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1030	        }
  1031	
  1032	        private static void Emit(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf,
  1033	            Array values, List<MzPeakParquet.LeafRow> rows)
  1034	        {
  1035	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
  1036	            cols[leaf] = (values, def, rep);
  1037	        }
