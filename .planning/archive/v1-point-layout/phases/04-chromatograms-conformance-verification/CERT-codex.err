    89	        // Reads both archives and emits a single JSON verdict. Decodes the reference chunk layout to
    90	        // absolute (m/z, intensity) pairs, builds TRFP's per-spectrum signal from its point layout, and
    91	        // compares the nonzero (m/z, intensity) multiset of every reference-profile spectrum. Centroid
    92	        // coverage is scoped to indices present in BOTH peaks facets (the reference centroids MS2 while
    93	        // TRFP keeps MS2 profile in spectra_data, so the centroid sets are disjoint here and the
    94	        // comparison is reported as skipped rather than dropped).
    95	        private const string CompareScript =
    96	            "import sys, json, zipfile, io, collections, struct\n" +
    97	            "import pyarrow.parquet as pq\n" +
    98	            "ref_path, trfp_path = sys.argv[1], sys.argv[2]\n" +
    99	            "def read(zpath, name):\n" +
   100	            "    z = zipfile.ZipFile(zpath)\n" +
   101	            "    return pq.read_table(io.BytesIO(z.read(name))).to_pylist() if name in z.namelist() else None\n" +
   102	            "ref_data = read(ref_path, 'spectra_data.parquet')\n" +
   103	            "ref = collections.defaultdict(list)\n" +
   104	            "for r in ref_data:\n" +
   105	            "    c = r['chunk']; si = c['spectrum_index']; mz = c['mz_chunk_start']\n" +
   106	            "    ref[si].append((mz, c['intensity'][0]))\n" +
   107	            "    for d, it in zip(c['mz_chunk_values'], c['intensity'][1:]):\n" +
   108	            "        mz += d; ref[si].append((mz, it))\n" +
   109	            "ref_profile_indices = sorted(ref.keys())\n" +
   110	            "ref_peaks = read(ref_path, 'spectra_peaks.parquet')\n" +
   111	            "refpk = collections.defaultdict(list)\n" +
   112	            "if ref_peaks:\n" +
   113	            "    for r in ref_peaks:\n" +
   114	            "        p = r['point']; refpk[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   115	            "trfp_data = read(trfp_path, 'spectra_data.parquet')\n" +
   116	            "trfp = collections.defaultdict(list)\n" +
   117	            "for r in trfp_data:\n" +
   118	            "    p = r['point']; trfp[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   119	            "trfp_peaks = read(trfp_path, 'spectra_peaks.parquet')\n" +
   120	            "trfppk = collections.defaultdict(list)\n" +
   121	            "if trfp_peaks:\n" +
   122	            "    for r in trfp_peaks:\n" +
   123	            "        p = r['point']; trfppk[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   124	            "def meta_map(rows):\n" +
   125	            "    m = {}\n" +
   126	            "    for r in rows:\n" +
   127	            "        s = r['spectrum']; m[s['index']] = (s['MS_1000511_ms_level'], s.get('MS_1000465_scan_polarity'), s['time'])\n" +
   128	            "    return m\n" +
   129	            "rm = meta_map(read(ref_path, 'spectra_metadata.parquet'))\n" +
   130	            "tm = meta_map(read(trfp_path, 'spectra_metadata.parquet'))\n" +
   131	            "def nz(pairs):\n" +
   132	            "    c = collections.Counter()\n" +
   133	            "    for mz, it in pairs:\n" +
   134	            "        if it == 0: continue\n" +
   135	            "        c[(mz, struct.unpack('f', struct.pack('f', it))[0])] += 1\n" +
   136	            "    return c\n" +
   137	            "profile_ok = all(nz(ref[si]) == nz(trfp.get(si, [])) for si in ref_profile_indices)\n" +
   138	            "centroid_compared, centroid_skipped, centroid_ok = [], [], True\n" +
   139	            "for si in sorted(refpk.keys()):\n" +
   140	            "    if si in trfppk:\n" +
   141	            "        centroid_compared.append(si)\n" +
   142	            "        if nz(refpk[si]) != nz(trfppk[si]): centroid_ok = False\n" +
   143	            "    else:\n" +
   144	            "        centroid_skipped.append(si)\n" +
   145	            "out = {\n" +
   146	            "  'spectrum_count_ok': len(rm) == len(tm), 'ref_spectrum_count': len(rm), 'trfp_spectrum_count': len(tm),\n" +
   147	            "  'ms_level_ok': all(rm[i][0] == tm[i][0] for i in rm if i in tm),\n" +
   148	            "  'polarity_ok': all(rm[i][1] is None or tm.get(i,(None,None,None))[1] is None or rm[i][1]==tm[i][1] for i in rm),\n" +
   149	            "  'rt_ok': all(i in tm and abs(rm[i][2]-tm[i][2]) < 1e-3 for i in rm),\n" +
   150	            "  'profile_multiset_ok': profile_ok,\n" +
   151	            "  'ref_profile_indices': ref_profile_indices, 'ref_profile_count': len(ref_profile_indices),\n" +
   152	            "  'compared_indices': ref_profile_indices,\n" +
   153	            "  'centroid_indices_compared': centroid_compared, 'centroid_multiset_ok': centroid_ok,\n" +
   154	            "  'centroid_indices_skipped': centroid_skipped,\n" +
   155	            "}\n" +
   156	            "print(json.dumps(out))\n";
   157	
