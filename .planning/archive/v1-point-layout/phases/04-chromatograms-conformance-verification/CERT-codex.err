    61	        private static Facet ReadPointFacet(byte[] bytes)
    62	        {
    63	            using (var ms = new MemoryStream(bytes))
    64	            using (var reader = ParquetReader.CreateAsync(ms).Result)
    65	            {
    66	                var schema = reader.Schema;
    67	                var rg = reader.OpenRowGroupReader(0);
    68	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data
    69	                    .Cast<ulong>().ToArray();
    70	                var mz = rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data
    71	                    .Cast<double>().ToArray();
    72	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
    73	                    .Cast<float>().ToArray();
    74	                var meta = reader.CustomMetadata;
    75	                return new Facet
    76	                {
    77	                    SpectrumIndex = idx,
    78	                    Mz = mz,
    79	                    Intensity = inten,
    80	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
    81	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
    82	                };
    83	            }
    84	        }
