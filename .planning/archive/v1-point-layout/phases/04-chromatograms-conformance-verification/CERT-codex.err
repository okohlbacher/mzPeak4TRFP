   834	        private static void AddScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   835	            string path, Array values, bool[] present)
   836	        {
   837	            var leaf = Leaf(schema, path);
   838	            var rows = present.Select(p => p ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
   839	            var (def, _r) = MzPeakParquet.NestedLevels(leaf, rows);
   840	            cols[leaf] = (values, def, null);
   841	        }
   842	
   843	        // A scalar leaf inside a top-level struct present only on the first M rows (the MSn count),
   844	        // null on rows M..N-1. values has length M (one per MSn).
   845	        private static void AddMsnScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   846	            string path, int n, Array values)
   847	        {
   848	            var leaf = Leaf(schema, path);
   849	            int m = values.Length;
   850	            var rows = Enumerable.Range(0, n)
   851	                .Select(i => i < m ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
   852	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   853	            cols[leaf] = (values, def, null);
   854	        }
   855	
   856	        private static void AddMsnString(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   857	            string path, int n, string[] values)
   858	        {
   859	            var leaf = Leaf(schema, path);
   860	            int m = values.Length;
   861	            var rows = new List<MzPeakParquet.LeafRow>();
   862	            var present = new List<string>();
   863	            for (int i = 0; i < n; i++)
   864	            {
   865	                if (i >= m) rows.Add(MzPeakParquet.Absent());
   866	                else if (values[i] != null) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i]); }
   867	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
   868	            }
   869	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   870	            cols[leaf] = (present.ToArray(), def, null);
   871	        }
   872	
   873	        private static void AddMsnPrecursorIndex(IDictionary<DataField, (Array, int[], int[])> cols,
   874	            ParquetSchema schema, string path, int n, List<Record> msn)
   875	        {
   876	            var leaf = Leaf(schema, path);
   877	            int m = msn.Count;
   878	            var rows = new List<MzPeakParquet.LeafRow>();
   879	            var present = new List<ulong>();
   880	            for (int i = 0; i < n; i++)
   881	            {
   882	                if (i >= m) rows.Add(MzPeakParquet.Absent());
   883	                else if (msn[i].PrecursorIndex.HasValue)
   884	                { rows.Add(MzPeakParquet.Present(leaf)); present.Add(msn[i].PrecursorIndex.Value); }
   885	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
   886	            }
   887	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   888	            cols[leaf] = (present.ToArray(), def, null);
   889	        }
