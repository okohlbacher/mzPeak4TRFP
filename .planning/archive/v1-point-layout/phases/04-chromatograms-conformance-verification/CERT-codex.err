   491	        // A present-but-empty list on a single-row facet (the list value is defined, no elements).
   492	        private void AddEmptyList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   493	            string listPath)
   494	        {
   495	            var list = (ListField)FindField(schema, listPath);
   496	            foreach (var leaf in schema.GetDataFields())
   497	            {
   498	                if (!leaf.Path.ToString().StartsWith(listPath + "/")) continue;
   499	                var rows = new[] { MzPeakParquet.EmptyList(list) };
   500	                var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   501	                cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   502	            }
   503	        }
   504	
   505	        // The auxiliary_arrays list is empty, but its element struct carries a non-nullable data leaf
   506	        // (data/list/item: uint8 not null); emit the same empty-list level for every descendant leaf.
   507	        private void AddEmptyAuxList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   508	            string listPath)
   509	        {
   510	            var list = (ListField)FindField(schema, listPath);
   511	            foreach (var leaf in schema.GetDataFields())
   512	            {
   513	                if (!leaf.Path.ToString().StartsWith(listPath + "/")) continue;
   514	                var rows = new[] { MzPeakParquet.EmptyList(list) };
   515	                var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   516	                cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
