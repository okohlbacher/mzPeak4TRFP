    40	        // The label must already be normalized to snake_case by the caller; this method
    41	        // performs no label normalization and only rewrites the ':' in CURIE accessions to '_'.
    42	        public static string CvColumn(string accession, string label, string unitAccession = null)
    43	        {
    44	            var head = accession.Replace(':', '_') + "_" + label;
    45	            if (unitAccession == null) return head;
    46	            return head + "_unit_" + unitAccession.Replace(':', '_');
    47	        }
    48	
    49	        public static DataColumn Column(DataField field, Array defined, int[] defLevels, int[] repLevels)
    50	        {
    51	            if (defLevels == null) return new DataColumn(field, defined);
    52	            return new DataColumn(field, defined, defLevels, repLevels);
    53	        }
    54	
    55	        // A leaf's presence model for one row. Cells is the per-element definition-level list:
    56	        //   - a non-repeated (scalar) leaf has exactly one cell (its def-level for this row);
    57	        //   - a repeated (list) leaf has one cell per list element (each its def-level), OR a single
    58	        //     cell for a null/empty list (the list itself stops below the element-present level).
    59	        // Definition levels are expressed RELATIVE to the leaf's own MaxDefinitionLevel via the
    60	        // builder helpers (Present/LeafNull/EmptyList/NullList), so callers never hard-code 1 and
    61	        // the same description is correct regardless of how deep the leaf actually sits.
    62	        public readonly struct LeafRow
    63	        {
    64	            public readonly bool Repeated;
    65	            public readonly int[] Cells;          // resolved def-levels, one per emitted entry
    66	            public readonly bool[] Values;         // per entry: does the leaf VALUE array carry a slot
    67	            public LeafRow(bool repeated, int[] cells, bool[] values)
    68	            {
    69	                Repeated = repeated; Cells = cells; Values = values;
    70	            }
    71	        }
    72	
    73	        // GENERAL per-leaf definition/repetition-level computer for arbitrary nested shapes built
    74	        // from StructField / ListField / DataField. Uses Parquet.Net's own schema walk
    75	        // (Field.MaxDefinitionLevel / MaxRepetitionLevel) as the level ceiling, so it is correct for
    76	        // top-level struct, nested struct-in-struct, list-of-struct, null vs empty list, and a null
    77	        // leaf inside a present element alike — never a flat 1. Rep-level is 0 for the first entry of
    78	        // a row and the leaf's MaxRepetitionLevel for subsequent elements of the same list.
    79	        public static (int[] defLevels, int[] repLevels) NestedLevels(DataField leaf, IReadOnlyList<LeafRow> rows)
    80	        {
    81	            int maxRep = leaf.MaxRepetitionLevel;
    82	            var def = new List<int>();
    83	            var rep = maxRep == 0 ? null : new List<int>();
    84	
    85	            foreach (var row in rows)
    86	            {
    87	                if (row.Cells.Length == 0)
    88	                {
    89	                    def.Add(0);
    90	                    rep?.Add(0);
    91	                    continue;
    92	                }
    93	
    94	                for (int i = 0; i < row.Cells.Length; i++)
    95	                {
    96	                    def.Add(row.Cells[i]);
    97	                    rep?.Add(i == 0 ? 0 : maxRep);
    98	                }
    99	            }
   100	
   101	            return (def.ToArray(), rep?.ToArray());
   102	        }
   103	
   104	        // Builder helpers expressed against the leaf's own max levels. Definition-level semantics
   105	        // (measured against Parquet.Net 5.0.1): a present non-null leaf reaches MaxDefinitionLevel;
   106	        // a leaf that is null inside a present element reaches MaxDefinitionLevel-1; a present-but-
   107	        // empty list reaches the list-present level (MaxDefinitionLevel minus the element+value
   108	        // levels); a null list reaches 0.
   109	        public static int PresentLevel(DataField leaf) => leaf.MaxDefinitionLevel;
   110	        public static int LeafNullLevel(DataField leaf) => leaf.MaxDefinitionLevel - 1;
   111	
   112	        // A non-repeated leaf that is present on this row (top struct / nested struct present).
   113	        public static LeafRow Present(DataField leaf) =>
   114	            new LeafRow(false, new[] { leaf.MaxDefinitionLevel }, new[] { true });
   115	
   116	        // A non-repeated leaf whose owning struct is null on this row (def-level 0 padded tail).
   117	        public static LeafRow Absent() => new LeafRow(false, new[] { 0 }, new[] { false });
   118	
   119	        // A non-repeated leaf at an explicit def-level (e.g. a nested struct present but the leaf
   120	        // value itself null -> MaxDefinitionLevel-1, with no value slot).
   121	        public static LeafRow AtLevel(int level, bool hasValue) =>
   122	            new LeafRow(false, new[] { level }, new[] { hasValue });
   123	
   124	        // A list leaf with N elements, each at an explicit def-level; hasValue marks which elements
   125	        // contribute a value slot (a null element value sits one level below the present level).
   126	        public static LeafRow ListOf(int[] levels, bool[] hasValue) =>
   127	            new LeafRow(true, levels, hasValue);
   128	
   129	        // A present-but-empty list (no elements). Level is the list-present level for this leaf.
   130	        public static LeafRow EmptyList(int level) => new LeafRow(true, new[] { level }, new[] { false });
   131	
   132	        // The definition level reached by a present-but-empty list: one below the enclosing
   133	        // ListField's MaxDefinitionLevel (the list value is defined but holds no repeated entry;
   134	        // the deepest level of the ListField counts the presence of at least one element).
   135	        public static LeafRow EmptyList(ListField list) =>
   136	            new LeafRow(true, new[] { list.MaxDefinitionLevel - 1 }, new[] { false });
   137	
   138	        // A null list whose entire ancestor chain is absent at the root — genuine top-level absence,
   139	        // def-level 0. Reserve this ONLY for a list whose outermost owning struct is itself null.
   140	        public static LeafRow NullList() => new LeafRow(true, new[] { 0 }, new[] { false });
   141	
   142	        // A null list whose parent struct(s) ARE present but the list field itself is null. The
   143	        // definition level is the "parent present, list null" level read from the list's own ancestor
   144	        // chain: list.MaxDefinitionLevel counts list-defined(+1) and element-present(+1) above the
   145	        // parent-present level, so the parent-present-list-null level is MaxDefinitionLevel - 2. This
   146	        // is distinct from EmptyList (list defined, no elements = MaxDefinitionLevel - 1) and from
   147	        // NullList() (root absent = 0); it lets a reader tell "activation present, parameters null"
   148	        // apart from "activation absent".
   149	        public static LeafRow NullList(ListField list) =>
   150	            new LeafRow(true, new[] { list.MaxDefinitionLevel - 2 }, new[] { false });
   151	
   152	        // A null list at an explicit definition level, for cases where an ancestor above the list's
   153	        // immediate parent is the one that is null (e.g. grandparent present, parent null).
   154	        public static LeafRow NullListAt(int level) => new LeafRow(true, new[] { level }, new[] { false });
   155	
   156	        public static async Task WriteAsync(Stream output, ParquetSchema schema,
   157	            IReadOnlyDictionary<string, string> customMetadata,
   158	            IDictionary<DataField, (Array defined, int[] defLevels, int[] repLevels)> columns)
   159	        {
   160	            using (var writer = await ParquetWriter.CreateAsync(schema, output).ConfigureAwait(false))
   161	            {
   162	                writer.CompressionMethod = CompressionMethod.Zstd;
   163	                if (customMetadata != null) writer.CustomMetadata = customMetadata;
   164	
   165	                using (var rg = writer.CreateRowGroup())
   166	                {
   167	                    foreach (var field in schema.GetDataFields())
   168	                    {
   169	                        var triple = columns[field];
   170	                        await rg.WriteColumnAsync(Column(field, triple.defined, triple.defLevels, triple.repLevels))
   171	                            .ConfigureAwait(false);
   172	                    }
   173	                }
   174	            }
   175	        }
   176	    }
   177	}

