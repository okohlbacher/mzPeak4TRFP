   129	        // Runs a pyarrow snippet against an arbitrary parquet entry of the archive (the {PARQUET}
   130	        // token is replaced with the temp file path), returning the printed JSON object.
   131	        private static JObject PyArrowEntry(string archive, string entry, string snippet)
   132	        {
   133	            var python = ResolvePython();
   134	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   135	
   136	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   137	            File.WriteAllBytes(path, ReadEntry(archive, entry));
   138	            try
   139	            {
   140	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   141	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   142	                {
   143	                    RedirectStandardOutput = true,
   144	                    RedirectStandardError = true,
   145	                    UseShellExecute = false
   146	                };
   147	                using (var proc = Process.Start(psi))
   148	                {
   149	                    var stdout = proc.StandardOutput.ReadToEnd();
   150	                    var stderr = proc.StandardError.ReadToEnd();
   151	                    proc.WaitForExit();
   152	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   153	                    return JObject.Parse(stdout.Trim());
   154	                }
   155	            }
   156	            finally
   157	            {
   158	                File.Delete(path);
   159	            }
   160	        }
