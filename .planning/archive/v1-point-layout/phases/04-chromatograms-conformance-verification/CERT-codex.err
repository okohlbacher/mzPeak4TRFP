  1276	
  1277	        // A controlled-value PARAM (accession + name, no value). Records the CV prefix so the
  1278	        // generated cv_list stays exhaustive.
  1279	        private JObject CvParam(string accession, string name, string value)
  1280	        {
  1281	            CollectPrefix(accession);
  1282	            return JParam(name, accession, string.IsNullOrEmpty(value) ? null : value, null);
  1283	        }
  1284	
  1285	        // A PARAM object matching the param.json schema (name required; accession/value/unit nullable).
  1286	        private JObject JParam(string name, string accession, object value, string unit)
  1287	        {
  1288	            CollectPrefix(unit);
  1289	            return new JObject
  1290	            {
  1291	                ["name"] = name,
  1292	                ["accession"] = accession == null ? JValue.CreateNull() : new JValue(accession),
  1293	                ["value"] = value == null ? JValue.CreateNull() : JToken.FromObject(value),
  1294	                ["unit"] = unit == null ? JValue.CreateNull() : new JValue(unit)
  1295	            };
  1296	        }
