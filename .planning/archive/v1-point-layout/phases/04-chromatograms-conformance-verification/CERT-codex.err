   538	        // A single all-null row for a leaf in a present-but-null top-level struct: definition level
   539	        // sits one below the leaf's own present level (the owning struct is null), no value slot.
   540	        private static void AddNullLeaf(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf)
   541	        {
   542	            var rows = new[] { MzPeakParquet.AtLevel(0, false) };
   543	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   544	            cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
