   281	
   282	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   283	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   284	        // index sort is applied only when an ascending violation is detected, never dropping or
   285	        // merging equal-m/z points.
   286	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   287	        {
   288	            var n = masses?.Length ?? 0;
   289	            var mz = new double[n];
   290	            var inten = new float[n];
   291	            bool ascending = true;
   292	            for (int i = 0; i < n; i++)
   293	            {
   294	                mz[i] = masses[i];
   295	                inten[i] = (float)intensities[i];
   296	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   297	            }
   298	
   299	            if (ascending) return (mz, inten);
   300	
   301	            var order = new int[n];
   302	            for (int i = 0; i < n; i++) order[i] = i;
   303	            Array.Sort(order, (a, b) =>
   304	            {
   305	                int c = masses[a].CompareTo(masses[b]);
   306	                return c != 0 ? c : a.CompareTo(b);
   307	            });
   308	            var sortedMz = new double[n];
   309	            var sortedInten = new float[n];
   310	            for (int i = 0; i < n; i++)
   311	            {
   312	                sortedMz[i] = masses[order[i]];
   313	                sortedInten[i] = (float)intensities[order[i]];
   314	            }
   315	            return (sortedMz, sortedInten);
   316	        }
   317	
   318	        private void CaptureTic(IRawDataPlus raw, List<Record> records, List<double> time,
   319	            List<float> intensity, List<long> msLevel)
   320	        {
   321	            ChromatogramSignal[] trace;
   322	            try
   323	            {
   324	                raw.SelectInstrument(Device.MS, 1);
   325	                var settings = new ChromatogramTraceSettings(TraceType.TIC);
   326	                var data = raw.GetChromatogramData(new IChromatogramSettings[] { settings }, -1, -1);
   327	                trace = ChromatogramSignal.FromChromatogramData(data);
   328	            }
   329	            catch (Exception ex)
   330	            {
   331	                Log.Warn($"Device TIC trace unavailable, falling back to summed TIC: {ex.Message}");
   332	                trace = Array.Empty<ChromatogramSignal>();
   333	            }
   334	
   335	            if (trace.Length == 0)
   336	            {
   337	                foreach (var r in records)
   338	                {
   339	                    time.Add(r.Time);
   340	                    intensity.Add(r.TotalIonCurrent);
   341	                    msLevel.Add(r.MsLevel);
   342	                }
   343	                _chromFromDeviceTrace = false;
   344	                return;
   345	            }
   346	
   347	            var signal = trace[0];
   348	            if (signal.Times.Count == records.Count)
   349	            {
   350	                for (int i = 0; i < records.Count; i++)
   351	                {
   352	                    time.Add(signal.Times[i]);
   353	                    intensity.Add((float)signal.Intensities[i]);
   354	                    msLevel.Add(records[i].MsLevel);
   355	                }
   356	                _chromFromDeviceTrace = true;
   357	                return;
   358	            }
   359	
   360	            var byScan = new Dictionary<int, (double time, double intensity)>();
   361	            for (int k = 0; k < signal.Scans.Count; k++)
   362	            {
   363	                byScan[signal.Scans[k]] = (signal.Times[k], signal.Intensities[k]);
   364	            }
   365	
   366	            bool allDevice = true;
   367	            foreach (var r in records)
   368	            {
   369	                if (byScan.TryGetValue(r.ScanNumber, out var sample))
   370	                {
   371	                    time.Add(sample.time);
   372	                    intensity.Add((float)sample.intensity);
   373	                }
   374	                else
   375	                {
   376	                    time.Add(r.Time);
   377	                    intensity.Add(r.TotalIonCurrent);
   378	                    allDevice = false;
   379	                }
   380	                msLevel.Add(r.MsLevel);
   381	            }
   382	            _chromFromDeviceTrace = allDevice;
   383	        }
