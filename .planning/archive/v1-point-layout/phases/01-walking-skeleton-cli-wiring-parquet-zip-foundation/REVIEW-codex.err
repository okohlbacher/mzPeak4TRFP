   910	
   911	        private static int ParseToEnum(Type enumType, string formatString, string keyName)
   912	        {
   913	            if (int.TryParse(formatString, out var formatInt)) //can be parsed as int
   914	            {
   915	                if (Enum.IsDefined(enumType, formatInt))
   916	                {
   917	                    return formatInt;
   918	                }
   919	                else
   920	                {
   921	                    throw new OptionException(
   922	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   923	                    keyName);
   924	                }
   925	
   926	            }
   927	            else //try parse as a string
   928	            {
   929	                try
   930	                {
   931	                    return (int)Enum.Parse(enumType, formatString, true);
   932	                }
   933	
   934	                catch (Exception)
