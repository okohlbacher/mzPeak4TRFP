    26	class BufferFormat(Enum):
    27	    """
    28	    The different orientations data arrays may be written in.
    29	
    30	    - ``Point`` - Each data point is stored as a row in the table as-is. Easy to do filtering random access queries over.
    31	    - ``Chunk`` - Segments of data in a specific start-stop range are stored in an encoded block. More compact but harder to do queries over.
    32	    - ``ChunkSecondary`` - Paired with ``Chunk``, these points are stored in separate blocks parallel to the paired ``Chunk``.
    33	    - ``ChunkStart`` - The start of an encoded chunk's value range.
    34	    - ``ChunkEnd`` - The end of an encoded chunk's value range.
    35	    - ``ChunkEncoding`` - The method used to encode the chunk's values.
    36	    """
    37	
    38	    Point = 1
    39	    ChunkStart = 2
    40	    ChunkEnd = 3
