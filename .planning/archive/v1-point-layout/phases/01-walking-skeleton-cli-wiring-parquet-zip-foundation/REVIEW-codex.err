   215	        rgs = []
   216	        for i in range(self.meta.num_row_groups):
   217	            rg = self.meta.row_group(i)
   218	            col_idx = rg.column(self.index_i)
   219	            if col_idx.statistics.has_min_max:
   220	                other = Span(col_idx.statistics.min, col_idx.statistics.max)
