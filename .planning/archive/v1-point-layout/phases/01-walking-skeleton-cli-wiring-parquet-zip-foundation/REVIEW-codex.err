   240	class _BatchIterator(Iterator[tuple[int, pa.RecordBatch]]):
   241	    """
   242	    Incrementally partition a stream of :class:`pyarrow.RecordBatch` instances into
   243	    blocks of single spectrum or chromatogram data.
   244	
   245	    This class serves two purposes:
   246	        1. Providing a more efficient sequential scan of a data file that pre-fetches larger
   247	           blocks of data.
   248	        2. Granular reading for single entities if row group filters are applied, even if the
   249	           entity spans multiple row groups.
   250	
   251	    .. note::
   252	
   253	        The iterator will *start* from the first index in the first row group that
   254	        :attr:`it` spans, so care must be taken to ensure that the desired entity is
   255	        fully contained in :attr:`it`'s spanned row groups **and** :meth:`seek` must
   256	        be used to advance the iterator to the desired entity's index if a sequential
   257	        scan is not desired.
   258	
   259	
   260	    Attributes
   261	    ----------
   262	    it : :class:`Iterator` of :class:`pyarrow.RecordBatch`
   263	        The stream of Arrow batches to unpack from.
   264	    batch : :class:`pyarrow.StructArray`
   265	        The current batch being segmented.
   266	    current_index : int
   267	        The entry index that was last processed.
   268	    index_column : str
   269	        The name of entry index column.
   270	    """
   271	
   272	    it: Iterator[pa.RecordBatch]
   273	    batch: pa.StructArray
   274	    current_index: int
   275	    index_column: str
   276	
   277	    def __repr__(self):
   278	        return (
   279	            f"{self.__class__.__name__}({self.it}, {self.current_index}, {self.index_column}"
   280	            f", buffered={len(self.batch) if self.batch is not None else None})"
   281	        )
   282	
   283	    def __init__(
   284	        self,
   285	        it: Iterator[pa.StructArray],
   286	        current_index: int = None,
   287	        index_column: str = "spectrum_index",
   288	    ):
   289	        self.it = it
   290	        self.batch = None
   291	        self.index_column = index_column
   292	
   293	        # Set up index precondition for _read_next_chunk first-time initialization step
   294	        self.current_index = None
   295	        self._read_next_chunk(update_index=True)
   296	
   297	        # Seek to the requested index if necessary
   298	        if current_index is not None and self.current_index is not None and current_index > self.current_index:
   299	            self.seek(current_index)
   300	
   301	    def _infer_starting_index(self) -> int | None:
   302	        """
   303	        Get the smallest value in the index column.
   304	
   305	        Returns :const:`None` if :attr:`batch` is :const:`None`.
   306	
   307	        Returns
   308	        -------
   309	        :class:`int` or :const:`None`
   310	        """
   311	        if self.batch is None:
   312	            return None
   313	        return pc.min(pc.struct_field(self.batch, self.index_column)).as_py()
   314	
   315	    def _next_index_value(self) -> int | None:
   316	        """
   317	        Get the first value in the index column.
   318	
   319	        Returns :const:`None` if either :attr:`batch` is :const:`None`
   320	        or if the index column is empty.
   321	
   322	        Returns
   323	        -------
   324	        :class:`int` or :const:`None`
   325	        """
   326	        if self.batch is None:
   327	            return
   328	        arr: pa.UInt64Array = pc.struct_field(self.batch, self.index_column)
   329	        if len(arr) > 0:
   330	            return arr[0].as_py()

