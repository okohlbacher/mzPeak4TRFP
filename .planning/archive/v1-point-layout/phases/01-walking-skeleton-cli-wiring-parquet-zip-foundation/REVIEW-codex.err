   936	                    throw new OptionException(
   937	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   938	                    keyName);
   939	                }
   940	            }
   941	        }
   942	
   943	        private static HashSet<int> ParseMsLevel(string inputString)
