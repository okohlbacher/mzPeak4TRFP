   106	        private string NormalizeFileName(string outputFile, string extension, bool gzip)
   107	        {
   108	            string result = outputFile == null ? Path.Combine(ParseInput.OutputDirectory, ParseInput.RawFileNameWithoutExtension) : outputFile;
   109	            string tail = "";
   110	
   111	            string[] extensions;
   112	            if (gzip)
   113	                extensions = new string[] { ".gz", extension };
   114	            else
   115	                extensions = new string[] { extension };
   116	
   117	            result = result.TrimEnd('.');
   118	
   119	            foreach (var ext in extensions)
   120	            {
   121	                if (result.ToLower().EndsWith(ext.ToLower()))
   122	                    result = result.Substring(0, result.Length - ext.Length);
   123	
   124	                tail = ext + tail;
   125	                result = result.TrimEnd('.');
   126	            }
   127	
   128	            return result + tail;
   129	        }
