   161	            ms.Position = 0;
   162	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   163	            {
   164	                var rg = reader.OpenRowGroupReader(0);
   165	
   166	                // accession: row0 present (def 3), row1 null (def 2). String leaves read back
   167	                // with the null embedded inline; def levels are the authoritative lock.
   168	                var acc = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/accession")).Result;
   169	                Assert.That(acc.Data, Is.EqualTo(new[] { "MS:1000511", null }));
   170	                Assert.That(acc.DefinitionLevels, Is.EqualTo(new[] { 3, 2 }));
   171	
   172	                var unit = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/unit")).Result;
   173	                Assert.That(unit.Data, Is.EqualTo(new[] { "UO:0000031", null }));
   174	                Assert.That(unit.DefinitionLevels, Is.EqualTo(new[] { 3, 2 }));
   175	
   176	                var str = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/string")).Result;
   177	                Assert.That(str.Data, Is.EqualTo(new[] { "hello", null }));
   178	                Assert.That(str.DefinitionLevels, Is.EqualTo(new[] { 4, 3 }));
   179	
   180	                // integer populated on both rows.
   181	                var integer = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/integer")).Result;
   182	                Assert.That(integer.Data, Is.EqualTo(new long[] { 7, 9 }));
   183	                Assert.That(integer.DefinitionLevels, Is.EqualTo(new[] { 4, 4 }));
   184	
   185	                // name populated on both rows.
   186	                var name = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/name")).Result;
   187	                Assert.That(name.Data, Is.EqualTo(new[] { "ms level", "intensity" }));
   188	            }
   189	        }
   190	
   191	        [Test]
   192	        public void WrittenFile_ReportsZstdCompression()
   193	        {
   194	            var spectrum = new StructField("spectrum", new DataField<ulong>("index"));
   195	            var schema = new ParquetSchema(spectrum);
   196	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   197	            {
   198	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 0 }, new[] { 1 }, null)
   199	            };
   200	
   201	            var ms = new MemoryStream();
   202	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string>(),
   203	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   204	
   205	            ms.Position = 0;
   206	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   207	            {
   208	                var columns = reader.Metadata.RowGroups[0].Columns;
   209	                Assert.That(columns, Is.Not.Empty);
   210	                foreach (var c in columns)
   211	                    Assert.That(c.MetaData.Codec, Is.EqualTo(Parquet.Meta.CompressionCodec.ZSTD));
   212	
   213	                var rg = reader.OpenRowGroupReader(0);
   214	                var col = rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result;
   215	                Assert.That(col.Data, Is.EqualTo(new ulong[] { 0 }));
   216	            }
   217	        }
   218	    }
   219	}

