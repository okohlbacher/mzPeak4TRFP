   878	        /// <summary>
   879	        /// Show the help message
   880	        /// </summary>
   881	        /// <param name="message">the help message</param>
   882	        /// <param name="optionException">the option exception, can be null</param>
   883	        /// <param name="optionSet">the option set object</param>
   884	        private static void ShowHelp(string message, OptionException optionException, OptionSet optionSet)
   885	        {
   886	            if (optionException != null)
   887	            {
   888	                if (!optionException.OptionName.IsNullOrEmpty())
   889	                {
   890	                    Console.Error.Write(optionException.OptionName + ": ");
   891	                }
   892	
   893	                Console.Error.WriteLine(optionException.Message);
   894	            }
   895	
   896	            Console.Error.WriteLine(message);
   897	            optionSet.WriteOptionDescriptions(Console.Error);
   898	            Environment.Exit(-1);
   899	        }
   900	
   901	        private static string GetValidEnumLevels(Type enumType)
   902	        {
   903	            List<string> output = new List<string>();
   904	            foreach (int v in Enum.GetValues(enumType))
   905	            {
   906	                output.Add(String.Format("{0} ({1})", Enum.GetName(enumType, v), v));
   907	            }
   908	
   909	            return String.Join("\n", output);
   910	        }
   911	
   912	        private static int ParseToEnum(Type enumType, string formatString, string keyName)
   913	        {
   914	            if (int.TryParse(formatString, out var formatInt)) //can be parsed as int
   915	            {
   916	                if (Enum.IsDefined(enumType, formatInt))
   917	                {
   918	                    return formatInt;
   919	                }
   920	                else
   921	                {
   922	                    throw new OptionException(
   923	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   924	                    keyName);
   925	                }
   926	
   927	            }
   928	            else //try parse as a string
   929	            {
   930	                try
   931	                {
   932	                    return (int)Enum.Parse(enumType, formatString, true);
   933	                }
   934	
   935	                catch (Exception)
   936	                {
   937	                    throw new OptionException(
   938	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   939	                    keyName);
   940	                }
   941	            }
   942	        }
   943	
   944	        private static HashSet<int> ParseMsLevel(string inputString)
   945	        {
   946	            try
   947	            {
   948	                var levelIterator = new NumberIterator(inputString, 1, 10);
   949	                return new HashSet<int>(levelIterator.IterateScans());
   950	            }
   951	            catch (Exception ex)
   952	            {
   953	                throw new OptionException($"Cannot parse MS level from {inputString} - {ex.Message}", "msLevel");
   954	            }
   955	        }
   956	    }
   957	}
