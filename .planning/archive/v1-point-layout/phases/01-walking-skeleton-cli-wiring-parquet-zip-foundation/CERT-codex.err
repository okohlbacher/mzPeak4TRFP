    93	            else if (!ParseInput.Gzip || ParseInput.OutputFormat == OutputFormat.IndexMzML)
    94	            {
    95	                Writer = File.CreateText(fileName);
    96	            }
    97	            else
    98	            {
    99	                var fileStream = File.Create(fileName);
