   293	        private protected int GetParentFromScanString(string scanString)
   294	        {
   295	            var parts = Regex.Split(scanString, " ");
   296	
   297	            //find the position of the first (from the end) precursor with a different mass 
   298	            //to account for possible supplementary activations written in the filter
   299	            var lastIonMass = parts.Last().Split('@').First();
   300	            int last = parts.Length;
   301	            while (last > 0 &&
   302	                   parts[last - 1].Split('@').First() == lastIonMass)
   303	            {
   304	                last--;
   305	            }
   306	
   307	            string parentFilter = String.Join(" ", parts.Take(last));
   308	            if (_precursorScanNumbers.ContainsKey(parentFilter))
   309	            {
   310	                return _precursorScanNumbers[parentFilter];
   311	            }
   312	
   313	            return -2; //unsuccessful parsing
   314	        }
   315	
   316	        private protected int FindLastReaction(IScanEvent scanEvent, int msLevel)
   317	        {
   318	            int lastReactionIndex = msLevel - 2;
   319	
   320	            //iteratively trying find the last available index for reaction
   321	            while (true)
   322	            {
   323	                try
   324	                {
   325	                    scanEvent.GetReaction(lastReactionIndex + 1);
   326	                }
   327	                catch (IndexOutOfRangeException)
   328	                {
   329	                    //stop trying
   330	                    break;
   331	                }
   332	
   333	                lastReactionIndex++;
   334	            }
   335	
   336	            //supplemental activation flag is on -> one of the levels (not necissirily the last one) used supplemental activation
   337	            //check last two activations
   338	            if (scanEvent.SupplementalActivation == TriState.On)
   339	            {
   340	                var lastActivation = scanEvent.GetReaction(lastReactionIndex).ActivationType;
   341	                var beforeLastActivation = scanEvent.GetReaction(lastReactionIndex - 1).ActivationType;
   342	
   343	                if ((beforeLastActivation == ActivationType.ElectronTransferDissociation || beforeLastActivation == ActivationType.ElectronCaptureDissociation) &&
   344	                    (lastActivation == ActivationType.CollisionInducedDissociation || lastActivation == ActivationType.HigherEnergyCollisionalDissociation))
   345	                    return lastReactionIndex - 1; //ETD or ECD followed by HCD or CID -> supplemental activation in the last level (move the last reaction one step back)
   346	                else
   347	                    return lastReactionIndex;
   348	            }
   349	            else //just use the last one
   350	            {
   351	                return lastReactionIndex;
   352	            }
   353	        }
