    11	using ThermoFisher.CommonCore.Data.Interfaces;
    12	using ThermoRawFileParser.Util;
    13	
    14	namespace ThermoRawFileParser.Writer
    15	{
    16	    public class MzPeakSpectrumWriter : SpectrumWriter
    17	    {
    18	        private static readonly ILog Log =
    19	            LogManager.GetLogger(MethodBase.GetCurrentMethod().DeclaringType);
    20	
    21	        private const string SpectrumArrayIndex =
    22	            "{\"prefix\":\"point\",\"entries\":[" +
    23	            "{\"context\":\"spectrum\",\"path\":\"point.mz\",\"data_type\":\"MS:1000523\",\"array_type\":\"MS:1000514\"," +
    24	            "\"array_name\":\"m/z array\",\"unit\":\"MS:1000040\",\"buffer_format\":\"point\",\"buffer_priority\":\"primary\"}," +
    25	            "{\"context\":\"spectrum\",\"path\":\"point.intensity\",\"data_type\":\"MS:1000521\",\"array_type\":\"MS:1000515\"," +
    26	            "\"array_name\":\"intensity array\",\"unit\":\"MS:1000131\",\"buffer_format\":\"point\",\"buffer_priority\":\"primary\"}" +
    27	            "]}";
    28	
    29	        public MzPeakSpectrumWriter(ParseInput parseInput) : base(parseInput)
    30	        {
    31	        }
    32	
    33	        public override void Write(IRawDataPlus raw, int firstScanNumber, int lastScanNumber)
    34	        {
    35	            if (!raw.HasMsData)
    36	            {
    37	                throw new RawFileParserException("No MS data in RAW file, no output will be produced");
    38	            }
    39	
    40	            ConfigureWriter(".mzpeak");
    41	
    42	            double[] masses = null;
    43	            double[] intensities = null;
    44	            double rt = 0;
    45	
    46	            for (var scanNumber = firstScanNumber; scanNumber <= lastScanNumber && masses == null; scanNumber++)
    47	            {
    48	                try
    49	                {
    50	                    var scanFilter = raw.GetFilterForScanNumber(scanNumber);
    51	                    int level = (int)scanFilter.MSOrder;
    52	                    if (level > ParseInput.MaxLevel || !ParseInput.MsLevel.Contains(level)) continue;
    53	
    54	                    var scanEvent = raw.GetScanEventForScanNumber(scanNumber);
    55	                    var mzData = ReadMZData(raw, scanEvent, scanNumber,
    56	                        !ParseInput.NoPeakPicking.Contains((int)scanFilter.MSOrder), false, false);
    57	
    58	                    if (mzData.masses != null && mzData.masses.Length >= 1)
    59	                    {
    60	                        masses = mzData.masses;
    61	                        intensities = mzData.intensities;
    62	                        rt = raw.RetentionTimeFromScanNumber(scanNumber);
    63	                    }
    64	                }
    65	                catch (Exception ex)
    66	                {
    67	                    Log.Error($"Scan #{scanNumber} cannot be processed because of the following exception: {ex.Message}");
    68	                    Log.Debug($"{ex.StackTrace}\n{ex.InnerException}");
    69	                    ParseInput.NewError();
    70	                }
    71	            }
    72	
    73	            if (masses == null)
    74	            {
    75	                throw new RawFileParserException("No in-range spectrum with data points to write");
    76	            }
    77	
    78	            var dataBytes = BuildDataFacet(masses, intensities);
    79	            var metaBytes = BuildMetadataFacet(rt);
    80	            var indexBytes = BuildIndex();
    81	
    82	            using (var zip = new ZipArchive(Writer.BaseStream, ZipArchiveMode.Create, true))
    83	            {
    84	                AddStored(zip, "mzpeak_index.json", indexBytes);
    85	                AddStored(zip, "spectra_data.parquet", dataBytes);
    86	                AddStored(zip, "spectra_metadata.parquet", metaBytes);
    87	            }
    88	
    89	            Writer.Flush();
    90	            Writer.Close();
    91	
    92	            Log.Info($"Wrote mzPeak archive with 1 spectrum ({masses.Length} points)");
    93	        }
    94	
    95	        private static void AddStored(ZipArchive zip, string name, byte[] bytes)
    96	        {
    97	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
    98	            using (var s = entry.Open())
    99	            {
   100	                s.Write(bytes, 0, bytes.Length);
   101	            }
   102	        }
   103	
   104	        private static byte[] BuildDataFacet(double[] masses, double[] intensities)
   105	        {
   106	            var point = new StructField("point",
   107	                new DataField<ulong>("spectrum_index"),
   108	                new DataField<double>("mz"),
   109	                new DataField<float>("intensity"));
   110	            var schema = new ParquetSchema(point);
   111	
   112	            var n = masses.Length;
   113	            var idx = new ulong[n];
   114	            var mz = new double[n];
   115	            var inten = new float[n];
   116	            for (int i = 0; i < n; i++)
   117	            {
   118	                idx[i] = 0;
   119	                mz[i] = masses[i];
   120	                inten[i] = (float)intensities[i];
   121	            }
   122	
   123	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   124	            {
   125	                [Leaf(schema, "point/spectrum_index")] = (idx, null, null),
   126	                [Leaf(schema, "point/mz")] = (mz, null, null),
   127	                [Leaf(schema, "point/intensity")] = (inten, null, null)
   128	            };
   129	
   130	            var meta = new Dictionary<string, string>
   131	            {
   132	                ["spectrum_count"] = "1",
   133	                ["spectrum_data_point_count"] = n.ToString(),
   134	                ["spectrum_array_index"] = SpectrumArrayIndex
   135	            };
   136	
   137	            return WriteFacet(schema, meta, cols);
   138	        }
   139	
   140	        private static byte[] BuildMetadataFacet(double rt)
   141	        {
   142	            var spectrum = new StructField("spectrum",
   143	                new DataField<ulong>("index"),
   144	                new DataField<string>("id", true),
   145	                new DataField<double>("time", true));
   146	            var schema = new ParquetSchema(spectrum);
   147	
   148	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   149	            {
   150	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 0 }, new[] { 1 }, null),
   151	                [Leaf(schema, "spectrum/id")] = (new[] { "index=0" }, new[] { 2 }, null),
   152	                [Leaf(schema, "spectrum/time")] = (new[] { rt }, new[] { 2 }, null)
   153	            };
   154	
   155	            var meta = new Dictionary<string, string>
   156	            {
   157	                ["spectrum_count"] = "1",
   158	                ["spectrum_data_point_count"] = "0"
   159	            };
   160	
   161	            return WriteFacet(schema, meta, cols);
   162	        }
   163	
   164	        private static byte[] WriteFacet(ParquetSchema schema, IReadOnlyDictionary<string, string> meta,
   165	            IDictionary<DataField, (Array, int[], int[])> cols)
   166	        {
   167	            using (var ms = new MemoryStream())
   168	            {
   169	                MzPeakParquet.WriteAsync(ms, schema, meta, cols).GetAwaiter().GetResult();
   170	                return ms.ToArray();
   171	            }
   172	        }
   173	
   174	        private static byte[] BuildIndex()
   175	        {
   176	            var index = new JObject
   177	            {
   178	                ["files"] = new JArray
   179	                {
   180	                    new JObject
   181	                    {
   182	                        ["name"] = "spectra_data.parquet",
   183	                        ["entity_type"] = "spectrum",
   184	                        ["data_kind"] = "data arrays"
   185	                    },
   186	                    new JObject
   187	                    {
   188	                        ["name"] = "spectra_metadata.parquet",
   189	                        ["entity_type"] = "spectrum",
   190	                        ["data_kind"] = "metadata"
   191	                    }
   192	                },
   193	                ["metadata"] = new JObject()
   194	            };
   195	
   196	            return new UTF8Encoding(false).GetBytes(index.ToString());
   197	        }
   198	
   199	        private static DataField Leaf(ParquetSchema schema, string path)
   200	        {
   201	            foreach (var d in schema.GetDataFields())
   202	                if (d.Path.ToString() == path) return d;
   203	            throw new RawFileParserException($"Leaf not found: {path}");
   204	        }
   205	    }
   206	}

