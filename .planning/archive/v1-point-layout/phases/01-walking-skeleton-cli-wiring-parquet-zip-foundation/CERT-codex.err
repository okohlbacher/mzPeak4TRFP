    10	using ThermoRawFileParser.XIC;
    11	using System.Globalization;
    12	using System.Collections.Generic;
    13	using System.Data;
    14	using ThermoRawFileParser.Util;
    15	
    16	[assembly: log4net.Config.XmlConfigurator()]
    17	
    18	namespace ThermoRawFileParser
    19	{
    20	    public static class MainClass
    21	    {
    22	        private static readonly ILog Log =
    23	            LogManager.GetLogger(MethodBase.GetCurrentMethod().DeclaringType);
    24	
    25	        public static string Version = Assembly.GetExecutingAssembly().GetName().Version.ToString();
    26	        public static void Main(string[] args)
    27	        {
    28	            // Set Invariant culture as default for all further processing
    29	            CultureInfo.DefaultThreadCurrentCulture = CultureInfo.InvariantCulture;
    30	
    31	            // Introduce subcommand for xics and spectra query
    32	            if (args.Length > 0)
    33	            {
    34	                switch (args[0])
    35	                {
    36	                    case "xic":
    37	                        XicParametersParsing(args.Skip(1).ToArray()); // skip first command
    38	                        break;
    39	                    case "query":
    40	                        SpectrumQueryParametersParsing(args.Skip(1).ToArray());
    41	                        break;
    42	                    default:
    43	                        RegularParametersParsing(args);
    44	                        break;
    45	                }
    46	            }
    47	            else
    48	            {
    49	                RegularParametersParsing(args);
    50	            }
    51	        }
    52	
    53	        private static void XicParametersParsing(string[] args)
    54	        {
    55	            XicParameters parameters = new XicParameters();
    56	            string singleFile = null;
    57	            string fileDirectory = null;
    58	            string outputFile = null;
    59	            string outputDirectory = null;
    60	            string logFormatString = null;
    61	
    62	            var optionSet = new OptionSet
    63	            {
    64	                {
    65	                    "h|help", "Prints out the options.",
    66	                    h => parameters.help = h != null
    67	                },
    68	                {
    69	                    "i=|input=", "The raw file input (Required). Specify this or an input directory -d",
    70	                    v => singleFile = v
    71	                },
    72	                {
    73	                    "d=|input_directory=",
    74	                    "The directory containing the raw files (Required). Specify this or an input file -i.",
    75	                    v => fileDirectory = v
    76	                },
    77	                {
    78	                    "j=|json=",
    79	                    "The json input file (Required).",
    80	                    v => parameters.jsonFilePath = v
    81	                },
    82	                {
    83	                    "p|print_example",
    84	                    "Show a json input file example.",
    85	                    v => parameters.printJsonExample = v != null
    86	                },
    87	                {
    88	                    "b=|output=",
    89	                    "The output file. Specify this or an output directory. Specifying neither writes to the input directory.",
    90	                    v => outputFile = v
    91	                },
    92	                {
    93	                    "o=|output_directory=",
    94	                    "The output directory. Specify this or an output file. Specifying neither writes to the input directory.",
    95	                    v => outputDirectory = v
    96	                },
    97	                {
    98	                    "6|base64",
    99	                    "Encodes the content of the xic vectors as base 64 encoded string.",
   100	                    v => parameters.base64 = v != null
   101	                },
   102	                {
   103	                    "s|stdout",
   104	                    "Pipes the output into standard output. Logging is being turned off.",
   105	                    v => parameters.stdout = v != null
   106	                },
   107	                {
   108	                    "w|warningsAreErrors", "Return non-zero exit code for warnings; default only for errors",
   109	                    v => parameters.Vigilant = v != null
   110	                },
   111	                {
   112	                    "l=|logging=", "Optional logging level: 0 for silent, 1 for verbose, 2 for default, 3 for warning, 4 for error; both numeric and text (case insensitive) value recognized.",
   113	                    v => logFormatString = v
   114	                }
   115	            };
   116	
   117	            try
   118	            {
   119	                // parse the command line
   120	                var extra = optionSet.Parse(args);
   121	
   122	                if (!extra.IsNullOrEmpty())
   123	                {
   124	                    throw new OptionException("unexpected extra arguments", null);
   125	                }
   126	
   127	
   128	                if (parameters.help)
   129	                {
   130	                    ShowHelp("usage is:", new OptionException(),
   131	                        optionSet);
   132	                    return;
   133	                }
   134	
   135	                if (parameters.printJsonExample)
   136	                {
   137	                    var exampleJson =
   138	                        "[\n  {\n    \"mz\":673.363,\n    \"tolerance\":10,\n    \"tolerance_unit\": \"ppm\",\n  },\n  {\n    \"mz\":867.345,\n    \"tolerance\": 0.02,\n    \"tolerance_unit\": \"da\",\n    \"rt_start\":87.56,\n    \"rt_end\":99.56\n  }\n]";
   139	
   140	                    Console.WriteLine(exampleJson);
   141	                    return;
   142	                }
   143	
   144	
   145	                if (singleFile != null && !File.Exists(singleFile))
   146	                {
   147	                    throw new OptionException(
   148	                        "specify a valid RAW file location",
   149	                        "-i, --input");
   150	                }
   151	
   152	                if (fileDirectory != null && !Directory.Exists(fileDirectory))
   153	                {
   154	                    throw new OptionException(
   155	                        "specify a valid input directory",
   156	                        "-d, --input_directory");
   157	                }
   158	
   159	
   160	                if (parameters.jsonFilePath == null)
   161	                {
   162	                    throw new OptionException(
   163	                        "specify an json input file. If you are not sure about the structure of the json file, use -p for printing an examplarily json input file",
   164	                        "-j, --json");
   165	                }
   166	
   167	
   168	                if (parameters.jsonFilePath != null && !File.Exists(parameters.jsonFilePath))
   169	                {
   170	                    throw new OptionException(
   171	                        "specify a valid json file location",
   172	                        "-j, --json");
   173	                }
   174	
   175	
   176	                if (outputDirectory != null && !Directory.Exists(outputDirectory))
   177	                {
   178	                    throw new OptionException(
   179	                        "specify a valid output location",
   180	                        "-o, --output");
   181	                }
   182	
   183	                if ((singleFile == null && fileDirectory == null) || (singleFile != null && fileDirectory != null))
   184	                {
   185	                    throw new OptionException(
   186	                        "specify either an input file or an input directory",
   187	                        "-i, --input xor -d, --input_directory");
   188	                }
   189	
   190	                if (outputFile != null && outputDirectory != null)
   191	                {
   192	                    throw new OptionException(
   193	                        "cannot use an output file and an output directory simultaneously",
   194	                        "-b, --output_file; -o, --output");
   195	                }
   196	
   197	                if (singleFile != null)
   198	                {
   199	                    parameters.rawFileList.Add(Path.GetFullPath(singleFile));
   200	                    
   201	                    if (outputFile != null)
   202	                    {
   203	                        parameters.outputFileList.Add(Path.GetFullPath(outputFile));
   204	                    }
   205	                    else if (outputDirectory != null)
   206	                    {
   207	                        parameters.outputFileList.Add(Path.Combine(outputDirectory ?? throw new NoNullAllowedException("Output directory cannot be null"),
   208	                                                        Path.GetFileNameWithoutExtension(singleFile) + ".json"));
   209	                    }
   210	                    else
   211	                    {
   212	                        parameters.outputFileList.Add(Path.Combine(Path.GetDirectoryName(Path.GetFullPath(singleFile)),
   213	                                                        Path.GetFileNameWithoutExtension(singleFile) + ".json"));
   214	                    }
   215	                }
   216	                else
   217	                {
   218	                    if (outputFile != null)
   219	                    {
   220	                        throw new OptionException("Cannot use single output file to proceess a directory, use directory output instead", "-o, --output");
   221	                    }
   222	                    else if (outputDirectory != null)
   223	                    {
   224	                        outputDirectory = Path.GetFullPath(outputDirectory);
   225	                    }
   226	                    else
   227	                    {
   228	                        outputDirectory = Path.GetFullPath(fileDirectory);
   229	                    }
   230	
   231	                    var directoryInfo = new DirectoryInfo(Path.GetFullPath(fileDirectory));
   232	                    var files = directoryInfo.GetFiles("*", SearchOption.TopDirectoryOnly)
   233	                        .Where(f => f.Extension.ToLower() == ".raw").ToArray<FileInfo>();
   234	                    foreach (var file in files)
   235	                    {
   236	                        parameters.rawFileList.Add(file.FullName);
   237	                        parameters.outputFileList.Add(Path.Combine(outputDirectory ?? throw new NoNullAllowedException("Output directory cannot be null"),
   238	                                                    Path.GetFileNameWithoutExtension(file.Name) + ".json"));
   239	                    }
   240	                }
   241	
   242	                if (logFormatString != null)
   243	                {
   244	                    parameters.LogFormat = (LogFormat)ParseToEnum(typeof(LogFormat), logFormatString, "-l, --logging");
   245	                }
   246	
   247	                if (parameters.stdout) parameters.LogFormat = LogFormat.SILENT; //switch off logging in stdout
   248	            }
   249	            catch (OptionException optionException)
   250	            {
   251	                ShowHelp("Error - usage is:", optionException,
   252	                    optionSet);
   253	            }
   254	            catch (ArgumentNullException)
   255	            {
   256	                if (parameters.help)
   257	                {
   258	                    ShowHelp("usage is:", new OptionException(),
   259	                        optionSet);
   260	                }
   261	                else
   262	                {
   263	                    ShowHelp("Error - usage is:", new OptionException(),
   264	                        optionSet);
   265	                }
   266	            }
   267	
   268	            var exitCode = 1;
   269	            try
   270	            {
   271	                switch (parameters.LogFormat)
   272	                {
   273	                    case LogFormat.VERBOSE:
   274	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   275	                            Level.Debug;
   276	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   277	                            .RaiseConfigurationChanged(EventArgs.Empty);
   278	                        break;
   279	                    case LogFormat.SILENT:
   280	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   281	                            Level.Off;
   282	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   283	                            .RaiseConfigurationChanged(EventArgs.Empty);
   284	                        break;
   285	                    case LogFormat.WARNING:
   286	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   287	                            Level.Warn;
   288	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   289	                            .RaiseConfigurationChanged(EventArgs.Empty);
   290	                        break;
   291	                    case LogFormat.ERROR:
   292	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   293	                            Level.Error;
   294	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   295	                            .RaiseConfigurationChanged(EventArgs.Empty);
   296	                        break;
   297	                }
   298	
   299	                XicExecutor.Run(parameters);
   300	
   301	                Log.Info($"Processing completed {parameters.Errors} errors, {parameters.Warnings} warnings");
   302	
   303	                exitCode = parameters.Vigilant ? parameters.Errors + parameters.Warnings : parameters.Errors;
   304	            }
   305	            catch (Exception ex)
   306	            {
   307	                if (ex is RawFileParserException)
   308	                {
   309	                    Log.Error(ex.Message);
   310	                }
   311	                else
   312	                {
   313	                    Log.Error("An unexpected error occured:");
   314	                    Log.Error(ex.ToString());
   315	                }
   316	            }
   317	            finally
   318	            {
   319	                Environment.Exit(exitCode);
   320	            }
   321	        }
   322	
   323	        private static void SpectrumQueryParametersParsing(string[] args)
   324	        {
   325	            string logFormatString = null;
   326	            QueryParameters parameters = new QueryParameters();
   327	            var optionSet = new OptionSet
   328	            {
   329	                {
   330	                    "h|help", "Prints out the options.",
   331	                    h => parameters.help = h != null
   332	                },
   333	                {
   334	                    "i=|input=", "The raw file input (Required).",
   335	                    v => parameters.rawFilePath = v
   336	                },
   337	                {
   338	                    "n=|scans=",
   339	                    "The scan numbers. e.g. \"1-5, 20, 25-30\"",
   340	                    v => parameters.scans = v
   341	                },
   342	                {
   343	                    "b=|output=",
   344	                    "The output file. Specifying none writes the output file to the input file parent directory.",
   345	                    v => parameters.outputFile = v
   346	                },
   347	                {
   348	                    "p|noPeakPicking",
   349	                    "Don't use the peak picking provided by the native Thermo library. By default peak picking is enabled.",
   350	                    v => parameters.noPeakPicking = v != null
   351	                },
   352	                {
   353	                    "s|stdout",
   354	                    "Pipes the output into standard output. Logging is being turned off",
   355	                    v => parameters.stdout = v != null
   356	                },
   357	                {
   358	                   "w|warningsAreErrors", "Return non-zero exit code for warnings; default only for errors",
   359	                    v => parameters.Vigilant = v != null
   360	                },
   361	                {
   362	                    "l=|logging=", "Optional logging level: 0 for silent, 1 for verbose, 2 for default, 3 for warning, 4 for error; both numeric and text (case insensitive) value recognized.",
   363	                    v => logFormatString = v
   364	                }
   365	            };
   366	
   367	            try
   368	            {
   369	                // parse the command line
   370	                var extra = optionSet.Parse(args);
   371	
   372	                if (!extra.IsNullOrEmpty())
   373	                {
   374	                    throw new OptionException("unexpected extra arguments", null);
   375	                }
   376	
   377	                if (parameters.help)
   378	                {
   379	                    ShowHelp("usage is:", new OptionException(),
   380	                        optionSet);
   381	                    return;
   382	                }
   383	
   384	                if (parameters.rawFilePath == null)
   385	                {
   386	                    throw new OptionException(
   387	                        "specify an input file",
   388	                        "-i, --input ");
   389	                }
   390	
   391	                if (parameters.rawFilePath != null && !File.Exists(parameters.rawFilePath))
   392	                {
   393	                    throw new OptionException(
   394	                        "specify a valid RAW file location",
   395	                        "-i, --input");
   396	                }
   397	
   398	                if (parameters.scans.IsNullOrEmpty())
   399	                {
   400	                    throw new OptionException(
   401	                        "specify a valid scan range",
   402	                        "-s, --scans");
   403	                }
   404	
   405	                if (logFormatString != null)
   406	                {
   407	                    parameters.LogFormat = (LogFormat)ParseToEnum(typeof(LogFormat), logFormatString, "-l, --logging");
   408	                }
   409	
   410	                if (parameters.stdout) parameters.LogFormat = LogFormat.SILENT; //switch off logging in stdout
   411	            }
   412	            catch (OptionException optionException)
   413	            {
   414	                ShowHelp("Error - usage is:", optionException,
   415	                    optionSet);
   416	            }
   417	            catch (ArgumentNullException)
   418	            {
   419	                if (parameters.help)
   420	                {
   421	                    ShowHelp("usage is:", new OptionException(),
   422	                        optionSet);
   423	                }
   424	                else
   425	                {
   426	                    ShowHelp("Error - usage is:", new OptionException(),
   427	                        optionSet);
   428	                }
   429	            }
   430	
   431	            var exitCode = 1;
   432	            try
   433	            {
   434	                switch (parameters.LogFormat)
   435	                {
   436	                    case LogFormat.VERBOSE:
   437	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   438	                            Level.Debug;
   439	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   440	                            .RaiseConfigurationChanged(EventArgs.Empty);
   441	                        break;
   442	                    case LogFormat.SILENT:
   443	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   444	                            Level.Off;
   445	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   446	                            .RaiseConfigurationChanged(EventArgs.Empty);
   447	                        break;
   448	                    case LogFormat.WARNING:
   449	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   450	                            Level.Warn;
   451	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   452	                            .RaiseConfigurationChanged(EventArgs.Empty);
   453	                        break;
   454	                    case LogFormat.ERROR:
   455	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   456	                            Level.Error;
   457	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   458	                            .RaiseConfigurationChanged(EventArgs.Empty);
   459	                        break;
   460	                }
   461	
   462	                QueryExecutor.Run(parameters);
   463	
   464	                Log.Info($"Processing completed {parameters.Errors} errors, {parameters.Warnings} warnings");
   465	
   466	                exitCode = parameters.Vigilant ? parameters.Errors + parameters.Warnings : parameters.Errors;
   467	            }
   468	            catch (Exception ex)
   469	            {
   470	                if (ex is RawFileParserException)
   471	                {
   472	                    Log.Error(ex.Message);
   473	                }
   474	                else
   475	                {
   476	                    Log.Error("An unexpected error occured:");
   477	                    Log.Error(ex.ToString());
   478	                }
   479	            }
   480	            finally
   481	            {
   482	                Environment.Exit(exitCode);
   483	            }
   484	        }
   485	
   486	        private static void RegularParametersParsing(string[] args)
   487	        {
   488	            var help = false;
   489	            var version = false;
   490	            string outputFormatString = null;
   491	            string metadataFormatString = null;
   492	            string logFormatString = null;
   493	            var parseInput = new ParseInput();
   494	
   495	            var optionSet = new OptionSet
   496	            {
   497	                {
   498	                    "h|help", "Prints out the options.",
   499	                    h => help = h != null
   500	                },
   501	                {
   502	                    "v|version", "Prints out the version of the executable.",
   503	                    v => version = v != null
   504	                },
   505	                {
   506	                    "i=|input=", "The raw file input (Required). Specify this or an input directory -d.",
   507	                    v => parseInput.RawFilePath = v
   508	                },
   509	                {
   510	                    "d=|input_directory=",
   511	                    "The directory containing the raw files (Required). Specify this or an input raw file -i.",
   512	                    v => parseInput.RawDirectoryPath = v
   513	                },
   514	                {
   515	                    "b=|output=",
   516	                    "The output file. Specify this or an output directory -o. Specifying neither writes to the input directory.",
   517	                    v => parseInput.OutputFile = v
   518	                },
   519	                {
   520	                    "o=|output_directory=",
   521	                    "The output directory. Specify this or an output file -b. Specifying neither writes to the input directory.",
   522	                    v => parseInput.OutputDirectory = v
   523	                },
   524	                {
   525	                    "s|stdout",
   526	                    "Write to standard output. Cannot be combined with file or directory output. Implies silent logging, i.e. logging level 0",
   527	                    v => parseInput.StdOut = v != null
   528	                },
   529	                {
   530	                    "f=|format=",
   531	                    "The spectra output format: 0 for MGF, 1 for mzML, 2 for indexed mzML, 3 for Parquet, 4 for mzPeak, 5 for None (no output); both numeric and text (case insensitive) value recognized. Defaults to indexed mzML if no format is specified.",
   532	                    v => outputFormatString = v
   533	                },
   534	                {
   535	                    "m=|metadata=", "The metadata output format: 0 for JSON, 1 for TXT, 2 for None (no output); both numeric and text (case insensitive) value recognized. Defaults to None",
   536	                    v => metadataFormatString = v
   537	                },
   538	                {
   539	                    "c=|metadata_output_file",
   540	                    "The metadata output file. By default the metadata file is written to the output directory.",
   541	                    v => parseInput.MetadataOutputFile = v
   542	                },
   543	                {
   544	                    "g|gzip", "GZip the output file.",
   545	                    v => parseInput.Gzip = v != null
   546	                },
   547	                {
   548	                    "p:|noPeakPicking:",
   549	                    "Don't use the peak picking provided by the native Thermo library. By default peak picking is enabled. Optional argument allows disabling peak peaking only for selected MS levels and should be a comma-separated list of integers (1,2,3) and/or intervals (1-3), open-end intervals (1-) are allowed",
   550	                    v => parseInput.NoPeakPicking = v is null ? ParseInput.AllLevels : ParseMsLevel(v)
   551	                },
   552	                {
   553	                    "z|noZlibCompression",
   554	                    "Don't use zlib compression for the m/z ratios and intensities. By default zlib compression is enabled.",
   555	                    v => parseInput.NoZlibCompression = v != null
   556	                },
   557	                {
   558	                    "a|allDetectors",
   559	                    "Extract additional detector data: UV/PDA etc",
   560	                    v => parseInput.AllDetectors = v != null
   561	                },
   562	                {
   563	                    "l=|logging=", "Optional logging level: 0 for silent, 1 for verbose, 2 for default, 3 for warning, 4 for error; both numeric and text (case insensitive) value recognized.",
   564	                    v => logFormatString = v
   565	                },
   566	                {
   567	                    "e|ignoreInstrumentErrors", "Ignore missing properties by the instrument.",
   568	                    v => parseInput.IgnoreInstrumentErrors = v != null
   569	                },
   570	                {
   571	                    "x|excludeExceptionData", "Exclude reference and exception data",
   572	                    v => parseInput.ExData = v != null
   573	                },
   574	                {
   575	                    "L=|msLevel=",
   576	                    "Select MS levels (MS1, MS2, etc) included in the output, should be a comma-separated list of integers (1,2,3) and/or intervals (1-3), open-end intervals (1-) are allowed",
   577	                    v => parseInput.MsLevel = ParseMsLevel(v)
   578	                },
   579	                {
   580	                    "P|mgfPrecursor",
   581	                    "Include precursor scan number in MGF file TITLE",
   582	                    v => parseInput.MgfPrecursor = v != null
   583	                },
   584	                {
   585	                    "N|noiseData", "Include noise data in mzML output",
   586	                    v => parseInput.NoiseData = v != null
   587	                },
   588	                {
   589	                    "C|chargeData", "Include instrument detected charge states in mzML output (only for high resolution centroided data)",
   590	                    v => parseInput.ChargeData = v != null
   591	                },
   592	                {
   593	                  "w|warningsAreErrors", "Return non-zero exit code for warnings; default only for errors",
   594	                    v => parseInput.Vigilant = v != null 
   595	                },
   596	                {
   597	                    "u:|s3_url:",
   598	                    "Optional property to write directly the data into S3 Storage.",
   599	                    v => parseInput.S3Url = v
   600	                },
   601	                {
   602	                    "k:|s3_accesskeyid:",
   603	                    "Optional key for the S3 bucket to write the file output.",
   604	                    v => parseInput.S3AccessKeyId = v
   605	                },
   606	                {
   607	                    "t:|s3_secretaccesskey:",
   608	                    "Optional key for the S3 bucket to write the file output.",
   609	                    v => parseInput.S3SecretAccessKey = v
   610	                },
   611	                {
   612	                    "n:|s3_bucketName:",
   613	                    "S3 bucket name",
   614	                    v => parseInput.BucketName = v
   615	                }
   616	            };
   617	
   618	            try
   619	            {
   620	                // parse the command line
   621	                var extra = optionSet.Parse(args);
   622	
   623	                if (!extra.IsNullOrEmpty())
   624	                {
   625	                    throw new OptionException("Unexpected extra arguments", null);
   626	                }
   627	
   628	                if (help)
   629	                {
   630	                    var helpMessage =
   631	                        $"Usage is {Assembly.GetExecutingAssembly().GetName().Name}.exe [subcommand] [options]\noptional subcommands are xic|query (use [subcommand] -h for more info]):";
   632	                    ShowHelp(helpMessage, null, optionSet);
   633	                    return;
   634	                }
   635	
   636	                if (version)
   637	                {
   638	                    Console.WriteLine(Version);
