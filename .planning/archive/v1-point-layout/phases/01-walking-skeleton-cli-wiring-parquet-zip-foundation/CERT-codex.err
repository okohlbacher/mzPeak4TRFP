   355	        private protected MZData ReadMZData(IRawData rawFile, IScanEvent scanEvent, int scanNumber, bool centroid, bool charge, bool noiseData)
   356	        {
   357	            double[] raw_masses;// copy of original (unsorted) masses
   358	
   359	            MZData mzData = new MZData();
   360	
   361	            var scan = Scan.FromFile(rawFile, scanNumber);
   362	
   363	            //If centroiding is requested
   364	            if (centroid)
   365	            {
   366	                mzData.isCentroided = true; // flag that the data is centroided
   367	                // Check if the scan has a centroid stream
   368	                if (scan.HasCentroidStream)
   369	                {
   370	                    mzData.basePeakMass = scan.CentroidScan.BasePeakMass;
   371	                    mzData.basePeakIntensity = scan.CentroidScan.BasePeakIntensity;
   372	
   373	                    mzData.masses = scan.CentroidScan.Masses;
   374	                    raw_masses = scan.CentroidScan.Masses;
   375	                    mzData.intensities = scan.CentroidScan.Intensities;
   376	
   377	                    if (charge)
   378	                    {
   379	                        mzData.charges = scan.CentroidScan.Charges;
   380	                    }
   381	                }
   382	                else // otherwise take the segmented (low res) scan
   383	                {
   384	                    mzData.basePeakMass = scan.ScanStatistics.BasePeakMass;
   385	                    mzData.basePeakIntensity = scan.ScanStatistics.BasePeakIntensity;
   386	
   387	                    //cannot centroid empty segmented scan
   388	                    if (scan.SegmentedScan.PositionCount > 0)
   389	                    {
   390	                        // If the spectrum is profile perform centroiding
   391	                        var segmentedScan = scanEvent.ScanData == ScanDataType.Profile
   392	                            ? Scan.ToCentroid(scan).SegmentedScan
   393	                            : scan.SegmentedScan;
   394	
   395	                        mzData.masses = segmentedScan.Positions;
   396	                        raw_masses = segmentedScan.Positions;
   397	                        mzData.intensities = segmentedScan.Intensities;
   398	                    }
   399	                    else
   400	                    {
   401	                        mzData.masses = Array.Empty<double>();
   402	                        mzData.intensities = Array.Empty<double>();
   403	                        raw_masses = Array.Empty<double>();
   404	                    }
   405	                }
   406	            }
   407	            else // use the segmented data as is
   408	            {
   409	                switch (scanEvent.ScanData) //check if the data centroided already
   410	                {
   411	                    case ScanDataType.Centroid:
   412	                        mzData.isCentroided = true;
   413	                        break;
   414	                    case ScanDataType.Profile:
   415	                        mzData.isCentroided = false;
   416	                        break;
   417	                }
   418	
   419	                mzData.basePeakMass = scan.ScanStatistics.BasePeakMass;
   420	                mzData.basePeakIntensity = scan.ScanStatistics.BasePeakIntensity;
   421	
   422	                mzData.masses = scan.SegmentedScan.Positions;
   423	                raw_masses = scan.SegmentedScan.Positions;
   424	                mzData.intensities = scan.SegmentedScan.Intensities;
   425	            }
   426	
   427	            // Sort all arrays by m/z
   428	            if (raw_masses != null)
   429	            {
   430	                if (mzData.masses != null)
   431	                {
   432	                    Array.Sort((double[])raw_masses.Clone(), mzData.masses);
   433	
   434	                }
   435	                if (mzData.intensities != null)
   436	                {
   437	                    Array.Sort((double[])raw_masses.Clone(), mzData.intensities);
   438	                }
   439	                if (charge && mzData.charges != null)
   440	                {
   441	                    Array.Sort((double[])raw_masses.Clone(), mzData.charges);
   442	                }
   443	
   444	            }
   445	            // If requested, read the noise data
   446	            if (noiseData)
   447	            {
   448	                mzData.baselineData = scan.PreferredBaselines;
   449	                mzData.noiseData = scan.PreferredNoises;
   450	                mzData.massData = scan.PreferredMasses;
   451	            }
   452	
   453	            return mzData;
   454	        }
   455	    }
   456	}
