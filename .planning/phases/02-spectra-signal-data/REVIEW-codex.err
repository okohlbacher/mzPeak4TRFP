import sys,zipfile,io,pyarrow.parquet as pq
z=zipfile.ZipFile(sys.argv[1])
t=pq.read_table(io.BytesIO(z.read("spectra_data.parquet")))
md=pq.read_metadata(io.BytesIO(z.read("spectra_data.parquet"))).metadata
sc=int(md[b"spectrum_count"]); pc=int(md[b"spectrum_data_point_count"])
col=t.column("point").combine_chunks()
si=col.field("spectrum_index").to_pylist(); mz=col.field("mz").to_pylist()
assert t.num_rows==pc, (t.num_rows,pc)
assert sc>1, sc
assert sorted(set(si))==list(range(max(si)+1)), "spectrum_index dense 0-based"
import itertools
for k,g in itertools.groupby(zip(si,mz),key=lambda x:x[0]):
    ms=[m for _,m in g]; assert ms==sorted(ms), f"spectrum {k} not mz-ascending"
import json
ai=json.loads(md[b"spectrum_array_index"])
mzent=[e for e in ai["entries"] if e["path"]=="point.mz"][0]
assert mzent.get("sorting_rank")==0, mzent
print("DATA_OK",sc,pc)
PY</automated>
  </verify>
