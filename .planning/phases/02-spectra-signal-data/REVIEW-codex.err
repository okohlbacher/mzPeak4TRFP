MzPeakParquet (ThermoRawFileParser/Writer/MzPeak/MzPeakParquet.cs):
  static Task WriteAsync(Stream output, ParquetSchema schema,
    IReadOnlyDictionary<string,string> customMetadata,
    IDictionary<DataField,(Array defined,int[] defLevels,int[] repLevels)> columns)
  // Iterates schema.GetDataFields() in leaf order, pairs each leaf with caller data by
