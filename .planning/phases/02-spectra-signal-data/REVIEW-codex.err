  // (defined-only data array), exactly as Phase-1 BuildDataFacet does.

SpectrumWriter (base, already inherited):
  MZData ReadMZData(IRawData rawFile, IScanEvent scanEvent, int scanNumber,
                    bool centroid, bool charge, bool noiseData)
  // MZData has: double[] masses, double[] intensities, bool isCentroided,
  //             double? basePeakMass, double? basePeakIntensity.
  // ReadMZData ALREADY sorts masses/intensities by m/z via Array.Sort with a cloned key
  // array — but that sort is NOT guaranteed stable across equal-m/z ties, so this plan
  // adds an explicit stable (mz,intensity) sort over the f64/f32 pairs before emit.
  // centroid arg = !ParseInput.NoPeakPicking.Contains((int)scanFilter.MSOrder)
  //                (identical to ParquetSpectrumWriter / MzMlSpectrumWriter).

Existing helpers already in MzPeakSpectrumWriter.cs (reuse, do not duplicate):
  WriteFacet(ParquetSchema, IReadOnlyDictionary<string,string>, IDictionary<...>) -> byte[]
  AddStored(ZipArchive, string name, byte[])         // STORED entry
  Leaf(ParquetSchema, string path)                   // DataField lookup by "point/mz" etc.
  const string SpectrumArrayIndex                    // EXTEND: add "sorting_rank":0 on point.mz

Filter logic (mirror ParquetSpectrumWriter.Write exactly):
  int level = (int)raw.GetScanEventForScanNumber(scanNumber).MSOrder;
  if (level <= ParseInput.MaxLevel) { read scan; if (ParseInput.MsLevel.Contains(level)) emit; }
  // firstScanNumber/lastScanNumber already encode the scan-range filter.
