   108	            }
   109	        }
   110	
   111	        private static byte[] BuildDataFacet(double[] masses, double[] intensities)
   112	        {
   113	            var point = new StructField("point",
   114	                new DataField<ulong>("spectrum_index"),
   115	                new DataField<double>("mz"),
   116	                new DataField<float>("intensity"));
   117	            var schema = new ParquetSchema(point);
   118	
   119	            var n = masses.Length;
   120	            var idx = new ulong[n];
   121	            var mz = new double[n];
   122	            var inten = new float[n];
   123	            for (int i = 0; i < n; i++)
   124	            {
   125	                idx[i] = 0;
   126	                mz[i] = masses[i];
   127	                inten[i] = (float)intensities[i];
   128	            }
   129	
   130	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   131	            {
   132	                [Leaf(schema, "point/spectrum_index")] = (idx, null, null),
   133	                [Leaf(schema, "point/mz")] = (mz, null, null),
   134	                [Leaf(schema, "point/intensity")] = (inten, null, null)
   135	            };
   136	
   137	            var meta = new Dictionary<string, string>
   138	            {
   139	                ["spectrum_count"] = "1",
   140	                ["spectrum_data_point_count"] = n.ToString(),
   141	                ["spectrum_array_index"] = SpectrumArrayIndex
   142	            };
   143	
   144	            return WriteFacet(schema, meta, cols);
   145	        }
   146	
   147	        private static byte[] BuildMetadataFacet(double rt)
   148	        {
   149	            var spectrum = new StructField("spectrum",
   150	                new DataField<ulong>("index"),
   151	                new DataField<string>("id", false),
   152	                new DataField<double>("time", false));
   153	            var schema = new ParquetSchema(spectrum);
   154	
   155	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   156	            {
   157	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 0 }, new[] { 1 }, null),
   158	                [Leaf(schema, "spectrum/id")] = (new[] { "index=0" }, new[] { 1 }, null),
   159	                [Leaf(schema, "spectrum/time")] = (new[] { rt }, new[] { 1 }, null)
   160	            };
   161	
   162	            var meta = new Dictionary<string, string>
   163	            {
   164	                ["spectrum_count"] = "1",
   165	                ["spectrum_data_point_count"] = "0"
   166	            };
   167	
   168	            return WriteFacet(schema, meta, cols);
   169	        }
   170	
   171	        private static byte[] WriteFacet(ParquetSchema schema, IReadOnlyDictionary<string, string> meta,
   172	            IDictionary<DataField, (Array, int[], int[])> cols)
   173	        {
   174	            using (var ms = new MemoryStream())
   175	            {
   176	                MzPeakParquet.WriteAsync(ms, schema, meta, cols).GetAwaiter().GetResult();
   177	                return ms.ToArray();
   178	            }
   179	        }
