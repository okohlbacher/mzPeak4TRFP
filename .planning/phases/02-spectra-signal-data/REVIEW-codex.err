   197	                        ["entity_type"] = "spectrum",
   198	                        ["data_kind"] = "metadata"
   199	                    }
   200	                },
   201	                ["metadata"] = new JObject
   202	                {
   203	                    ["version"] = MzPeakVersion
   204	                }
   205	            };
   206	
   207	            return new UTF8Encoding(false).GetBytes(index.ToString());
   208	        }
