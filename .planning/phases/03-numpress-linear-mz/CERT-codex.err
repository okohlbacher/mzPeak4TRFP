/bin/zsh -lc "python3.11 -c \"exec('''
import math, struct, json, random, zipfile, io
import numpy as np
import pynumpress
import pyarrow.parquet as pq

def optimal(data):
    n=len(data)
    if n==0: return 0.0
    if n==1: return math.floor(0x7fffffff / data[0])
    maxd=max(data[0], data[1])
    for i in range(2,n):
        extrapol=data[i-1]+(data[i-1]-data[i-2])
        diff=data[i]-extrapol
        maxd=max(maxd, math.ceil(abs(diff)+1))
    return math.floor(0x7fffffff / maxd)

def encfp(fp):
    return struct.pack('>d', fp)

def decfp(b):
    return struct.unpack('>d', b[:8])[0]

def i32(x):
    x &= 0xffffffff
    return x - 0x100000000 if x & 0x80000000 else x

def encint(x):
    ux = x & 0xffffffff
    init = ux & 0xf0000000
    if init == 0:
        l=8
        for i in range(8):
            mask = 0xf0000000 >> (4*i)
            if ux & mask:
                l=i; break
        return [l] + [0xf & (ux >> (4*(i-l))) for i in range(l,8)]
    if init == 0xf0000000:
        l=7
        for i in range(8):
            mask = 0xf0000000 >> (4*i)
            if (ux & mask) "'!= mask:
                l=i; break
        return [l+8] + [0xf & (ux >> (4*(i-l))) for i in range(l,8)]
    return [0] + [0xf & (ux >> (4*i)) for i in range(8)]

def encode_linear(data, fp=None):
    if fp is None: fp=optimal(data)
    res=bytearray(encfp(fp))
    n=len(data)
    if n==0: return bytes(res)
    ints=[0, int(data[0]*fp + 0.5), 0]
    res += struct.pack('"'<I', ints[1] & 0xffffffff)
    if n==1: return bytes(res)
    ints[2] = int(data[1]*fp + 0.5)
    res += struct.pack('<I', ints[2] & 0xffffffff)
    half=[]
    for k in range(2,n):
        ints[0]=ints[1]; ints[1]=ints[2]; ints[2]=int(data[k]*fp + 0.5)
        diff=i32(ints[2] - (ints[1] + (ints[1] - ints[0])))
        half += encint(diff)
        for hbi in range(len(half)//2):
            res.append(((half[2*hbi] << 4) | (half[2*hbi+1] & 0xf)) & 0xff)
        half = [half[-1]] if len(half)%2 else []
    if len(half)==1:
        res.append((half[0] << 4) & 0xff)
    return bytes(res)

def decint(data, state):
    di, half = state
    head = (data[di] >> 4) if half == 0 else (data[di] & 0xf)
    half = 1 - half
    if half == 0: di += 1
    if head <= 8:
        n=head; value=0
    else:
        n=head-8; value=0xffffffff
    for i in range(8-n):
        hb = (data[di] >> 4) if half == 0 else (data[di] & 0xf)
        mask = 0xf << (4*i)
        value = (value & ~mask) | (hb << (4*i))
        half = 1 - half
        if half == 0: di += 1
    state[0]=di; state[1]=half
    return i32(value)

def decode_linear(data):
    data=bytes(data); n=len(data)
    if n == 8: return []
    if n < 8: raise ValueError('too short fp')
    if n < 12: raise ValueError('too short first')
    fp=decfp(data)
    ri=8
    ints=[0,0,0]
    ints[1] = int.from_bytes(data[ri:ri+4], 'little', signed=False); ri += 4
    out=[ints[1]/fp]
    if n == 12: return out
    if n < 16: raise ValueError('too short second')
    ints[2] = int.from_bytes(data[ri:ri+4], 'little', signed=False); ri += 4
    out.append(ints[2]/fp)
    state=[ri,0]
    while state[0] < n:
        di, half=state
        if di == n-1 and half == 1 and (data[di] & 0xf) == 0:
            break
        ints[0]=ints[1]; ints[1]=ints[2]
        diff=decint(data,state)
        ints[2] = ints[1] + (ints[1] - ints[0]) + diff
        out.append(ints[2]/fp)
    return out

def anchor(dec,start,end):
    lo=0; hi=len(dec)
    if hi-lo >= 2 and abs(dec[lo]-start) > abs(dec[lo+1]-start): lo+=1
    if hi-lo >= 2 and abs(dec[hi-1]-end) > abs(dec[hi-2]-end): hi-=1
    return dec[lo:hi]

data=[100.0,100.5,101.0,101.5]
fp=21367996.0
ours=encode_linear(data, fp)
py=bytes(pynumpress.encode_linear(np.array(data), fp))
known=bytes.fromhex('41 74 60 CB C0 00 00 00 70 F9 5C 7F CE FF FF 7F 88')
rng=random.Random(23)
data2=[]; cur=300.0
for i in range(300):
    cur += rng.random()*0.5+1e-4; data2.append(cur)
fp2=optimal(data2); pyfp2=float(pynumpress.optimal_linear_fixed_point(np.array(data2)))
ours2=encode_linear(data2, fp2); py2=bytes(pynumpress.encode_linear(np.array(data2), fp2))
dec2=decode_linear(ours2); bound2=0.5/fp2
with zipfile.ZipFile('refs/mzPeak/small.numpress.mzpeak') as z:
    table=pq.read_table(io.BytesIO(z.read('spectra_data.parquet')))
col=table.column('chunk').combine_chunks()
cv=col.field('mz_chunk_values').to_pylist()
nb=col.field('mz_numpress_linear_bytes').to_pylist()
cs=col.field('mz_chunk_start').to_pylist(); ce=col.field('mz_chunk_end').to_pylist(); enc=col.field('chunk_encoding').to_pylist()
row0=bytes(nb[0]); fp0=decfp(row0[:8]); dec0=decode_linear(row0); al0=anchor(dec0, cs[0], ce[0])
first20=[]
for i in range(min(20,len(nb))):
    b=bytes(nb[i]); fp_i=decfp(b[:8]); dec=anchor(decode_linear(b), cs[i], ce[i])
    first20.append({'i':i,'fp':fp_i,'len':len(dec),'start_err':abs(dec[0]-cs[i]) if dec else None,'end_err':abs(dec[-1]-ce[i]) if dec else None,'bound':0.5/fp_i})
print(json.dumps({
 'known_identity': ours.hex()==known.hex()==py.hex(),
 'known_hex': ours.hex(' '),
 'known_decode_maxerr': max(abs(a-b) for a,b in zip(decode_linear(ours),data)),
 'random_fp_identity': fp2==pyfp2,
