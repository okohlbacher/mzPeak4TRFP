  1624	
  1625	        // Runs the production MzPeakSpectrumWriter.Write loop against small.RAW into a temp directory.
  1626	        // failScan: throw AFTER that scan's filter key is staged (a real post-key read failure).
  1627	        // dropParentBeforeChild: just before that child's precursor is built, drop its resolved parent's
  1628	        //   ordinal from the live map — a parent that was read but never emitted, so the child must not read
  1629	        //   a selected-ion intensity through it. Returns the archive path.
  1630	        private static string WriteWithInjection(string dir, int? failScan, int? dropParentBeforeChild)
  1631	        {
  1632	            var input = new ParseInput(TestRawFile, null, dir, OutputFormat.MzPeak)
  1633	            {
  1634	                MzPeakPointLayout = true
  1635	            };
  1636	            var writer = new MzPeakSpectrumWriter(input);
  1637	            if (failScan.HasValue)
  1638	            {
  1639	                writer.AfterFilterKeyStaged = scan =>
  1640	                {
  1641	                    if (scan == failScan.Value)
  1642	                        throw new InvalidOperationException($"injected read failure on scan {scan}");
  1643	                };
  1644	            }
  1645	            if (dropParentBeforeChild.HasValue)
  1646	            {
  1647	                writer.BeforeBuildPrecursor = (scan, scanToOrdinal) =>
  1648	                {
  1649	                    if (scan != dropParentBeforeChild.Value) return;
  1650	                    // Strip every emitted parent so this child cannot resolve a precursor_index, while its
  1651	                    // parent scan number is still positive — exactly the read-but-not-emitted condition.
  1652	                    scanToOrdinal.Clear();
  1653	                };
  1654	            }
  1655	            using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
  1656	            {
  1657	                raw.SelectInstrument(Device.MS, 1);
  1658	                writer.Write(raw, raw.RunHeaderEx.FirstSpectrum, raw.RunHeaderEx.LastSpectrum);
  1659	            }
  1660	            return Path.Combine(dir, "small.mzpeak");
  1661	        }
  1662	
  1663	        // Maps each MSn child's own ordinal (source_index) to its precursor_index (parent ordinal, null
  1664	        // when the parent was not emitted) and its selected-ion intensity (null when not read).
  1665	        private static (Dictionary<ulong, ulong?> precursorIndex, Dictionary<ulong, float?> selIntensity)
  1666	            ReadMsnChildMaps(byte[] metaBytes)
  1667	        {
  1668	            using (var ms = new MemoryStream(metaBytes))
  1669	            using (var reader = ParquetReader.CreateAsync(ms).Result)
  1670	            {
  1671	                var schema = reader.Schema;
  1672	                var rg = reader.OpenRowGroupReader(0);
  1673	
  1674	                var preSrc = rg.ReadColumnAsync(Leaf(schema, "precursor/source_index")).Result;
  1675	                var preIdx = rg.ReadColumnAsync(Leaf(schema, "precursor/precursor_index")).Result;
  1676	                var siSrc = rg.ReadColumnAsync(Leaf(schema, "selected_ion/source_index")).Result;
  1677	                var siInt = rg.ReadColumnAsync(Leaf(schema,
  1678	                    "selected_ion/MS_1000042_intensity_unit_MS_1000131")).Result;
  1679	
  1680	                var precursorIndex = ZipNullable<ulong>(preSrc.Data, preIdx.Data);
  1681	                var selIntensity = ZipNullable<float>(siSrc.Data, siInt.Data);
  1682	                return (precursorIndex, selIntensity);
  1683	            }
  1684	        }
  1685	
  1686	        // Pairs a nullable source_index column (one defined value per MSn row, null on the padded tail)
  1687	        // with a value column that holds a value only where present, producing source_index -> value?
  1688	        // (null where the value itself is absent). Rows whose source_index is null are skipped.
  1689	        private static Dictionary<ulong, T?> ZipNullable<T>(Array keys, Array values) where T : struct
  1690	        {
  1691	            var map = new Dictionary<ulong, T?>();
  1692	            for (int i = 0; i < keys.Length; i++)
  1693	            {
  1694	                var key = keys.GetValue(i);
  1695	                if (key == null) continue;
  1696	                var v = values.GetValue(i);
  1697	                map[(ulong)key] = v == null ? (T?)null : (T)v;
  1698	            }
  1699	            return map;
  1700	        }
  1701	
  1702	        [Test]
  1703	        public void FailedParent_DoesNotPoison_LaterChild_PrecursorResolution()
  1704	        {
  1705	            // Part A — staging isolation: a post-key read failure on an MS1 must consume no ordinal and no
  1706	            // precursor-map entry. Skip scan 8 (an MS1) through the real Write loop and assert the output
  1707	            // stays dense and every precursor_index still points at a real emitted ordinal.
  1708	            var dirA = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
  1709	            Directory.CreateDirectory(dirA);
  1710	            try
  1711	            {
  1712	                var archive = WriteWithInjection(dirA, failScan: 8, dropParentBeforeChild: null);
  1713	
  1714	                var data = ReadAllRowGroups(ReadEntry(archive, "spectra_data.parquet"));
  1715	                var metaIdx = ReadMetadataIndices(ReadEntry(archive, "spectra_metadata.parquet"));
  1716	
  1717	                Assert.That(data.SpectrumCount, Is.EqualTo(metaIdx.Length),
  1718	                    "metadata rows == data spectrum_count after the skip");
  1719	                Assert.That(metaIdx.OrderBy(x => x).ToArray(),
  1720	                    Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()),
  1721	                    "ordinals dense 0..N-1 despite the skipped scan");
  1722	                Assert.That(data.SpectrumCount, Is.EqualTo(V1SpectrumCount - 1),
  1723	                    "exactly one scan was skipped");
  1724	
  1725	                var (pre, _) = ReadMsnChildMaps(ReadEntry(archive, "spectra_metadata.parquet"));
  1726	                foreach (var v in pre.Values.Where(v => v.HasValue))
  1727	                    Assert.That(v.Value, Is.LessThan((ulong)data.SpectrumCount),
  1728	                        "no precursor_index may dangle past the emitted set");
  1729	            }
  1730	            finally
  1731	            {
  1732	                Directory.Delete(dirA, true);
  1733	            }
  1734	
  1735	            // Part B — the C1 isolation guard: drive the real Write loop so that, at the moment an MSn child
  1736	            // builds its precursor, its resolved parent has a positive scan number but no emitted ordinal
  1737	            // (read-but-not-committed). The child must end with NO precursor_index and NO selected-ion
  1738	            // intensity — it must not read intensity through the absent parent. Before the C1 fix the
  1739	            // intensity was computed from the parent's scan regardless, and this fails.
  1740	            const int childScan = 3; // the first MSn child in small.RAW
