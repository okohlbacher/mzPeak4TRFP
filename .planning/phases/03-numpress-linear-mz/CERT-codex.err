    85	        // Reads both archives and emits a single JSON verdict. Decodes the reference chunk layout to
    86	        // absolute (m/z, intensity) pairs, builds TRFP's per-spectrum signal from its point layout, and
    87	        // compares the nonzero (m/z, intensity) multiset of every reference-profile spectrum. Centroid
    88	        // coverage is scoped to indices present in BOTH peaks facets (the reference centroids MS2 while
    89	        // TRFP keeps MS2 profile in spectra_data, so the centroid sets are disjoint here and the
    90	        // comparison is reported as skipped rather than dropped).
    91	        private const string CompareScript =
    92	            "import sys, json, zipfile, io, collections, struct\n" +
    93	            "import pyarrow.parquet as pq\n" +
    94	            "ref_path, trfp_path = sys.argv[1], sys.argv[2]\n" +
    95	            "def read(zpath, name):\n" +
    96	            "    z = zipfile.ZipFile(zpath)\n" +
    97	            "    return pq.read_table(io.BytesIO(z.read(name))).to_pylist() if name in z.namelist() else None\n" +
    98	            "ref_data = read(ref_path, 'spectra_data.parquet')\n" +
    99	            "def dd(start, arr):\n" +
   100	            "    buf=[]; last=start\n" +
   101	            "    if not arr: return [start]\n" +
   102	            "    if arr[0] is None:\n" +
   103	            "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   104	            "        last=None\n" +
   105	            "    else: buf.append(start)\n" +
   106	            "    for it in arr:\n" +
   107	            "        if it is not None:\n" +
   108	            "            if last is not None: last=it+last; buf.append(last)\n" +
   109	            "            else: buf.append(it); last=it\n" +
   110	            "        else: buf.append(None); last=None\n" +
   111	            "    return buf\n" +
   112	            "ref = collections.defaultdict(list)\n" +
   113	            "for r in ref_data:\n" +
   114	            "    c = r['chunk']; si = c['spectrum_index']\n" +
   115	            "    dmz = dd(c['mz_chunk_start'], c['mz_chunk_values'] if c['mz_chunk_values'] is not None else [])\n" +
   116	            "    for mz, it in zip(dmz, c['intensity']):\n" +
   117	            "        if mz is None or it is None: continue\n" +
   118	            "        ref[si].append((mz, it))\n" +
   119	            "ref_profile_indices = sorted(ref.keys())\n" +
   120	            "ref_peaks = read(ref_path, 'spectra_peaks.parquet')\n" +
   121	            "refpk = collections.defaultdict(list)\n" +
   122	            "if ref_peaks:\n" +
   123	            "    for r in ref_peaks:\n" +
   124	            "        p = r['point']; refpk[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   125	            "trfp_data = read(trfp_path, 'spectra_data.parquet')\n" +
   126	            "trfp = collections.defaultdict(list)\n" +
   127	            "for r in trfp_data:\n" +
   128	            "    p = r['point']; trfp[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   129	            "trfp_peaks = read(trfp_path, 'spectra_peaks.parquet')\n" +
   130	            "trfppk = collections.defaultdict(list)\n" +
   131	            "if trfp_peaks:\n" +
   132	            "    for r in trfp_peaks:\n" +
   133	            "        p = r['point']; trfppk[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   134	            "def meta_map(rows):\n" +
   135	            "    m = {}\n" +
   136	            "    for r in rows:\n" +
   137	            "        s = r['spectrum']; m[s['index']] = (s['MS_1000511_ms_level'], s.get('MS_1000465_scan_polarity'), s['time'])\n" +
   138	            "    return m\n" +
   139	            "rm = meta_map(read(ref_path, 'spectra_metadata.parquet'))\n" +
   140	            "tm = meta_map(read(trfp_path, 'spectra_metadata.parquet'))\n" +
   141	            "def nz(pairs):\n" +
   142	            "    c = collections.Counter()\n" +
   143	            "    for mz, it in pairs:\n" +
   144	            "        if it == 0: continue\n" +
   145	            "        c[(mz, struct.unpack('f', struct.pack('f', it))[0])] += 1\n" +
   146	            "    return c\n" +
   147	            "profile_ok = all(nz(ref[si]) == nz(trfp.get(si, [])) for si in ref_profile_indices)\n" +
   148	            "centroid_compared, centroid_skipped, centroid_ok = [], [], True\n" +
   149	            "for si in sorted(refpk.keys()):\n" +
   150	            "    if si in trfppk:\n" +
   151	            "        centroid_compared.append(si)\n" +
   152	            "        if nz(refpk[si]) != nz(trfppk[si]): centroid_ok = False\n" +
   153	            "    else:\n" +
   154	            "        centroid_skipped.append(si)\n" +
   155	            "out = {\n" +
   156	            "  'spectrum_count_ok': len(rm) == len(tm), 'ref_spectrum_count': len(rm), 'trfp_spectrum_count': len(tm),\n" +
   157	            "  'ms_level_ok': all(rm[i][0] == tm[i][0] for i in rm if i in tm),\n" +
   158	            "  'polarity_ok': all(rm[i][1] is None or tm.get(i,(None,None,None))[1] is None or rm[i][1]==tm[i][1] for i in rm),\n" +
   159	            "  'rt_ok': all(i in tm and abs(rm[i][2]-tm[i][2]) < 1e-3 for i in rm),\n" +
   160	            "  'profile_multiset_ok': profile_ok,\n" +
   161	            "  'ref_profile_indices': ref_profile_indices, 'ref_profile_count': len(ref_profile_indices),\n" +
   162	            "  'compared_indices': ref_profile_indices,\n" +
   163	            "  'centroid_indices_compared': centroid_compared, 'centroid_multiset_ok': centroid_ok,\n" +
   164	            "  'centroid_indices_skipped': centroid_skipped,\n" +
   165	            "}\n" +
   166	            "print(json.dumps(out))\n";
   167	
