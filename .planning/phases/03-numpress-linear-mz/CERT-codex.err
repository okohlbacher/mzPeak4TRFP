  1486	        private static void AssertSameMultiset(Facet a, Facet b)
  1487	        {
  1488	            Assert.That(a.Mz.Length, Is.EqualTo(b.Mz.Length));
  1489	            var ta = Enumerable.Range(0, a.Mz.Length)
  1490	                .Select(i => (a.SpectrumIndex[i], a.Mz[i], a.Intensity[i]))
  1491	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ThenBy(x => x.Item3).ToArray();
  1492	            var tb = Enumerable.Range(0, b.Mz.Length)
  1493	                .Select(i => (b.SpectrumIndex[i], b.Mz[i], b.Intensity[i]))
  1494	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ThenBy(x => x.Item3).ToArray();
  1495	            Assert.That(tb, Is.EqualTo(ta), "(spectrum_index, mz, intensity) multiset identical across caps");
  1496	        }
  1497	
  1498	        private static Facet ReadAllRowGroups(byte[] bytes)
  1499	        {
  1500	            using (var ms = new MemoryStream(bytes))
  1501	            using (var reader = ParquetReader.CreateAsync(ms).Result)
  1502	            {
  1503	                var schema = reader.Schema;
  1504	                var idx = new List<ulong>(); var mz = new List<double>(); var inten = new List<float>();
  1505	                for (int g = 0; g < reader.RowGroupCount; g++)
  1506	                {
  1507	                    var rg = reader.OpenRowGroupReader(g);
  1508	                    idx.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data.Cast<ulong>());
  1509	                    mz.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data.Cast<double>());
  1510	                    inten.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data.Cast<float>());
  1511	                }
  1512	                var meta = reader.CustomMetadata;
  1513	                return new Facet
  1514	                {
  1515	                    SpectrumIndex = idx.ToArray(),
  1516	                    Mz = mz.ToArray(),
  1517	                    Intensity = inten.ToArray(),
  1518	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
  1519	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
  1520	                };
  1521	            }
  1522	        }
