   545	        [Test]
   546	        public void MultiRowGroupRoundTrip_EqualsSingleRowGroup()
   547	        {
   548	            var schema = PointSchema();
   549	            var idx = new ulong[] { 0, 0, 1, 1, 2, 2 };
   550	            var mz = new[] { 100.0, 200.0, 110.0, 210.0, 120.0, 220.0 };
   551	            var inten = new[] { 1f, 2f, 3f, 4f, 5f, 6f };
   552	
   553	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   554	            try
   555	            {
   556	                using (var fs = File.Create(path))
   557	                {
   558	                    var handle = MzPeakParquet.OpenAsync(fs, schema, null).GetAwaiter().GetResult();
   559	                    handle.WriteRowGroupAsync(schema, PointSlice(schema,
   560	                        idx.Take(3).ToArray(), mz.Take(3).ToArray(), inten.Take(3).ToArray()))
   561	                        .GetAwaiter().GetResult();
   562	                    handle.WriteRowGroupAsync(schema, PointSlice(schema,
   563	                        idx.Skip(3).ToArray(), mz.Skip(3).ToArray(), inten.Skip(3).ToArray()))
   564	                        .GetAwaiter().GetResult();
   565	                    handle.CloseAsync(null).GetAwaiter().GetResult();
   566	                }
   567	
   568	                var single = new MemoryStream();
   569	                MzPeakParquet.WriteAsync(single, schema, null,
   570	                    PointSlice(schema, idx, mz, inten)).GetAwaiter().GetResult();
   571	
   572	                ulong[] gIdx; double[] gMz; float[] gInt;
   573	                int rowGroupCount;
   574	                using (var fs = File.OpenRead(path))
   575	                using (var reader = ParquetReader.CreateAsync(fs).Result)
   576	                {
   577	                    rowGroupCount = reader.RowGroupCount;
   578	                    var ai = new List<ulong>(); var am = new List<double>(); var an = new List<float>();
   579	                    for (int g = 0; g < reader.RowGroupCount; g++)
   580	                    {
   581	                        var rg = reader.OpenRowGroupReader(g);
   582	                        ai.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data.Cast<ulong>());
   583	                        am.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data.Cast<double>());
   584	                        an.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data.Cast<float>());
   585	                    }
   586	                    gIdx = ai.ToArray(); gMz = am.ToArray(); gInt = an.ToArray();
   587	                }
   588	
   589	                Assert.That(rowGroupCount, Is.GreaterThan(1), "multi-row-group output must have >1 row group");
   590	
   591	                single.Position = 0;
   592	                using (var reader = ParquetReader.CreateAsync(single).Result)
   593	                {
   594	                    var rg = reader.OpenRowGroupReader(0);
   595	                    var sIdx = rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data.Cast<ulong>().ToArray();
   596	                    var sMz = rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data.Cast<double>().ToArray();
   597	                    var sInt = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data.Cast<float>().ToArray();
   598	                    Assert.That(gIdx, Is.EqualTo(sIdx));
   599	                    Assert.That(gMz, Is.EqualTo(sMz));
   600	                    Assert.That(gInt, Is.EqualTo(sInt));
   601	                }
   602	            }
   603	            finally
