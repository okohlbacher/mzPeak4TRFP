   168	            if (dataSize == 1) return Trim(result, ri);
   169	
   170	            ints[2] = (long)(data[1] * fixedPoint + 0.5);
   171	            for (i = 0; i < 4; i++)
   172	                result[ri++] = (byte)((ints[2] >> (i * 8)) & 0xff);
