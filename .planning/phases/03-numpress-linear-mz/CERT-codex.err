   288	        private static int CountProfileWithCentroidStreamScans()
   289	        {
   290	            using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
   291	            {
   292	                raw.SelectInstrument(Device.MS, 1);
   293	                int first = raw.RunHeaderEx.FirstSpectrum;
   294	                int last = raw.RunHeaderEx.LastSpectrum;
   295	                int qualifying = 0;
   296	                for (int scan = first; scan <= last; scan++)
   297	                {
   298	                    var scanEvent = raw.GetScanEventForScanNumber(scan);
   299	                    if (scanEvent.ScanData == ScanDataType.Profile && Scan.FromFile(raw, scan).HasCentroidStream)
   300	                        qualifying++;
   301	                }
   302	                return qualifying;
   303	            }
   304	        }
