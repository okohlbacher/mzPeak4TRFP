   941	        private static int ParseToEnum(Type enumType, string formatString, string keyName)
   942	        {
   943	            if (int.TryParse(formatString, out var formatInt)) //can be parsed as int
   944	            {
   945	                if (Enum.IsDefined(enumType, formatInt))
   946	                {
   947	                    return formatInt;
   948	                }
   949	                else
   950	                {
   951	                    throw new OptionException(
   952	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   953	                    keyName);
   954	                }
   955	
   956	            }
   957	            else //try parse as a string
   958	            {
   959	                try
   960	                {
   961	                    return (int)Enum.Parse(enumType, formatString, true);
   962	                }
   963	
   964	                catch (Exception)
   965	                {
   966	                    throw new OptionException(
   967	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   968	                    keyName);
   969	                }
   970	            }
   971	        }
