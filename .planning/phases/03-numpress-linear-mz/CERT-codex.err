  1544	                    "distinct spectrum_index == spectrum_count");
  1545	                Assert.That(metaIdx.Length, Is.EqualTo(data.SpectrumCount),
  1546	                    "metadata spectrum rows == spectrum_count");
  1547	                Assert.That(metaIdx.OrderBy(x => x).ToArray(),
  1548	                    Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()),
  1549	                    "ordinals dense 0..N-1");
  1550	                Assert.That(data.Mz.Length, Is.EqualTo(data.PointCount),
  1551	                    "footer spectrum_data_point_count == point rows");
  1552	
  1553	                // Known v1 baseline totals on the data facet.
  1554	                Assert.That(data.SpectrumCount, Is.EqualTo(V1SpectrumCount), "v1 baseline spectrum count");
  1555	                Assert.That(data.PointCount, Is.EqualTo(V1DataPointCount), "v1 baseline total data points");
  1556	
  1557	                // Footer KV present and correct on the streamed data facet.
  1558	                using (var ms = new MemoryStream(ReadEntry(archive, "spectra_data.parquet")))
  1559	                using (var reader = ParquetReader.CreateAsync(ms).Result)
  1560	                {
  1561	                    var kv = reader.CustomMetadata;
  1562	                    Assert.That(kv["spectrum_count"], Is.EqualTo(V1SpectrumCount.ToString()));
  1563	                    Assert.That(kv["spectrum_data_point_count"], Is.EqualTo(V1DataPointCount.ToString()));
  1564	                    Assert.That(kv.ContainsKey("spectrum_array_index"), Is.True);
  1565	                }
  1566	
  1567	                // Known v1 baseline totals + footer KV on the streamed peaks facet.
  1568	                var peaks = ReadAllRowGroups(ReadEntry(archive, "spectra_peaks.parquet"));
  1569	                Assert.That(peaks.SpectrumCount, Is.EqualTo(V1PeakSpectrumCount), "v1 baseline peak-bearing spectra");
  1570	                Assert.That(peaks.PointCount, Is.EqualTo(V1PeakPointCount), "v1 baseline total peak points");
  1571	                Assert.That(peaks.Mz.Length, Is.EqualTo(V1PeakPointCount), "peak point rows == footer count");
  1572	                using (var ms = new MemoryStream(ReadEntry(archive, "spectra_peaks.parquet")))
  1573	                using (var reader = ParquetReader.CreateAsync(ms).Result)
  1574	                {
  1575	                    var kv = reader.CustomMetadata;
  1576	                    Assert.That(kv["spectrum_count"], Is.EqualTo(V1PeakSpectrumCount.ToString()));
  1577	                    Assert.That(kv["spectrum_data_point_count"], Is.EqualTo(V1PeakPointCount.ToString()));
  1578	                    Assert.That(kv.ContainsKey("spectrum_array_index"), Is.True);
  1579	                }
  1580	
  1581	                // Known v1 baseline TIC point count + footer KV on the streamed chrom-data facet.
  1582	                var chrom = ReadChromFacet(ReadEntry(archive, "chromatograms_data.parquet"));
  1583	                Assert.That(chrom.Time.Length, Is.EqualTo(V1TicPointCount), "v1 baseline TIC point count");
  1584	                using (var ms = new MemoryStream(ReadEntry(archive, "chromatograms_data.parquet")))
  1585	                using (var reader = ParquetReader.CreateAsync(ms).Result)
  1586	                {
