   994	                Assert.That(np, Is.LessThan(delta),
   995	                    $"numpress spectra_data ({np}) must be smaller than delta-chunked ({delta})");
   996	            }
   997	            finally { Directory.Delete(ndir, true); Directory.Delete(ldir, true); }
   998	        }
