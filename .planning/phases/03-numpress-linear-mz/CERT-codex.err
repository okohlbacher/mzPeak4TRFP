    26	namespace ThermoRawFileParser.Writer
    27	{
    28	    public static class MSNumpress
    29	    {
    30	        // floor(0x7FFFFFFF / maxDouble), where maxDouble bounds the linear-prediction residual.
    31	        public static double OptimalLinearFixedPoint(double[] data)
    32	        {
    33	            int dataSize = data.Length;
    34	            if (dataSize == 0) return 0.0;
    35	            if (dataSize == 1) return Math.Floor(0x7FFFFFFF / data[0]);
    36	
    37	            double maxDouble = Math.Max(data[0], data[1]);
    38	            for (int i = 2; i < dataSize; i++)
    39	            {
    40	                double extrapol = data[i - 1] + (data[i - 1] - data[i - 2]);
    41	                double diff = data[i] - extrapol;
    42	                maxDouble = Math.Max(maxDouble, Math.Ceiling(Math.Abs(diff) + 1));
    43	            }
    44	            return Math.Floor(0x7FFFFFFF / maxDouble);
    45	        }
    46	
    47	        // The 8-byte big-endian IEEE-754 fixed-point prefix.
    48	        private static void EncodeFixedPoint(double fixedPoint, byte[] result)
    49	        {
    50	            byte[] fp = BitConverter.GetBytes(fixedPoint);
    51	            for (int i = 0; i < 8; i++)
    52	                result[i] = BitConverter.IsLittleEndian ? fp[7 - i] : fp[i];
    53	        }
    54	
    55	        private static double DecodeFixedPoint(byte[] data)
    56	        {
    57	            byte[] fp = new byte[8];
    58	            for (int i = 0; i < 8; i++)
    59	                fp[i] = BitConverter.IsLittleEndian ? data[7 - i] : data[i];
    60	            return BitConverter.ToDouble(fp, 0);
    61	        }
    62	
    63	        // Encode one int (masked to 32 bits) as half-bytes: the head nibble counts leading
    64	        // zero-nibbles (init==0 case) or, offset by 8, leading-one-nibbles (init==0xf0000000
    65	        // case); the remaining nibbles carry the value low-to-high.
    66	        private static int EncodeInt(int x, byte[] res, int resOffset)
    67	        {
