   254	        private static ulong[] ReadMetadataIndices(byte[] bytes)
   255	        {
   256	            using (var ms = new MemoryStream(bytes))
   257	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   258	            {
   259	                var schema = reader.Schema;
   260	                var rg = reader.OpenRowGroupReader(0);
   261	                return rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result.Data
   262	                    .Cast<ulong>().ToArray();
   263	            }
   264	        }
