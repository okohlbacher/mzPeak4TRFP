   202	
   203	        public static double[] DecodeLinear(byte[] data)
   204	        {
   205	            int dataSize = data.Length;
   206	            if (dataSize == 8) return Array.Empty<double>();
   207	            if (dataSize < 8) throw new ArgumentException("Corrupt input data: not enough bytes for fixed point.");
   208	            if (dataSize < 12) throw new ArgumentException("Corrupt input data: not enough bytes to read first value.");
