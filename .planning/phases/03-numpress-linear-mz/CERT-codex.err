   767	        [Test]
   768	        public void Metadata_CvList_Covers_Collected_Set_In_Index_And_Footer()
   769	        {
   770	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   771	            var dir = Convert(input, out var archive);
   772	            try
   773	            {
   774	                var metaBytes = ReadEntry(archive, "spectra_metadata.parquet");
   775	
   776	                var index = JObject.Parse(
   777	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
   778	                var metadata = (JObject)index["metadata"];
   779	                var idxCv = (JArray)metadata["cv_list"];
   780	                Assert.That(idxCv, Is.Not.Null.And.Not.Empty);
   781	
   782	                var footer = FooterKv(metaBytes);
   783	                Assert.That(footer.ContainsKey("cv_list"), "footer carries cv_list");
   784	
   785	                // Authoritative set: schema column CURIEs PLUS every accession/unit recursively gathered
   786	                // from the index metadata blocks AND the footer JSON blocks (PARAM lists, components, ...).
   787	                var collected = CollectAllCvPrefixes(metaBytes, metadata);
   788	                var footerBlocks = new JObject();
   789	                foreach (var key in new[]
   790	                    {
   791	                        "file_description", "instrument_configuration_list", "software_list",
   792	                        "data_processing_method_list", "run"
   793	                    })
   794	                {
   795	                    if (footer.TryGetValue(key, out var raw)) footerBlocks[key] = JToken.Parse(raw);
   796	                }
   797	                CollectCuriePrefixes(footerBlocks, collected);
   798	                Assert.That(collected, Is.Not.Empty, "metadata must use CV-named columns and params");
   799	
   800	                var idxIds = idxCv.Select(e => (string)e["id"]).ToHashSet();
   801	                Assert.That(idxIds, Is.EquivalentTo(collected),
   802	                    $"index cv_list {string.Join(",", idxIds.OrderBy(x => x))} must EQUAL collected " +
   803	                    $"{string.Join(",", collected.OrderBy(x => x))} -- no hard-coded extras, nothing missing");
   804	                foreach (var e in idxCv)
   805	                {
   806	                    Assert.That((string)e["id"], Is.Not.Null.And.Not.Empty);
   807	                    Assert.That((string)e["version"], Is.Not.Null.And.Not.Empty);
   808	                    Assert.That((string)e["uri"], Is.Not.Null.And.Not.Empty);
   809	                }
   810	
   811	                var footCv = JArray.Parse(footer["cv_list"]);
   812	                var footIds = footCv.Select(e => (string)e["id"]).ToHashSet();
   813	                Assert.That(footIds, Is.EquivalentTo(collected),
   814	                    "footer cv_list must EQUAL the collected CV-prefix set exactly");
   815	                Assert.That(footIds, Is.EquivalentTo(idxIds), "index and footer cv_list agree");
   816	            }
   817	            finally
   818	            {
   819	                Directory.Delete(dir, true);
   820	            }
   821	        }
