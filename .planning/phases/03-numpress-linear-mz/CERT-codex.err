  1005	        [Test]
  1006	        public void Chromatogram_Metadata_Facet_Shape_And_Values()
  1007	        {
  1008	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1009	            var dir = Convert(input, out var archive);
  1010	            try
  1011	            {
  1012	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
  1013	                int n = data.SpectrumCount;
  1014	
  1015	                var snippet =
  1016	                    "import pyarrow.parquet as pq, json\n" +
  1017	                    "t = pq.read_table(r'{PARQUET}')\n" +
  1018	                    "d = t.to_pylist()\n" +
  1019	                    "c = d[0]['chromatogram']\n" +
  1020	                    "ct = t.schema.field('chromatogram').type\n" +
  1021	                    "aux = ct.field('auxiliary_arrays').type.value_type\n" +
  1022	                    "out = {}\n" +
  1023	                    "out['rows'] = len(d)\n" +
  1024	                    "out['id'] = c['id']\n" +
  1025	                    "out['type'] = c['MS_1000626_chromatogram_type']\n" +
  1026	                    "out['pol'] = int(c['MS_1000465_scan_polarity'])\n" +
  1027	                    "out['pol_type'] = str(ct.field('MS_1000465_scan_polarity').type)\n" +
  1028	                    "out['ndp'] = c['MS_1003060_number_of_data_points']\n" +
  1029	                    "out['dpr_null'] = c['data_processing_ref'] is None\n" +
  1030	                    "out['params_empty'] = c['parameters'] == []\n" +
  1031	                    "out['aux_empty'] = c['auxiliary_arrays'] == []\n" +
  1032	                    "out['naux'] = int(c['number_of_auxiliary_arrays'])\n" +
  1033	                    "out['aux_fields'] = [f.name for f in aux]\n" +
  1034	                    "out['prec_in_schema'] = 'precursor' in [f.name for f in t.schema]\n" +
  1035	                    "out['seli_in_schema'] = 'selected_ion' in [f.name for f in t.schema]\n" +
  1036	                    "out['prec_null'] = d[0]['precursor'] is None or d[0]['precursor']['source_index'] is None\n" +
  1037	                    "out['seli_null'] = d[0]['selected_ion'] is None or d[0]['selected_ion']['source_index'] is None\n" +
  1038	                    "selt = t.schema.field('selected_ion').type\n" +
  1039	                    "out['seli_fields'] = [f.name for f in selt]\n" +
  1040	                    "print(json.dumps(out))\n";
  1041	                var o = PyArrowEntry(archive, "chromatograms_metadata.parquet", snippet);
