  1589	                    Assert.That(kv.ContainsKey("chromatogram_array_index"), Is.True);
  1590	                    Assert.That(kv.ContainsKey("chromatogram_tic_source"), Is.True);
  1591	                }
  1592	
  1593	                // cv_list covers the chrom-data prefixes (derived prefixes MS/UO, not whole CURIEs).
  1594	                var index = JObject.Parse(
  1595	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
  1596	                var ids = ((JArray)index["metadata"]["cv_list"]).Select(e => (string)e["id"]).ToHashSet();
  1597	                foreach (var curie in new[]
  1598	                {
  1599	                    "MS:1000523", "MS:1000595", "UO:0000031", "MS:1000521", "MS:1000515",
  1600	                    "MS:1000131", "MS:1000522", "MS:1000786", "UO:0000186"
  1601	                })
  1602	                {
