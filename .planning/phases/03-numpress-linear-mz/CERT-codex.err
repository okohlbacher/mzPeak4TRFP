   218	            result.Add(ints[1] / fixedPoint);
   219	
   220	            if (dataSize == 12) return result.ToArray();
   221	
   222	            if (dataSize < 16) throw new ArgumentException("Corrupt input data: not enough bytes to read second value.");
   223	            ints[2] = 0;
   224	            for (int i = 0; i < 4; i++)
   225	                ints[2] |= ((long)data[ri++]) << (i * 8);
   226	            result.Add(ints[2] / fixedPoint);
   227	
   228	            int half = 0;
   229	            int di = ri;
   230	            while (di < dataSize)
   231	            {
   232	                if (di == dataSize - 1 && half == 1 && (data[di] & 0xf) == 0)
