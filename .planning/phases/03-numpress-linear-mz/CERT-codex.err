  1614	        [Test]
  1615	        public void RegisterChromDataPrefixes_Registers_All_Nine_Accessions()
  1616	        {
  1617	            var prefixes = MzPeakSpectrumWriter.ChromDataAccessions;
  1618	            Assert.That(prefixes, Is.EquivalentTo(new[]
  1619	            {
  1620	                "MS:1000523", "MS:1000595", "UO:0000031", "MS:1000521", "MS:1000515",
  1621	                "MS:1000131", "MS:1000522", "MS:1000786", "UO:0000186"
  1622	            }), "all nine chrom-data accessions are registered before cv_list is finalized");
