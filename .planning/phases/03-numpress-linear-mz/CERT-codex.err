   261	        [Test]
   262	        public void Numpress_RoundTrip_RealAndSynthetic_WithinHalfOverFp()
   263	        {
   264	            var rnd = new Random(11);
   265	            foreach (int n in new[] { 3, 17, 251, 1024 })
   266	            {
   267	                var data = new double[n];
   268	                double cur = 150.0 + rnd.NextDouble();
   269	                for (int i = 0; i < n; i++) { cur += rnd.NextDouble() * 0.4 + 1e-4; data[i] = cur; }
   270	                double fp = MSNumpress.OptimalLinearFixedPoint(data);
   271	                Assert.That(fp, Is.GreaterThan(0.0));
   272	                var enc = MSNumpress.EncodeLinear(data, fp);
   273	                var dec = MSNumpress.DecodeLinear(enc);
   274	                Assert.That(dec.Length, Is.EqualTo(n), $"length preserved for n={n}");
   275	                double bound = 0.5 / fp;
   276	                for (int i = 0; i < n; i++)
   277	                    Assert.That(Math.Abs(dec[i] - data[i]), Is.LessThanOrEqualTo(bound),
   278	                        $"n={n} index {i} within 0.5/fp");
   279	            }
   280	        }
