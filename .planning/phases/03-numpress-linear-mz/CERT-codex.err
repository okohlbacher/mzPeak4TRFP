     1	using System;
     2	using System.Collections.Generic;
     3	using System.Diagnostics;
     4	using System.IO;
     5	using System.IO.Compression;
     6	using System.Linq;
     7	using Newtonsoft.Json.Linq;
     8	using NUnit.Framework;
     9	using Parquet;
    10	using Parquet.Schema;
    11	using ThermoRawFileParser;
    12	using ThermoRawFileParser.Writer;
    13	
    14	namespace ThermoRawFileParserTest
    15	{
    16	    [TestFixture]
    17	    public class MzPeakChunkTests
    18	    {
    19	        private static long MzBits(double v) => BitConverter.DoubleToInt64Bits(v);
    20	        private static int IntBits(float v) => BitConverter.SingleToInt32Bits(v);
    21	
    22	        // Encode + decode every window and concatenate; returns the reconstructed (mz,intensity) pairs
    23	        // dropping null pairs, mirroring the writer/reader contract.
    24	        private static List<(double mz, float inten)> RoundTrip(double[] mz, float[] inten, double width)
    25	        {
    26	            var outp = new List<(double, float)>();
    27	            foreach (var (s, e) in MzPeakChunkCodec.Chunk(mz, width))
    28	            {
    29	                var slice = new double?[e - s];
    30	                for (int i = s; i < e; i++) slice[i - s] = mz[i];
    31	                MzPeakChunkCodec.DeltaEncode(slice, out var start, out _, out var values);
    32	                var dmz = MzPeakChunkCodec.DeltaDecode(start, values);
    33	                for (int i = 0; i < dmz.Length; i++)
    34	                {
    35	                    if (!dmz[i].HasValue) continue;
    36	                    outp.Add((dmz[i].Value, inten[s + i]));
    37	                }
    38	            }
    39	            return outp;
    40	        }
    41	
    42	        [Test]
    43	        public void RoundTrip_Gapless_BitwiseExact()
    44	        {
    45	            var rnd = new Random(7);
    46	            int n = 5000;
    47	            var mz = new double[n];
    48	            var inten = new float[n];
    49	            double cur = 100.0;
    50	            for (int i = 0; i < n; i++)
    51	            {
    52	                cur += rnd.NextDouble() * 0.5;
    53	                mz[i] = cur;
    54	                inten[i] = (float)(rnd.NextDouble() * 1e6);
    55	            }
    56	
    57	            var rt = RoundTrip(mz, inten, 50.0);
    58	            Assert.That(rt.Count, Is.EqualTo(n), "no points lost");
    59	
    60	            var src = Enumerable.Range(0, n)
    61	                .Select(i => (MzBits(mz[i]), IntBits(inten[i])))
    62	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ToArray();
    63	            var got = rt
    64	                .Select(p => (MzBits(p.mz), IntBits(p.inten)))
    65	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ToArray();
    66	            Assert.That(got, Is.EqualTo(src), "decoded multiset is BITWISE equal to input");
    67	        }
    68	
    69	        [Test]
    70	        public void AllEqual_DuplicateMz_BitwiseExact()
    71	        {
    72	            int n = 200;
    73	            var mz = Enumerable.Repeat(345.678901234, n).ToArray();
    74	            var inten = Enumerable.Range(0, n).Select(i => (float)(i + 1)).ToArray();
    75	
    76	            var rt = RoundTrip(mz, inten, 50.0);
    77	            Assert.That(rt.Count, Is.EqualTo(n));
    78	            foreach (var p in rt)
    79	                Assert.That(MzBits(p.mz), Is.EqualTo(MzBits(345.678901234)),
    80	                    "every repeated m/z reconstructs bit-exactly (delta 0.0)");
    81	        }
    82	
    83	        [Test]
    84	        public void SinglePoint_OneChunk_ValuesEmpty()
    85	        {
    86	            var mz = new[] { 512.3456 };
    87	            var inten = new[] { 999.5f };
    88	            var chunks = MzPeakChunkCodec.Chunk(mz, 50.0);
    89	            Assert.That(chunks.Count, Is.EqualTo(1), "whole-spectrum single point yields one chunk");
    90	            Assert.That(chunks[0], Is.EqualTo((0, 1)));
    91	
    92	            MzPeakChunkCodec.DeltaEncode(new double?[] { mz[0] }, out var start, out var end, out var values);
    93	            Assert.That(values.Length, Is.EqualTo(0), "mz_chunk_values empty for a single point");
    94	            Assert.That(start, Is.EqualTo(mz[0]));
    95	            Assert.That(end, Is.EqualTo(mz[0]));
    96	
    97	            var dmz = MzPeakChunkCodec.DeltaDecode(start, values);
    98	            Assert.That(dmz.Length, Is.EqualTo(1));
    99	            Assert.That(MzBits(dmz[0].Value), Is.EqualTo(MzBits(mz[0])));
   100	        }
   101	
   102	        [Test]
   103	        public void Guards_Empty_NoChunk_And_NonMonotonic_Throws()
   104	        {
   105	            Assert.That(MzPeakChunkCodec.Chunk(Array.Empty<double>(), 50.0), Is.Empty,
   106	                "empty spectrum yields no chunk row");
   107	
   108	            Assert.Throws<ArgumentException>(
   109	                () => MzPeakChunkCodec.Chunk(new[] { 300.0, 200.0, 100.0 }, 50.0),
   110	                "non-monotonic input throws");
   111	
   112	            Assert.Throws<ArgumentException>(
   113	                () => MzPeakChunkCodec.DeltaEncode(Array.Empty<double?>(), out _, out _, out _),
   114	                "DeltaEncode rejects an empty slice");
   115	        }
   116	
   117	        [Test]
   118	        public void Chunk_NonFiniteOrNonPositiveWidth_Throws()
   119	        {
   120	            var mz = new[] { 100.0, 150.0, 200.0 };
   121	
   122	            // A non-positive or non-finite width never advances the partition threshold; each must throw
   123	            // rather than loop forever.
   124	            Assert.Throws<ArgumentOutOfRangeException>(() => MzPeakChunkCodec.Chunk(mz, 0.0), "width 0");
   125	            Assert.Throws<ArgumentOutOfRangeException>(() => MzPeakChunkCodec.Chunk(mz, -1.0), "width -1");
   126	            Assert.Throws<ArgumentOutOfRangeException>(() => MzPeakChunkCodec.Chunk(mz, double.NaN), "width NaN");
   127	            Assert.Throws<ArgumentOutOfRangeException>(
   128	                () => MzPeakChunkCodec.Chunk(mz, double.PositiveInfinity), "width +inf");
   129	
   130	            // A valid finite width partitions normally and covers every point.
   131	            var chunks = MzPeakChunkCodec.Chunk(mz, 50.0);
   132	            Assert.That(chunks.Count, Is.GreaterThan(0), "valid width yields chunks");
   133	            Assert.That(chunks.Sum(c => c.end - c.start), Is.EqualTo(mz.Length), "all points covered");
   134	        }
