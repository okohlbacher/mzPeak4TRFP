  1000	        [Test]
  1001	        public void Validator_ThreeModes_ZeroErrors()
  1002	        {
  1003	            var validator = ResolveValidator();
  1004	            if (validator == null) Assert.Ignore("mzpeak-validate not available");
  1005	
  1006	            foreach (var mode in new[] { DataMode.Numpress, DataMode.Lossless, DataMode.Point })
  1007	            {
  1008	                var archive = Convert(mode, out var dir);
  1009	                var jsonPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".json");
  1010	                try
  1011	                {
  1012	                    var psi = new ProcessStartInfo(validator, $"\"{archive}\" --json \"{jsonPath}\"")
  1013	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
  1014	                    using (var p = Process.Start(psi))
  1015	                    { p.StandardOutput.ReadToEnd(); p.StandardError.ReadToEnd(); p.WaitForExit(); }
  1016	
  1017	                    Assert.That(File.Exists(jsonPath), "validator must emit a JSON report");
  1018	                    var report = JObject.Parse(File.ReadAllText(jsonPath));
  1019	                    var errors = ((JArray)report["findings"])
  1020	                        .Where(f => (string)f["level"] == "error")
  1021	                        .Select(f => (string)f["ruleId"]).ToArray();
  1022	                    Assert.That(errors, Is.Empty, $"{mode} archive must validate 0 errors: {string.Join(",", errors)}");
  1023	                }
  1024	                finally
  1025	                {
  1026	                    if (File.Exists(jsonPath)) File.Delete(jsonPath);
  1027	                    Directory.Delete(dir, true);
  1028	                }
  1029	            }
  1030	        }
