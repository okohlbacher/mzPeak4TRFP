   868	        [Test]
   869	        public void Numpress_L2_Bound_And_Intensity_BitExact_vs_Lossless()
   870	        {
   871	            var numpress = Convert(DataMode.Numpress, out var ndir);
   872	            var lossless = Convert(DataMode.Lossless, out var ldir);
   873	            try
   874	            {
   875	                // Decode numpress m/z per chunk via OUR C# anchor-aligned codec (pyarrow only supplies the
   876	                // raw bytes / anchors / intensity). Compare positionally to --lossless (Phase-2 bit-exact).
   877	                var npSnippet =
   878	                    "import pyarrow.parquet as pq, json, struct\n" +
   879	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   880	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   881	                    "ce=t.field('mz_chunk_end').to_pylist(); nb=t.field('mz_numpress_linear_bytes').to_pylist()\n" +
   882	                    "inn=t.field('intensity').to_pylist()\n" +
   883	                    "rows=[]\n" +
   884	                    "for i in range(len(si)):\n" +
   885	                    "    rows.append({'si':si[i],'cs':cs[i],'ce':ce[i],'nb':[int(x) for x in bytes(nb[i])],\n" +
   886	                    "                 'int':[struct.unpack('<i',struct.pack('<f',float(x)))[0] for x in inn[i]]})\n" +
   887	                    "print(json.dumps(rows))\n";
   888	                var npRows = PyArrowArray(numpress, "spectra_data.parquet", npSnippet);
   889	
   890	                var lossSnippet =
   891	                    "import pyarrow.parquet as pq, json, struct\n" +
   892	                    "def dd(start, arr):\n" +
   893	                    "    buf=[]; last=start\n" +
   894	                    "    if not arr: return [start]\n" +
   895	                    "    if arr[0] is None:\n" +
   896	                    "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   897	                    "        last=None\n" +
   898	                    "    else: buf.append(start)\n" +
   899	                    "    for it in arr:\n" +
   900	                    "        if it is not None:\n" +
   901	                    "            if last is not None: last=it+last; buf.append(last)\n" +
   902	                    "            else: buf.append(it); last=it\n" +
   903	                    "        else: buf.append(None); last=None\n" +
   904	                    "    return buf\n" +
   905	                    "from collections import defaultdict\n" +
   906	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   907	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   908	                    "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   909	                    "mz=defaultdict(list); it=defaultdict(list)\n" +
   910	                    "for i in range(len(si)):\n" +
   911	                    "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
   912	                    "    for m,v in zip(dmz, inn[i]):\n" +
   913	                    "        if m is None or v is None: continue\n" +
   914	                    "        mz[si[i]].append(m); it[si[i]].append(struct.unpack('<i',struct.pack('<f',float(v)))[0])\n" +
   915	                    "print(json.dumps({'mz':{str(k):v for k,v in mz.items()},'it':{str(k):v for k,v in it.items()}}))\n";
   916	                var loss = PyArrow(lossless, "spectra_data.parquet", lossSnippet);
   917	                var lossMz = (JObject)loss["mz"];
   918	                var lossIt = (JObject)loss["it"];
   919	
   920	                // Anti-vacuity: at least one chunk row.
   921	                Assert.That(npRows.Count, Is.GreaterThan(0), "numpress has at least one chunk row");
   922	
   923	                long pointCount = ArchivePointCount(numpress);
   924	
   925	                var npMz = new Dictionary<string, List<double>>();
   926	                var npIt = new Dictionary<string, List<int>>();
   927	                long totalCompared = 0;
   928	
   929	                foreach (var row in npRows)
   930	                {
   931	                    double cs = (double)row["cs"], ce = (double)row["ce"];
   932	                    var bytes = ((JArray)row["nb"]).Select(x => (byte)(int)x).ToArray();
   933	                    var inten = ((JArray)row["int"]).Select(x => (int)x).ToList();
   934	
   935	                    double fp = NpFixedPoint(bytes);
   936	                    Assert.That(double.IsFinite(fp) && fp > 0.0, Is.True, "per-chunk fp finite and > 0");
   937	
   938	                    var dec = MzPeakChunkCodec.NumpressDecode(cs, ce, bytes);
   939	                    Assert.That(dec.Length, Is.EqualTo(inten.Count),
   940	                        "decoded m/z length == chunk intensity length");
   941	
   942	                    // The numpress half-step bound is 0.5/fp; allow a small relative slack for the
   943	                    // round-half quantization and the floating-point division on reconstruction.
   944	                    double bound = (0.5 / fp) * (1.0 + 1e-6);
   945	                    // start anchor (always); end anchor when >= 1 value; 1/2-value chunks guarded.
   946	                    Assert.That(Math.Abs(dec[0] - cs), Is.LessThanOrEqualTo(bound), "start anchor within 0.5/fp");
   947	                    Assert.That(Math.Abs(dec[dec.Length - 1] - ce), Is.LessThanOrEqualTo(bound), "end anchor within 0.5/fp");
   948	
   949	                    var key = ((ulong)(double)row["si"]).ToString();
   950	                    if (!npMz.ContainsKey(key)) { npMz[key] = new List<double>(); npIt[key] = new List<int>(); }
   951	                    foreach (var m in dec) npMz[key].Add(m);
   952	                    npIt[key].AddRange(inten);
   953	
   954	                    // per-chunk: numpress m/z within 0.5/fp of the SAME-position lossless m/z handled below.
   955	                    totalCompared += dec.Length;
   956	                }
   957	
   958	                Assert.That(totalCompared, Is.EqualTo(pointCount),
   959	                    "total compared m/z == spectrum_data_point_count (no chunk skipped, no value dropped)");
   960	
   961	                Assert.That(npMz.Keys.OrderBy(x => x), Is.EqualTo(lossMz.Properties().Select(p => p.Name).OrderBy(x => x)),
   962	                    "same spectrum_index set as --lossless");
   963	
   964	                int intMismatch = 0;
   965	                double worstAbs = 0;
   966	                foreach (var kv in npMz)
   967	                {
   968	                    var lm = ((JArray)lossMz[kv.Key]).Select(x => (double)x).ToArray();
   969	                    var li = ((JArray)lossIt[kv.Key]).Select(x => (int)x).ToArray();
   970	                    Assert.That(kv.Value.Count, Is.EqualTo(lm.Length),
   971	                        $"spectrum {kv.Key} decoded length == lossless length");
   972	                    for (int i = 0; i < lm.Length; i++)
   973	                        worstAbs = Math.Max(worstAbs, Math.Abs(kv.Value[i] - lm[i]));
   974	                    if (!npIt[kv.Key].SequenceEqual(li)) intMismatch++;
   975	                }
   976	
   977	                Assert.That(intMismatch, Is.EqualTo(0), "intensity bit-exact f32 vs --lossless");
   978	                // Worst case across small.RAW with smallest fp ~ 1e6 => ~5e-7 Th.
   979	                Assert.That(worstAbs, Is.LessThanOrEqualTo(5e-7),
   980	                    $"numpress m/z within the numpress-linear bound vs lossless (worst {worstAbs})");
   981	            }
   982	            finally { Directory.Delete(ndir, true); Directory.Delete(ldir, true); }
   983	        }
