  1092	                    Assert.That(schema.GetDataFields().Any(d => d.Path.ToString() == "point/chromatogram_index"),
  1093	                        "chromatograms_data stays the point struct in chunked mode by design");
  1094	                    Assert.That(schema.GetDataFields().Any(d => d.Path.ToString() == "point/time"));
  1095	                    Assert.That(schema.GetDataFields().Any(d => d.Path.ToString() == "point/ms_level"));
  1096	                }
  1097	            }
  1098	            finally { Directory.Delete(dir, true); }
