   659	        [Test]
   660	        public void Metadata_ListLeaf_Paths_Are_Canonical_Item_And_CvValues()
   661	        {
   662	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   663	            var dir = Convert(input, out var archive);
   664	            try
   665	            {
   666	                var metaBytes = ReadEntry(archive, "spectra_metadata.parquet");
   667	                using (var ms = new MemoryStream(metaBytes))
   668	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   669	                {
   670	                    var paths = reader.Schema.GetDataFields().Select(d => d.Path.ToString()).ToHashSet();
   671	
   672	                    // Canonical list-element leaf path is ".../list/item/...", not a flat column.
   673	                    Assert.That(paths.Any(p => p.StartsWith("spectrum/parameters/list/item/")), Is.True,
   674	                        "spectrum.parameters leaves sit under .../list/item/");
   675	                    Assert.That(paths, Does.Contain(
   676	                        "scan/scan_windows/list/item/MS_1000501_scan_window_lower_limit_unit_MS_1000040"));
   677	                    Assert.That(paths, Does.Contain(
   678	                        "scan/scan_windows/list/item/MS_1000500_scan_window_upper_limit_unit_MS_1000040"));
   679	                    Assert.That(paths.Any(p => p.StartsWith("precursor/activation/parameters/list/item/")), Is.True);
   680	                    Assert.That(paths, Does.Contain(
   681	                        "selected_ion/MS_1000744_selected_ion_mz_unit_MS_1000040"));
   682	                    Assert.That(paths, Does.Contain("selected_ion/MS_1000041_charge_state"));
   683	                    Assert.That(paths, Does.Contain(
   684	                        "precursor/isolation_window/MS_1000827_isolation_window_target_mz"),
   685	                        "isolation_window_target_mz carries no unit suffix");
   686	
   687	                    // Ground-truth selected_ion carries ion-mobility columns and a parameters list even
   688	                    // when the source has no mobility values; the struct shape must match exactly.
   689	                    Assert.That(paths, Does.Contain("selected_ion/ion_mobility_value"));
   690	                    Assert.That(paths, Does.Contain("selected_ion/ion_mobility_type"));
   691	                    Assert.That(paths.Any(p => p.StartsWith("selected_ion/parameters/list/item/")), Is.True,
   692	                        "selected_ion.parameters leaves sit under .../list/item/");
   693	                }
   694	
   695	                // CV values: selected_ion_mz finite/positive on MSn rows; charge_state null on small.RAW.
   696	                var snippet =
   697	                    "import pyarrow.parquet as pq, json\n" +
   698	                    "t = pq.read_table(r'{PARQUET}')\n" +
   699	                    "d = t.to_pylist()\n" +
   700	                    "N = len(d)\n" +
   701	                    "M = sum(1 for i in range(N) if d[i]['selected_ion'] is not None and d[i]['selected_ion']['source_index'] is not None)\n" +
   702	                    "out = {}\n" +
   703	                    "out['sel_mz_pos'] = all(d[i]['selected_ion']['MS_1000744_selected_ion_mz_unit_MS_1000040'] > 0 for i in range(M))\n" +
   704	                    "out['charge_all_null'] = all(d[i]['selected_ion']['MS_1000041_charge_state'] is None for i in range(M))\n" +
   705	                    "out['iso_target_pos'] = all(d[i]['precursor']['isolation_window']['MS_1000827_isolation_window_target_mz'] > 0 for i in range(M))\n" +
   706	                    "out['im_value_null'] = all(d[i]['selected_ion']['ion_mobility_value'] is None for i in range(M))\n" +
   707	                    "out['im_type_null'] = all(d[i]['selected_ion']['ion_mobility_type'] is None for i in range(M))\n" +
   708	                    "out['sel_params_empty'] = all(d[i]['selected_ion']['parameters'] == [] for i in range(M))\n" +
   709	                    "print(json.dumps(out))\n";
   710	                var o = PyArrowMetadata(archive, snippet);
   711	                Assert.That((bool)o["sel_mz_pos"], Is.True, "selected_ion_mz positive on every MSn row");
   712	                Assert.That((bool)o["charge_all_null"], Is.True, "small.RAW has no Charge State trailer");
   713	                Assert.That((bool)o["iso_target_pos"], Is.True, "isolation target positive on every MSn row");
   714	                Assert.That((bool)o["im_value_null"], Is.True, "ion_mobility_value null on every MSn row");
   715	                Assert.That((bool)o["im_type_null"], Is.True, "ion_mobility_type null on every MSn row");
   716	                Assert.That((bool)o["sel_params_empty"], Is.True, "selected_ion.parameters empty on every MSn row");
   717	            }
   718	            finally
   719	            {
   720	                Directory.Delete(dir, true);
   721	            }
   722	        }
