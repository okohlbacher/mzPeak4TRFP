   310	        [Test]
   311	        public void Numpress_Pynumpress_CrossCheck_ByteIdentity_Decode_OptimalFp()
   312	        {
   313	            var py = ResolvePython311();
   314	            if (py == null) Assert.Ignore("python3.11/pynumpress not available");
   315	
   316	            var rnd = new Random(23);
   317	            int n = 300;
   318	            var data = new double[n];
   319	            double cur = 300.0;
   320	            for (int i = 0; i < n; i++) { cur += rnd.NextDouble() * 0.5 + 1e-4; data[i] = cur; }
   321	
   322	            double ourFp = MSNumpress.OptimalLinearFixedPoint(data);
   323	            double pyFp = PyOptimalFp(py, data);
   324	            Assert.That(ourFp, Is.EqualTo(pyFp), "OptimalLinearFixedPoint parity with pynumpress");
   325	
   326	            var ours = MSNumpress.EncodeLinear(data, ourFp);
   327	            var pyBytes = PyEncodeLinear(py, data, ourFp);
   328	            Assert.That(ours, Is.EqualTo(pyBytes), "byte-identity vs pynumpress at shared fp");
   329	
   330	            var pyDecoded = PyDecodeLinear(py, ours);
   331	            double bound = 0.5 / ourFp;
   332	            Assert.That(pyDecoded.Length, Is.EqualTo(n));
   333	            for (int i = 0; i < n; i++)
   334	                Assert.That(Math.Abs(pyDecoded[i] - data[i]), Is.LessThanOrEqualTo(bound),
   335	                    "pynumpress decode of our bytes within 0.5/fp");
   336	        }
