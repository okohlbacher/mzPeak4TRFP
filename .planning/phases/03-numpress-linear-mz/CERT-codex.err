   763	        [Test]
   764	        public void Validator_Chunked_And_Point_ZeroErrors()
   765	        {
   766	            var validator = ResolveValidator();
   767	            if (validator == null) Assert.Ignore("mzpeak-validate not available");
   768	
   769	            foreach (var point in new[] { false, true })
   770	            {
   771	                var archive = Convert(point, out var dir);
   772	                var jsonPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".json");
   773	                try
   774	                {
   775	                    var psi = new ProcessStartInfo(validator, $"\"{archive}\" --json \"{jsonPath}\"")
   776	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   777	                    using (var p = Process.Start(psi))
   778	                    { p.StandardOutput.ReadToEnd(); p.StandardError.ReadToEnd(); p.WaitForExit(); }
   779	
   780	                    Assert.That(File.Exists(jsonPath), "validator must emit a JSON report");
   781	                    var report = JObject.Parse(File.ReadAllText(jsonPath));
   782	                    var errors = ((JArray)report["findings"])
   783	                        .Where(f => (string)f["level"] == "error")
   784	                        .Select(f => (string)f["ruleId"]).ToArray();
   785	                    Assert.That(errors, Is.Empty,
   786	                        $"{(point ? "--point" : "chunked")} archive must validate 0 errors: {string.Join(",", errors)}");
   787	                }
   788	                finally
   789	                {
   790	                    if (File.Exists(jsonPath)) File.Delete(jsonPath);
   791	                    Directory.Delete(dir, true);
   792	                }
   793	            }
   794	        }
