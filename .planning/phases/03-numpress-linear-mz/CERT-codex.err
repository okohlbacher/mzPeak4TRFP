   238	                "anchored decode start within 0.5/fp of mz_chunk_start");
   239	            Assert.That(Math.Abs(aligned[aligned.Length - 1] - end), Is.LessThanOrEqualTo(0.5 / fp),
   240	                "anchored decode end within 0.5/fp of mz_chunk_end");
