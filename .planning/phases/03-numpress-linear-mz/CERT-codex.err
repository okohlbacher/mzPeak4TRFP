   813	        [Test]
   814	        public void Numpress_Schema_Footer_NullValues_Encoding()
   815	        {
   816	            var archive = Convert(DataMode.Numpress, out var dir);
   817	            try
   818	            {
   819	                var snippet =
   820	                    "import pyarrow.parquet as pq, json\n" +
   821	                    "t = pq.read_table(r'{PARQUET}')\n" +
   822	                    "ct = t.schema.field('chunk').type\n" +
   823	                    "col = t.column('chunk').combine_chunks()\n" +
   824	                    "cv = col.field('mz_chunk_values').to_pylist()\n" +
   825	                    "out = {'names':[ct.field(i).name for i in range(ct.num_fields)],\n" +
   826	                    "       'enc':sorted(set(col.field('chunk_encoding').to_pylist())),\n" +
   827	                    "       'cv_null':sum(1 for x in cv if x is None),\n" +
   828	                    "       'cv_present_empty':sum(1 for x in cv if x is not None and len(x)==0),\n" +
   829	                    "       'rows':len(cv),\n" +
   830	                    "       'npk_item':str(ct.field(6).type.value_field.type)}\n" +
   831	                    "print(json.dumps(out))\n";
   832	                var o = PyArrow(archive, "spectra_data.parquet", snippet);
   833	                var names = o["names"].Select(x => (string)x).ToArray();
   834	                Assert.That(names, Is.EqualTo(new[]
   835	                {
   836	                    "spectrum_index", "mz_chunk_start", "mz_chunk_end", "mz_chunk_values",
   837	                    "chunk_encoding", "intensity", "mz_numpress_linear_bytes"
   838	                }), "numpress chunk struct has 7 fields incl mz_numpress_linear_bytes");
   839	                Assert.That(o["enc"].Select(x => (string)x).ToArray(), Is.EqualTo(new[] { "MS:1002312" }),
   840	                    "chunk_encoding == MS:1002312");
   841	                Assert.That((int)o["cv_null"], Is.EqualTo((int)o["rows"]),
   842	                    "mz_chunk_values null_count == row count");
   843	                Assert.That((int)o["cv_present_empty"], Is.EqualTo(0),
   844	                    "mz_chunk_values has ZERO present/empty lists (genuinely null, not zero-length)");
   845	                Assert.That((string)o["npk_item"], Is.EqualTo("uint8"), "numpress bytes item is uint8");
   846	
   847	                var footerSnippet =
   848	                    "import pyarrow.parquet as pq, json\n" +
   849	                    "m = pq.read_metadata(r'{PARQUET}').metadata\n" +
   850	                    "print(m[b'spectrum_array_index'].decode())\n";
   851	                var f = PyArrow(archive, "spectra_data.parquet", footerSnippet);
   852	                Assert.That((string)f["prefix"], Is.EqualTo("chunk"));
   853	                var entries = (JArray)f["entries"];
   854	                Assert.That(entries.Select(e => (string)e["buffer_format"]).ToArray(),
   855	                    Is.EqualTo(new[] { "chunk_start", "chunk_end", "chunk_values", "chunk_encoding", "chunk_secondary", "chunk_transform" }));
   856	                var npk = entries.First(e => (string)e["path"] == "chunk.mz_numpress_linear_bytes");
   857	                Assert.That((string)npk["buffer_format"], Is.EqualTo("chunk_transform"));
   858	                Assert.That((string)npk["transform"], Is.EqualTo("MS:1002312"));
   859	                Assert.That((int)npk["sorting_rank"], Is.EqualTo(0));
   860	                var inten = entries.First(e => (string)e["path"] == "chunk.intensity");
   861	                Assert.That((string)inten["buffer_format"], Is.EqualTo("chunk_secondary"));
   862	                Assert.That((string)inten["transform"], Is.EqualTo("MS:1003902"));
   863	                Assert.That(inten["sorting_rank"].Type, Is.EqualTo(JTokenType.Null), "intensity entry unchanged");
   864	            }
   865	            finally { Directory.Delete(dir, true); }
   866	        }
