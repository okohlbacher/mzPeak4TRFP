   199	                Assert.That(testMzMl.run.spectrumList.spectrum[0].binaryDataArrayList.binaryDataArray.Any(a => a.cvParam.Any(c => c.accession == "MS:1000515")));
   200	            }
   201	
   202	            File.Delete(Path.Combine(tempFilePath, "small.mzML"));
   203	        }
