    20	    public class MzPeakWriterTests
    21	    {
    22	        private static string TestRawFile =>
    23	            Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Data", "small.RAW");
    24	
    25	        private sealed class Facet
    26	        {
    27	            public ulong[] SpectrumIndex;
    28	            public double[] Mz;
    29	            public float[] Intensity;
    30	            public int SpectrumCount;
    31	            public int PointCount;
    32	        }
    33	
    34	        private static string Convert(ParseInput parseInput, out string archive)
    35	        {
    36	            var dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    37	            Directory.CreateDirectory(dir);
    38	            parseInput.OutputDirectory = dir;
    39	            // These fixtures assert the v1 point spectra_data layout, which is now the --point opt-in
    40	            // (chunked is the default); force point so the v1 invariants continue to be asserted here.
    41	            parseInput.MzPeakPointLayout = true;
    42	            RawFileParser.Parse(parseInput);
    43	            Assert.That(parseInput.Errors, Is.EqualTo(0));
    44	            archive = Path.Combine(dir, "small.mzpeak");
    45	            Assert.That(File.Exists(archive));
    46	            return dir;
    47	        }
    48	
    49	        private static byte[] ReadEntry(string archive, string name)
    50	        {
    51	            using (var zip = ZipFile.OpenRead(archive))
    52	            {
    53	                var entry = zip.GetEntry(name);
    54	                if (entry == null) return null;
    55	                using (var s = entry.Open())
    56	                using (var ms = new MemoryStream())
    57	                {
    58	                    s.CopyTo(ms);
    59	                    return ms.ToArray();
    60	                }
    61	            }
    62	        }
    63	
    64	        private static Facet ReadPointFacet(byte[] bytes)
    65	        {
    66	            using (var ms = new MemoryStream(bytes))
    67	            using (var reader = ParquetReader.CreateAsync(ms).Result)
    68	            {
    69	                var schema = reader.Schema;
    70	                var rg = reader.OpenRowGroupReader(0);
    71	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data
    72	                    .Cast<ulong>().ToArray();
    73	                var mz = rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data
    74	                    .Cast<double>().ToArray();
    75	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
    76	                    .Cast<float>().ToArray();
    77	                var meta = reader.CustomMetadata;
    78	                return new Facet
    79	                {
    80	                    SpectrumIndex = idx,
    81	                    Mz = mz,
    82	                    Intensity = inten,
    83	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
    84	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
    85	                };
    86	            }
    87	        }
    88	
    89	        private static DataField Leaf(ParquetSchema schema, string path)
    90	        {
    91	            return schema.GetDataFields().First(d => d.Path.ToString() == path);
    92	        }
    93	
    94	        private sealed class ChromFacet
    95	        {
    96	            public ulong[] ChromatogramIndex;
    97	            public double[] Time;
    98	            public float[] Intensity;
    99	            public long[] MsLevel;
   100	            public string TicSource;
   101	            public int PointCount;
   102	        }
   103	
   104	        private static ChromFacet ReadChromFacet(byte[] bytes)
   105	        {
   106	            using (var ms = new MemoryStream(bytes))
   107	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   108	            {
   109	                var schema = reader.Schema;
   110	                var rg = reader.OpenRowGroupReader(0);
   111	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/chromatogram_index")).Result.Data
   112	                    .Cast<ulong>().ToArray();
   113	                var time = rg.ReadColumnAsync(Leaf(schema, "point/time")).Result.Data
   114	                    .Cast<double>().ToArray();
   115	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
   116	                    .Cast<float>().ToArray();
   117	                var lvl = rg.ReadColumnAsync(Leaf(schema, "point/ms_level")).Result.Data
   118	                    .Cast<long>().ToArray();
   119	                var meta = reader.CustomMetadata;
   120	                return new ChromFacet
   121	                {
   122	                    ChromatogramIndex = idx,
   123	                    Time = time,
   124	                    Intensity = inten,
   125	                    MsLevel = lvl,
   126	                    TicSource = meta["chromatogram_tic_source"],
   127	                    PointCount = int.Parse(meta["chromatogram_data_point_count"])
   128	                };
   129	            }
   130	        }
   131	
   132	        // Runs a pyarrow snippet against an arbitrary parquet entry of the archive (the {PARQUET}
   133	        // token is replaced with the temp file path), returning the printed JSON object.
   134	        private static JObject PyArrowEntry(string archive, string entry, string snippet)
   135	        {
   136	            var python = ResolvePython();
   137	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   138	
   139	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   140	            File.WriteAllBytes(path, ReadEntry(archive, entry));
   141	            try
   142	            {
   143	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   144	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   145	                {
   146	                    RedirectStandardOutput = true,
   147	                    RedirectStandardError = true,
   148	                    UseShellExecute = false
   149	                };
   150	                using (var proc = Process.Start(psi))
   151	                {
   152	                    var stdout = proc.StandardOutput.ReadToEnd();
   153	                    var stderr = proc.StandardError.ReadToEnd();
   154	                    proc.WaitForExit();
   155	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   156	                    return JObject.Parse(stdout.Trim());
   157	                }
   158	            }
   159	            finally
   160	            {
   161	                File.Delete(path);
   162	            }
   163	        }
