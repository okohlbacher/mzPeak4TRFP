  1032	        private static double NpFixedPoint(byte[] b)
  1033	        {
  1034	            var fp = new byte[8];
  1035	            for (int i = 0; i < 8; i++) fp[i] = BitConverter.IsLittleEndian ? b[7 - i] : b[i];
  1036	            return BitConverter.ToDouble(fp, 0);
  1037	        }
  1038	
  1039	        private static long ArchivePointCount(string archive)
  1040	        {
  1041	            var snippet =
  1042	                "import pyarrow.parquet as pq\n" +
  1043	                "m = pq.read_metadata(r'{PARQUET}').metadata\n" +
  1044	                "print('{\\\"n\\\":' + m[b'spectrum_data_point_count'].decode() + '}')\n";
  1045	            return (long)PyArrow(archive, "spectra_data.parquet", snippet)["n"];
  1046	        }
  1047	
  1048	        // PyArrow variant that returns a JSON array (the standard PyArrow asserts a JSON object).
  1049	        private static List<JObject> PyArrowArray(string archive, string entry, string snippet)
  1050	        {
  1051	            var python = ResolvePython();
  1052	            if (python == null) Assert.Ignore("python3/pyarrow not available");
  1053	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
  1054	            File.WriteAllBytes(path, ReadEntry(archive, entry));
  1055	            try
  1056	            {
  1057	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
  1058	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
  1059	                { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
  1060	                using (var proc = Process.Start(psi))
  1061	                {
  1062	                    var stdout = proc.StandardOutput.ReadToEnd();
  1063	                    var stderr = proc.StandardError.ReadToEnd();
  1064	                    proc.WaitForExit();
  1065	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
  1066	                    return JArray.Parse(stdout.Trim()).Cast<JObject>().ToList();
  1067	                }
  1068	            }
  1069	            finally { File.Delete(path); }
  1070	        }
