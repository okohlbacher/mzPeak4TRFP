   985	        [Test]
   986	        public void Numpress_Smaller_Than_Delta_Chunked()
   987	        {
   988	            var numpress = Convert(DataMode.Numpress, out var ndir);
   989	            var lossless = Convert(DataMode.Lossless, out var ldir);
   990	            try
