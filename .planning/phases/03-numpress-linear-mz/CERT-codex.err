   165	        [Test]
   166	        public void SpectraData_Ascending_And_MultisetPreserved()
   167	        {
   168	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   169	            var dir = Convert(input, out var archive);
   170	            try
   171	            {
   172	                var facet = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   173	
   174	                Assert.That(facet.Mz.Length, Is.EqualTo(facet.PointCount));
   175	                Assert.That(facet.Mz.Length, Is.EqualTo(facet.SpectrumIndex.Length));
   176	                Assert.That(facet.Intensity.Length, Is.EqualTo(facet.PointCount));
   177	
   178	                for (int i = 1; i < facet.SpectrumIndex.Length; i++)
   179	                {
   180	                    if (facet.SpectrumIndex[i] == facet.SpectrumIndex[i - 1])
   181	                        Assert.That(facet.Mz[i], Is.GreaterThanOrEqualTo(facet.Mz[i - 1]),
   182	                            $"spectrum {facet.SpectrumIndex[i]} not non-decreasing at {i}");
   183	                }
   184	            }
   185	            finally
   186	            {
   187	                Directory.Delete(dir, true);
   188	            }
   189	        }
