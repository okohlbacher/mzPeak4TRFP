   138	        [Test]
   139	        public void RoundTrip_Param_NullableAccessionUnitString()
   140	        {
   141	            var spectrum = new StructField("spectrum", MzPeakParquet.BuildParamField("p"));
   142	            var schema = new ParquetSchema(spectrum);
   143	
   144	            // Union-as-struct discipline: each PARAM row populates EXACTLY ONE of the four value
   145	            // leaves; the other three are null. Row0 populates integer; row1 populates string.
   146	            // value/* leaves: maxDef=4 (4=non-null, 3=null). accession/name/unit: maxDef=3 (3=non-null, 2=null).
   147	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   148	            {
   149	                [Leaf(schema, "spectrum/p/value/integer")] = (new long[] { 7 }, new[] { 4, 3 }, null),
   150	                [Leaf(schema, "spectrum/p/value/float")] = (new double[0], new[] { 3, 3 }, null),
   151	                [Leaf(schema, "spectrum/p/value/string")] = (new[] { "hello" }, new[] { 3, 4 }, null),
   152	                [Leaf(schema, "spectrum/p/value/boolean")] = (new bool[0], new[] { 3, 3 }, null),
   153	                [Leaf(schema, "spectrum/p/accession")] = (new[] { "MS:1000511" }, new[] { 3, 2 }, null),
   154	                [Leaf(schema, "spectrum/p/name")] = (new[] { "ms level", "intensity" }, new[] { 3, 3 }, null),
   155	                [Leaf(schema, "spectrum/p/unit")] = (new[] { "UO:0000031" }, new[] { 3, 2 }, null)
   156	            };
   157	
   158	            var ms = new MemoryStream();
   159	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string>(),
   160	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   161	
   162	            ms.Position = 0;
   163	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   164	            {
   165	                var rg = reader.OpenRowGroupReader(0);
   166	
   167	                // integer: row0 populated (def 4), row1 null (def 3).
   168	                var integer = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/integer")).Result;
   169	                Assert.That(integer.Data, Is.EqualTo(new long?[] { 7, null }));
   170	                Assert.That(integer.DefinitionLevels, Is.EqualTo(new[] { 4, 3 }));
   171	
   172	                // string: row0 null (def 3), row1 populated (def 4).
   173	                var str = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/string")).Result;
   174	                Assert.That(str.Data, Is.EqualTo(new[] { null, "hello" }));
   175	                Assert.That(str.DefinitionLevels, Is.EqualTo(new[] { 3, 4 }));
   176	
   177	                // float never populated: both rows null (def 3).
   178	                var fl = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/float")).Result;
   179	                Assert.That(fl.DefinitionLevels, Is.EqualTo(new[] { 3, 3 }));
   180	
   181	                // boolean never populated: both rows null (def 3).
   182	                var boolean = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/value/boolean")).Result;
   183	                Assert.That(boolean.DefinitionLevels, Is.EqualTo(new[] { 3, 3 }));
   184	
   185	                // accession: row0 present (def 3), row1 null (def 2).
   186	                var acc = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/accession")).Result;
   187	                Assert.That(acc.Data, Is.EqualTo(new[] { "MS:1000511", null }));
   188	                Assert.That(acc.DefinitionLevels, Is.EqualTo(new[] { 3, 2 }));
   189	
   190	                var unit = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/unit")).Result;
   191	                Assert.That(unit.Data, Is.EqualTo(new[] { "UO:0000031", null }));
   192	                Assert.That(unit.DefinitionLevels, Is.EqualTo(new[] { 3, 2 }));
   193	
   194	                // name populated on both rows.
   195	                var name = rg.ReadColumnAsync(Leaf(schema, "spectrum/p/name")).Result;
   196	                Assert.That(name.Data, Is.EqualTo(new[] { "ms level", "intensity" }));
   197	            }
   198	        }
