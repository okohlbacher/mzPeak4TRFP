   595	
   596	        // Every MS_/UO_/IMS_ CV code embedded in any column name across the metadata schema, as the
   597	        // validator's cv_list_declared rule collects them.
   598	        private static HashSet<string> CollectedCvCodes(byte[] metaBytes)
   599	        {
   600	            var codes = new HashSet<string>();
   601	            using (var ms = new MemoryStream(metaBytes))
   602	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   603	            {
   604	                foreach (var d in reader.Schema.GetDataFields())
   605	                {
   606	                    foreach (System.Text.RegularExpressions.Match mch in
   607	                        System.Text.RegularExpressions.Regex.Matches(d.Path.ToString(), @"(MS|UO|IMS)_\d+"))
   608	                    {
   609	                        codes.Add(mch.Groups[1].Value);
   610	                    }
   611	                }
   612	            }
   613	            return codes;
   614	        }
   615	
   616	        // Recursively walk an arbitrary JSON tree and collect the ontology prefix of every CURIE that
   617	        // appears as a value of an "accession" or "unit" key (e.g. "MS:1000133" -> "MS"). This reaches
   618	        // every PARAM list element, component, file_description, run, and nested block alike.
   619	        private static void CollectCuriePrefixes(JToken node, HashSet<string> into)
   620	        {
   621	            if (node is JObject obj)
   622	            {
   623	                foreach (var prop in obj.Properties())
   624	                {
   625	                    if ((prop.Name == "accession" || prop.Name == "unit") &&
   626	                        prop.Value.Type == JTokenType.String)
   627	                    {
   628	                        var mch = System.Text.RegularExpressions.Regex.Match(
   629	                            (string)prop.Value, @"^(MS|UO|IMS):\d+$");
   630	                        if (mch.Success) into.Add(mch.Groups[1].Value);
   631	                    }
   632	                    CollectCuriePrefixes(prop.Value, into);
   633	                }
   634	            }
   635	            else if (node is JArray arr)
   636	            {
   637	                foreach (var item in arr) CollectCuriePrefixes(item, into);
   638	            }
   639	        }
   640	
   641	        // The authoritative collected set: every CURIE prefix used in any metadata block, gathered from
   642	        // BOTH the schema column names AND recursively from every accession/unit in the JSON metadata.
   643	        private static HashSet<string> CollectAllCvPrefixes(byte[] metaBytes, JObject metadataBlocks)
   644	        {
   645	            var codes = CollectedCvCodes(metaBytes);
   646	            CollectCuriePrefixes(metadataBlocks, codes);
   647	            return codes;
   648	        }
   649	
   650	        private static Dictionary<string, string> FooterKv(byte[] metaBytes)
   651	        {
   652	            using (var ms = new MemoryStream(metaBytes))
   653	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   654	            {
   655	                return new Dictionary<string, string>(reader.CustomMetadata);
   656	            }
   657	        }
