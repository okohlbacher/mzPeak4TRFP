   220	                "import pyarrow.parquet as pq, json, struct\n" +

 succeeded in 0ms:
   220	                "import pyarrow.parquet as pq, json, struct\n" +
   221	                "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   222	                "nb=t.field('mz_numpress_linear_bytes').to_pylist()\n" +
   223	                "cs=t.field('mz_chunk_start').to_pylist(); ce=t.field('mz_chunk_end').to_pylist()\n" +
   224	                "row=bytes(nb[0])\n" +
