   234	
   235	                ints[0] = ints[1];
   236	                ints[1] = ints[2];
   237	                int diff = DecodeInt(data, ref di, ref half);
   238	                ints[2] = ints[1] + (ints[1] - ints[0]) + diff;
   239	                result.Add(ints[2] / fixedPoint);
   240	            }
   241	            return result.ToArray();
   242	        }
   243	
   244	        private static byte[] Trim(byte[] src, int len)
   245	        {
   246	            var outp = new byte[len];
   247	            Array.Copy(src, outp, len);
   248	            return outp;
   249	        }
   250	    }
   251	}

