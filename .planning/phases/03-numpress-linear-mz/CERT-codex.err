   136	        [Test]
   137	        public void RefNull_NoneAbsoluteDelta_DecodesLikeReference()
   138	        {
   139	            // Reproduces refs/mzPeak/small.chunked.mzpeak row 1 (spectrum 0): a leading null, then an
   140	            // absolute restart, then consecutive deltas. The leading (null,null) pair is dropped.
   141	            double start = 252.96545361882283;
   142	            var values = new double?[]
   143	            {
   144	                null,
   145	                252.96545361882283,
   146	                0.00038742706865946275,
   147	                0.00038742825540794,
   148	                0.00038742944209957386,
   149	                0.00038743062887647284
   150	            };
   151	            var inten = new float?[] { null, 1328.245849609375f, 3272.78173828125f, 4725.3662109375f,
   152	                4891.2607421875f, 3677.263671875f };
   153	
   154	            var dmz = MzPeakChunkCodec.DeltaDecode(start, values);
   155	            var pairs = new List<(double, float)>();
   156	            for (int i = 0; i < dmz.Length; i++)
   157	                if (dmz[i].HasValue && inten[i].HasValue) pairs.Add((dmz[i].Value, inten[i].Value));
   158	
   159	            Assert.That(pairs.Count, Is.EqualTo(5), "the leading (null,null) pair is dropped");
   160	            Assert.That(MzBits(pairs[0].Item1), Is.EqualTo(MzBits(252.96545361882283)),
   161	                "post-null value is an absolute restart");
   162	            Assert.That(MzBits(pairs[1].Item1),
   163	                Is.EqualTo(MzBits(252.96545361882283 + 0.00038742706865946275)),
   164	                "subsequent deltas apply cumulatively");
   165	            Assert.That(pairs[0].Item2, Is.EqualTo(1328.245849609375f));
   166	            Assert.That(pairs[1].Item2, Is.EqualTo(3272.78173828125f));
   167	        }
