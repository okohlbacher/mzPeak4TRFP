   948	        [Test]
   949	        public void Chromatogram_Data_Facet_Shape_And_PerScan_Alignment()
   950	        {
   951	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   952	            var dir = Convert(input, out var archive);
   953	            try
   954	            {
   955	                using (var ms = new MemoryStream(ReadEntry(archive, "chromatograms_data.parquet")))
   956	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   957	                {
   958	                    var schema = reader.Schema;
   959	                    Assert.That(Leaf(schema, "point/chromatogram_index").ClrType, Is.EqualTo(typeof(ulong)));
   960	                    Assert.That(Leaf(schema, "point/time").ClrType, Is.EqualTo(typeof(double)));
   961	                    Assert.That(Leaf(schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)));
   962	                    Assert.That(Leaf(schema, "point/ms_level").ClrType, Is.EqualTo(typeof(long)));
   963	                }
   964	
   965	                var chrom = ReadChromFacet(ReadEntry(archive, "chromatograms_data.parquet"));
   966	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   967	                int n = data.SpectrumCount;
   968	
   969	                Assert.That(chrom.Time.Length, Is.EqualTo(n), "one TIC point per emitted scan");
   970	                Assert.That(chrom.TicSource, Is.EqualTo("device"),
   971	                    "default conversion must take the device-trace path, not the summed fallback");
   972	                Assert.That(chrom.ChromatogramIndex.All(x => x == 0UL), Is.True, "single chromatogram, index all 0");
   973	                var levels = chrom.MsLevel.Distinct().OrderBy(x => x).ToArray();
   974	                Assert.That(levels, Is.EqualTo(new long[] { 1, 2 }), "ms_level multiset {1,2}, never 0");
   975	
   976	                // Per-scan spectrum (time, ms_level) read from spectra_metadata, aligned by ordinal.
   977	                var snippet =
   978	                    "import pyarrow.parquet as pq, json\n" +
   979	                    "t = pq.read_table(r'{PARQUET}')\n" +
   980	                    "d = t.to_pylist()\n" +
   981	                    "out = {'time':[d[i]['spectrum']['time'] for i in range(len(d))],\n" +
   982	                    "       'lvl':[int(d[i]['spectrum']['MS_1000511_ms_level']) for i in range(len(d))]}\n" +
   983	                    "print(json.dumps(out))\n";
   984	                var o = PyArrowEntry(archive, "spectra_metadata.parquet", snippet);
   985	                var sTime = o["time"].Select(x => (double)x).ToArray();
   986	                var sLvl = o["lvl"].Select(x => (long)x).ToArray();
   987	
   988	                Assert.That(sTime.Length, Is.EqualTo(n));
   989	                for (int i = 0; i < n; i++)
   990	                {
   991	                    Assert.That(chrom.Time[i], Is.EqualTo(sTime[i]).Within(1e-6),
   992	                        $"TIC time[{i}] must equal spectrum time");
   993	                    Assert.That(chrom.MsLevel[i], Is.EqualTo(sLvl[i]),
   994	                        $"TIC ms_level[{i}] must equal spectrum ms_level");
   995	                }
   996	                for (int i = 1; i < n; i++)
   997	                    Assert.That(chrom.Time[i], Is.GreaterThanOrEqualTo(chrom.Time[i - 1]), "time non-decreasing");
   998	            }
   999	            finally
  1000	            {
  1001	                Directory.Delete(dir, true);
  1002	            }
  1003	        }
