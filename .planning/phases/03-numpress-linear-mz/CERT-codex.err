   346	
   347	        private static double ReadBeDouble(byte[] b)
   348	        {
   349	            var fp = new byte[8];
   350	            for (int i = 0; i < 8; i++) fp[i] = BitConverter.IsLittleEndian ? b[7 - i] : b[i];
   351	            return BitConverter.ToDouble(fp, 0);
   352	        }
   353	
   354	        // Drop a phantom extrapolated value at either end when it is farther from its anchor than
   355	        // the adjacent value (the canonical numpress-linear decode can emit a leading and/or trailing
   356	        // phantom; the true chunk is bounded by mz_chunk_start / mz_chunk_end).
   357	        private static double[] AnchorAlign(double[] dec, double start, double end)
   358	        {
   359	            int lo = 0, hi = dec.Length;
   360	            if (hi - lo >= 2 && Math.Abs(dec[lo] - start) > Math.Abs(dec[lo + 1] - start)) lo++;
   361	            if (hi - lo >= 2 && Math.Abs(dec[hi - 1] - end) > Math.Abs(dec[hi - 2] - end)) hi--;
   362	            return dec.Skip(lo).Take(hi - lo).ToArray();
   363	        }
   364	
   365	        private static string ResolvePython311()
   366	        {
   367	            foreach (var cand in new[] { "python3.11", "python3", "python" })
   368	            {
   369	                try
   370	                {
   371	                    var psi = new ProcessStartInfo(cand, "-c \"import pynumpress\"")
   372	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   373	                    using (var p = Process.Start(psi)) { p.WaitForExit(); if (p.ExitCode == 0) return cand; }
   374	                }
   375	                catch { }
   376	            }
   377	            return null;
   378	        }
   379	
   380	        private static string RunPython(string python, string code)
   381	        {
   382	            var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   383	            { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   384	            using (var proc = Process.Start(psi))
   385	            {
   386	                var stdout = proc.StandardOutput.ReadToEnd();
   387	                var stderr = proc.StandardError.ReadToEnd();
   388	                proc.WaitForExit();
   389	                Assert.That(proc.ExitCode, Is.EqualTo(0), $"python failed: {stderr}");
   390	                return stdout.Trim();
   391	            }
   392	        }
   393	
   394	        private static byte[] PyEncodeLinear(string python, double[] data, double fp)
   395	        {
   396	            var arr = string.Join(",", data.Select(d => d.ToString("R", System.Globalization.CultureInfo.InvariantCulture)));
   397	            var code =
   398	                "import pynumpress, numpy as np, json\n" +
   399	                $"b=pynumpress.encode_linear(np.array([{arr}]), {fp.ToString("R", System.Globalization.CultureInfo.InvariantCulture)})\n" +
   400	                "print(json.dumps([int(x) for x in bytes(b)]))\n";
   401	            return JArray.Parse(RunPython(python, code)).Select(x => (byte)(int)x).ToArray();
   402	        }
   403	
   404	        private static double[] PyDecodeLinear(string python, byte[] bytes)
   405	        {
   406	            var arr = string.Join(",", bytes.Select(b => (int)b));
   407	            var code =
   408	                "import pynumpress, numpy as np, json\n" +
   409	                $"d=pynumpress.decode_linear(np.array([{arr}], dtype=np.uint8))\n" +
   410	                "print(json.dumps([float(x) for x in d]))\n";
   411	            return JArray.Parse(RunPython(python, code)).Select(x => (double)x).ToArray();
   412	        }
   413	
   414	        private static double PyOptimalFp(string python, double[] data)
   415	        {
   416	            var arr = string.Join(",", data.Select(d => d.ToString("R", System.Globalization.CultureInfo.InvariantCulture)));
   417	            var code =
   418	                "import pynumpress, numpy as np\n" +
   419	                $"print(repr(float(pynumpress.optimal_linear_fixed_point(np.array([{arr}])))))\n";
   420	            return double.Parse(RunPython(python, code), System.Globalization.CultureInfo.InvariantCulture);
   421	        }
