   183	                for (hbi = 0; hbi < (halfByteCount / 2); hbi++)
   184	                    result[ri++] = (byte)((halfBytes[2 * hbi] << 4) | (halfBytes[2 * hbi + 1] & 0xf));
   185	
   186	                if (halfByteCount % 2 != 0)
   187	                {
   188	                    halfBytes[0] = halfBytes[halfByteCount - 1];
   189	                    halfByteCount = 1;
   190	                }
   191	                else
   192	                {
   193	                    halfByteCount = 0;
   194	                }
   195	            }
   196	
   197	            if (halfByteCount == 1)
   198	                result[ri++] = (byte)(halfBytes[0] << 4);
