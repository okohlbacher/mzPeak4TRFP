   231	            });
   232	            Assert.That(loDef, Is.EqualTo(new[] { 2, 0, 2 }));
   233	
   234	            // list-of-struct leaves: max-def 5; present-elem 5, leaf-null-in-elem 4, empty-list 2, null-list 0
   235	            Assert.That(nameLeaf.MaxDefinitionLevel, Is.EqualTo(5));
   236	            Assert.That(paramsList.MaxDefinitionLevel, Is.EqualTo(3));
   237	            // empty-list level for these leaves is the cheat-sheet 2 (= list MaxDef - 1)
   238	            Assert.That(MzPeakParquet.EmptyList(paramsList).Cells[0], Is.EqualTo(2));
   239	            // row0: 2 elements (both name present); row1: null list; row2: empty list
   240	            var (nDef, nRep) = MzPeakParquet.NestedLevels(nameLeaf, new[]

