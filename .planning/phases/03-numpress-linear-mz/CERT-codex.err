   282	        [Test]
   283	        public void Numpress_EdgeCases_Empty_Single_Two()
   284	        {
   285	            // empty -> 8-byte fp-only output, decodes to empty.
   286	            var emptyEnc = MSNumpress.EncodeLinear(Array.Empty<double>(), 1000.0);
   287	            Assert.That(emptyEnc.Length, Is.EqualTo(8));
   288	            Assert.That(MSNumpress.DecodeLinear(emptyEnc).Length, Is.EqualTo(0));
   289	
   290	            // single value -> 12 bytes; OUR DecodeLinear is the oracle (pynumpress rejects 12-byte streams).
   291	            var single = new[] { 555.55 };
   292	            double sfp = MSNumpress.OptimalLinearFixedPoint(single);
   293	            var sEnc = MSNumpress.EncodeLinear(single, sfp);
   294	            Assert.That(sEnc.Length, Is.EqualTo(12));
   295	            var sDec = MSNumpress.DecodeLinear(sEnc);
   296	            Assert.That(sDec.Length, Is.EqualTo(1));
   297	            Assert.That(Math.Abs(sDec[0] - single[0]), Is.LessThanOrEqualTo(0.5 / sfp));
   298	
   299	            // two values -> 16 bytes (no residuals).
   300	            var two = new[] { 200.0, 200.25 };
   301	            double tfp = MSNumpress.OptimalLinearFixedPoint(two);
   302	            var tEnc = MSNumpress.EncodeLinear(two, tfp);
   303	            Assert.That(tEnc.Length, Is.EqualTo(16));
   304	            var tDec = MSNumpress.DecodeLinear(tEnc);
   305	            Assert.That(tDec.Length, Is.EqualTo(2));
   306	            for (int i = 0; i < 2; i++)
   307	                Assert.That(Math.Abs(tDec[i] - two[i]), Is.LessThanOrEqualTo(0.5 / tfp));
   308	        }
