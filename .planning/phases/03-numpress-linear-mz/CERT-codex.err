   239	                peaksFacet = new PointFacetStream(Cap);
   240	                chromFacet = new ChromDataFacetStream(Cap);
   241	
   242	                for (var scanNumber = firstScanNumber; scanNumber <= lastScanNumber; scanNumber++)
   243	                {
   244	                    StagedScan staged;
   245	                    try
   246	                    {
   247	                        staged = StageScan(raw, scanNumber, ordinal, scanNumberToOrdinal);
   248	                    }
   249	                    catch (Exception ex)
   250	                    {
   251	                        Log.Error($"Scan #{scanNumber} cannot be processed because of the following exception: {ex.Message}");
   252	                        Log.Debug($"{ex.StackTrace}\n{ex.InnerException}");
