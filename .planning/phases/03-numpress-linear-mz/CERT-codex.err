   930	        private static string GetValidEnumLevels(Type enumType)
   931	        {
   932	            List<string> output = new List<string>();
   933	            foreach (int v in Enum.GetValues(enumType))
   934	            {
   935	                output.Add(String.Format("{0} ({1})", Enum.GetName(enumType, v), v));
   936	            }
   937	
   938	            return String.Join("\n", output);
   939	        }
