  1311	        private static void AddScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1312	            string path, Array values, bool[] present)
  1313	        {
  1314	            var leaf = Leaf(schema, path);
  1315	            var rows = present.Select(p => p ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1316	            var (def, _r) = MzPeakParquet.NestedLevels(leaf, rows);
  1317	            cols[leaf] = (values, def, null);
  1318	        }
  1319	
  1320	        // A scalar leaf inside a top-level struct present only on the first M rows (the MSn count),
  1321	        // null on rows M..N-1. values has length M (one per MSn).
  1322	        private static void AddMsnScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1323	            string path, int n, Array values)
  1324	        {
  1325	            var leaf = Leaf(schema, path);
  1326	            int m = values.Length;
  1327	            var rows = Enumerable.Range(0, n)
  1328	                .Select(i => i < m ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1329	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1330	            cols[leaf] = (values, def, null);
  1331	        }
  1332	
  1333	        private static void AddMsnString(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1334	            string path, int n, string[] values)
  1335	        {
  1336	            var leaf = Leaf(schema, path);
  1337	            int m = values.Length;
  1338	            var rows = new List<MzPeakParquet.LeafRow>();
  1339	            var present = new List<string>();
  1340	            for (int i = 0; i < n; i++)
  1341	            {
  1342	                if (i >= m) rows.Add(MzPeakParquet.Absent());
  1343	                else if (values[i] != null) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i]); }
  1344	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
  1345	            }
  1346	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1347	            cols[leaf] = (present.ToArray(), def, null);
  1348	        }
