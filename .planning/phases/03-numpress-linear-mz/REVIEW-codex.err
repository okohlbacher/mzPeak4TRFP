   248	                { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   249	                using (var p = Process.Start(psi)) { p.WaitForExit(); return "mzpeak-validate"; }
   250	            }
   251	            catch { return null; }
   252	        }
