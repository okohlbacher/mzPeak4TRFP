   886	                    [_mz] = (_bMz.ToArray(), null, null),
   887	                    [_int] = (_bInt.ToArray(), null, null)
   888	                };
   889	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
   890	                _bIdx.Clear(); _bMz.Clear(); _bInt.Clear();
