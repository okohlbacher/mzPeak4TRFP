  1049	        // A chrom-data facet streamed to a seekable temp file. Bounded by scan count anyway; streamed for
  1050	        // uniformity with the point facets.
  1051	        private sealed class ChromDataFacetStream : IDisposable
  1052	        {
  1053	            public readonly string TempPath;
  1054	            private readonly ParquetSchema _schema;
  1055	            private readonly DataField _idx, _time, _int, _lvl;
  1056	            private readonly int _cap;
  1057	            private FileStream _sink;
  1058	            private MzPeakParquet.Handle _handle;
  1059	            private readonly List<ulong> _bIdx = new List<ulong>();
  1060	            private readonly List<double> _bTime = new List<double>();
  1061	            private readonly List<float> _bInt = new List<float>();
  1062	            private readonly List<long> _bLvl = new List<long>();
  1063	
  1064	            public long PointCount { get; private set; }
  1065	
  1066	            public ChromDataFacetStream(int cap)
  1067	            {
  1068	                _cap = cap;
  1069	                TempPath = Path.GetTempFileName();
  1070	                _schema = new ParquetSchema(ChromDataStructField());
  1071	                _idx = Leaf(_schema, "point/chromatogram_index");
  1072	                _time = Leaf(_schema, "point/time");
  1073	                _int = Leaf(_schema, "point/intensity");
  1074	                _lvl = Leaf(_schema, "point/ms_level");
  1075	                try
  1076	                {
  1077	                    _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
  1078	                    _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
  1079	                }
  1080	                catch
  1081	                {
  1082	                    _handle?.Dispose();
  1083	                    _sink?.Dispose();
  1084	                    TryDelete(TempPath);
  1085	                    throw;
  1086	                }
  1087	            }
  1088	
  1089	            public void Append(double time, float intensity, long msLevel)
  1090	            {
  1091	                _bIdx.Add(0UL); _bTime.Add(time); _bInt.Add(intensity); _bLvl.Add(msLevel);
  1092	                PointCount++;
  1093	                if (_bIdx.Count >= _cap) Flush();
  1094	            }
  1095	
  1096	            private void Flush()
  1097	            {
  1098	                if (_bIdx.Count == 0) return;
  1099	                var cols = new Dictionary<DataField, (Array, int[], int[])>
  1100	                {
  1101	                    [_idx] = (_bIdx.ToArray(), null, null),
  1102	                    [_time] = (_bTime.ToArray(), null, null),
  1103	                    [_int] = (_bInt.ToArray(), null, null),
  1104	                    [_lvl] = (_bLvl.ToArray(), null, null)
  1105	                };
  1106	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
  1107	                _bIdx.Clear(); _bTime.Clear(); _bInt.Clear(); _bLvl.Clear();
  1108	            }
  1109	
  1110	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
  1111	            {
  1112	                Flush();
  1113	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
  1114	                _handle = null;
  1115	                _sink.Dispose();
  1116	                _sink = null;
  1117	            }
  1118	
  1119	            public void Dispose()
  1120	            {
  1121	                _handle?.Dispose();
  1122	                _sink?.Dispose();
  1123	            }
  1124	        }
