  1419	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
  1420	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1421	            string listPath, int n, List<List<Param>> perRow)
  1422	        {
  1423	            int m = perRow.Count;
  1424	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
  1425	            var padded = new List<List<Param>>();
  1426	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
  1427	            AddParamList(cols, schema, listPath, padded, structPresent);
  1428	        }
  1429	
  1430	        private void AddParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1431	            string listPath, List<List<Param>> perRow, bool[] structPresent)
  1432	        {
  1433	            var list = (ListField)FindField(schema, listPath);
  1434	            var accLeaf = Leaf(schema, listPath + "/list/item/accession");
  1435	            var nameLeaf = Leaf(schema, listPath + "/list/item/name");
  1436	            var unitLeaf = Leaf(schema, listPath + "/list/item/unit");
  1437	            var intLeaf = Leaf(schema, listPath + "/list/item/value/integer");
  1438	            var fltLeaf = Leaf(schema, listPath + "/list/item/value/float");
  1439	            var strLeaf = Leaf(schema, listPath + "/list/item/value/string");
  1440	            var boolLeaf = Leaf(schema, listPath + "/list/item/value/boolean");
  1441	
  1442	            var accRows = new List<MzPeakParquet.LeafRow>();
  1443	            var nameRows = new List<MzPeakParquet.LeafRow>();
  1444	            var unitRows = new List<MzPeakParquet.LeafRow>();
  1445	            var intRows = new List<MzPeakParquet.LeafRow>();
  1446	            var fltRows = new List<MzPeakParquet.LeafRow>();
  1447	            var strRows = new List<MzPeakParquet.LeafRow>();
  1448	            var boolRows = new List<MzPeakParquet.LeafRow>();
  1449	
  1450	            var accVals = new List<string>();
  1451	            var nameVals = new List<string>();
  1452	            var unitVals = new List<string>();
  1453	            var intVals = new List<long>();
  1454	            var fltVals = new List<double>();
  1455	            var strVals = new List<string>();
  1456	            var boolVals = new List<bool>();
  1457	
  1458	            for (int row = 0; row < perRow.Count; row++)
  1459	            {
  1460	                if (!structPresent[row])
  1461	                {
  1462	                    accRows.Add(MzPeakParquet.NullList()); nameRows.Add(MzPeakParquet.NullList());
  1463	                    unitRows.Add(MzPeakParquet.NullList()); intRows.Add(MzPeakParquet.NullList());
  1464	                    fltRows.Add(MzPeakParquet.NullList()); strRows.Add(MzPeakParquet.NullList());
  1465	                    boolRows.Add(MzPeakParquet.NullList());
  1466	                    continue;
  1467	                }
  1468	
  1469	                var items = perRow[row];
  1470	                if (items.Count == 0)
  1471	                {
  1472	                    accRows.Add(MzPeakParquet.EmptyList(list)); nameRows.Add(MzPeakParquet.EmptyList(list));
  1473	                    unitRows.Add(MzPeakParquet.EmptyList(list)); intRows.Add(MzPeakParquet.EmptyList(list));
  1474	                    fltRows.Add(MzPeakParquet.EmptyList(list)); strRows.Add(MzPeakParquet.EmptyList(list));
  1475	                    boolRows.Add(MzPeakParquet.EmptyList(list));
  1476	                    continue;
  1477	                }
  1478	
  1479	                foreach (var it in items) { CollectPrefix(it.Accession); CollectPrefix(it.Unit); }
  1480	                AddListLeaf(accRows, accVals, accLeaf, items, p => p.Accession);
  1481	                AddListLeaf(nameRows, nameVals, nameLeaf, items, p => p.Name);
  1482	                AddListLeaf(unitRows, unitVals, unitLeaf, items, p => p.Unit);
  1483	                AddListLeafNumStruct(intRows, intVals, intLeaf, items, p => p.Integer);
  1484	                AddListLeafNumStruct(fltRows, fltVals, fltLeaf, items, p => p.Float);
  1485	                AddListLeaf(strRows, strVals, strLeaf, items, p => p.String);
  1486	                AddListLeafNumStruct(boolRows, boolVals, boolLeaf, items, p => p.Boolean);
  1487	            }
  1488	
  1489	            Emit(cols, accLeaf, accVals.ToArray(), accRows);
  1490	            Emit(cols, nameLeaf, nameVals.ToArray(), nameRows);
  1491	            Emit(cols, unitLeaf, unitVals.ToArray(), unitRows);
  1492	            Emit(cols, intLeaf, intVals.ToArray(), intRows);
  1493	            Emit(cols, fltLeaf, fltVals.ToArray(), fltRows);
  1494	            Emit(cols, strLeaf, strVals.ToArray(), strRows);
  1495	            Emit(cols, boolLeaf, boolVals.ToArray(), boolRows);
  1496	        }
  1497	
  1498	        private static void AddListLeaf(List<MzPeakParquet.LeafRow> rows, List<string> vals, DataField leaf,
  1499	            List<Param> items, Func<Param, string> sel)
  1500	        {
  1501	            var levels = new int[items.Count];
  1502	            var has = new bool[items.Count];
  1503	            for (int i = 0; i < items.Count; i++)
  1504	            {
  1505	                var v = sel(items[i]);
  1506	                if (v != null) { vals.Add(v); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1507	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1508	            }
  1509	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1510	        }
  1511	
  1512	        private static void AddListLeafNumStruct<T>(List<MzPeakParquet.LeafRow> rows, List<T> vals, DataField leaf,
  1513	            List<Param> items, Func<Param, T?> sel) where T : struct
  1514	        {
  1515	            var levels = new int[items.Count];
  1516	            var has = new bool[items.Count];
  1517	            for (int i = 0; i < items.Count; i++)
  1518	            {
  1519	                var v = sel(items[i]);
  1520	                if (v.HasValue) { vals.Add(v.Value); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1521	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1522	            }
  1523	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1524	        }
  1525	
  1526	        private static void Emit(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf,
  1527	            Array values, List<MzPeakParquet.LeafRow> rows)
  1528	        {
  1529	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
  1530	            cols[leaf] = (values, def, rep);
  1531	        }
  1532	
  1533	        private void AddScanWindows(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1534	            List<Record> records)
  1535	        {
  1536	            var lowerLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"));
  1537	            var upperLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"));
  1538	
  1539	            var lowerRows = new List<MzPeakParquet.LeafRow>();
  1540	            var upperRows = new List<MzPeakParquet.LeafRow>();
  1541	            var lowerVals = new List<float>();
  1542	            var upperVals = new List<float>();
  1543	
  1544	            for (int row = 0; row < records.Count; row++)
  1545	            {
  1546	                lowerRows.Add(MzPeakParquet.ListOf(new[] { lowerLeaf.MaxDefinitionLevel }, new[] { true }));
  1547	                upperRows.Add(MzPeakParquet.ListOf(new[] { upperLeaf.MaxDefinitionLevel }, new[] { true }));
  1548	                lowerVals.Add(records[row].WindowLower);
  1549	                upperVals.Add(records[row].WindowUpper);
  1550	            }
  1551	
  1552	            Emit(cols, lowerLeaf, lowerVals.ToArray(), lowerRows);
  1553	            Emit(cols, upperLeaf, upperVals.ToArray(), upperRows);
  1554	        }
  1555	
  1556	        private static Field FindField(ParquetSchema schema, string path)
  1557	        {
  1558	            var parts = path.Split('/');
  1559	            Field current = schema.Fields.First(f => f.Name == parts[0]);
  1560	            for (int i = 1; i < parts.Length; i++)
  1561	            {
  1562	                current = ((StructField)current).Fields.First(f => f.Name == parts[i]);
  1563	            }
  1564	            return current;
  1565	        }

