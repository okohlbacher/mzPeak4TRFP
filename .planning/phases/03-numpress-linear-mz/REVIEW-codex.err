  1266	
  1267	        private StructField BuildPrecursorField()
  1268	        {
  1269	            var isolationWindow = new StructField("isolation_window",
  1270	                new DataField<float>(Cv("MS:1000827", "isolation_window_target_mz"), true),
  1271	                new DataField<float>(Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"), true),
  1272	                new DataField<float>(Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"), true),
  1273	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
  1274	            var activation = new StructField("activation",
  1275	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
  1276	            return new StructField("precursor",
