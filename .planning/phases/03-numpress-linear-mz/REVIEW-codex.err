  1126	        private byte[] BuildMetadataFacet(List<Record> records)
  1127	        {
  1128	            int n = records.Count;
  1129	
  1130	            var spectrum = BuildSpectrumField();
  1131	            var scan = BuildScanField();
  1132	            var precursor = BuildPrecursorField();
  1133	            var selectedIon = BuildSelectedIonField();
  1134	            var schema = new ParquetSchema(spectrum, scan, precursor, selectedIon);
  1135	
  1136	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
  1137	            var presentAll = records.Select(_ => true).ToArray();
  1138	
  1139	            // precursor / selected_ion are independent tables: the k-th MSn (ascending ordinal) sits
  1140	            // at row k, null-padded on rows M..N-1.
  1141	            var msnRecords = records.Where(r => r.IsMsn).OrderBy(r => r.Ordinal).ToList();
  1142	
  1143	            // spectrum facet (present on all N rows)
  1144	            AddScalar(cols, schema, "spectrum/index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1145	            AddScalar(cols, schema, "spectrum/id", records.Select(r => r.Id).ToArray(), presentAll);
  1146	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000511", "ms_level"),
  1147	                records.Select(r => (byte)r.MsLevel).ToArray(), presentAll);
  1148	            AddScalar(cols, schema, "spectrum/time", records.Select(r => r.Time).ToArray(), presentAll);
  1149	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000465", "scan_polarity"),
  1150	                records.Select(r => r.Polarity).ToArray(), presentAll);
  1151	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000525", "spectrum_representation"),
  1152	                records.Select(r => r.Representation).ToArray(), presentAll);
  1153	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000559", "spectrum_type"),
  1154	                records.Select(r => r.SpectrumType).ToArray(), presentAll);
  1155	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"),
  1156	                records.Select(r => r.LowestMz).ToArray(), presentAll);
  1157	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000527", "highest_observed_mz", "MS:1000040"),
  1158	                records.Select(r => r.HighestMz).ToArray(), presentAll);
  1159	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1003060", "number_of_data_points"),
  1160	                records.Select(r => r.DataPointCount).ToArray(), presentAll);
  1161	
  1162	            // number_of_peaks: present only where peaks were written (leaf-null otherwise).
  1163	            var npkLeaf = Leaf(schema, "spectrum/" + Cv("MS:1003059", "number_of_peaks"));
  1164	            var npkRows = records.Select(r => r.PeakCount.HasValue
  1165	                ? MzPeakParquet.Present(npkLeaf)
  1166	                : MzPeakParquet.AtLevel(npkLeaf.MaxDefinitionLevel - 1, false)).ToArray();
  1167	            var (npkDef, _) = MzPeakParquet.NestedLevels(npkLeaf, npkRows);
  1168	            cols[npkLeaf] = (records.Where(r => r.PeakCount.HasValue).Select(r => r.PeakCount.Value).ToArray(), npkDef, null);
  1169	
  1170	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000504", "base_peak_mz", "MS:1000040"),
  1171	                records.Select(r => r.BasePeakMz).ToArray(), presentAll);
  1172	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000505", "base_peak_intensity", "MS:1000131"),
  1173	                records.Select(r => r.BasePeakIntensity).ToArray(), presentAll);
  1174	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000285", "total_ion_current", "MS:1000131"),
  1175	                records.Select(r => r.TotalIonCurrent).ToArray(), presentAll);
  1176	
  1177	            AddParamList(cols, schema, "spectrum/parameters", records.Select(r => r.SpectrumParams).ToList(), presentAll);
  1178	
  1179	            // scan facet (present on all N rows)
  1180	            AddScalar(cols, schema, "scan/source_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1181	            AddScalar(cols, schema, "scan/scan_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1182	            AddScalar(cols, schema, "scan/" + Cv("MS:1000016", "scan_start_time", "UO:0000031"),
  1183	                records.Select(r => r.ScanStartTime).ToArray(), presentAll);
  1184	            AddScalar(cols, schema, "scan/" + Cv("MS:1000512", "filter_string"),
  1185	                records.Select(r => r.FilterString).ToArray(), presentAll);
  1186	            AddScalar(cols, schema, "scan/" + Cv("MS:1000927", "ion_injection_time", "UO:0000028"),
  1187	                records.Select(r => r.IonInjectionTime).ToArray(), presentAll);
  1188	            AddScalar(cols, schema, "scan/instrument_configuration_ref",
  1189	                records.Select(r => r.InstrumentConfigRef).ToArray(), presentAll);
  1190	            AddScanWindows(cols, schema, records);
  1191	
  1192	            // precursor facet (present on rows 0..M-1, null on M..N-1)
  1193	            AddMsnScalar(cols, schema, "precursor/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
  1194	            AddMsnPrecursorIndex(cols, schema, "precursor/precursor_index", n, msnRecords);
  1195	            AddMsnString(cols, schema, "precursor/precursor_id", n, msnRecords.Select(r => r.PrecursorId).ToArray());
  1196	            AddMsnScalar(cols, schema, "precursor/isolation_window/" + Cv("MS:1000827", "isolation_window_target_mz"),
  1197	                n, msnRecords.Select(r => r.IsolationTarget).ToArray());
  1198	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"),
  1199	                n, msnRecords.Select(r => r.IsolationLowerOffset).ToArray());
  1200	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"),
  1201	                n, msnRecords.Select(r => r.IsolationUpperOffset).ToArray());
  1202	            AddMsnParamList(cols, schema, "precursor/isolation_window/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
  1203	            AddMsnParamList(cols, schema, "precursor/activation/parameters", n, msnRecords.Select(r => r.ActivationParams).ToList());
  1204	
  1205	            // selected_ion facet (present on rows 0..M-1, null on M..N-1)
  1206	            AddMsnScalar(cols, schema, "selected_ion/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
  1207	            AddMsnPrecursorIndex(cols, schema, "selected_ion/precursor_index", n, msnRecords);
  1208	            AddMsnScalar(cols, schema, "selected_ion/" + Cv("MS:1000744", "selected_ion_mz", "MS:1000040"),
  1209	                n, msnRecords.Select(r => r.SelectedIonMz).ToArray());
  1210	            AddMsnNullableInt(cols, schema, "selected_ion/" + Cv("MS:1000041", "charge_state"),
  1211	                n, msnRecords.Select(r => r.ChargeState).ToArray());
  1212	            AddMsnNullableFloat(cols, schema, "selected_ion/" + Cv("MS:1000042", "intensity", "MS:1000131"),
  1213	                n, msnRecords.Select(r => r.SelectedIonIntensity).ToArray());
  1214	
  1215	            // Ion-mobility columns exist to match the ground-truth struct shape; the Thermo RAW path
  1216	            // carries no per-selected-ion mobility value, so they stay leaf-null on every MSn row.
  1217	            AddMsnNullableDouble(cols, schema, "selected_ion/ion_mobility_value", n, msnRecords.Select(_ => (double?)null).ToArray());
  1218	            AddMsnString(cols, schema, "selected_ion/ion_mobility_type", n, msnRecords.Select(_ => (string)null).ToArray());
  1219	            AddMsnParamList(cols, schema, "selected_ion/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
  1220	
  1221	            var custom = new Dictionary<string, string>
  1222	            {
  1223	                ["spectrum_count"] = n.ToString(),
  1224	                ["spectrum_data_point_count"] = "0",
  1225	                ["spectrum_array_index"] = SpectrumArrayIndex
  1226	            };
  1227	            AddMetadataBlocks(custom, records);
  1228	
  1229	            return WriteFacet(schema, custom, cols);
  1230	        }
