  1283	
  1284	        private StructField BuildSelectedIonField()
  1285	        {
  1286	            return new StructField("selected_ion",
  1287	                new DataField<ulong>("source_index", true),
  1288	                new DataField<ulong>("precursor_index", true),
  1289	                new DataField<double>(Cv("MS:1000744", "selected_ion_mz", "MS:1000040"), true),
  1290	                new DataField<int>(Cv("MS:1000041", "charge_state"), true),
  1291	                new DataField<float>(Cv("MS:1000042", "intensity", "MS:1000131"), true),
  1292	                new DataField<double>("ion_mobility_value", true),
