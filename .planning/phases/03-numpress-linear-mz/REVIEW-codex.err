   359	        [Test]
   360	        public void BitwiseMultiset_Chunked_Equals_Point()
   361	        {
   362	            var chunked = Convert(false, out var cdir);
   363	            var pointed = Convert(true, out var pdir);
   364	            try
   365	            {
   366	                // Decode chunked m/z with the null-aware delta decode, build per-spectrum BITWISE keys
   367	                // (DoubleToInt64Bits / SingleToInt32Bits), and compare the multisets to the point facet.
   368	                var decodeSnippet =
   369	                    "import pyarrow.parquet as pq, json, struct\n" +
   370	                    "from collections import defaultdict\n" +
   371	                    "def dd(start, arr):\n" +
   372	                    "    buf=[]; last=start\n" +
   373	                    "    if not arr: return [start]\n" +
   374	                    "    if arr[0] is None:\n" +
   375	                    "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   376	                    "        last=None\n" +
   377	                    "    else: buf.append(start)\n" +
   378	                    "    for it in arr:\n" +
   379	                    "        if it is not None:\n" +
   380	                    "            if last is not None: last=it+last; buf.append(last)\n" +
   381	                    "            else: buf.append(it); last=it\n" +
   382	                    "        else: buf.append(None); last=None\n" +
   383	                    "    return buf\n" +
   384	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   385	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   386	                    "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   387	                    "d=defaultdict(list)\n" +
   388	                    "for i in range(len(si)):\n" +
   389	                    "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
   390	                    "    for m,it in zip(dmz, inn[i]):\n" +
   391	                    "        if m is None or it is None: continue\n" +
   392	                    "        d[si[i]].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   393	                    "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   394	                var chunkKeys = PyArrow(chunked, "spectra_data.parquet", decodeSnippet);
   395	
   396	                var pointSnippet =
   397	                    "import pyarrow.parquet as pq, json, struct\n" +
   398	                    "from collections import defaultdict\n" +
   399	                    "t = pq.read_table(r'{PARQUET}').column('point').combine_chunks()\n" +
   400	                    "si=t.field('spectrum_index').to_pylist(); mz=t.field('mz').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   401	                    "d=defaultdict(list)\n" +
   402	                    "for s,m,it in zip(si,mz,inn):\n" +
   403	                    "    d[s].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   404	                    "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   405	                var pointKeys = PyArrow(pointed, "spectra_data.parquet", pointSnippet);
   406	
   407	                Assert.That(chunkKeys.Properties().Select(p => p.Name).OrderBy(x => x),
   408	                    Is.EqualTo(pointKeys.Properties().Select(p => p.Name).OrderBy(x => x)),
   409	                    "same spectrum_index set");
   410	
   411	                int mzMismatch = 0, intMismatch = 0;
   412	                foreach (var prop in chunkKeys.Properties())
   413	                {
   414	                    var c = ((JArray)prop.Value).Select(a => ((long)a[0], (int)a[1])).OrderBy(x => x).ToArray();
   415	                    var p = ((JArray)pointKeys[prop.Name]).Select(a => ((long)a[0], (int)a[1])).OrderBy(x => x).ToArray();
   416	                    Assert.That(c.Length, Is.EqualTo(p.Length), $"spectrum {prop.Name} point count");
   417	                    var cMz = c.Select(x => x.Item1).ToArray(); var pMz = p.Select(x => x.Item1).ToArray();
   418	                    var cIn = c.Select(x => x.Item2).OrderBy(x => x).ToArray();
   419	                    var pIn = p.Select(x => x.Item2).OrderBy(x => x).ToArray();
   420	                    if (!cMz.SequenceEqual(pMz)) mzMismatch++;
   421	                    if (!cIn.SequenceEqual(pIn)) intMismatch++;
   422	                }
   423	                // Intensity is never delta-encoded -> must be bitwise-identical.
   424	                Assert.That(intMismatch, Is.EqualTo(0), "intensity is bitwise-identical chunked vs point");
   425	                // Empirical finding (recorded in SUMMARY): f64 delta encode+reconstruct is bit-exact on real
   426	                // Thermo m/z, so the m/z multiset matches bitwise with zero tolerance (exact / L1).
   427	                Assert.That(mzMismatch, Is.EqualTo(0),
   428	                    "m/z is BITWISE-identical chunked vs point (delta round-trip is bit-exact on Thermo m/z)");
   429	            }
   430	            finally { Directory.Delete(cdir, true); Directory.Delete(pdir, true); }
   431	        }
   432	
   433	        // The chunk decode snippet shared by the bitwise-equivalence locks: null-aware delta decode of
   434	        // every chunk row across ALL row groups (pyarrow read_table merges row groups), emitting a
   435	        // per-spectrum map of sorted [mz_bits, intensity_bits] pairs with null pairs dropped.
   436	        private const string ChunkDecodeSnippet =
   437	            "import pyarrow.parquet as pq, json, struct\n" +
   438	            "from collections import defaultdict\n" +
   439	            "def dd(start, arr):\n" +
   440	            "    buf=[]; last=start\n" +
   441	            "    if not arr: return [start]\n" +
   442	            "    if arr[0] is None:\n" +
   443	            "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   444	            "        last=None\n" +
   445	            "    else: buf.append(start)\n" +
   446	            "    for it in arr:\n" +
   447	            "        if it is not None:\n" +
   448	            "            if last is not None: last=it+last; buf.append(last)\n" +
   449	            "            else: buf.append(it); last=it\n" +
   450	            "        else: buf.append(None); last=None\n" +
   451	            "    return buf\n" +
   452	            "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   453	            "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   454	            "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   455	            "d=defaultdict(list)\n" +
   456	            "for i in range(len(si)):\n" +
   457	            "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
   458	            "    for m,it in zip(dmz, inn[i]):\n" +
   459	            "        if m is None or it is None: continue\n" +
   460	            "        d[si[i]].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   461	            "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   462	
   463	        private static int RowGroupCount(string archive, string entry)
   464	        {
   465	            using (var ms = new MemoryStream(ReadEntry(archive, entry)))
   466	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   467	                return reader.RowGroupCount;
   468	        }
