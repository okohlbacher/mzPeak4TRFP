   435	        // Footer KV for the chunked spectra_data facet: same count keys as the point facet, with the chunk
   436	        // spectrum_array_index instead of the point one.
   437	        private static Dictionary<string, string> ChunkFooter(int spectrumCount, long pointCount) =>
   438	            new Dictionary<string, string>
   439	            {
   440	                ["spectrum_count"] = spectrumCount.ToString(),
   441	                ["spectrum_data_point_count"] = pointCount.ToString(),
   442	                ["spectrum_array_index"] = ChunkedSpectrumArrayIndex
   443	            };
   444	
   445	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   446	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   447	        // index sort is applied only when an ascending violation is detected, never dropping or
   448	        // merging equal-m/z points.
   449	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   450	        {
   451	            var n = masses?.Length ?? 0;
   452	            var mz = new double[n];
   453	            var inten = new float[n];
   454	            bool ascending = true;
   455	            for (int i = 0; i < n; i++)
   456	            {
   457	                mz[i] = masses[i];
   458	                inten[i] = (float)intensities[i];
   459	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   460	            }
   461	
   462	            if (ascending) return (mz, inten);
   463	
   464	            var order = new int[n];
   465	            for (int i = 0; i < n; i++) order[i] = i;
   466	            Array.Sort(order, (a, b) =>
   467	            {
   468	                int c = masses[a].CompareTo(masses[b]);
   469	                return c != 0 ? c : a.CompareTo(b);
   470	            });
   471	            var sortedMz = new double[n];
   472	            var sortedInten = new float[n];
   473	            for (int i = 0; i < n; i++)
   474	            {
   475	                sortedMz[i] = masses[order[i]];
   476	                sortedInten[i] = (float)intensities[order[i]];
   477	            }
   478	            return (sortedMz, sortedInten);
   479	        }
   480	
   481	        private void CaptureTic(IRawDataPlus raw, List<Record> records, List<double> time,
   482	            List<float> intensity, List<long> msLevel)
   483	        {
   484	            ChromatogramSignal[] trace;
   485	            try
   486	            {
   487	                raw.SelectInstrument(Device.MS, 1);
   488	                var settings = new ChromatogramTraceSettings(TraceType.TIC);
   489	                var data = raw.GetChromatogramData(new IChromatogramSettings[] { settings }, -1, -1);
   490	                trace = ChromatogramSignal.FromChromatogramData(data);
   491	            }
   492	            catch (Exception ex)
   493	            {
   494	                Log.Warn($"Device TIC trace unavailable, falling back to summed TIC: {ex.Message}");
   495	                trace = Array.Empty<ChromatogramSignal>();
   496	            }
   497	
   498	            if (trace.Length == 0)
   499	            {
   500	                foreach (var r in records)
   501	                {
   502	                    time.Add(r.Time);
   503	                    intensity.Add(r.TotalIonCurrent);
   504	                    msLevel.Add(r.MsLevel);
   505	                }
   506	                _chromFromDeviceTrace = false;
   507	                return;
   508	            }
   509	
   510	            var signal = trace[0];
   511	            if (signal.Times.Count == records.Count)
   512	            {
   513	                for (int i = 0; i < records.Count; i++)
   514	                {
   515	                    time.Add(signal.Times[i]);
   516	                    intensity.Add((float)signal.Intensities[i]);
   517	                    msLevel.Add(records[i].MsLevel);
   518	                }
   519	                _chromFromDeviceTrace = true;
   520	                return;

