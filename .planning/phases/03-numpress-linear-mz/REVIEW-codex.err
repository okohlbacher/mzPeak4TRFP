    42	        [Test]
    43	        public void RoundTrip_Gapless_BitwiseExact()
    44	        {
    45	            var rnd = new Random(7);
    46	            int n = 5000;
    47	            var mz = new double[n];
    48	            var inten = new float[n];
    49	            double cur = 100.0;
    50	            for (int i = 0; i < n; i++)
    51	            {
    52	                cur += rnd.NextDouble() * 0.5;
    53	                mz[i] = cur;
    54	                inten[i] = (float)(rnd.NextDouble() * 1e6);
    55	            }
    56	
    57	            var rt = RoundTrip(mz, inten, 50.0);
    58	            Assert.That(rt.Count, Is.EqualTo(n), "no points lost");
    59	
    60	            var src = Enumerable.Range(0, n)
    61	                .Select(i => (MzBits(mz[i]), IntBits(inten[i])))
    62	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ToArray();
    63	            var got = rt
    64	                .Select(p => (MzBits(p.mz), IntBits(p.inten)))
    65	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ToArray();
    66	            Assert.That(got, Is.EqualTo(src), "decoded multiset is BITWISE equal to input");
    67	        }
