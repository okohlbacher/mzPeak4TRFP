   972	                    _bStart.Add(start);
   973	                    _bEnd.Add(end);
   974	                    _bEnc.Add(ChunkEncodingCurie);
   975	
   976	                    if (values.Length == 0)
   977	                    {
   978	                        _mzRows.Add(MzPeakParquet.EmptyList((ListField)FindField(_schema, "chunk/mz_chunk_values")));
   979	                    }
   980	                    else
   981	                    {
   982	                        var levels = new int[values.Length];
   983	                        var has = new bool[values.Length];
   984	                        for (int i = 0; i < values.Length; i++)
   985	                        {
   986	                            levels[i] = _mzItem.MaxDefinitionLevel; has[i] = true;
   987	                            _mzVals.Add(values[i].Value);
   988	                        }
   989	                        _mzRows.Add(MzPeakParquet.ListOf(levels, has));
   990	                    }
   991	
   992	                    int k = e - s;
   993	                    var iLevels = new int[k];
   994	                    var iHas = new bool[k];
   995	                    for (int i = 0; i < k; i++)
   996	                    {
   997	                        iLevels[i] = _intItem.MaxDefinitionLevel; iHas[i] = true;
   998	                        _intVals.Add(intensity[s + i]);
   999	                    }
  1000	                    _intRows.Add(MzPeakParquet.ListOf(iLevels, iHas));
  1001	
  1002	                    PointCount += k;
  1003	                    if (_bIdx.Count >= _cap) Flush();
  1004	                }
  1005	            }
