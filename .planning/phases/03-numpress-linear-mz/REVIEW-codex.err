   228	        private static string ResolvePython()
   229	        {
   230	            foreach (var cand in new[] { "python3", "python" })
   231	            {
   232	                try
   233	                {
   234	                    var psi = new ProcessStartInfo(cand, "-c \"import pyarrow\"")
   235	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   236	                    using (var p = Process.Start(psi)) { p.WaitForExit(); if (p.ExitCode == 0) return cand; }
   237	                }
   238	                catch { }
   239	            }
   240	            return null;
   241	        }
