  1297	        private string Cv(string accession, string label, string unit = null)
  1298	        {
  1299	            CollectPrefix(accession);
  1300	            if (unit != null) CollectPrefix(unit);
  1301	            return MzPeakParquet.CvColumn(accession, label, unit);
  1302	        }
  1303	
  1304	        private void CollectPrefix(string curie)
  1305	        {
  1306	            if (string.IsNullOrEmpty(curie)) return;
  1307	            var i = curie.IndexOf(':');
  1308	            if (i > 0) _cvPrefixes.Add(curie.Substring(0, i));
  1309	        }
