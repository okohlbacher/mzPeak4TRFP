   770	        // Streams a finished temp-file facet into a STORED zip entry via a 64 KB bounded CopyTo, never
   771	        // reading the whole facet into a byte[].
   772	        private static void AddStoredFromFile(ZipArchive zip, string name, string tempPath)
   773	        {
   774	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   775	            using (var es = entry.Open())
   776	            using (var src = File.OpenRead(tempPath))
   777	                src.CopyTo(es, 1 << 16);
   778	        }
