   895	        /// <summary>
   896	        /// Show the help message
   897	        /// </summary>
   898	        /// <param name="message">the help message</param>
   899	        /// <param name="optionException">the option exception, can be null</param>
   900	        /// <param name="optionSet">the option set object</param>
   901	        private static void ShowHelp(string message, OptionException optionException, OptionSet optionSet)
   902	        {
   903	            if (optionException != null)
   904	            {
   905	                if (!optionException.OptionName.IsNullOrEmpty())
   906	                {
   907	                    Console.Error.Write(optionException.OptionName + ": ");
   908	                }
   909	
   910	                Console.Error.WriteLine(optionException.Message);
   911	            }
   912	
   913	            Console.Error.WriteLine(message);
   914	            optionSet.WriteOptionDescriptions(Console.Error);
   915	            Environment.Exit(-1);
   916	        }
