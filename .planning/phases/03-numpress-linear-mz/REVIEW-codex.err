  1232	        private StructField BuildSpectrumField()
  1233	        {
  1234	            return new StructField("spectrum",
  1235	                new DataField<ulong>("index", true),
  1236	                new DataField<string>("id", true),
  1237	                new DataField<byte>(Cv("MS:1000511", "ms_level"), true),
  1238	                new DataField<double>("time", true),
  1239	                new DataField<sbyte>(Cv("MS:1000465", "scan_polarity"), true),
  1240	                new DataField<string>(Cv("MS:1000525", "spectrum_representation"), true),
  1241	                new DataField<string>(Cv("MS:1000559", "spectrum_type"), true),
  1242	                new DataField<double>(Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"), true),
  1243	                new DataField<double>(Cv("MS:1000527", "highest_observed_mz", "MS:1000040"), true),
  1244	                new DataField<ulong>(Cv("MS:1003060", "number_of_data_points"), true),
  1245	                new DataField<ulong>(Cv("MS:1003059", "number_of_peaks"), true),
  1246	                new DataField<double>(Cv("MS:1000504", "base_peak_mz", "MS:1000040"), true),
  1247	                new DataField<float>(Cv("MS:1000505", "base_peak_intensity", "MS:1000131"), true),
  1248	                new DataField<float>(Cv("MS:1000285", "total_ion_current", "MS:1000131"), true),
  1249	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
  1250	        }
  1251	
  1252	        private StructField BuildScanField()
  1253	        {
  1254	            var window = new StructField("item",
  1255	                new DataField<float>(Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"), true),
  1256	                new DataField<float>(Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"), true));
  1257	            return new StructField("scan",
  1258	                new DataField<ulong>("source_index", true),
  1259	                new DataField<ulong>("scan_index", true),
  1260	                new DataField<float>(Cv("MS:1000016", "scan_start_time", "UO:0000031"), true),
  1261	                new DataField<string>(Cv("MS:1000512", "filter_string"), true),
  1262	                new DataField<float>(Cv("MS:1000927", "ion_injection_time", "UO:0000028"), true),
  1263	                new DataField<uint>("instrument_configuration_ref", true),
  1264	                new ListField("scan_windows", window));
