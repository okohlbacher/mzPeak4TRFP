   213	        private static byte[] ReadEntry(string archive, string name)
   214	        {
   215	            using (var zip = ZipFile.OpenRead(archive))
   216	            {
   217	                var entry = zip.GetEntry(name);
   218	                if (entry == null) return null;
   219	                using (var s = entry.Open())
   220	                using (var ms = new MemoryStream())
   221	                {
   222	                    s.CopyTo(ms);
   223	                    return ms.ToArray();
   224	                }
   225	            }
   226	        }
