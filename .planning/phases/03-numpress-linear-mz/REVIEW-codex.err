   328	        // Reads and builds everything for one scan into per-scan locals, touching NO shared/streaming
   329	        // state. Returns null for an out-of-range or empty scan (a clean skip); returns the staged scan on
   330	        // success. Any read/build failure throws and is handled by the caller as an error-counted skip, so
   331	        // a failed scan never commits an ordinal, rows, or a precursor-map entry.
   332	        private StagedScan StageScan(IRawDataPlus raw, int scanNumber, ulong ordinal,
   333	            IDictionary<int, ulong> scanNumberToOrdinal)
   334	        {
   335	            var scanFilter = raw.GetFilterForScanNumber(scanNumber);
   336	            int level = (int)scanFilter.MSOrder;
   337	            if (level > ParseInput.MaxLevel || !ParseInput.MsLevel.Contains(level)) return null;
   338	
   339	            var scanEvent = raw.GetScanEventForScanNumber(scanNumber);
   340	            var mzData = ReadMZData(raw, scanEvent, scanNumber, false, false, false);
   341	
   342	            var (mz, inten) = OrderedPairs(mzData.masses, mzData.intensities);
   343	            if (mz.Length == 0) return null;
   344	
   345	            double[] peakMz = null;
   346	            float[] peakInten = null;
   347	            ulong? peakCount = null;
   348	            if (scanEvent.ScanData == ScanDataType.Profile && Scan.FromFile(raw, scanNumber).HasCentroidStream)
   349	            {
   350	                var peakData = ReadMZData(raw, scanEvent, scanNumber, true, false, false);
   351	                var (pMz, pInten) = OrderedPairs(peakData.masses, peakData.intensities);
   352	                if (pMz.Length > 0)
   353	                {
   354	                    peakMz = pMz;
   355	                    peakInten = pInten;
   356	                    peakCount = (ulong)pMz.Length;
   357	                }
   358	            }
   359	
   360	            var scanStats = raw.GetScanStatsForScanNumber(scanNumber);
   361	            var trailer = new ScanTrailer(raw.GetTrailerExtraInformation(scanNumber));
   362	
   363	            // Mirror the mzML parent-derivation bookkeeping: map each scan's filter prefix to its scan
   364	            // number so an MSn child can resolve its parent via the scan string.
   365	            var filterMatch = level == 1
   366	                ? null
   367	                : (level == 2
   368	                    ? _filterStringIsolationMzPattern.Match(scanEvent.ToString())
   369	                    : _filterStringParentMzPattern.Match(scanEvent.ToString()));
   370	            var filterKey = level == 1 ? "" : (filterMatch != null && filterMatch.Success ? filterMatch.Groups[1].Value : "");
   371	
   372	            // The filter key is staged but nothing has committed yet. A failure raised here is
   373	            // indistinguishable from a real post-key read failure and must leave no trace of this scan.
   374	            AfterFilterKeyStaged?.Invoke(scanNumber);
   375	
   376	            var rec = new Record
   377	            {
   378	                Ordinal = ordinal,
   379	                ScanNumber = scanNumber,
   380	                MsLevel = level,
   381	                Id = ConstructSpectrumTitle((int)Device.MS, 1, scanNumber),
   382	                Time = raw.RetentionTimeFromScanNumber(scanNumber),
   383	                Polarity = scanFilter.Polarity == PolarityType.Negative ? (sbyte)-1 : (sbyte)1,
   384	                Representation = mzData.isCentroided ? "MS:1000127" : "MS:1000128",
   385	                SpectrumType = level == 1 ? "MS:1000579" : "MS:1000580",
   386	                LowestMz = mz[0],
   387	                HighestMz = mz[mz.Length - 1],
   388	                BasePeakMz = mzData.basePeakMass ?? 0.0,
   389	                BasePeakIntensity = (float)(mzData.basePeakIntensity ?? 0.0),
   390	                TotalIonCurrent = (float)scanStats.TIC,
   391	                DataPointCount = (ulong)mz.Length,
   392	                PeakCount = peakCount,
   393	                ScanStartTime = (float)raw.RetentionTimeFromScanNumber(scanNumber),
   394	                FilterString = scanEvent.ToString(),
   395	                IonInjectionTime = (float)(trailer.AsDouble("Ion Injection Time (ms):") ?? 0.0),
   396	                InstrumentConfigRef = AnalyzerIndex(scanFilter.MassAnalyzer, scanFilter.IonizationMode),
   397	                WindowLower = (float)scanStats.LowMass,
   398	                WindowUpper = (float)scanStats.HighMass
   399	            };
   400	
   401	            if (level >= 2)
   402	            {
   403	                BeforeBuildPrecursor?.Invoke(scanNumber, scanNumberToOrdinal);
   404	                BuildPrecursor(raw, scanNumber, scanEvent, scanFilter, trailer, scanNumberToOrdinal,
   405	                    filterKey, rec);
   406	            }
   407	
   408	            return new StagedScan
   409	            {
   410	                Mz = mz,
   411	                Inten = inten,
   412	                PeakMz = peakMz,
   413	                PeakInten = peakInten,
   414	                Rec = rec,
   415	                FilterKey = filterKey
   416	            };
   417	        }
