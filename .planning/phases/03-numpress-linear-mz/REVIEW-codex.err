   289	                var snippet =
   290	                    "import pyarrow.parquet as pq, json\n" +
   291	                    "f = pq.read_table(r'{PARQUET}').schema.field('chunk').type\n" +
   292	                    "out = {'names':[f.field(i).name for i in range(f.num_fields)],\n" +
   293	                    "       'mz_item':str(f.field(3).type.value_field.type),\n" +
   294	                    "       'int_item':str(f.field(5).type.value_field.type)}\n" +
   295	                    "print(json.dumps(out))\n";
   296	                var ours = PyArrow(archive, "spectra_data.parquet", snippet);
