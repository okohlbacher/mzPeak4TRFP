   470	        [Test]
   471	        public void ChunkFacet_MultiRowGroup_Equals_SingleRowGroup()
   472	        {
   473	            // Single-row-group chunked run (production cap): one row group for small.RAW.
   474	            var single = Convert(false, out var sdir);
   475	            try
   476	            {
   477	                Assert.That(RowGroupCount(single, "spectra_data.parquet"), Is.EqualTo(1),
   478	                    "production cap yields a single chunk row group for small.RAW");
   479	                var singleKeys = PyArrow(single, "spectra_data.parquet", ChunkDecodeSnippet);
   480	
   481	                // Lowered-cap chunked run through the REAL writer flush path: forces >=2 chunk row groups.
   482	                string mdir = null, multi = null;
   483	                try
   484	                {
   485	                    MzPeakSpectrumWriter.TestRowGroupRowCap = 8;
   486	                    multi = Convert(false, out mdir);
   487	                    Assert.That(RowGroupCount(multi, "spectra_data.parquet"), Is.GreaterThan(1),
   488	                        "lowered cap must drive the chunk list-column flush path into multiple row groups");
   489	
   490	                    var multiKeys = PyArrow(multi, "spectra_data.parquet", ChunkDecodeSnippet);
   491	
   492	                    Assert.That(multiKeys.Properties().Select(p => p.Name).OrderBy(x => x),
   493	                        Is.EqualTo(singleKeys.Properties().Select(p => p.Name).OrderBy(x => x)),
   494	                        "same spectrum_index set across caps");
   495	
   496	                    foreach (var prop in singleKeys.Properties())
   497	                    {
   498	                        var s = ((JArray)prop.Value).Select(a => ((long)a[0], (int)a[1]))
   499	                            .OrderBy(x => x).ToArray();
   500	                        var m = ((JArray)multiKeys[prop.Name]).Select(a => ((long)a[0], (int)a[1]))
   501	                            .OrderBy(x => x).ToArray();
   502	                        Assert.That(m, Is.EqualTo(s),
   503	                            $"spectrum {prop.Name}: (mz,intensity) multiset BITWISE-identical across caps");
   504	                    }
   505	                }
   506	                finally
   507	                {
   508	                    MzPeakSpectrumWriter.TestRowGroupRowCap = null;
   509	                    if (mdir != null) Directory.Delete(mdir, true);
   510	                }
   511	            }
   512	            finally { Directory.Delete(sdir, true); }
   513	        }
