   425	        // Footer KV for a streamed point facet (spectra_data / spectra_peaks), identical to the v1
   426	        // single-row-group facet's metadata.
   427	        private static Dictionary<string, string> PointFooter(int spectrumCount, long pointCount) =>
   428	            new Dictionary<string, string>
   429	            {
   430	                ["spectrum_count"] = spectrumCount.ToString(),
   431	                ["spectrum_data_point_count"] = pointCount.ToString(),
   432	                ["spectrum_array_index"] = SpectrumArrayIndex
