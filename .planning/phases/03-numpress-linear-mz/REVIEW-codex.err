   861	            // The cap is a HARD upper bound on the in-memory buffer: a single scan's points are split
   862	            // across as many row groups as needed (a scan MAY span row groups in the point layout),
   863	            // filling the remaining capacity, flushing at the cap, then continuing with the same ordinal.
   864	            public void Append(ulong ordinal, double[] mz, float[] intensity)
   865	            {
   866	                int i = 0;
   867	                while (i < mz.Length)
   868	                {
   869	                    int room = _cap - _bIdx.Count;
   870	                    int take = Math.Min(room, mz.Length - i);
   871	                    for (int j = 0; j < take; j++, i++)
   872	                    {
   873	                        _bIdx.Add(ordinal); _bMz.Add(mz[i]); _bInt.Add(intensity[i]);
   874	                    }
   875	                    if (_bIdx.Count >= _cap) Flush();
   876	                }
   877	                PointCount += mz.Length;
   878	            }
