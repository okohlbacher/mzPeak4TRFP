     2	using System.Collections.Generic;
     3	
     4	namespace ThermoRawFileParser.Writer
     5	{
     6	    // Null-aware delta encode/decode + fixed m/z-window chunker for the chunk spectra_data layout.
     7	    // The structure is null-aware so the decoder can read reference / externally-produced files whose
     8	    // values carry null gap markers ([None, absolute, delta] / [None, None]); the encode/chunk path is
     9	    // exercised by callers with no nulls (the writer never produces gap markers).
    10	    public static class MzPeakChunkCodec
    11	    {
    12	        public const double DefaultChunkSize = 50.0;
    13	
    14	        // Delta-encode a window's m/z slice. start/end are the first/last non-null m/z; values holds the
    15	        // consecutive deltas (length k-1 for a gapless slice) and excludes the start, which lives in start.
    16	        // Mirrors null_delta_encode: a value after a null is stored ABSOLUTE, a leading null is kept as a
    17	        // marker. The writer passes all-present slices, so this reduces to plain consecutive deltas.
    18	        public static void DeltaEncode(double?[] mz, out double start, out double end, out double?[] values)
    19	        {
    20	            if (mz == null || mz.Length == 0)
    21	                throw new ArgumentException("DeltaEncode requires a non-empty slice.", nameof(mz));
    22	
    23	            start = 0.0; end = 0.0;
    24	            bool sawStart = false;
    25	            for (int i = 0; i < mz.Length; i++)
    26	            {
    27	                if (mz[i].HasValue)
    28	                {
    29	                    if (!sawStart) { start = mz[i].Value; sawStart = true; }
    30	                    end = mz[i].Value;
    31	                }
    32	            }
    33	
    34	            var buffer = new List<double?>(mz.Length);
    35	            int idx = 0;
    36	            double? last = mz[idx++];
    37	            if (!last.HasValue) buffer.Add(null);
    38	            for (; idx < mz.Length; idx++)
    39	            {
    40	                var item = mz[idx];
    41	                if (item.HasValue)
    42	                {
    43	                    if (last.HasValue) buffer.Add(item.Value - last.Value);
    44	                    else buffer.Add(item.Value);
    45	                    last = item;
    46	                }
    47	                else
    48	                {
    49	                    buffer.Add(null);
    50	                    last = null;
    51	                }
    52	            }
    53	            values = buffer.ToArray();
    54	        }
    55	
    56	        // Reconstruct the m/z array from start + delta values. Mirrors null_delta_decode byte-for-byte:
    57	        // start is the first reconstructed m/z; cumulative add for present deltas; absolute restart after a
    58	        // null; nulls preserved aligned to intensity. The [None, None] case decodes to a single peak at
    59	        // start; a leading [None, present, ...] treats the present value as an absolute restart.
    60	        public static double?[] DeltaDecode(double start, double?[] values)
    61	        {
    62	            var arr = values ?? Array.Empty<double?>();
    63	            var buf = new List<double?>(arr.Length + 1);
    64	            double? last = start;
    65	
    66	            if (arr.Length == 0)
    67	            {
    68	                buf.Add(start);
    69	                return buf.ToArray();
    70	            }
    71	
    72	            if (!arr[0].HasValue)
    73	            {
    74	                if (arr.Length > 1 && !arr[1].HasValue) buf.Add(last);
    75	                last = null;
    76	            }
    77	            else
    78	            {
    79	                buf.Add(start);
    80	            }
    81	
    82	            foreach (var item in arr)
    83	            {
    84	                if (item.HasValue)
    85	                {
    86	                    if (last.HasValue) { double d = item.Value + last.Value; buf.Add(d); last = d; }
    87	                    else { buf.Add(item.Value); last = item; }
    88	                }
    89	                else
    90	                {
    91	                    buf.Add(null);
    92	                    last = null;
    93	                }
    94	            }
    95	            return buf.ToArray();
    96	        }
    97	
    98	        // Partition a sorted, non-decreasing m/z axis into [start,end) intervals each spanning <= width from
    99	        // the interval's own first m/z. Mirrors null_chunk_every_k: threshold advances by width, a boundary
   100	        // length-1 chunk is rolled into the adjacent chunk, the final residual is always emitted. An empty
   101	        // input yields zero intervals (no chunk row). A single-point spectrum yields one length-1 interval.
   102	        // Throws ArgumentException on non-monotonic (descending) input; the codec assumes ascending order.
   103	        public static List<(int start, int end)> Chunk(double[] mz, double width)
   104	        {
   105	            // A non-finite or non-positive width never advances the threshold and would loop forever;
   106	            // reject it up front so the partition loop is always guaranteed to terminate.
   107	            if (!(width > 0.0) || double.IsInfinity(width))
   108	                throw new ArgumentOutOfRangeException(nameof(width), width,
   109	                    "Chunk width must be a finite value greater than 0.");
   110	
   111	            var result = new List<(int, int)>();
   112	            if (mz == null || mz.Length == 0) return result;
   113	
   114	            for (int i = 1; i < mz.Length; i++)
   115	                if (mz[i] < mz[i - 1])
   116	                    throw new ArgumentException("Chunk requires non-decreasing m/z input.", nameof(mz));
   117	
   118	            int n = mz.Length;
   119	            int offset = 0;
   120	            double threshold = mz[0] + width;
   121	            for (int i = 1; i < n; i++)
   122	            {
   123	                if (mz[i] > threshold)
   124	                {
   125	                    if (i - offset != 1)
   126	                    {
   127	                        result.Add((offset, i));
   128	                        offset = i;
   129	                    }
   130	                    while (threshold < mz[i]) threshold += width;
   131	                }
   132	            }
   133	            result.Add((offset, n));
   134	            return result;
   135	        }
   136	    }
   137	}

