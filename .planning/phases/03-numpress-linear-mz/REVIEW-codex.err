   918	        private static string GetValidEnumLevels(Type enumType)
   919	        {
   920	            List<string> output = new List<string>();
   921	            foreach (int v in Enum.GetValues(enumType))
   922	            {
   923	                output.Add(String.Format("{0} ({1})", Enum.GetName(enumType, v), v));
   924	            }
   925	
   926	            return String.Join("\n", output);
   927	        }
   928	
   929	        private static int ParseToEnum(Type enumType, string formatString, string keyName)
   930	        {
   931	            if (int.TryParse(formatString, out var formatInt)) //can be parsed as int
   932	            {
   933	                if (Enum.IsDefined(enumType, formatInt))
   934	                {
   935	                    return formatInt;
   936	                }
   937	                else
   938	                {
   939	                    throw new OptionException(
   940	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   941	                    keyName);
   942	                }
   943	
   944	            }
   945	            else //try parse as a string
   946	            {
   947	                try
   948	                {
   949	                    return (int)Enum.Parse(enumType, formatString, true);
   950	                }
   951	
   952	                catch (Exception)
   953	                {
   954	                    throw new OptionException(
   955	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   956	                    keyName);
   957	                }
   958	            }
   959	        }
   960	
   961	        private static HashSet<int> ParseMsLevel(string inputString)
   962	        {
   963	            try
   964	            {
   965	                var levelIterator = new NumberIterator(inputString, 1, 10);
   966	                return new HashSet<int>(levelIterator.IterateScans());
   967	            }
   968	            catch (Exception ex)
   969	            {
   970	                throw new OptionException($"Cannot parse MS level from {inputString} - {ex.Message}", "msLevel");
   971	            }
   972	        }
   973	    }

