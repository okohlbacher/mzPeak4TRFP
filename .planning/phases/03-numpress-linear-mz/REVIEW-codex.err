   761	        private static void AddStored(ZipArchive zip, string name, byte[] bytes)
   762	        {
   763	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   764	            using (var s = entry.Open())
   765	            {
   766	                s.Write(bytes, 0, bytes.Length);
