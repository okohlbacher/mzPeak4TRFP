  1003	        public void Chromatogram_Metadata_Facet_Shape_And_Values()
  1004	        {
  1005	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1006	            var dir = Convert(input, out var archive);
  1007	            try
  1008	            {
  1009	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
  1010	                int n = data.SpectrumCount;
  1011	
  1012	                var snippet =
  1013	                    "import pyarrow.parquet as pq, json\n" +
  1014	                    "t = pq.read_table(r'{PARQUET}')\n" +
  1015	                    "d = t.to_pylist()\n" +
  1016	                    "c = d[0]['chromatogram']\n" +
  1017	                    "ct = t.schema.field('chromatogram').type\n" +
  1018	                    "aux = ct.field('auxiliary_arrays').type.value_type\n" +
  1019	                    "out = {}\n" +
  1020	                    "out['rows'] = len(d)\n" +
  1021	                    "out['id'] = c['id']\n" +
  1022	                    "out['type'] = c['MS_1000626_chromatogram_type']\n" +
  1023	                    "out['pol'] = int(c['MS_1000465_scan_polarity'])\n" +
  1024	                    "out['pol_type'] = str(ct.field('MS_1000465_scan_polarity').type)\n" +
  1025	                    "out['ndp'] = c['MS_1003060_number_of_data_points']\n" +
  1026	                    "out['dpr_null'] = c['data_processing_ref'] is None\n" +
  1027	                    "out['params_empty'] = c['parameters'] == []\n" +
  1028	                    "out['aux_empty'] = c['auxiliary_arrays'] == []\n" +
  1029	                    "out['naux'] = int(c['number_of_auxiliary_arrays'])\n" +
  1030	                    "out['aux_fields'] = [f.name for f in aux]\n" +
  1031	                    "out['prec_in_schema'] = 'precursor' in [f.name for f in t.schema]\n" +
  1032	                    "out['seli_in_schema'] = 'selected_ion' in [f.name for f in t.schema]\n" +
  1033	                    "out['prec_null'] = d[0]['precursor'] is None or d[0]['precursor']['source_index'] is None\n" +
  1034	                    "out['seli_null'] = d[0]['selected_ion'] is None or d[0]['selected_ion']['source_index'] is None\n" +
  1035	                    "selt = t.schema.field('selected_ion').type\n" +
  1036	                    "out['seli_fields'] = [f.name for f in selt]\n" +
  1037	                    "print(json.dumps(out))\n";
  1038	                var o = PyArrowEntry(archive, "chromatograms_metadata.parquet", snippet);
  1039	
  1040	                Assert.That((int)o["rows"], Is.EqualTo(1), "exactly one chromatogram row");
  1041	                Assert.That((string)o["id"], Is.EqualTo("TIC"));
  1042	                Assert.That((string)o["type"], Is.EqualTo("MS:1000235"));
  1043	                Assert.That((int)o["pol"], Is.EqualTo(0));
  1044	                Assert.That((string)o["pol_type"], Is.EqualTo("int8"));
  1045	                Assert.That((long)o["ndp"], Is.EqualTo((long)n));
  1046	                Assert.That((bool)o["dpr_null"], Is.True);
  1047	                Assert.That((bool)o["params_empty"], Is.True);
  1048	                Assert.That((bool)o["aux_empty"], Is.True);
  1049	                Assert.That((int)o["naux"], Is.EqualTo(0));
  1050	
  1051	                var auxFields = o["aux_fields"].Select(x => (string)x).ToArray();
  1052	                foreach (var f in new[] { "data", "name", "data_type", "compression", "unit", "parameters", "data_processing_ref" })
  1053	                    Assert.That(auxFields, Does.Contain(f), $"AUX_ARRAY element exposes {f}");
  1054	
  1055	                Assert.That((bool)o["prec_in_schema"], Is.True);
  1056	                Assert.That((bool)o["seli_in_schema"], Is.True);
  1057	                Assert.That((bool)o["prec_null"], Is.True, "precursor present-but-null on the row");
  1058	                Assert.That((bool)o["seli_null"], Is.True, "selected_ion present-but-null on the row");
  1059	
  1060	                // The chromatogram selected_ion struct must carry the same ground-truth columns as the
  1061	                // spectra selected_ion, including the ion-mobility columns and the parameters list.
  1062	                var seliFields = o["seli_fields"].Select(x => (string)x).ToArray();
  1063	                foreach (var f in new[]
  1064	                {
  1065	                    "source_index", "precursor_index", "MS_1000744_selected_ion_mz_unit_MS_1000040",
  1066	                    "MS_1000041_charge_state", "MS_1000042_intensity_unit_MS_1000131",
  1067	                    "ion_mobility_value", "ion_mobility_type", "parameters"
  1068	                })
  1069	                    Assert.That(seliFields, Does.Contain(f), $"chromatogram selected_ion exposes {f}");
  1070	            }
  1071	            finally
  1072	            {
  1073	                Directory.Delete(dir, true);
  1074	            }
  1075	        }
