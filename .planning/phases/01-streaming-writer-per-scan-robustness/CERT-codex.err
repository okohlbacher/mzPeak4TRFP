   559	        [Test]
   560	        public void Metadata_MS2Only_KeepsPrecursor_NullParent_NoSwap()
   561	        {
   562	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak)
   563	            {
   564	                MsLevel = new HashSet<int> { 2 }
   565	            };
   566	            var dir = Convert(input, out var archive);
   567	            try
   568	            {
   569	                var snippet =
   570	                    "import pyarrow.parquet as pq, json\n" +
   571	                    "t = pq.read_table(r'{PARQUET}')\n" +
   572	                    "d = t.to_pylist()\n" +
   573	                    "N = len(d)\n" +
   574	                    "pp = [d[i]['precursor'] is not None and d[i]['precursor']['source_index'] is not None for i in range(N)]\n" +
   575	                    "M = sum(pp)\n" +
   576	                    "out = {}\nout['N']=N\nout['M']=M\n" +
   577	                    "out['all_pidx_null'] = all(d[i]['precursor']['precursor_index'] is None for i in range(M))\n" +
   578	                    "out['all_present'] = M==N\n" +
   579	                    "print(json.dumps(out))\n";
   580	                var o = PyArrowMetadata(archive, snippet);
   581	
   582	                Assert.That((int)o["M"], Is.GreaterThan(0), "MS2-only run still emits precursor entries");
   583	                Assert.That((bool)o["all_present"], Is.True, "every emitted spectrum is an MSn -> precursor on all rows");
   584	                Assert.That((bool)o["all_pidx_null"], Is.True,
   585	                    "parent MS1 filtered out -> precursor_index null, entry kept, no swap");
   586	            }
   587	            finally
   588	            {
   589	                Directory.Delete(dir, true);
   590	            }
   591	        }
   592	
   593	        // Every MS_/UO_/IMS_ CV code embedded in any column name across the metadata schema, as the
   594	        // validator's cv_list_declared rule collects them.
   595	        private static HashSet<string> CollectedCvCodes(byte[] metaBytes)
   596	        {
   597	            var codes = new HashSet<string>();
   598	            using (var ms = new MemoryStream(metaBytes))
   599	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   600	            {
   601	                foreach (var d in reader.Schema.GetDataFields())
   602	                {
   603	                    foreach (System.Text.RegularExpressions.Match mch in
   604	                        System.Text.RegularExpressions.Regex.Matches(d.Path.ToString(), @"(MS|UO|IMS)_\d+"))
   605	                    {
   606	                        codes.Add(mch.Groups[1].Value);
   607	                    }
   608	                }
   609	            }
   610	            return codes;
   611	        }
   612	
   613	        // Recursively walk an arbitrary JSON tree and collect the ontology prefix of every CURIE that
   614	        // appears as a value of an "accession" or "unit" key (e.g. "MS:1000133" -> "MS"). This reaches
   615	        // every PARAM list element, component, file_description, run, and nested block alike.
   616	        private static void CollectCuriePrefixes(JToken node, HashSet<string> into)
   617	        {
   618	            if (node is JObject obj)
   619	            {
   620	                foreach (var prop in obj.Properties())
   621	                {
   622	                    if ((prop.Name == "accession" || prop.Name == "unit") &&
   623	                        prop.Value.Type == JTokenType.String)
   624	                    {
   625	                        var mch = System.Text.RegularExpressions.Regex.Match(
   626	                            (string)prop.Value, @"^(MS|UO|IMS):\d+$");
   627	                        if (mch.Success) into.Add(mch.Groups[1].Value);
   628	                    }
   629	                    CollectCuriePrefixes(prop.Value, into);
   630	                }
   631	            }
   632	            else if (node is JArray arr)
   633	            {
   634	                foreach (var item in arr) CollectCuriePrefixes(item, into);
   635	            }
   636	        }
   637	
   638	        // The authoritative collected set: every CURIE prefix used in any metadata block, gathered from
   639	        // BOTH the schema column names AND recursively from every accession/unit in the JSON metadata.
   640	        private static HashSet<string> CollectAllCvPrefixes(byte[] metaBytes, JObject metadataBlocks)
   641	        {
   642	            var codes = CollectedCvCodes(metaBytes);
   643	            CollectCuriePrefixes(metadataBlocks, codes);
   644	            return codes;
   645	        }
   646	
   647	        private static Dictionary<string, string> FooterKv(byte[] metaBytes)
   648	        {
   649	            using (var ms = new MemoryStream(metaBytes))
   650	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   651	            {
   652	                return new Dictionary<string, string>(reader.CustomMetadata);
   653	            }
   654	        }
   655	
   656	        [Test]
   657	        public void Metadata_ListLeaf_Paths_Are_Canonical_Item_And_CvValues()
   658	        {
   659	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   660	            var dir = Convert(input, out var archive);
   661	            try
   662	            {
   663	                var metaBytes = ReadEntry(archive, "spectra_metadata.parquet");
   664	                using (var ms = new MemoryStream(metaBytes))
   665	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   666	                {
   667	                    var paths = reader.Schema.GetDataFields().Select(d => d.Path.ToString()).ToHashSet();
   668	
   669	                    // Canonical list-element leaf path is ".../list/item/...", not a flat column.
   670	                    Assert.That(paths.Any(p => p.StartsWith("spectrum/parameters/list/item/")), Is.True,
   671	                        "spectrum.parameters leaves sit under .../list/item/");
   672	                    Assert.That(paths, Does.Contain(
   673	                        "scan/scan_windows/list/item/MS_1000501_scan_window_lower_limit_unit_MS_1000040"));
   674	                    Assert.That(paths, Does.Contain(
   675	                        "scan/scan_windows/list/item/MS_1000500_scan_window_upper_limit_unit_MS_1000040"));
   676	                    Assert.That(paths.Any(p => p.StartsWith("precursor/activation/parameters/list/item/")), Is.True);
   677	                    Assert.That(paths, Does.Contain(
   678	                        "selected_ion/MS_1000744_selected_ion_mz_unit_MS_1000040"));
   679	                    Assert.That(paths, Does.Contain("selected_ion/MS_1000041_charge_state"));
   680	                    Assert.That(paths, Does.Contain(
   681	                        "precursor/isolation_window/MS_1000827_isolation_window_target_mz"),
   682	                        "isolation_window_target_mz carries no unit suffix");
   683	
   684	                    // Ground-truth selected_ion carries ion-mobility columns and a parameters list even
   685	                    // when the source has no mobility values; the struct shape must match exactly.
   686	                    Assert.That(paths, Does.Contain("selected_ion/ion_mobility_value"));
   687	                    Assert.That(paths, Does.Contain("selected_ion/ion_mobility_type"));
   688	                    Assert.That(paths.Any(p => p.StartsWith("selected_ion/parameters/list/item/")), Is.True,
   689	                        "selected_ion.parameters leaves sit under .../list/item/");
   690	                }
   691	
   692	                // CV values: selected_ion_mz finite/positive on MSn rows; charge_state null on small.RAW.
   693	                var snippet =
   694	                    "import pyarrow.parquet as pq, json\n" +
   695	                    "t = pq.read_table(r'{PARQUET}')\n" +
   696	                    "d = t.to_pylist()\n" +
   697	                    "N = len(d)\n" +
   698	                    "M = sum(1 for i in range(N) if d[i]['selected_ion'] is not None and d[i]['selected_ion']['source_index'] is not None)\n" +
   699	                    "out = {}\n" +
   700	                    "out['sel_mz_pos'] = all(d[i]['selected_ion']['MS_1000744_selected_ion_mz_unit_MS_1000040'] > 0 for i in range(M))\n" +
   701	                    "out['charge_all_null'] = all(d[i]['selected_ion']['MS_1000041_charge_state'] is None for i in range(M))\n" +
   702	                    "out['iso_target_pos'] = all(d[i]['precursor']['isolation_window']['MS_1000827_isolation_window_target_mz'] > 0 for i in range(M))\n" +
   703	                    "out['im_value_null'] = all(d[i]['selected_ion']['ion_mobility_value'] is None for i in range(M))\n" +
   704	                    "out['im_type_null'] = all(d[i]['selected_ion']['ion_mobility_type'] is None for i in range(M))\n" +
   705	                    "out['sel_params_empty'] = all(d[i]['selected_ion']['parameters'] == [] for i in range(M))\n" +
   706	                    "print(json.dumps(out))\n";
   707	                var o = PyArrowMetadata(archive, snippet);
   708	                Assert.That((bool)o["sel_mz_pos"], Is.True, "selected_ion_mz positive on every MSn row");
   709	                Assert.That((bool)o["charge_all_null"], Is.True, "small.RAW has no Charge State trailer");
   710	                Assert.That((bool)o["iso_target_pos"], Is.True, "isolation target positive on every MSn row");
   711	                Assert.That((bool)o["im_value_null"], Is.True, "ion_mobility_value null on every MSn row");
   712	                Assert.That((bool)o["im_type_null"], Is.True, "ion_mobility_type null on every MSn row");
   713	                Assert.That((bool)o["sel_params_empty"], Is.True, "selected_ion.parameters empty on every MSn row");
   714	            }
   715	            finally
   716	            {
   717	                Directory.Delete(dir, true);
   718	            }
   719	        }
