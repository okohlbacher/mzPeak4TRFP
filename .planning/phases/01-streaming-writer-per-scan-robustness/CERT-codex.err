  1228	        private static void AddListLeaf(List<MzPeakParquet.LeafRow> rows, List<string> vals, DataField leaf,
  1229	            List<Param> items, Func<Param, string> sel)
  1230	        {
  1231	            var levels = new int[items.Count];
  1232	            var has = new bool[items.Count];
  1233	            for (int i = 0; i < items.Count; i++)
  1234	            {
  1235	                var v = sel(items[i]);
  1236	                if (v != null) { vals.Add(v); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1237	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1238	            }
  1239	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1240	        }
