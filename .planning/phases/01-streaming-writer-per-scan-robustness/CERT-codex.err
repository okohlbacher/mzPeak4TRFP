    75	        [Test]
    76	        public void RoundTrip_NestedStruct_ListOfStruct_ParallelNullableTopLevel()
    77	        {
    78	            var mzRange = new StructField("mz_range",
    79	                new DataField<double>("lo"), new DataField<double>("hi"));
    80	            var paramItem = new StructField("item",
    81	                new DataField<string>("name"), new DataField<double>("val", true));
    82	            var paramsList = new ListField("parameters", paramItem);
    83	            var spectrum = new StructField("spectrum",
    84	                new DataField<ulong>("index"), mzRange, paramsList);
    85	            var scan = new StructField("scan",
    86	                new DataField<ulong>("source_index"), new DataField<float>("rt"));
    87	            var schema = new ParquetSchema(spectrum, scan);
    88	
    89	            var cols = new Dictionary<DataField, (Array, int[], int[])>
    90	            {
    91	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 10, 11 }, new[] { 1, 0, 1 }, null),
    92	                [Leaf(schema, "spectrum/mz_range/lo")] = (new[] { 100.5, 50.0 }, new[] { 2, 0, 2 }, null),
    93	                [Leaf(schema, "spectrum/mz_range/hi")] = (new[] { 2000.0, 60.0 }, new[] { 2, 0, 2 }, null),
    94	                [Leaf(schema, "spectrum/parameters/list/item/name")] =
    95	                    (new[] { "a", "b" }, new[] { 5, 5, 0, 2 }, new[] { 0, 1, 0, 0 }),
    96	                [Leaf(schema, "spectrum/parameters/list/item/val")] =
    97	                    (new[] { 1.5 }, new[] { 5, 4, 0, 2 }, new[] { 0, 1, 0, 0 }),
    98	                [Leaf(schema, "scan/source_index")] = (new ulong[] { 10 }, new[] { 0, 1, 0 }, null),
    99	                [Leaf(schema, "scan/rt")] = (new[] { 1.23f }, new[] { 0, 1, 0 }, null)
   100	            };
   101	
   102	            var ms = new MemoryStream();
   103	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string> { ["k"] = "v" },
   104	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   105	
   106	            ms.Position = 0;
   107	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   108	            {
   109	                var rg = reader.OpenRowGroupReader(0);
   110	
   111	                // On read, Data holds only the defined values; nulls live in DefinitionLevels.
   112	                var indexCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result;
   113	                Assert.That(indexCol.Data, Is.EqualTo(new ulong[] { 10, 11 }));
   114	                Assert.That(indexCol.DefinitionLevels, Is.EqualTo(new[] { 1, 0, 1 }));
   115	
   116	                var loCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/mz_range/lo")).Result;
   117	                Assert.That(loCol.Data, Is.EqualTo(new[] { 100.5, 50.0 }));
   118	                Assert.That(loCol.DefinitionLevels, Is.EqualTo(new[] { 2, 0, 2 }));
   119	
   120	                var scanCol = rg.ReadColumnAsync(Leaf(schema, "scan/source_index")).Result;
   121	                Assert.That(scanCol.Data, Is.EqualTo(new ulong[] { 10 }));
   122	                Assert.That(scanCol.DefinitionLevels, Is.EqualTo(new[] { 0, 1, 0 }));
   123	
   124	                // list-of-struct: 2 items in row0 (second val null), empty list in row2.
   125	                // String leaves read back with nulls embedded inline; def levels are the lock.
   126	                var nameCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/parameters/list/item/name")).Result;
   127	                Assert.That(nameCol.Data, Is.EqualTo(new[] { "a", "b", null, null }));
   128	                Assert.That(nameCol.DefinitionLevels, Is.EqualTo(new[] { 5, 5, 0, 2 }));
   129	                Assert.That(nameCol.RepetitionLevels, Is.EqualTo(new[] { 0, 1, 0, 0 }));
   130	
   131	                // val is an explicitly-nullable leaf; it reads back with nulls embedded inline.
   132	                var valCol = rg.ReadColumnAsync(Leaf(schema, "spectrum/parameters/list/item/val")).Result;
   133	                Assert.That(valCol.Data, Is.EqualTo(new double?[] { 1.5, null, null, null }));
   134	                Assert.That(valCol.DefinitionLevels, Is.EqualTo(new[] { 5, 4, 0, 2 }));
   135	            }
   136	        }
