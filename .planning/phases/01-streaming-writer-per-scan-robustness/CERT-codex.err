   873	        private static string ResolveValidator()
   874	        {
   875	            foreach (var cand in new[] { "mzpeak-validate" })
   876	            {
   877	                try
   878	                {
   879	                    var psi = new ProcessStartInfo(cand, "--help")
   880	                    {
   881	                        RedirectStandardOutput = true,
   882	                        RedirectStandardError = true,
   883	                        UseShellExecute = false
   884	                    };
   885	                    using (var p = Process.Start(psi))
   886	                    {
   887	                        p.WaitForExit();
   888	                        return cand;
   889	                    }
   890	                }
   891	                catch { }
   892	            }
   893	            return null;
   894	        }
   895	
   896	        [Test]
   897	        public void Validator_Gate_ScanError_And_CvList_Absent_NoNewError()
   898	        {
   899	            var validator = ResolveValidator();
   900	            if (validator == null) Assert.Ignore("mzpeak-validate not available");
   901	
   902	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   903	            var dir = Convert(input, out var archive);
   904	            var jsonPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".json");
   905	            try
   906	            {
   907	                var psi = new ProcessStartInfo(validator, $"\"{archive}\" --json \"{jsonPath}\"")
   908	                {
   909	                    RedirectStandardOutput = true,
   910	                    RedirectStandardError = true,
   911	                    UseShellExecute = false
   912	                };
   913	                using (var p = Process.Start(psi))
   914	                {
   915	                    p.StandardOutput.ReadToEnd();
   916	                    p.StandardError.ReadToEnd();
   917	                    p.WaitForExit();
   918	                }
   919	
   920	                Assert.That(File.Exists(jsonPath), "validator must emit a JSON report");
   921	                var report = JObject.Parse(File.ReadAllText(jsonPath));
   922	                var errorIds = ((JArray)report["findings"])
   923	                    .Where(f => (string)f["level"] == "error")
   924	                    .Select(f => (string)f["ruleId"])
   925	                    .ToHashSet();
   926	
   927	                // The pre-existing reference-archive failures; our writer introduces none of them.
   928	                var allowlist = new HashSet<string> { "index_schema_valid", "cv_list_declared" };
   929	
   930	                Assert.That(errorIds, Does.Not.Contain("columns_spectra_metadata"),
   931	                    "scan-facet error must be cleared");
   932	                Assert.That(errorIds, Does.Not.Contain("cv_list_declared"),
   933	                    "cv_list_declared must be cleared by the generated cv_list");
   934	                var newErrors = errorIds.Except(allowlist).ToArray();
   935	                Assert.That(newErrors, Is.Empty,
   936	                    $"no new ERROR id beyond the pre-existing allowlist: {string.Join(",", newErrors)}");
   937	            }
   938	            finally
   939	            {
   940	                if (File.Exists(jsonPath)) File.Delete(jsonPath);
   941	                Directory.Delete(dir, true);
   942	            }
   943	        }
