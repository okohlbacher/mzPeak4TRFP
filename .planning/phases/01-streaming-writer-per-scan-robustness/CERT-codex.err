   164	        [Test]
   165	        public void TestMzml()
   166	        {
   167	            // Get temp path for writing the test mzML
   168	            var tempFilePath = Path.GetTempPath();
   169	
   170	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
   171	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.MzML);
   172	
   173	            RawFileParser.Parse(parseInput);
   174	
   175	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   176	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   177	
   178	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mzML")));
   179	            // Deserialize the mzML file
   180	            using (var fs = new FileStream(Path.Combine(tempFilePath, "small.mzML"), FileMode.Open,
   181	                FileAccess.Read, FileShare.ReadWrite))
   182	            {
   183	                var xmlSerializer = new XmlSerializer(typeof(mzMLType));
   184	                var testMzMl = (mzMLType)xmlSerializer.Deserialize(fs);
   185	
   186	                Assert.That(testMzMl.run.spectrumList.count, Is.EqualTo("48"));
   187	                Assert.That(testMzMl.run.spectrumList.spectrum.Length, Is.EqualTo(48));
   188	
   189	                Assert.That(testMzMl.run.chromatogramList.count, Is.EqualTo("1"));
   190	                Assert.That(testMzMl.run.chromatogramList.chromatogram.Length, Is.EqualTo(1));
   191	
   192	                Assert.That(testMzMl.run.chromatogramList.chromatogram[0].defaultArrayLength, Is.EqualTo(48));
   193	
   194	                Assert.That(testMzMl.run.spectrumList.spectrum[0].binaryDataArrayList.count, Is.EqualTo("2"));
   195	                Assert.That(testMzMl.run.spectrumList.spectrum[0].binaryDataArrayList.binaryDataArray.Length, Is.EqualTo(2));
   196	                //test that the m/z array is present
   197	                Assert.That(testMzMl.run.spectrumList.spectrum[0].binaryDataArrayList.binaryDataArray.Any(a => a.cvParam.Any(c => c.accession == "MS:1000514")));
   198	                //test that the intensity array is present
   199	                Assert.That(testMzMl.run.spectrumList.spectrum[0].binaryDataArrayList.binaryDataArray.Any(a => a.cvParam.Any(c => c.accession == "MS:1000515")));
   200	            }
   201	
   202	            File.Delete(Path.Combine(tempFilePath, "small.mzML"));
   203	        }
