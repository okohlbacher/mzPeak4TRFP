   140	        /// <summary>
   141	        /// Calculate the selected ion m/z value. This is necessary because the precursor mass found in the reaction
   142	        /// isn't always the monoisotopic mass.
   143	        /// https://github.com/ProteoWizard/pwiz/blob/master/pwiz/data/vendor_readers/Thermo/SpectrumList_Thermo.cpp#L564-L574
   144	        /// </summary>
   145	        /// <param name="reaction">the scan event reaction</param>
   146	        /// <param name="monoisotopicMz">the monoisotopic m/z value</param>
   147	        /// <param name="isolationWidth">the scan event reaction</param>
   148	        public static double CalculateSelectedIonMz(IReaction reaction, double? monoisotopicMz,
   149	            double? isolationWidth)
   150	        {
   151	            var selectedIonMz = reaction.PrecursorMass;
   152	
   153	            // take the isolation width from the reaction if no value was found in the trailer data
   154	            if (isolationWidth == null || isolationWidth < ZeroDelta)
   155	            {
   156	                isolationWidth = reaction.IsolationWidth;
   157	            }
   158	
   159	            isolationWidth /= 2;
   160	
   161	            if (monoisotopicMz != null && monoisotopicMz > ZeroDelta
   162	                                       && Math.Abs(
   163	                                           reaction.PrecursorMass - monoisotopicMz.Value) >
   164	                                       PrecursorMzDelta)
   165	            {
   166	                selectedIonMz = monoisotopicMz.Value;
   167	
   168	                // check if the monoisotopic mass lies in the precursor mass isolation window
   169	                // otherwise take the precursor mass                                    
   170	                if (isolationWidth <= 2.0)
   171	                {
   172	                    if ((selectedIonMz <
   173	                         (reaction.PrecursorMass - DefaultIsolationWindowLowerOffset * 2)) ||
   174	                        (selectedIonMz >
   175	                         (reaction.PrecursorMass + DefaultIsolationWindowUpperOffset)))
   176	                    {
   177	                        selectedIonMz = reaction.PrecursorMass;
   178	                    }
   179	                }
   180	                else if ((selectedIonMz < (reaction.PrecursorMass - isolationWidth)) ||
   181	                         (selectedIonMz > (reaction.PrecursorMass + isolationWidth)))
   182	                {
   183	                    selectedIonMz = reaction.PrecursorMass;
   184	                }
   185	            }
   186	
   187	            return selectedIonMz;
   188	        }
   189	
   190	        public static IReaction GetReaction(IScanEvent scanEvent, int scanNumber)
   191	        {
   192	            IReaction reaction = null;
   193	            try
   194	            {
   195	                var order = (int)scanEvent.MSOrder;
   196	                if (order < 0)
   197	                {
   198	                    reaction = scanEvent.GetReaction(0);
   199	                }
   200	                else if (order > 1)
   201	                {
   202	                    reaction = scanEvent.GetReaction(order - 2);
   203	                }
   204	                else
   205	                {
   206	                    Log.Warn($"Attempting to get reaction for MS{order} scan# {scanNumber} failed");
   207	                }
   208	                    
   209	            }
   210	            catch (ArgumentOutOfRangeException)
   211	            {
   212	                Log.Warn("No reaction found for scan " + scanNumber);
   213	            }
   214	
   215	            return reaction;
   216	        }
