  1154	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
  1155	            var padded = new List<List<Param>>();
  1156	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
  1157	            AddParamList(cols, schema, listPath, padded, structPresent);
  1158	        }
