  1149	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
  1150	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1151	            string listPath, int n, List<List<Param>> perRow)
  1152	        {
