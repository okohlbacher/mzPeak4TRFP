    77	        /// <param name="extension">The extension of the output file</param>
    78	        protected void ConfigureWriter(string extension)
    79	        {
    80	            if (ParseInput.StdOut)
    81	            {
    82	                Writer = new StreamWriter(Console.OpenStandardOutput());
    83	                Writer.AutoFlush = true;
    84	                return;
    85	            }
    86	
    87	            var fileName = NormalizeFileName(ParseInput.OutputFile, extension, ParseInput.Gzip);
    88	            if (ParseInput.OutputFormat == OutputFormat.Parquet ||
    89	                ParseInput.OutputFormat == OutputFormat.MzPeak)
    90	            {
    91	                Writer = new StreamWriter(File.Create(fileName));
    92	            }
    93	            else if (!ParseInput.Gzip || ParseInput.OutputFormat == OutputFormat.IndexMzML)
    94	            {
    95	                Writer = File.CreateText(fileName);
    96	            }
    97	            else
    98	            {
    99	                var fileStream = File.Create(fileName);
   100	                var compress = new GZipStream(fileStream, CompressionMode.Compress);
   101	                Writer = new StreamWriter(compress);
   102	            }
   103	
   104	        }
