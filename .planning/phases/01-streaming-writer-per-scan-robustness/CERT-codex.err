  1340	
  1341	        // Standard-library mzML decoder: yields per-spectrum (mz, intensity) f64 arrays, decoding each
  1342	        // binaryDataArray per its own precision (32/64-bit float) and compression (zlib/none) CV flags.
  1343	        private const string DecodeMzmlScript =
  1344	            "import sys, json, base64, zlib, struct\n" +
  1345	            "import xml.etree.ElementTree as ET\n" +
  1346	            "path = sys.argv[1]\n" +
  1347	            "ns = {'m': 'http://psi.hupo.org/ms/mzml'}\n" +
  1348	            "tree = ET.parse(path); root = tree.getroot()\n" +
  1349	            "def localname(t):\n" +
  1350	            "    return t.rsplit('}', 1)[-1]\n" +
  1351	            "def decode_array(bda):\n" +
  1352	            "    accs = set()\n" +
  1353	            "    for cv in bda:\n" +
  1354	            "        if localname(cv.tag) == 'cvParam': accs.add(cv.get('accession'))\n" +
  1355	            "    bits = 64 if 'MS:1000523' in accs else (32 if 'MS:1000521' in accs else 64)\n" +
  1356	            "    zipped = 'MS:1000574' in accs\n" +
  1357	            "    is_mz = 'MS:1000514' in accs\n" +
  1358	            "    is_int = 'MS:1000515' in accs\n" +
  1359	            "    b64 = None\n" +
  1360	            "    for c in bda:\n" +
  1361	            "        if localname(c.tag) == 'binary': b64 = c.text or ''\n" +
  1362	            "    raw = base64.b64decode(b64) if b64 else b''\n" +
  1363	            "    if zipped and raw: raw = zlib.decompress(raw)\n" +
  1364	            "    fmt = ('<%dd' % (len(raw)//8)) if bits == 64 else ('<%df' % (len(raw)//4))\n" +
  1365	            "    vals = list(struct.unpack(fmt, raw)) if raw else []\n" +
  1366	            "    return is_mz, is_int, vals\n" +
  1367	            "spectra = []\n" +
  1368	            "for sp in root.iter():\n" +
  1369	            "    if localname(sp.tag) != 'spectrum': continue\n" +
  1370	            "    mz, inten = [], []\n" +
  1371	            "    for bda in sp.iter():\n" +
  1372	            "        if localname(bda.tag) != 'binaryDataArray': continue\n" +
  1373	            "        is_mz, is_int, vals = decode_array(bda)\n" +
  1374	            "        if is_mz: mz = vals\n" +
  1375	            "        elif is_int: inten = vals\n" +
  1376	            "    spectra.append({'mz': mz, 'intensity': inten})\n" +
  1377	            "print(json.dumps({'spectra': spectra}))\n";
  1378	
