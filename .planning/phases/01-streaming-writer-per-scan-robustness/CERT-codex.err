   210	        [Test]
   211	        public void MsLevelFilter_Excludes_FilteredOut_Spectra()
   212	        {
   213	            var fullInput = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   214	            var fullDir = Convert(fullInput, out var fullArchive);
   215	            int fullSpectra, fullRows;
   216	            try
   217	            {
   218	                var f = ReadPointFacet(ReadEntry(fullArchive, "spectra_data.parquet"));
   219	                fullSpectra = f.SpectrumCount;
   220	                fullRows = f.PointCount;
   221	            }
   222	            finally
   223	            {
   224	                Directory.Delete(fullDir, true);
   225	            }
   226	
   227	            var ms2Input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak)
   228	            {
   229	                MsLevel = new HashSet<int> { 2 }
   230	            };
   231	            var ms2Dir = Convert(ms2Input, out var ms2Archive);
   232	            try
   233	            {
   234	                var f = ReadPointFacet(ReadEntry(ms2Archive, "spectra_data.parquet"));
   235	                Assert.That(f.SpectrumCount, Is.GreaterThan(0));
   236	                Assert.That(f.SpectrumCount, Is.LessThan(fullSpectra),
   237	                    "MS2-only run must contain fewer spectra than the unfiltered run");
   238	                Assert.That(f.PointCount, Is.LessThan(fullRows),
   239	                    "MS2-only run must contain fewer rows than the unfiltered run");
   240	
   241	                var meta = ReadEntry(ms2Archive, "spectra_metadata.parquet");
   242	                var mf = ReadMetadataIndices(meta);
   243	                Assert.That(mf.Length, Is.EqualTo(f.SpectrumCount));
   244	            }
   245	            finally
   246	            {
   247	                Directory.Delete(ms2Dir, true);
   248	            }
   249	        }
   250	
   251	        private static ulong[] ReadMetadataIndices(byte[] bytes)
   252	        {
   253	            using (var ms = new MemoryStream(bytes))
   254	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   255	            {
   256	                var schema = reader.Schema;
   257	                var rg = reader.OpenRowGroupReader(0);
   258	                return rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result.Data
   259	                    .Cast<ulong>().ToArray();
   260	            }
   261	        }
