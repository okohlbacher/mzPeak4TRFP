   856	        private byte[] BuildMetadataFacet(List<Record> records)
   857	        {
   858	            int n = records.Count;
   859	
   860	            var spectrum = BuildSpectrumField();
   861	            var scan = BuildScanField();
   862	            var precursor = BuildPrecursorField();
   863	            var selectedIon = BuildSelectedIonField();
   864	            var schema = new ParquetSchema(spectrum, scan, precursor, selectedIon);
   865	
   866	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
   867	            var presentAll = records.Select(_ => true).ToArray();
   868	
   869	            // precursor / selected_ion are independent tables: the k-th MSn (ascending ordinal) sits
   870	            // at row k, null-padded on rows M..N-1.
   871	            var msnRecords = records.Where(r => r.IsMsn).OrderBy(r => r.Ordinal).ToList();
   872	
   873	            // spectrum facet (present on all N rows)
   874	            AddScalar(cols, schema, "spectrum/index", records.Select(r => r.Ordinal).ToArray(), presentAll);
   875	            AddScalar(cols, schema, "spectrum/id", records.Select(r => r.Id).ToArray(), presentAll);
   876	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000511", "ms_level"),
   877	                records.Select(r => (byte)r.MsLevel).ToArray(), presentAll);
   878	            AddScalar(cols, schema, "spectrum/time", records.Select(r => r.Time).ToArray(), presentAll);
   879	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000465", "scan_polarity"),
   880	                records.Select(r => r.Polarity).ToArray(), presentAll);
   881	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000525", "spectrum_representation"),
   882	                records.Select(r => r.Representation).ToArray(), presentAll);
   883	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000559", "spectrum_type"),
   884	                records.Select(r => r.SpectrumType).ToArray(), presentAll);
   885	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"),
   886	                records.Select(r => r.LowestMz).ToArray(), presentAll);
   887	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000527", "highest_observed_mz", "MS:1000040"),
   888	                records.Select(r => r.HighestMz).ToArray(), presentAll);
   889	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1003060", "number_of_data_points"),
   890	                records.Select(r => r.DataPointCount).ToArray(), presentAll);
   891	
   892	            // number_of_peaks: present only where peaks were written (leaf-null otherwise).
   893	            var npkLeaf = Leaf(schema, "spectrum/" + Cv("MS:1003059", "number_of_peaks"));
   894	            var npkRows = records.Select(r => r.PeakCount.HasValue
   895	                ? MzPeakParquet.Present(npkLeaf)
   896	                : MzPeakParquet.AtLevel(npkLeaf.MaxDefinitionLevel - 1, false)).ToArray();
   897	            var (npkDef, _) = MzPeakParquet.NestedLevels(npkLeaf, npkRows);
   898	            cols[npkLeaf] = (records.Where(r => r.PeakCount.HasValue).Select(r => r.PeakCount.Value).ToArray(), npkDef, null);
   899	
   900	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000504", "base_peak_mz", "MS:1000040"),
   901	                records.Select(r => r.BasePeakMz).ToArray(), presentAll);
   902	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000505", "base_peak_intensity", "MS:1000131"),
   903	                records.Select(r => r.BasePeakIntensity).ToArray(), presentAll);
   904	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000285", "total_ion_current", "MS:1000131"),
   905	                records.Select(r => r.TotalIonCurrent).ToArray(), presentAll);
   906	
   907	            AddParamList(cols, schema, "spectrum/parameters", records.Select(r => r.SpectrumParams).ToList(), presentAll);
   908	
   909	            // scan facet (present on all N rows)
   910	            AddScalar(cols, schema, "scan/source_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
   911	            AddScalar(cols, schema, "scan/scan_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
   912	            AddScalar(cols, schema, "scan/" + Cv("MS:1000016", "scan_start_time", "UO:0000031"),
   913	                records.Select(r => r.ScanStartTime).ToArray(), presentAll);
   914	            AddScalar(cols, schema, "scan/" + Cv("MS:1000512", "filter_string"),
   915	                records.Select(r => r.FilterString).ToArray(), presentAll);
   916	            AddScalar(cols, schema, "scan/" + Cv("MS:1000927", "ion_injection_time", "UO:0000028"),
   917	                records.Select(r => r.IonInjectionTime).ToArray(), presentAll);
   918	            AddScalar(cols, schema, "scan/instrument_configuration_ref",
   919	                records.Select(r => r.InstrumentConfigRef).ToArray(), presentAll);
   920	            AddScanWindows(cols, schema, records);
   921	
   922	            // precursor facet (present on rows 0..M-1, null on M..N-1)
   923	            AddMsnScalar(cols, schema, "precursor/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   924	            AddMsnPrecursorIndex(cols, schema, "precursor/precursor_index", n, msnRecords);
   925	            AddMsnString(cols, schema, "precursor/precursor_id", n, msnRecords.Select(r => r.PrecursorId).ToArray());
   926	            AddMsnScalar(cols, schema, "precursor/isolation_window/" + Cv("MS:1000827", "isolation_window_target_mz"),
   927	                n, msnRecords.Select(r => r.IsolationTarget).ToArray());
   928	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"),
   929	                n, msnRecords.Select(r => r.IsolationLowerOffset).ToArray());
   930	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"),
   931	                n, msnRecords.Select(r => r.IsolationUpperOffset).ToArray());
   932	            AddMsnParamList(cols, schema, "precursor/isolation_window/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
   933	            AddMsnParamList(cols, schema, "precursor/activation/parameters", n, msnRecords.Select(r => r.ActivationParams).ToList());
   934	
   935	            // selected_ion facet (present on rows 0..M-1, null on M..N-1)
   936	            AddMsnScalar(cols, schema, "selected_ion/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   937	            AddMsnPrecursorIndex(cols, schema, "selected_ion/precursor_index", n, msnRecords);
   938	            AddMsnScalar(cols, schema, "selected_ion/" + Cv("MS:1000744", "selected_ion_mz", "MS:1000040"),
   939	                n, msnRecords.Select(r => r.SelectedIonMz).ToArray());
   940	            AddMsnNullableInt(cols, schema, "selected_ion/" + Cv("MS:1000041", "charge_state"),
   941	                n, msnRecords.Select(r => r.ChargeState).ToArray());
   942	            AddMsnNullableFloat(cols, schema, "selected_ion/" + Cv("MS:1000042", "intensity", "MS:1000131"),
   943	                n, msnRecords.Select(r => r.SelectedIonIntensity).ToArray());
   944	
   945	            // Ion-mobility columns exist to match the ground-truth struct shape; the Thermo RAW path
   946	            // carries no per-selected-ion mobility value, so they stay leaf-null on every MSn row.
   947	            AddMsnNullableDouble(cols, schema, "selected_ion/ion_mobility_value", n, msnRecords.Select(_ => (double?)null).ToArray());
   948	            AddMsnString(cols, schema, "selected_ion/ion_mobility_type", n, msnRecords.Select(_ => (string)null).ToArray());
   949	            AddMsnParamList(cols, schema, "selected_ion/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
   950	
   951	            var custom = new Dictionary<string, string>
   952	            {
   953	                ["spectrum_count"] = n.ToString(),
   954	                ["spectrum_data_point_count"] = "0",
   955	                ["spectrum_array_index"] = SpectrumArrayIndex
   956	            };
   957	            AddMetadataBlocks(custom, records);
   958	
   959	            return WriteFacet(schema, custom, cols);
   960	        }
