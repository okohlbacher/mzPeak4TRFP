   127	        [Test]
   128	        public void TestFolderMgfs()
   129	        {
   130	            // Get temp path for writing the test MGF
   131	            var tempInPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
   132	            var tempOutPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
   133	
   134	            Directory.CreateDirectory(tempInPath);
   135	            Directory.CreateDirectory(tempOutPath);
   136	
   137	            File.Copy(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW"), Path.Combine(tempInPath, "small.RAW"));
   138	            File.Copy(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small2.RAW"), Path.Combine(tempInPath, "small2.RAW"));
   139	            File.Create(Path.Combine(tempInPath, "Not_raw_file")).Close(); // Create an empty file to test handling of multiple files
   140	
   141	            var parseInput = new ParseInput(null, tempInPath, tempOutPath, OutputFormat.MGF);
   142	
   143	            RawFileParser.Parse(parseInput);
   144	
   145	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   146	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   147	
   148	            var numFiles = Directory.GetFiles(tempOutPath, "*.mgf");
   149	            Assert.That(numFiles.Length, Is.EqualTo(2));
   150	
   151	            AssertMgfSpectra(Path.Combine(tempOutPath, "small.mgf"), 34);
   152	            AssertMgfSpectra(Path.Combine(tempOutPath, "small2.mgf"), 49);
   153	
   154	            Directory.Delete(tempInPath, true);
   155	            Directory.Delete(tempOutPath, true);
   156	        }
   157	
   158	        private static void AssertMgfSpectra(string mgfPath, int expected)
   159	        {
   160	            var count = File.ReadLines(mgfPath).Count(l => l.Trim() == "BEGIN IONS");
   161	            Assert.That(count, Is.EqualTo(expected));
   162	        }
