   605	        private static Array EmptyArray(Type clr) => Array.CreateInstance(clr, 0);
   606	
   607	        private uint AnalyzerIndex(MassAnalyzerType analyzer, IonizationModeType ionization)
   608	        {
   609	            int idx = _analyzerOrder.IndexOf(analyzer);
   610	            if (idx < 0)
   611	            {
   612	                _analyzerOrder.Add(analyzer);
   613	                _ionizationOrder.Add(ionization);
   614	                idx = _analyzerOrder.Count - 1;
   615	            }
   616	            return (uint)idx;
   617	        }
   618	
   619	        private void BuildPrecursor(IRawDataPlus raw, int scanNumber, IScanEvent scanEvent,
   620	            IScanFilter scanFilter, ScanTrailer trailer, IDictionary<int, ulong> scanNumberToOrdinal,
   621	            string filterKey, Record rec)
   622	        {
   623	            rec.IsMsn = true;
   624	
   625	            // Parent scan via Master Scan Number trailer, falling back to the scan-string parent the
   626	            // mzML path derives. Map the parent scan number to its emitted ordinal; if the parent was
   627	            // filtered out / not emitted, keep the precursor entry but leave precursor_index null.
   628	            int parentScan;
   629	            var master = trailer.AsPositiveInt("Master Scan Number:");
   630	            if (master.HasValue) parentScan = master.Value;
   631	            else parentScan = GetParentFromScanString(filterKey);
   632	
   633	            if (parentScan > 0 && scanNumberToOrdinal.TryGetValue(parentScan, out var p))
   634	            {
   635	                rec.PrecursorIndex = p;
   636	                rec.PrecursorId = ConstructSpectrumTitle((int)Device.MS, 1, parentScan);
   637	            }
   638	
   639	            var reaction = GetReaction(scanEvent, scanNumber);
   640	            if (reaction == null) return;
   641	
   642	            double? isolationWidth = reaction.IsolationWidth;
   643	            if (isolationWidth < 0) isolationWidth = null;
   644	
   645	            rec.IsolationTarget = (float)reaction.PrecursorMass;
   646	            if (isolationWidth != null)
   647	            {
   648	                var offset = isolationWidth.Value / 2 + reaction.IsolationWidthOffset;
   649	                rec.IsolationLowerOffset = (float)(isolationWidth.Value - offset);
   650	                rec.IsolationUpperOffset = (float)offset;
   651	            }
   652	
   653	            if (OntologyMapping.DissociationTypes.TryGetValue(reaction.ActivationType, out var diss))
   654	            {
   655	                rec.ActivationParams.Add(new Param { Accession = diss.accession, Name = diss.name });
   656	            }
   657	
   658	            if (reaction.CollisionEnergyValid)
   659	            {
   660	                rec.ActivationParams.Add(new Param
   661	                {
   662	                    Accession = "MS:1000045",
   663	                    Name = "collision energy",
   664	                    Float = reaction.CollisionEnergy,
   665	                    Unit = "UO:0000266"
   666	                });
   667	            }
   668	
   669	            int? charge = trailer.AsPositiveInt("Charge State:");
   670	            double? monoisotopicMz = trailer.AsDouble("Monoisotopic M/Z:");
   671	            rec.SelectedIonMz = CalculateSelectedIonMz(reaction, monoisotopicMz, isolationWidth);
   672	            rec.ChargeState = charge;
   673	
   674	            if (rec.SelectedIonMz > ZeroDelta && parentScan > 0)
   675	            {
   676	                rec.SelectedIonIntensity = (float)CalculatePrecursorPeakIntensity(raw, parentScan,
   677	                    reaction.PrecursorMass, isolationWidth,
   678	                    ParseInput.NoPeakPicking.Contains(rec.MsLevel - 1));
   679	            }
   680	        }
