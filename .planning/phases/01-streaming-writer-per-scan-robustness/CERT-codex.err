  1584	        [Test]
  1585	        public void FailedParent_DoesNotPoison_LaterChild_PrecursorResolution()
  1586	        {
  1587	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1588	            var writer = new MzPeakSpectrumWriter(input);
  1589	            var scanToOrdinal = new Dictionary<int, ulong>();
  1590	            ulong ordinal = 0;
  1591	
  1592	            const string parentKey = "FTMS + p NSI Full ms";
  1593	
  1594	            // Scan 10 is an MS1 parent that FAILS after computing its filterKey: the commit is never
  1595	            // applied, so _precursorScanNumbers[parentKey] is NOT written for scan 10.
  1596	            // (No CommitScanForTest call == the skip path.)
  1597	
  1598	            // Scan 20 is a later VALID MS1 parent sharing the same filter prefix: it commits.
  1599	            var parentOrdinal = writer.CommitScanForTest(parentKey, 20, ref ordinal, scanToOrdinal);
  1600	
  1601	            // Scan 30 is an MSn child of that filter prefix: it must resolve to scan 20's ordinal,
  1602	            // never to the skipped scan 10.
  1603	            var resolved = writer.ResolveParentOrdinalForTest(parentKey, scanToOrdinal);
  1604	
  1605	            Assert.That(resolved, Is.EqualTo(parentOrdinal),
  1606	                "child resolves to the later valid parent, not the skipped scan");
  1607	            Assert.That(scanToOrdinal.ContainsKey(10), Is.False,
  1608	                "skipped scan 10 consumed no ordinal");
  1609	            Assert.That(ordinal, Is.EqualTo(1UL), "only the one committed scan advanced the ordinal");
  1610	            Assert.That(scanToOrdinal[20], Is.EqualTo(0UL), "ordinals stay dense from 0");
  1611	        }
