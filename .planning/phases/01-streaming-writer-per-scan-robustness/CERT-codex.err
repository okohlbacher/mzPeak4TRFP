    26	        {
    27	            public ulong[] SpectrumIndex;
    28	            public double[] Mz;
    29	            public float[] Intensity;
    30	            public int SpectrumCount;
    31	            public int PointCount;
    32	        }
    33	
    34	        private static string Convert(ParseInput parseInput, out string archive)
    35	        {
    36	            var dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    37	            Directory.CreateDirectory(dir);
    38	            parseInput.OutputDirectory = dir;
    39	            RawFileParser.Parse(parseInput);
    40	            Assert.That(parseInput.Errors, Is.EqualTo(0));
    41	            archive = Path.Combine(dir, "small.mzpeak");
    42	            Assert.That(File.Exists(archive));
    43	            return dir;
    44	        }
    45	
    46	        private static byte[] ReadEntry(string archive, string name)
    47	        {
    48	            using (var zip = ZipFile.OpenRead(archive))
    49	            {
    50	                var entry = zip.GetEntry(name);
    51	                if (entry == null) return null;
    52	                using (var s = entry.Open())
    53	                using (var ms = new MemoryStream())
    54	                {
    55	                    s.CopyTo(ms);
    56	                    return ms.ToArray();
    57	                }
    58	            }
    59	        }
    60	
    61	        private static Facet ReadPointFacet(byte[] bytes)
    62	        {
    63	            using (var ms = new MemoryStream(bytes))
    64	            using (var reader = ParquetReader.CreateAsync(ms).Result)
    65	            {
    66	                var schema = reader.Schema;
    67	                var rg = reader.OpenRowGroupReader(0);
    68	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data
    69	                    .Cast<ulong>().ToArray();
    70	                var mz = rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data
    71	                    .Cast<double>().ToArray();
    72	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
    73	                    .Cast<float>().ToArray();
    74	                var meta = reader.CustomMetadata;
    75	                return new Facet
    76	                {
    77	                    SpectrumIndex = idx,
    78	                    Mz = mz,
    79	                    Intensity = inten,
    80	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
    81	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
    82	                };
    83	            }
    84	        }
    85	
    86	        private static DataField Leaf(ParquetSchema schema, string path)
    87	        {
    88	            return schema.GetDataFields().First(d => d.Path.ToString() == path);
    89	        }
    90	
    91	        private sealed class ChromFacet
    92	        {
    93	            public ulong[] ChromatogramIndex;
    94	            public double[] Time;
    95	            public float[] Intensity;
    96	            public long[] MsLevel;
    97	            public string TicSource;
    98	            public int PointCount;
    99	        }
   100	
   101	        private static ChromFacet ReadChromFacet(byte[] bytes)
   102	        {
   103	            using (var ms = new MemoryStream(bytes))
   104	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   105	            {
   106	                var schema = reader.Schema;
   107	                var rg = reader.OpenRowGroupReader(0);
   108	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/chromatogram_index")).Result.Data
   109	                    .Cast<ulong>().ToArray();
   110	                var time = rg.ReadColumnAsync(Leaf(schema, "point/time")).Result.Data
   111	                    .Cast<double>().ToArray();
   112	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
   113	                    .Cast<float>().ToArray();
   114	                var lvl = rg.ReadColumnAsync(Leaf(schema, "point/ms_level")).Result.Data
   115	                    .Cast<long>().ToArray();
   116	                var meta = reader.CustomMetadata;
   117	                return new ChromFacet
   118	                {
   119	                    ChromatogramIndex = idx,
   120	                    Time = time,
   121	                    Intensity = inten,
   122	                    MsLevel = lvl,
   123	                    TicSource = meta["chromatogram_tic_source"],
   124	                    PointCount = int.Parse(meta["chromatogram_data_point_count"])
   125	                };
   126	            }
   127	        }
   128	
   129	        // Runs a pyarrow snippet against an arbitrary parquet entry of the archive (the {PARQUET}
   130	        // token is replaced with the temp file path), returning the printed JSON object.
   131	        private static JObject PyArrowEntry(string archive, string entry, string snippet)
   132	        {
   133	            var python = ResolvePython();
   134	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   135	
   136	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   137	            File.WriteAllBytes(path, ReadEntry(archive, entry));
   138	            try
   139	            {
   140	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   141	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   142	                {
   143	                    RedirectStandardOutput = true,
   144	                    RedirectStandardError = true,
   145	                    UseShellExecute = false
   146	                };
   147	                using (var proc = Process.Start(psi))
   148	                {
   149	                    var stdout = proc.StandardOutput.ReadToEnd();
   150	                    var stderr = proc.StandardError.ReadToEnd();
   151	                    proc.WaitForExit();
   152	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   153	                    return JObject.Parse(stdout.Trim());
   154	                }
   155	            }
   156	            finally
   157	            {
   158	                File.Delete(path);
   159	            }
   160	        }
