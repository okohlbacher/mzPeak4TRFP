    14	    [TestFixture]
    15	    public class MzPeakParquetTests
    16	    {
    17	        private static DataField Leaf(ParquetSchema schema, string dotPath)
    18	        {
    19	            return schema.GetDataFields().First(d => d.Path.ToString() == dotPath);
