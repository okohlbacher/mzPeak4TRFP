   962	        private StructField BuildSpectrumField()
   963	        {
   964	            return new StructField("spectrum",
   965	                new DataField<ulong>("index", true),
   966	                new DataField<string>("id", true),
   967	                new DataField<byte>(Cv("MS:1000511", "ms_level"), true),
   968	                new DataField<double>("time", true),
   969	                new DataField<sbyte>(Cv("MS:1000465", "scan_polarity"), true),
   970	                new DataField<string>(Cv("MS:1000525", "spectrum_representation"), true),
   971	                new DataField<string>(Cv("MS:1000559", "spectrum_type"), true),
   972	                new DataField<double>(Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"), true),
   973	                new DataField<double>(Cv("MS:1000527", "highest_observed_mz", "MS:1000040"), true),
   974	                new DataField<ulong>(Cv("MS:1003060", "number_of_data_points"), true),
   975	                new DataField<ulong>(Cv("MS:1003059", "number_of_peaks"), true),
   976	                new DataField<double>(Cv("MS:1000504", "base_peak_mz", "MS:1000040"), true),
   977	                new DataField<float>(Cv("MS:1000505", "base_peak_intensity", "MS:1000131"), true),
   978	                new DataField<float>(Cv("MS:1000285", "total_ion_current", "MS:1000131"), true),
   979	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
   980	        }
   981	
   982	        private StructField BuildScanField()
   983	        {
   984	            var window = new StructField("item",
   985	                new DataField<float>(Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"), true),
   986	                new DataField<float>(Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"), true));
   987	            return new StructField("scan",
   988	                new DataField<ulong>("source_index", true),
   989	                new DataField<ulong>("scan_index", true),
   990	                new DataField<float>(Cv("MS:1000016", "scan_start_time", "UO:0000031"), true),
   991	                new DataField<string>(Cv("MS:1000512", "filter_string"), true),
   992	                new DataField<float>(Cv("MS:1000927", "ion_injection_time", "UO:0000028"), true),
   993	                new DataField<uint>("instrument_configuration_ref", true),
   994	                new ListField("scan_windows", window));
   995	        }
   996	
   997	        private StructField BuildPrecursorField()
