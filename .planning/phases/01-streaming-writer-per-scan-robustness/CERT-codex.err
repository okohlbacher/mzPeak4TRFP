  1126	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
  1127	            }
  1128	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1129	            cols[leaf] = (present.ToArray(), def, null);
