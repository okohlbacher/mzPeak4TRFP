   284	
   285	        private static int CountProfileWithCentroidStreamScans()
   286	        {
   287	            using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
   288	            {
   289	                raw.SelectInstrument(Device.MS, 1);
   290	                int first = raw.RunHeaderEx.FirstSpectrum;
   291	                int last = raw.RunHeaderEx.LastSpectrum;
   292	                int qualifying = 0;
   293	                for (int scan = first; scan <= last; scan++)
   294	                {
   295	                    var scanEvent = raw.GetScanEventForScanNumber(scan);
   296	                    if (scanEvent.ScanData == ScanDataType.Profile && Scan.FromFile(raw, scan).HasCentroidStream)
   297	                        qualifying++;
   298	                }
   299	                return qualifying;
   300	            }
   301	        }
   302	
   303	        [Test]
   304	        public void Peaks_Routes_Only_Profile_Scans_With_CentroidStream_NoDuplication()
   305	        {
   306	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   307	            var dir = Convert(input, out var archive);
   308	            try
   309	            {
   310	                var peaksBytes = ReadEntry(archive, "spectra_peaks.parquet");
   311	                Assert.That(peaksBytes, Is.Not.Null, "small.RAW must produce spectra_peaks.parquet");
   312	
   313	                var indexJson = JObject.Parse(
   314	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
   315	                var peaksEntry = ((JArray)indexJson["files"])
   316	                    .FirstOrDefault(f => (string)f["name"] == "spectra_peaks.parquet");
   317	                Assert.That(peaksEntry, Is.Not.Null, "index must list spectra_peaks when the facet is written");
   318	                Assert.That((string)peaksEntry["data_kind"], Is.EqualTo("peaks"));
   319	
   320	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   321	                var peaks = ReadPointFacet(peaksBytes);
   322	
   323	                Assert.That(peaks.Mz.Length, Is.EqualTo(peaks.PointCount));
   324	                var peakSpectra = peaks.SpectrumIndex.Distinct().ToHashSet();
   325	                Assert.That(peakSpectra.Count, Is.EqualTo(peaks.SpectrumCount),
   326	                    "spectra_peaks must carry one ordinal per qualifying scan, no duplication");
   327	                Assert.That(peakSpectra.Count, Is.GreaterThan(0), "small.RAW has profile scans with a centroid stream");
   328	
   329	                var dataSpectra = data.SpectrumIndex.Distinct().ToHashSet();
   330	                Assert.That(peakSpectra.IsSubsetOf(dataSpectra) && !peakSpectra.SetEquals(dataSpectra), Is.True,
   331	                    "peaks ordinals must be a strict subset of spectra_data ordinals (centroid-only scans absent)");
   332	
   333	                int qualifying = CountProfileWithCentroidStreamScans();
   334	                Assert.That(peakSpectra.Count, Is.LessThanOrEqualTo(qualifying),
   335	                    "no scan outside the profile+centroid-stream set may appear in spectra_peaks");
   336	                Assert.That(qualifying, Is.GreaterThan(0));
   337	            }
   338	            finally
   339	            {
   340	                Directory.Delete(dir, true);
   341	            }
   342	        }
   343	
   344	        private static string ResolvePython()
   345	        {
   346	            foreach (var cand in new[] { "python3", "python" })
   347	            {
   348	                try
   349	                {
   350	                    var psi = new ProcessStartInfo(cand, "-c \"import pyarrow\"")
   351	                    {
   352	                        RedirectStandardOutput = true,
   353	                        RedirectStandardError = true,
   354	                        UseShellExecute = false
   355	                    };
   356	                    using (var p = Process.Start(psi))
   357	                    {
   358	                        p.WaitForExit();
   359	                        if (p.ExitCode == 0) return cand;
   360	                    }

 succeeded in 0ms:
   361	                }
   362	                catch { }
   363	            }
   364	            return null;
   365	        }
   366	
   367	        // Writes the metadata parquet to a temp file and runs a python pyarrow snippet that prints
   368	        // a single JSON object to stdout. The snippet sees the file path via the {PARQUET} token.
   369	        private static JObject PyArrowMetadata(string archive, string snippet)
   370	        {
   371	            var python = ResolvePython();
   372	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   373	
   374	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   375	            File.WriteAllBytes(path, ReadEntry(archive, "spectra_metadata.parquet"));
   376	            try
   377	            {
   378	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   379	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   380	                {
   381	                    RedirectStandardOutput = true,
   382	                    RedirectStandardError = true,
   383	                    UseShellExecute = false
   384	                };
   385	                using (var proc = Process.Start(psi))
   386	                {
   387	                    var stdout = proc.StandardOutput.ReadToEnd();
   388	                    var stderr = proc.StandardError.ReadToEnd();
   389	                    proc.WaitForExit();
   390	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   391	                    return JObject.Parse(stdout.Trim());
   392	                }
   393	            }
   394	            finally
   395	            {
   396	                File.Delete(path);
   397	            }
   398	        }
   399	
   400	        [Test]
   401	        public void Metadata_Scan_And_Spectrum_Facets_Shape_And_Values()
   402	        {
   403	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   404	            var dir = Convert(input, out var archive);
   405	            try
   406	            {
   407	                var snippet =
   408	                    "import pyarrow.parquet as pq, json\n" +
   409	                    "t = pq.read_table(r'{PARQUET}')\n" +
   410	                    "d = t.to_pylist()\n" +
   411	                    "N = len(d)\n" +
   412	                    "sp = [f.name for f in t.schema.field('spectrum').type]\n" +
   413	                    "sc = [f.name for f in t.schema.field('scan').type]\n" +
   414	                    "out = {}\n" +
   415	                    "out['rows'] = N\n" +
   416	                    "out['spectrum_fields'] = sp\n" +
   417	                    "out['scan_fields'] = sc\n" +
   418	                    "out['scan_link_ok'] = all(d[i]['scan']['source_index']==i and d[i]['scan']['scan_index']==i for i in range(N))\n" +
   419	                    "out['polarities'] = sorted(set(int(d[i]['spectrum']['MS_1000465_scan_polarity']) for i in range(N)))\n" +
   420	                    "out['reprs'] = sorted(set(d[i]['spectrum']['MS_1000525_spectrum_representation'] for i in range(N)))\n" +
   421	                    "out['types'] = sorted(set(d[i]['spectrum']['MS_1000559_spectrum_type'] for i in range(N)))\n" +
   422	                    "out['ndp_all_present'] = all(d[i]['spectrum']['MS_1003060_number_of_data_points'] is not None for i in range(N))\n" +
   423	                    "out['npk_present'] = sum(1 for i in range(N) if d[i]['spectrum']['MS_1003059_number_of_peaks'] is not None)\n" +
   424	                    "out['npk_null'] = sum(1 for i in range(N) if d[i]['spectrum']['MS_1003059_number_of_peaks'] is None)\n" +
   425	                    "out['npk_zero'] = any(d[i]['spectrum']['MS_1003059_number_of_peaks']==0 for i in range(N) if d[i]['spectrum']['MS_1003059_number_of_peaks'] is not None)\n" +
   426	                    "out['sw_path'] = str(t.schema.field('scan').type.field('scan_windows').type)\n" +
   427	                    "out['param_path'] = str(t.schema.field('spectrum').type.field('parameters').type)\n" +
   428	                    "out['polarity_type'] = str(t.schema.field('spectrum').type.field('MS_1000465_scan_polarity').type)\n" +
   429	                    "out['scan_start_type'] = str(t.schema.field('scan').type.field('MS_1000016_scan_start_time_unit_UO_0000031').type)\n" +
   430	                    "out['cfg_refs'] = sorted(set(int(d[i]['scan']['instrument_configuration_ref']) for i in range(N)))\n" +
   431	                    "print(json.dumps(out))\n";
   432	                var o = PyArrowMetadata(archive, snippet);
   433	
   434	                Assert.That((int)o["rows"], Is.EqualTo(48));
   435	                Assert.That((bool)o["scan_link_ok"], Is.True);
   436	
   437	                var spectrumFields = o["spectrum_fields"].Select(x => (string)x).ToArray();
   438	                Assert.That(spectrumFields, Does.Contain("MS_1000511_ms_level"));
   439	                Assert.That(spectrumFields, Does.Contain("MS_1000465_scan_polarity"));
   440	                Assert.That(spectrumFields, Does.Contain("MS_1000525_spectrum_representation"));
   441	                Assert.That(spectrumFields, Does.Contain("MS_1000559_spectrum_type"));
   442	                Assert.That(spectrumFields, Does.Contain("MS_1000528_lowest_observed_mz_unit_MS_1000040"));
   443	                Assert.That(spectrumFields, Does.Contain("MS_1000527_highest_observed_mz_unit_MS_1000040"));
   444	                Assert.That(spectrumFields, Does.Contain("MS_1003060_number_of_data_points"));
   445	                Assert.That(spectrumFields, Does.Contain("MS_1003059_number_of_peaks"));
   446	                Assert.That(spectrumFields, Does.Contain("MS_1000504_base_peak_mz_unit_MS_1000040"));
   447	                Assert.That(spectrumFields, Does.Contain("MS_1000505_base_peak_intensity_unit_MS_1000131"));
   448	                Assert.That(spectrumFields, Does.Contain("MS_1000285_total_ion_current_unit_MS_1000131"));
   449	
   450	                var scanFields = o["scan_fields"].Select(x => (string)x).ToArray();
   451	                Assert.That(scanFields, Does.Contain("source_index"));
   452	                Assert.That(scanFields, Does.Contain("scan_index"));
   453	                Assert.That(scanFields, Does.Contain("MS_1000016_scan_start_time_unit_UO_0000031"));
   454	                Assert.That(scanFields, Does.Contain("MS_1000512_filter_string"));
   455	                Assert.That(scanFields, Does.Contain("MS_1000927_ion_injection_time_unit_UO_0000028"));
   456	                Assert.That(scanFields, Does.Contain("instrument_configuration_ref"));
   457	
   458	                // polarity int8 sign in {-1,1}; representation/type CURIE strings.
   459	                Assert.That(o["polarity_type"].ToString(), Is.EqualTo("int8"));
   460	                foreach (var p in o["polarities"]) Assert.That(Math.Abs((int)p), Is.EqualTo(1));
   461	                foreach (var r in o["reprs"]) Assert.That((string)r, Does.Match(@"^MS:\d+$"));
   462	                foreach (var ty in o["types"]) Assert.That((string)ty, Does.Match(@"^MS:\d+$"));
   463	
   464	                // scan_start_time raw float32 minutes.
   465	                Assert.That(o["scan_start_type"].ToString(), Is.EqualTo("float"));
   466	
   467	                // count discipline: data_points always present; peaks NULL where unwritten, never 0.
   468	                Assert.That((bool)o["ndp_all_present"], Is.True);
   469	                Assert.That((int)o["npk_present"], Is.GreaterThan(0));
   470	                Assert.That((int)o["npk_null"], Is.GreaterThan(0));
   471	                Assert.That((bool)o["npk_zero"], Is.False, "number_of_peaks must be NULL, never 0, when no peaks written");
   472	
   473	                // list element named item: paths contain "item:".
   474	                Assert.That(o["sw_path"].ToString(), Does.Contain("item:"));
   475	                Assert.That(o["param_path"].ToString(), Does.Contain("item:"));
   476	
   477	                // two distinct analyzers -> config refs {0,1}.
   478	                Assert.That(o["cfg_refs"].Select(x => (int)x).ToArray(), Is.EqualTo(new[] { 0, 1 }));
   479	            }
   480	            finally
   481	            {
   482	                Directory.Delete(dir, true);
   483	            }
   484	        }
   485	
   486	        [Test]
   487	        public void Metadata_Precursor_And_SelectedIon_NullPadded_And_Linked()
   488	        {
   489	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   490	            var dir = Convert(input, out var archive);
   491	            try
   492	            {
   493	                var snippet =
   494	                    "import pyarrow.parquet as pq, json\n" +
   495	                    "t = pq.read_table(r'{PARQUET}')\n" +
   496	                    "d = t.to_pylist()\n" +
   497	                    "N = len(d)\n" +
   498	                    "pp = [d[i]['precursor'] is not None and d[i]['precursor']['source_index'] is not None for i in range(N)]\n" +
   499	                    "M = sum(pp)\n" +
   500	                    "out = {}\n" +
   501	                    "out['N'] = N\nout['M'] = M\n" +
   502	                    "out['msn_ordinals'] = sorted(int(d[i]['spectrum']['index']) for i in range(N) if d[i]['spectrum']['MS_1000511_ms_level'] >= 2)\n" +
   503	                    "out['msn_count'] = sum(1 for i in range(N) if d[i]['spectrum']['MS_1000511_ms_level'] >= 2)\n" +
   504	                    "out['prec_pattern'] = ''.join('1' if x else '0' for x in pp)\n" +
   505	                    "out['srcs'] = [d[i]['precursor']['source_index'] for i in range(M)]\n" +
   506	                    "out['pidx'] = [d[i]['precursor']['precursor_index'] for i in range(M)]\n" +
   507	                    "out['no_swap'] = all(d[i]['precursor']['source_index']!=d[i]['precursor']['precursor_index'] for i in range(M) if d[i]['precursor']['precursor_index'] is not None)\n" +
   508	                    "out['sel_src_mirror'] = all(d[i]['selected_ion']['source_index']==d[i]['precursor']['source_index'] for i in range(M))\n" +
   509	                    "out['sel_pidx_mirror'] = all((d[i]['selected_ion']['precursor_index'] is None) == (d[i]['precursor']['precursor_index'] is None) and (d[i]['precursor']['precursor_index'] is None or d[i]['selected_ion']['precursor_index']==d[i]['precursor']['precursor_index']) for i in range(M))\n" +
   510	                    "out['sel_null_tail'] = all(d[i]['selected_ion'] is None or d[i]['selected_ion']['source_index'] is None for i in range(M, N))\n" +
   511	                    "out['prec_null_tail'] = all(d[i]['precursor'] is None or d[i]['precursor']['source_index'] is None for i in range(M, N))\n" +
   512	                    "ap = d[0]['precursor']['activation']['parameters']\n" +
   513	                    "out['row0_act_acc'] = [e['accession'] for e in ap]\n" +
   514	                    "out['row0_ce_unit'] = [e['unit'] for e in ap if e['accession']=='MS:1000045']\n" +
   515	                    "out['ms1_ordinals'] = sorted(set(i for i in range(N) if d[i]['spectrum']['MS_1000511_ms_level']==1))\n" +
   516	                    "print(json.dumps(out))\n";
   517	                var o = PyArrowMetadata(archive, snippet);
   518	
   519	                int n = (int)o["N"], m = (int)o["M"];
   520	                Assert.That(m, Is.EqualTo((int)o["msn_count"]), "precursor count == MSn spectrum count");
   521	                Assert.That((string)o["prec_pattern"], Is.EqualTo(new string('1', m) + new string('0', n - m)),
   522	                    "precursor present on rows 0..M-1, null on M..N-1");
   523	                Assert.That((bool)o["prec_null_tail"], Is.True);
   524	                Assert.That((bool)o["sel_null_tail"], Is.True);
   525	
   526	                var srcs = o["srcs"].Select(x => (ulong)x).ToArray();
   527	                Assert.That(srcs, Is.EqualTo(srcs.OrderBy(x => x).ToArray()), "MSn ordinals ascending");
   528	
   529	                // EXACT set equality: the precursor source_index set IS the MSn-ordinal set derived from
   530	                // spectrum.ms_level >= 2 -- no extra precursor rows, none missing.
   531	                var msnOrdinals = o["msn_ordinals"].Select(x => (ulong)x).ToHashSet();
   532	                Assert.That(srcs.ToHashSet(), Is.EquivalentTo(msnOrdinals),
   533	                    "precursor.source_index set must equal the ms_level>=2 ordinal set exactly");
   534	
   535	                Assert.That((bool)o["no_swap"], Is.True, "precursor_index != source_index");
   536	                Assert.That((bool)o["sel_src_mirror"], Is.True,
   537	                    "selected_ion.source_index == precursor.source_index per row");
   538	                Assert.That((bool)o["sel_pidx_mirror"], Is.True,
   539	                    "selected_ion.precursor_index mirrors precursor.precursor_index per row (null-for-null)");
   540	
   541	                var ms1 = o["ms1_ordinals"].Select(x => (ulong)x).ToHashSet();
   542	                foreach (var pi in o["pidx"])
   543	                {
   544	                    if (pi.Type == JTokenType.Null) continue;
   545	                    Assert.That(ms1, Does.Contain((ulong)pi), "precursor_index must be an MS1 ordinal");
   546	                }
   547	
   548	                Assert.That(o["row0_act_acc"].Select(x => (string)x).ToArray(), Does.Contain("MS:1000133"),
   549	                    "small.RAW activation is CID MS:1000133");
   550	                Assert.That(o["row0_ce_unit"].Select(x => (string)x).ToArray(), Does.Contain("UO:0000266"),
   551	                    "collision energy carries unit UO:0000266");
   552	            }
   553	            finally
   554	            {
   555	                Directory.Delete(dir, true);
   556	            }
   557	        }
