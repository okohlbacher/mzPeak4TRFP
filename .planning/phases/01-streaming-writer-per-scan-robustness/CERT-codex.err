   663	                    Assert.That(handle, Is.Not.Null, "a seekable FileStream is accepted");
   664	                    handle.CloseAsync(null).GetAwaiter().GetResult();
   665	                }
   666	            }
   667	            finally
   668	            {
   669	                File.Delete(path);
   670	            }
   671	        }
