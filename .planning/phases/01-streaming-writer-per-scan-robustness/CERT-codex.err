  1263	        private void AddScanWindows(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1264	            List<Record> records)
  1265	        {
  1266	            var lowerLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"));
  1267	            var upperLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"));
  1268	
  1269	            var lowerRows = new List<MzPeakParquet.LeafRow>();
  1270	            var upperRows = new List<MzPeakParquet.LeafRow>();
  1271	            var lowerVals = new List<float>();
  1272	            var upperVals = new List<float>();
  1273	
  1274	            for (int row = 0; row < records.Count; row++)
  1275	            {
  1276	                lowerRows.Add(MzPeakParquet.ListOf(new[] { lowerLeaf.MaxDefinitionLevel }, new[] { true }));
  1277	                upperRows.Add(MzPeakParquet.ListOf(new[] { upperLeaf.MaxDefinitionLevel }, new[] { true }));
  1278	                lowerVals.Add(records[row].WindowLower);
  1279	                upperVals.Add(records[row].WindowUpper);
  1280	            }
  1281	
  1282	            Emit(cols, lowerLeaf, lowerVals.ToArray(), lowerRows);
  1283	            Emit(cols, upperLeaf, upperVals.ToArray(), upperRows);
  1284	        }
