   649	        {
   650	            var schema = PointSchema();
   651	            using (var nonSeekable = new NonSeekableStream())
   652	            {
   653	                Assert.That(() => MzPeakParquet.OpenAsync(nonSeekable, schema, null).GetAwaiter().GetResult(),
   654	                    Throws.ArgumentException);
   655	            }
   656	
   657	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   658	            try
