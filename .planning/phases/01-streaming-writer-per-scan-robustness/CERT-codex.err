  1417	                    .Select(f => (string)f["ruleId"]).ToArray();
  1418	                var warnings = findings.Where(f => (string)f["level"] == "warning")
  1419	                    .Select(f => (string)f["ruleId"]).ToArray();
  1420	
  1421	                Assert.That(errors, Is.Empty, $"0 errors required; got {string.Join(",", errors)}");
  1422	                Assert.That(warnings, Is.Empty, $"0 warnings required; got {string.Join(",", warnings)}");
  1423	
  1424	                var chromRules = findings.Select(f => (string)f["ruleId"])
  1425	                    .Where(r => r != null && r.Contains("chromatogram")).ToArray();
  1426	                Assert.That(chromRules, Is.Empty,
  1427	                    $"no chromatogram-related finding: {string.Join(",", chromRules)}");
  1428	            }
  1429	            finally
  1430	            {
  1431	                if (File.Exists(jsonPath)) File.Delete(jsonPath);
  1432	                Directory.Delete(dir, true);
  1433	            }
  1434	        }
