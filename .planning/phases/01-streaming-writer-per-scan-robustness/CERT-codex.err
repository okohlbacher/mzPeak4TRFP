   596	        // A single all-null row for a leaf in a present-but-null top-level struct: definition level
   597	        // sits one below the leaf's own present level (the owning struct is null), no value slot.
   598	        private static void AddNullLeaf(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf)
   599	        {
   600	            var rows = new[] { MzPeakParquet.AtLevel(0, false) };
   601	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   602	            cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   603	        }
