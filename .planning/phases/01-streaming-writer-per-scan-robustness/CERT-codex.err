   682	        private static void AddStored(ZipArchive zip, string name, byte[] bytes)
   683	        {
   684	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   685	            using (var s = entry.Open())
   686	            {
   687	                s.Write(bytes, 0, bytes.Length);
   688	            }
   689	        }
   690	
   691	        // Streams a finished temp-file facet into a STORED zip entry via a 64 KB bounded CopyTo, never
   692	        // reading the whole facet into a byte[].
   693	        private static void AddStoredFromFile(ZipArchive zip, string name, string tempPath)
   694	        {
   695	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   696	            using (var es = entry.Open())
   697	            using (var src = File.OpenRead(tempPath))
   698	                src.CopyTo(es, 1 << 16);
   699	        }
