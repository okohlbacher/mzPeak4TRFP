   368	        // Footer KV for a streamed point facet (spectra_data / spectra_peaks), identical to the v1
   369	        // single-row-group facet's metadata.
   370	        private static Dictionary<string, string> PointFooter(int spectrumCount, long pointCount) =>
   371	            new Dictionary<string, string>
   372	            {
   373	                ["spectrum_count"] = spectrumCount.ToString(),
   374	                ["spectrum_data_point_count"] = pointCount.ToString(),
   375	                ["spectrum_array_index"] = SpectrumArrayIndex
   376	            };
   377	
   378	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   379	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   380	        // index sort is applied only when an ascending violation is detected, never dropping or
   381	        // merging equal-m/z points.
   382	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   383	        {
   384	            var n = masses?.Length ?? 0;
   385	            var mz = new double[n];
   386	            var inten = new float[n];
   387	            bool ascending = true;
   388	            for (int i = 0; i < n; i++)
   389	            {
   390	                mz[i] = masses[i];
   391	                inten[i] = (float)intensities[i];
   392	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   393	            }
   394	
   395	            if (ascending) return (mz, inten);
   396	
   397	            var order = new int[n];
   398	            for (int i = 0; i < n; i++) order[i] = i;
   399	            Array.Sort(order, (a, b) =>
   400	            {
   401	                int c = masses[a].CompareTo(masses[b]);
   402	                return c != 0 ? c : a.CompareTo(b);
   403	            });
   404	            var sortedMz = new double[n];
   405	            var sortedInten = new float[n];
   406	            for (int i = 0; i < n; i++)
   407	            {
   408	                sortedMz[i] = masses[order[i]];
   409	                sortedInten[i] = (float)intensities[order[i]];
   410	            }
   411	            return (sortedMz, sortedInten);
   412	        }
