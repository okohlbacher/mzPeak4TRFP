   107	        [Test]
   108	        public void TestMgf()
   109	        {
   110	            // Get temp path for writing the test MGF
   111	            var tempFilePath = Path.GetTempPath();
   112	
   113	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
   114	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.MGF);
   115	
   116	            RawFileParser.Parse(parseInput);
   117	
   118	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   119	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   120	
   121	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mgf")));
   122	            AssertMgfSpectra(Path.Combine(tempFilePath, "small.mgf"), 34);
   123	
   124	            File.Delete(Path.Combine(tempFilePath, "small.mgf"));
   125	        }
