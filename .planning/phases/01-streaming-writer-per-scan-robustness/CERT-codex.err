  1286	        private static Field FindField(ParquetSchema schema, string path)
  1287	        {
  1288	            var parts = path.Split('/');
  1289	            Field current = schema.Fields.First(f => f.Name == parts[0]);
  1290	            for (int i = 1; i < parts.Length; i++)
  1291	            {
  1292	                current = ((StructField)current).Fields.First(f => f.Name == parts[i]);
  1293	            }
  1294	            return current;
  1295	        }
