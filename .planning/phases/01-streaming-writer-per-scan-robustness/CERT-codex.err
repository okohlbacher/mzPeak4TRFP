  1350	        private JArray BuildCvList()
  1351	        {
  1352	            var defs = new Dictionary<string, (string version, string fullName, string uri)>
  1353	            {
  1354	                ["MS"] = (MsCvVersion, "PSI-MS controlled vocabulary",
  1355	                    "https://raw.githubusercontent.com/HUPO-PSI/psi-ms-CV/master/psi-ms.obo"),
  1356	                ["UO"] = (UoCvVersion, "Unit Ontology", "http://purl.obolibrary.org/obo/uo.obo")
  1357	            };
  1358	
  1359	            var list = new JArray();
  1360	            foreach (var prefix in _cvPrefixes.OrderBy(p => p))
  1361	            {
  1362	                defs.TryGetValue(prefix, out var d);
  1363	                list.Add(new JObject
  1364	                {
  1365	                    ["id"] = prefix,
  1366	                    ["version"] = d.version ?? "unknown",
  1367	                    ["full_name"] = d.fullName ?? prefix,
  1368	                    ["uri"] = d.uri ?? ""
  1369	                });
  1370	            }
  1371	            return list;
  1372	        }
