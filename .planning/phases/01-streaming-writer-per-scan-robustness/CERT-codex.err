    58	        [Test]
    59	        public void TestExtensionsFull()
    60	        {
    61	            // Get temp path for writing the test files
    62	            var tempFilePath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    63	            Directory.CreateDirectory(tempFilePath);
    64	
    65	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
    66	            var parseInput = new ParseInput();
    67	            parseInput.RawFilePath = testRawFile;
    68	
    69	            List<OutputFormat> formats = new List<OutputFormat>();
    70	            string userInput;
    71	            string expectedOutput;
    72	
    73	            foreach (string line in File.ReadLines(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/ExtensionTest.tsv")).Skip(1))
    74	            {
    75	                string[] words = line.Split('\t');
    76	
    77	                switch (words[0].ToLower())
    78	                {
    79	                    case "mgf": formats = new List<OutputFormat> { OutputFormat.MGF }; break;
    80	                    case "mzml": formats = new List<OutputFormat> { OutputFormat.MzML, OutputFormat.IndexMzML }; break;
    81	                }
    82	
    83	                switch (words[1].ToLower())
    84	                {
    85	                    case "true": parseInput.Gzip = true; break;
    86	                    default: parseInput.Gzip = false; break;
    87	                }
    88	
    89	                userInput = words[2];
    90	                expectedOutput = words[3];
    91	
    92	                parseInput.OutputFile = Path.Combine(tempFilePath, userInput);
    93	
    94	                foreach (var format in formats)
    95	                {
    96	                    parseInput.OutputFormat = format;
    97	                    RawFileParser.Parse(parseInput);
    98	                    Assert.That(File.Exists(Path.Combine(tempFilePath, expectedOutput)));
    99	                    File.Delete(Path.Combine(tempFilePath, expectedOutput));
   100	                }
   101	
   102	            }
   103	
   104	            Directory.Delete(tempFilePath, true);
   105	        }
