   260	        [Test]
   261	        public void NestedLevels_RoundTrips_SpectraMetadataFacetShapes_ViaPyArrow()
   262	        {
   263	            var python = ResolvePython();
   264	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   265	
   266	            // precursor top-level struct: isolation_window (nested struct) + activation.parameters (PARAM list).
   267	            // scan top-level struct: scan_windows (list-of-struct). Mirrors the real mzPeak
   268	            // spectra-metadata facet shapes.
   269	            var isoWindow = new StructField("isolation_window",
   270	                new DataField<float>("target"), new DataField<float>("lower_offset"));
   271	            var activation = new StructField("activation",
   272	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
   273	            var precursor = new StructField("precursor",
   274	                new DataField<ulong>("source_index"), isoWindow, activation);
   275	
   276	            var windowItem = new StructField("item",
   277	                new DataField<float>("lower"), new DataField<float>("upper"));
   278	            var scanWindows = new ListField("scan_windows", windowItem);
   279	            var scan = new StructField("scan",
   280	                new DataField<ulong>("source_index"), scanWindows);
   281	
   282	            var schema = new ParquetSchema(precursor, scan);
   283	
   284	            // 4 rows. precursor present on rows 0,1,2 and NULL on row 3 (padded tail).
   285	            //   row0: iso present; activation present; activation.parameters = 2 items (CID accession, CE float)
   286	            //   row1: iso present; activation present; activation.parameters = EMPTY list
   287	            //   row2: iso present; activation PRESENT; activation.parameters = NULL list (struct-present, list-null)
   288	            //   row3: precursor struct NULL (root absent for this facet)
   289	            // rows 2 and 3 are the level-aware discriminator: activation!=null && parameters==null must
   290	            // encode a DIFFERENT definition level than activation==null / precursor==null.
   291	            var srcIdx = Leaf(schema, "precursor/source_index");
   292	            var isoTarget = Leaf(schema, "precursor/isolation_window/target");
   293	            var actAcc = Leaf(schema, "precursor/activation/parameters/list/item/accession");
   294	            var actFloat = Leaf(schema, "precursor/activation/parameters/list/item/value/float");
   295	            var actList = (ListField)((StructField)((StructField)schema.Fields
   296	                .First(f => f.Name == "precursor")).Fields.First(f => f.Name == "activation"))
   297	                .Fields.First(f => f.Name == "parameters");
   298	
   299	            var winLower = Leaf(schema, "scan/scan_windows/list/item/lower");
   300	            var scanSrc = Leaf(schema, "scan/source_index");
   301	
   302	            var (srcDef, _) = MzPeakParquet.NestedLevels(srcIdx, new[]
   303	            {
   304	                MzPeakParquet.Present(srcIdx), MzPeakParquet.Present(srcIdx),
   305	                MzPeakParquet.Present(srcIdx), MzPeakParquet.Absent()
   306	            });
   307	            var (isoDef, _) = MzPeakParquet.NestedLevels(isoTarget, new[]
   308	            {
   309	                MzPeakParquet.Present(isoTarget), MzPeakParquet.Present(isoTarget),
   310	                MzPeakParquet.Present(isoTarget), MzPeakParquet.Absent()
   311	            });
   312	            // accession: row0 both elements present; row1 empty; row2 struct-present-list-null; row3 precursor null
   313	            var (accDef, accRep) = MzPeakParquet.NestedLevels(actAcc, new[]
   314	            {
   315	                MzPeakParquet.ListOf(new[] { actAcc.MaxDefinitionLevel, actAcc.MaxDefinitionLevel }, new[] { true, true }),
   316	                MzPeakParquet.EmptyList(actList),
   317	                MzPeakParquet.NullList(actList),
   318	                MzPeakParquet.NullList()
   319	            });
   320	            // value/float: row0 elem0 null (CID has no float), elem1 present (CE)
   321	            var (fltDef, fltRep) = MzPeakParquet.NestedLevels(actFloat, new[]
   322	            {
   323	                MzPeakParquet.ListOf(new[] { actFloat.MaxDefinitionLevel - 1, actFloat.MaxDefinitionLevel }, new[] { false, true }),
   324	                MzPeakParquet.EmptyList(actList),
   325	                MzPeakParquet.NullList(actList),
   326	                MzPeakParquet.NullList()
   327	            });
   328	            // scan present on all 4 rows; one window each
   329	            var (scanSrcDef, _) = MzPeakParquet.NestedLevels(scanSrc, new[]
   330	            {
   331	                MzPeakParquet.Present(scanSrc), MzPeakParquet.Present(scanSrc),
   332	                MzPeakParquet.Present(scanSrc), MzPeakParquet.Present(scanSrc)
   333	            });
   334	            var (winDef, winRep) = MzPeakParquet.NestedLevels(winLower, Enumerable.Range(0, 4)
   335	                .Select(_ => MzPeakParquet.ListOf(new[] { winLower.MaxDefinitionLevel }, new[] { true })).ToArray());
   336	
   337	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   338	            {
   339	                [srcIdx] = (new ulong[] { 2, 3, 4 }, srcDef, null),
   340	                [isoTarget] = (new[] { 810.7f, 837.3f, 725.3f }, isoDef, null),
   341	                [Leaf(schema, "precursor/isolation_window/lower_offset")] =
   342	                    (new[] { 1.0f, 1.0f, 1.0f }, isoDef, null),
   343	                [actAcc] = (new[] { "MS:1000133", "MS:1000045" }, accDef, accRep),
   344	                [Leaf(schema, "precursor/activation/parameters/list/item/value/integer")] =
   345	                    (new long[0], NullLeaf(schema, "precursor/activation/parameters/list/item/value/integer", accDef, accRep), accRep),
   346	                [actFloat] = (new[] { 35.0 }, fltDef, fltRep),
   347	                [Leaf(schema, "precursor/activation/parameters/list/item/value/string")] =
   348	                    (new string[0], NullLeaf(schema, "precursor/activation/parameters/list/item/value/string", accDef, accRep), accRep),
   349	                [Leaf(schema, "precursor/activation/parameters/list/item/value/boolean")] =
   350	                    (new bool[0], NullLeaf(schema, "precursor/activation/parameters/list/item/value/boolean", accDef, accRep), accRep),
   351	                [Leaf(schema, "precursor/activation/parameters/list/item/name")] =
   352	                    (new[] { "collision-induced dissociation", "collision energy" }, accDef, accRep),
   353	                [Leaf(schema, "precursor/activation/parameters/list/item/unit")] =
   354	                    (new[] { "UO:0000266" }, UnitLevels(accDef, actAcc.MaxDefinitionLevel), accRep),
   355	                [scanSrc] = (new ulong[] { 0, 1, 2, 3 }, scanSrcDef, null),
   356	                [winLower] = (new[] { 200f, 200f, 210f, 210f }, winDef, winRep),
   357	                [Leaf(schema, "scan/scan_windows/list/item/upper")] =
   358	                    (new[] { 2000f, 2000f, 1635f, 1635f }, winDef, winRep)
   359	            };
   360	
   361	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   362	            using (var fs = File.Create(path))
   363	            {
   364	                MzPeakParquet.WriteAsync(fs, schema, new Dictionary<string, string>(),
   365	                    cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
