    51	        public void Column_DefRepLevels_MatchCheatSheet()
    52	        {
    53	            var paramItem = new StructField("item",
    54	                new DataField<string>("name"),
    55	                new DataField<double>("val", true));
    56	            var paramsList = new ListField("parameters", paramItem);
    57	            var spectrum = new StructField("spectrum",
    58	                new DataField<ulong>("index"), paramsList);
    59	            var schema = new ParquetSchema(spectrum);
    60	
    61	            var nameLeaf = Leaf(schema, "spectrum/parameters/list/item/name");
    62	            var indexLeaf = Leaf(schema, "spectrum/index");
    63	
    64	            var nameCol = MzPeakParquet.Column(nameLeaf, new[] { "a", "b" },
    65	                new[] { 5, 5, 0, 2 }, new[] { 0, 1, 0, 0 });
