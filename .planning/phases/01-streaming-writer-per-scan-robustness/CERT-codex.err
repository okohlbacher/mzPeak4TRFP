   549	        // A present-but-empty list on a single-row facet (the list value is defined, no elements).
   550	        private void AddEmptyList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   551	            string listPath)
   552	        {
   553	            var list = (ListField)FindField(schema, listPath);
   554	            foreach (var leaf in schema.GetDataFields())
   555	            {
   556	                if (!leaf.Path.ToString().StartsWith(listPath + "/")) continue;
   557	                var rows = new[] { MzPeakParquet.EmptyList(list) };
   558	                var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   559	                cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   560	            }
   561	        }
   562	
   563	        // The auxiliary_arrays list is empty, but its element struct carries a non-nullable data leaf
   564	        // (data/list/item: uint8 not null); emit the same empty-list level for every descendant leaf.
   565	        private void AddEmptyAuxList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   566	            string listPath)
   567	        {
   568	            var list = (ListField)FindField(schema, listPath);
   569	            foreach (var leaf in schema.GetDataFields())
   570	            {
   571	                if (!leaf.Path.ToString().StartsWith(listPath + "/")) continue;
   572	                var rows = new[] { MzPeakParquet.EmptyList(list) };
   573	                var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   574	                cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   575	            }
   576	        }
   577	
   578	        private void AddNullPrecursor(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema)
   579	        {
   580	            foreach (var leaf in schema.GetDataFields())
   581	            {
   582	                if (!leaf.Path.ToString().StartsWith("precursor/")) continue;
   583	                AddNullLeaf(cols, leaf);
   584	            }
   585	        }
   586	
   587	        private void AddNullSelectedIon(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema)
   588	        {
   589	            foreach (var leaf in schema.GetDataFields())
   590	            {
   591	                if (!leaf.Path.ToString().StartsWith("selected_ion/")) continue;
   592	                AddNullLeaf(cols, leaf);
   593	            }
   594	        }
