     2	using System.Collections.Generic;
     3	using System.IO;
     4	using System.Linq;
     5	using System.Xml.Serialization;
     6	using NUnit.Framework;
     7	using Parquet;
     8	using ThermoRawFileParser;
     9	using ThermoRawFileParser.Writer.MzML;
    10	
    11	namespace ThermoRawFileParserTest
    12	{
    13	    [TestFixture]
    14	    public class WriterTests
    15	    {
    16	        [Test]
    17	        public void TestExtensionsNull()
    18	        {
    19	            // Get temp path for writing the test files
    20	            var tempFilePath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    21	            Directory.CreateDirectory(tempFilePath);
    22	
    23	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
    24	            var parseInput = new ParseInput();
    25	            parseInput.RawFilePath = testRawFile;
    26	            parseInput.OutputDirectory = tempFilePath;
    27	
    28	            //empty filename
    29	            parseInput.OutputFormat = OutputFormat.MGF;
    30	            RawFileParser.Parse(parseInput);
    31	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mgf")));
    32	
    33	            parseInput.OutputFormat = OutputFormat.MzML;
    34	            RawFileParser.Parse(parseInput);
    35	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mzML")));
    36	            File.Delete(Path.Combine(tempFilePath, "small.mzML"));
    37	
    38	            parseInput.OutputFormat = OutputFormat.IndexMzML;
    39	            RawFileParser.Parse(parseInput);
    40	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mzML")));
    41	
    42	            parseInput.Gzip = true;
    43	            RawFileParser.Parse(parseInput);
    44	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mzML.gz")));
    45	            File.Delete(Path.Combine(tempFilePath, "small.mzML.gz"));
    46	
    47	            parseInput.OutputFormat = OutputFormat.MGF;
    48	            RawFileParser.Parse(parseInput);
    49	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mgf.gz")));
    50	
    51	            parseInput.OutputFormat = OutputFormat.MzML;
    52	            RawFileParser.Parse(parseInput);
    53	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mzML.gz")));
    54	
    55	            Directory.Delete(tempFilePath, true);
    56	        }
