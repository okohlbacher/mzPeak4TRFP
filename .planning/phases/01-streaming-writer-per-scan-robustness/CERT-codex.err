   378	        [Test]
   379	        public void TestMzML_MS2()
   380	        {
   381	            // Get temp path for writing the test mzML
   382	            var tempFilePath = Path.GetTempPath();
   383	
   384	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small2.RAW");
   385	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.MzML);
   386	
   387	            RawFileParser.Parse(parseInput);
   388	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   389	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   390	
   391	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small2.mzML")));
   392	            // Deserialize the mzML file
   393	            using (var fs = new FileStream(Path.Combine(tempFilePath, "small2.mzML"), FileMode.Open,
   394	                FileAccess.Read, FileShare.ReadWrite))
   395	            {
   396	                var xmlSerializer = new XmlSerializer(typeof(mzMLType));
   397	                var testMzMl = (mzMLType)xmlSerializer.Deserialize(fs);
   398	
   399	                Assert.That(testMzMl.run.spectrumList.spectrum.Length, Is.EqualTo(95));
   400	
   401	                var precursor = testMzMl.run.spectrumList.spectrum[16].precursorList.precursor[0].selectedIonList.selectedIon[0];
   402	                var selectedMz = Double.Parse(precursor.cvParam.Where(cv => cv.accession == "MS:1000744").First().value);
   403	                Assert.That(selectedMz - 604.7592 < 0.001);
   404	
   405	                var selectedZ = int.Parse(precursor.cvParam.Where(cv => cv.accession == "MS:1000041").First().value);
   406	                Assert.That(selectedZ, Is.EqualTo(2));
   407	
   408	                var selectedI = Double.Parse(precursor.cvParam.Where(cv => cv.accession == "MS:1000042").First().value);
   409	                Assert.That(selectedI - 17044 < 1);
   410	
   411	                Assert.That(testMzMl.run.chromatogramList.chromatogram[0].defaultArrayLength, Is.EqualTo(95));
   412	            }
   413	
   414	            File.Delete(Path.Combine(tempFilePath, "small2.mzML"));
   415	        }
