  1483	        private static void AssertSameMultiset(Facet a, Facet b)
  1484	        {
  1485	            Assert.That(a.Mz.Length, Is.EqualTo(b.Mz.Length));
  1486	            var ta = Enumerable.Range(0, a.Mz.Length)
  1487	                .Select(i => (a.SpectrumIndex[i], a.Mz[i], a.Intensity[i]))
  1488	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ThenBy(x => x.Item3).ToArray();
  1489	            var tb = Enumerable.Range(0, b.Mz.Length)
  1490	                .Select(i => (b.SpectrumIndex[i], b.Mz[i], b.Intensity[i]))
  1491	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ThenBy(x => x.Item3).ToArray();
  1492	            Assert.That(tb, Is.EqualTo(ta), "(spectrum_index, mz, intensity) multiset identical across caps");
  1493	        }
  1494	
  1495	        private static Facet ReadAllRowGroups(byte[] bytes)
  1496	        {
  1497	            using (var ms = new MemoryStream(bytes))
  1498	            using (var reader = ParquetReader.CreateAsync(ms).Result)
  1499	            {
  1500	                var schema = reader.Schema;
  1501	                var idx = new List<ulong>(); var mz = new List<double>(); var inten = new List<float>();
  1502	                for (int g = 0; g < reader.RowGroupCount; g++)
  1503	                {
  1504	                    var rg = reader.OpenRowGroupReader(g);
  1505	                    idx.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data.Cast<ulong>());
  1506	                    mz.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data.Cast<double>());
  1507	                    inten.AddRange(rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data.Cast<float>());
  1508	                }
  1509	                var meta = reader.CustomMetadata;
  1510	                return new Facet
  1511	                {
  1512	                    SpectrumIndex = idx.ToArray(),
  1513	                    Mz = mz.ToArray(),
  1514	                    Intensity = inten.ToArray(),
  1515	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
  1516	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
  1517	                };
  1518	            }
  1519	        }
