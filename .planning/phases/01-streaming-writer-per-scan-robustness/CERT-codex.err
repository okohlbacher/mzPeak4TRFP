  1501	        // A controlled-value PARAM (accession + name, no value). Records the CV prefix so the
  1502	        // generated cv_list stays exhaustive.
  1503	        private JObject CvParam(string accession, string name, string value)
  1504	        {
  1505	            CollectPrefix(accession);
  1506	            return JParam(name, accession, string.IsNullOrEmpty(value) ? null : value, null);
  1507	        }
  1508	
  1509	        // A PARAM object matching the param.json schema (name required; accession/value/unit nullable).
  1510	        private JObject JParam(string name, string accession, object value, string unit)
  1511	        {
  1512	            CollectPrefix(unit);
  1513	            return new JObject
  1514	            {
  1515	                ["name"] = name,
  1516	                ["accession"] = accession == null ? JValue.CreateNull() : new JValue(accession),
  1517	                ["value"] = value == null ? JValue.CreateNull() : JToken.FromObject(value),
  1518	                ["unit"] = unit == null ? JValue.CreateNull() : new JValue(unit)
  1519	            };
  1520	        }
