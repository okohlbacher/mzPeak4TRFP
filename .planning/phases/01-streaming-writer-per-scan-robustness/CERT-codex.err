  1166	            var unitLeaf = Leaf(schema, listPath + "/list/item/unit");
  1167	            var intLeaf = Leaf(schema, listPath + "/list/item/value/integer");
  1168	            var fltLeaf = Leaf(schema, listPath + "/list/item/value/float");
  1169	            var strLeaf = Leaf(schema, listPath + "/list/item/value/string");
  1170	            var boolLeaf = Leaf(schema, listPath + "/list/item/value/boolean");
  1171	
  1172	            var accRows = new List<MzPeakParquet.LeafRow>();
  1173	            var nameRows = new List<MzPeakParquet.LeafRow>();
  1174	            var unitRows = new List<MzPeakParquet.LeafRow>();
  1175	            var intRows = new List<MzPeakParquet.LeafRow>();
  1176	            var fltRows = new List<MzPeakParquet.LeafRow>();
  1177	            var strRows = new List<MzPeakParquet.LeafRow>();
  1178	            var boolRows = new List<MzPeakParquet.LeafRow>();
  1179	
  1180	            var accVals = new List<string>();
  1181	            var nameVals = new List<string>();
  1182	            var unitVals = new List<string>();
  1183	            var intVals = new List<long>();
  1184	            var fltVals = new List<double>();
  1185	            var strVals = new List<string>();
  1186	            var boolVals = new List<bool>();
  1187	
  1188	            for (int row = 0; row < perRow.Count; row++)
  1189	            {
  1190	                if (!structPresent[row])
  1191	                {
  1192	                    accRows.Add(MzPeakParquet.NullList()); nameRows.Add(MzPeakParquet.NullList());
  1193	                    unitRows.Add(MzPeakParquet.NullList()); intRows.Add(MzPeakParquet.NullList());
  1194	                    fltRows.Add(MzPeakParquet.NullList()); strRows.Add(MzPeakParquet.NullList());
  1195	                    boolRows.Add(MzPeakParquet.NullList());
  1196	                    continue;
  1197	                }
  1198	
  1199	                var items = perRow[row];
  1200	                if (items.Count == 0)
  1201	                {
  1202	                    accRows.Add(MzPeakParquet.EmptyList(list)); nameRows.Add(MzPeakParquet.EmptyList(list));
  1203	                    unitRows.Add(MzPeakParquet.EmptyList(list)); intRows.Add(MzPeakParquet.EmptyList(list));
  1204	                    fltRows.Add(MzPeakParquet.EmptyList(list)); strRows.Add(MzPeakParquet.EmptyList(list));
  1205	                    boolRows.Add(MzPeakParquet.EmptyList(list));
  1206	                    continue;
  1207	                }
  1208	
  1209	                foreach (var it in items) { CollectPrefix(it.Accession); CollectPrefix(it.Unit); }
  1210	                AddListLeaf(accRows, accVals, accLeaf, items, p => p.Accession);
  1211	                AddListLeaf(nameRows, nameVals, nameLeaf, items, p => p.Name);
  1212	                AddListLeaf(unitRows, unitVals, unitLeaf, items, p => p.Unit);
  1213	                AddListLeafNumStruct(intRows, intVals, intLeaf, items, p => p.Integer);
  1214	                AddListLeafNumStruct(fltRows, fltVals, fltLeaf, items, p => p.Float);
  1215	                AddListLeaf(strRows, strVals, strLeaf, items, p => p.String);
  1216	                AddListLeafNumStruct(boolRows, boolVals, boolLeaf, items, p => p.Boolean);
  1217	            }
  1218	
  1219	            Emit(cols, accLeaf, accVals.ToArray(), accRows);
  1220	            Emit(cols, nameLeaf, nameVals.ToArray(), nameRows);
  1221	            Emit(cols, unitLeaf, unitVals.ToArray(), unitRows);
  1222	            Emit(cols, intLeaf, intVals.ToArray(), intRows);
  1223	            Emit(cols, fltLeaf, fltVals.ToArray(), fltRows);
  1224	            Emit(cols, strLeaf, strVals.ToArray(), strRows);
  1225	            Emit(cols, boolLeaf, boolVals.ToArray(), boolRows);
  1226	        }
