   718	
   719	        // A point-facet (spectra_data / spectra_peaks) streamed to a seekable temp file in bounded row
   720	        // groups. Staging buffers accumulate per scan and flush at the cap; the final residual buffer is
   721	        // flushed by Close, which also attaches the footer KV before disposing the writer.
   722	        private sealed class PointFacetStream : IDisposable
   723	        {
   724	            public readonly string TempPath;
   725	            private readonly ParquetSchema _schema;
   726	            private readonly DataField _idx, _mz, _int;
   727	            private readonly int _cap;
   728	            private FileStream _sink;
   729	            private MzPeakParquet.Handle _handle;
   730	            private readonly List<ulong> _bIdx = new List<ulong>();
   731	            private readonly List<double> _bMz = new List<double>();
   732	            private readonly List<float> _bInt = new List<float>();
   733	
   734	            public long PointCount { get; private set; }
   735	
   736	            public PointFacetStream(int cap)
   737	            {
   738	                _cap = cap;
   739	                TempPath = Path.GetTempFileName();
   740	                _schema = new ParquetSchema(PointStructField());
   741	                _idx = Leaf(_schema, "point/spectrum_index");
   742	                _mz = Leaf(_schema, "point/mz");
   743	                _int = Leaf(_schema, "point/intensity");
   744	                _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
   745	                _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
   746	            }
   747	
   748	            public void Append(ulong ordinal, double[] mz, float[] intensity)
   749	            {
   750	                for (int i = 0; i < mz.Length; i++)
   751	                {
   752	                    _bIdx.Add(ordinal); _bMz.Add(mz[i]); _bInt.Add(intensity[i]);
   753	                }
   754	                PointCount += mz.Length;
   755	                if (_bIdx.Count >= _cap) Flush();
   756	            }
   757	
   758	            private void Flush()
   759	            {
   760	                if (_bIdx.Count == 0) return;
   761	                var cols = new Dictionary<DataField, (Array, int[], int[])>
   762	                {
   763	                    [_idx] = (_bIdx.ToArray(), null, null),
   764	                    [_mz] = (_bMz.ToArray(), null, null),
   765	                    [_int] = (_bInt.ToArray(), null, null)
   766	                };
   767	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
   768	                _bIdx.Clear(); _bMz.Clear(); _bInt.Clear();
   769	            }
   770	
   771	            // Finalize order: flush residual buffer -> CloseAsync(final KV) disposes the writer -> dispose
   772	            // the temp FileStream. After this returns the temp file is fully on disk.
   773	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
   774	            {
   775	                Flush();
   776	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
   777	                _handle = null;
   778	                _sink.Dispose();
   779	                _sink = null;
   780	            }
   781	
   782	            public void Dispose()
   783	            {
   784	                _handle?.Dispose();
   785	                _sink?.Dispose();
   786	            }
   787	        }
   788	
   789	        // A chrom-data facet streamed to a seekable temp file. Bounded by scan count anyway; streamed for
   790	        // uniformity with the point facets.
   791	        private sealed class ChromDataFacetStream : IDisposable
   792	        {
   793	            public readonly string TempPath;
   794	            private readonly ParquetSchema _schema;
   795	            private readonly DataField _idx, _time, _int, _lvl;
   796	            private readonly int _cap;
   797	            private FileStream _sink;
   798	            private MzPeakParquet.Handle _handle;
   799	            private readonly List<ulong> _bIdx = new List<ulong>();
   800	            private readonly List<double> _bTime = new List<double>();
   801	            private readonly List<float> _bInt = new List<float>();
   802	            private readonly List<long> _bLvl = new List<long>();
   803	
   804	            public long PointCount { get; private set; }
   805	
   806	            public ChromDataFacetStream(int cap)
   807	            {
   808	                _cap = cap;
   809	                TempPath = Path.GetTempFileName();
   810	                _schema = new ParquetSchema(ChromDataStructField());
   811	                _idx = Leaf(_schema, "point/chromatogram_index");
   812	                _time = Leaf(_schema, "point/time");
   813	                _int = Leaf(_schema, "point/intensity");
   814	                _lvl = Leaf(_schema, "point/ms_level");
   815	                _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
   816	                _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
   817	            }
   818	
   819	            public void Append(double time, float intensity, long msLevel)
   820	            {
   821	                _bIdx.Add(0UL); _bTime.Add(time); _bInt.Add(intensity); _bLvl.Add(msLevel);
   822	                PointCount++;
   823	                if (_bIdx.Count >= _cap) Flush();
   824	            }
   825	
   826	            private void Flush()
   827	            {
   828	                if (_bIdx.Count == 0) return;
   829	                var cols = new Dictionary<DataField, (Array, int[], int[])>
   830	                {
   831	                    [_idx] = (_bIdx.ToArray(), null, null),
   832	                    [_time] = (_bTime.ToArray(), null, null),
   833	                    [_int] = (_bInt.ToArray(), null, null),
   834	                    [_lvl] = (_bLvl.ToArray(), null, null)
   835	                };
   836	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
   837	                _bIdx.Clear(); _bTime.Clear(); _bInt.Clear(); _bLvl.Clear();
   838	            }
