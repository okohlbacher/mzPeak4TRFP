   527	                new DataField<string>("id", true),
   528	                new DataField<sbyte>(Cv("MS:1000465", "scan_polarity"), true),
   529	                new DataField<string>(Cv("MS:1000626", "chromatogram_type"), true),
   530	                new DataField<string>("data_processing_ref", true),
   531	                new DataField<ulong>(Cv("MS:1003060", "number_of_data_points"), true),
   532	                new ListField("parameters", MzPeakParquet.BuildParamField("item")),
   533	                new ListField("auxiliary_arrays", BuildAuxArrayField("item")),
   534	                new DataField<uint>("number_of_auxiliary_arrays", true));
