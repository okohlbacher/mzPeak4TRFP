  1002	                new DataField<float>(Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"), true),
  1003	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
  1004	            var activation = new StructField("activation",
  1005	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
  1006	            return new StructField("precursor",
  1007	                new DataField<ulong>("source_index", true),
  1008	                new DataField<ulong>("precursor_index", true),
  1009	                new DataField<string>("precursor_id", true),
  1010	                isolationWindow,
  1011	                activation);
  1012	        }
  1013	
  1014	        private StructField BuildSelectedIonField()
