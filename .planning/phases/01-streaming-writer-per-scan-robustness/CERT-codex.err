   455	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.Parquet);
   456	            parseInput.NoPeakPicking = new HashSet<int> { 1, 2 };
   457	
   458	            RawFileParser.Parse(parseInput);
   459	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   460	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   461	
   462	            // Actual test
