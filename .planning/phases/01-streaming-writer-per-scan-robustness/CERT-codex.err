  1104	        [Test]
  1105	        public void Chromatograms_Add_No_New_CvPrefix()
  1106	        {
  1107	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1108	            var dir = Convert(input, out var archive);
  1109	            try
  1110	            {
  1111	                var index = JObject.Parse(
  1112	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
  1113	                var ids = ((JArray)index["metadata"]["cv_list"]).Select(e => (string)e["id"]).ToHashSet();
  1114	                Assert.That(ids, Is.EquivalentTo(new[] { "MS", "UO" }),
  1115	                    "chromatograms introduce no new CV prefix and no version bump");
  1116	            }
  1117	            finally
  1118	            {
  1119	                Directory.Delete(dir, true);
  1120	            }
  1121	        }
  1122	
  1123	        // The generated cv_list must be genuinely exhaustive: it is finalized only after the chromatogram
  1124	        // facets have contributed their CURIEs, so every prefix that any chromatogram column or term uses
  1125	        // (chromatogram type, time/intensity/ms-level array terms and their units) appears in cv_list.
  1126	        [Test]
  1127	        public void CvList_Covers_Chromatogram_Introduced_Prefixes()
  1128	        {
  1129	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1130	            var dir = Convert(input, out var archive);
  1131	            try
  1132	            {
  1133	                var index = JObject.Parse(
  1134	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
  1135	                var ids = ((JArray)index["metadata"]["cv_list"]).Select(e => (string)e["id"]).ToHashSet();
  1136	
  1137	                // Prefixes the chromatogram facets introduce via their CV-named columns and array terms.
  1138	                var chromCuries = new[]
  1139	                {
  1140	                    "MS:1000235", "MS:1000626", "MS:1000595", "MS:1000786",
  1141	                    "UO:0000031", "UO:0000186"
  1142	                };
  1143	                foreach (var curie in chromCuries)
  1144	                {
  1145	                    var prefix = curie.Substring(0, curie.IndexOf(':'));
  1146	                    Assert.That(ids, Does.Contain(prefix),
  1147	                        $"cv_list must declare the chromatogram-introduced prefix {prefix} (from {curie})");
  1148	                }
  1149	            }
  1150	            finally
  1151	            {
  1152	                Directory.Delete(dir, true);
  1153	            }
  1154	        }
  1155	
  1156	        // L1 is an independent value check: our spectra_data m/z (f64) is compared bit-exact, per
  1157	        // spectrum, against the m/z array re-read directly from small.RAW (Scan.FromFile().SegmentedScan
  1158	        // .Positions) -- the source is NOT derived from our archive. The Thermo SegmentedScan returns
  1159	        // Positions sorted but Intensities in acquisition order (the two arrays are not index-paired and
  1160	        // their nonzero counts differ from the writer's realigned output), so re-deriving the exact
  1161	        // per-point intensity pairing from the SegmentedScan alone would require re-implementing the
  1162	        // reader's internal realignment. The differential suite (MzPeakDifferentialTests) compares
  1163	        // intensities value-for-value only over the reference-profile spectra. To avoid overclaiming
  1164	        // beyond that scope, this test asserts L2 here as a structural invariant for every emitted
  1165	        // spectrum (intensity is f32, finite, and the per-spectrum point count equals
  1166	        // number_of_data_points) and additionally runs an independent intensity check against an mzML
  1167	        // re-export of the same RAW for every spectrum that has a clean point-for-point correspondence,
  1168	        // so the value-equality claim rests on a source not derived from our archive.
  1169	        [Test]
  1170	        public void RoundTrip_L1_Mz_BitExact_Vs_IndependentRawRead_L2_Intensity_F32_Structural()
  1171	        {
  1172	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
  1173	            var dir = Convert(input, out var archive);
  1174	            try
  1175	            {
  1176	                using (var ms = new MemoryStream(ReadEntry(archive, "spectra_data.parquet")))
  1177	                using (var reader = ParquetReader.CreateAsync(ms).Result)
  1178	                {
  1179	                    Assert.That(Leaf(reader.Schema, "point/mz").ClrType, Is.EqualTo(typeof(double)), "m/z f64");
  1180	                    Assert.That(Leaf(reader.Schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)), "intensity f32");
  1181	                }
  1182	
  1183	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
  1184	                var ourMz = new Dictionary<ulong, List<double>>();
  1185	                var ourInt = new Dictionary<ulong, List<float>>();
  1186	                for (int i = 0; i < data.SpectrumIndex.Length; i++)
  1187	                {
  1188	                    var o = data.SpectrumIndex[i];
  1189	                    if (!ourMz.ContainsKey(o)) { ourMz[o] = new List<double>(); ourInt[o] = new List<float>(); }
  1190	                    ourMz[o].Add(data.Mz[i]);
  1191	                    ourInt[o].Add(data.Intensity[i]);
  1192	                }
  1193	
  1194	                var meta = PyArrowEntry(archive, "spectra_metadata.parquet",
  1195	                    "import pyarrow.parquet as pq, json\n" +
  1196	                    "t = pq.read_table(r'{PARQUET}')\n" +
  1197	                    "d = t.to_pylist()\n" +
  1198	                    "out = {'ndp':[int(d[i]['spectrum']['MS_1003060_number_of_data_points']) for i in range(len(d))]}\n" +
  1199	                    "print(json.dumps(out))\n");
  1200	                var ndp = meta["ndp"].Select(x => (int)x).ToArray();
  1201	                int n = ndp.Length;
  1202	
  1203	                using (var raw = RawFileReaderFactory.ReadFile(TestRawFile))
  1204	                {
  1205	                    raw.SelectInstrument(Device.MS, 1);
  1206	                    int first = raw.RunHeaderEx.FirstSpectrum;
  1207	                    int last = raw.RunHeaderEx.LastSpectrum;
  1208	                    var ordinalScan = new List<int>();
  1209	                    for (int scan = first; scan <= last; scan++)
  1210	                    {
  1211	                        var sf = raw.GetFilterForScanNumber(scan);
  1212	                        int lvl = (int)sf.MSOrder;
  1213	                        if (lvl > input.MaxLevel || !input.MsLevel.Contains(lvl)) continue;
  1214	                        var seg = Scan.FromFile(raw, scan).SegmentedScan;
  1215	                        if (seg.Positions == null || seg.Positions.Length == 0) continue;
  1216	                        ordinalScan.Add(scan);
  1217	                    }
  1218	
  1219	                    Assert.That(ordinalScan.Count, Is.EqualTo(n),
  1220	                        "ordinal->scan mapping must cover every emitted spectrum");
  1221	
  1222	                    for (ulong ord = 0; ord < (ulong)n; ord++)
  1223	                    {
  1224	                        int scan = ordinalScan[(int)ord];
  1225	                        var seg = Scan.FromFile(raw, scan).SegmentedScan;
  1226	                        // Source m/z, ascending (positions are returned sorted); independent of our archive.
  1227	                        var srcMz = (double[])seg.Positions.Clone();
  1228	                        Array.Sort(srcMz);
  1229	
  1230	                        var aMz = ourMz[ord].ToArray();
  1231	                        var aInt = ourInt[ord].ToArray();
  1232	
  1233	                        Assert.That(aMz.Length, Is.EqualTo(srcMz.Length),
  1234	                            $"ordinal {ord}: our m/z count must equal independent source count");
  1235	                        Assert.That(aMz.Length, Is.EqualTo(ndp[(int)ord]),
  1236	                            $"ordinal {ord}: count must equal number_of_data_points");
  1237	
  1238	                        for (int k = 0; k < aMz.Length; k++)
  1239	                        {
  1240	                            // L1: m/z bit-exact f64 vs the independently re-read source array.
  1241	                            Assert.That(aMz[k], Is.EqualTo(srcMz[k]),
  1242	                                $"ordinal {ord} m/z[{k}] not bit-exact vs independent source");
  1243	                            if (k > 0)
  1244	                                Assert.That(aMz[k], Is.GreaterThanOrEqualTo(aMz[k - 1]),
  1245	                                    $"ordinal {ord} m/z non-decreasing at {k}");
  1246	                            // L2 structural invariant: intensity is finite f32 for every emitted point.
  1247	                            Assert.That(float.IsFinite(aInt[k]), Is.True, $"ordinal {ord} intensity[{k}] finite");
  1248	                        }
  1249	                    }
  1250	                }
  1251	
  1252	                // Independent intensity check for the spectra the differential suite does NOT cover by
  1253	                // value: re-export the same RAW to a profile mzML (a source not derived from our archive)
  1254	                // and compare its decoded intensity arrays, narrowed to f32, against our spectra_data for
  1255	                // every spectrum whose m/z arrays correspond point-for-point. Spectra without a clean
  1256	                // correspondence are reported as structural-only and are not claimed value-equal.
  1257	                AssertIntensityMatchesIndependentMzml(dir, archive, ourMz, ourInt);
  1258	            }
  1259	            finally
  1260	            {
  1261	                Directory.Delete(dir, true);
  1262	            }
  1263	        }
  1264	
  1265	        // Re-exports the test RAW to a profile mzML in-process, decodes its binaryDataArrays in Python
  1266	        // (honoring each array's own 32/64-bit + zlib CV flags), and asserts that, for every emitted
  1267	        // spectrum with a bit-exact m/z correspondence, our f32-narrowed spectra_data intensities equal
  1268	        // the mzML intensities narrowed to f32. The mzML is an independent re-derivation of the RAW, so
  1269	        // matching intensities certify L2 value-equality beyond the differential suite's profile subset.
  1270	        private static void AssertIntensityMatchesIndependentMzml(string dir, string archive,
  1271	            Dictionary<ulong, List<double>> ourMz, Dictionary<ulong, List<float>> ourInt)
  1272	        {
  1273	            var python = ResolvePython();
  1274	            if (python == null) Assert.Ignore("python3 not available");
  1275	
  1276	            var mzml = Path.Combine(dir, "small.indep.profile.mzML");
  1277	            var mzmlInput = new ParseInput(TestRawFile, null, dir, OutputFormat.MzML)
  1278	            {
  1279	                NoPeakPicking = ParseInput.AllLevels
  1280	            };
  1281	            RawFileParser.Parse(mzmlInput);
  1282	            // TRFP names the mzML output after the RAW stem; relocate it to the deterministic path.
  1283	            var produced = Path.Combine(dir, "small.mzML");
  1284	            if (File.Exists(produced) && !File.Exists(mzml)) File.Move(produced, mzml);
  1285	            Assert.That(File.Exists(mzml), "independent profile mzML must exist");
  1286	
  1287	            // Decode the mzML into ordered per-spectrum (mz, intensity) f64 arrays. Index order in the
  1288	            // mzML matches our ordinal order (same scan-range filter, same source), so we compare by
  1289	            // position and only where the m/z arrays correspond exactly.
  1290	            var script = Path.Combine(dir, "decode_mzml.py");
  1291	            File.WriteAllText(script, DecodeMzmlScript);
  1292	            var psi = new ProcessStartInfo(python, $"\"{script}\" \"{mzml}\"")
  1293	            {
  1294	                RedirectStandardOutput = true,
  1295	                RedirectStandardError = true,
  1296	                UseShellExecute = false
  1297	            };
  1298	            string stdout, stderr;
  1299	            using (var proc = Process.Start(psi))
  1300	            {
  1301	                stdout = proc.StandardOutput.ReadToEnd();
  1302	                stderr = proc.StandardError.ReadToEnd();
  1303	                proc.WaitForExit();
  1304	                Assert.That(proc.ExitCode, Is.EqualTo(0), $"mzML decode failed: {stderr}");
  1305	            }
  1306	
  1307	            var spectra = (JArray)JObject.Parse(stdout.Trim())["spectra"];
  1308	            int compared = 0, structuralOnly = 0;
  1309	            for (int i = 0; i < spectra.Count; i++)
  1310	            {
  1311	                var ord = (ulong)i;
  1312	                if (!ourMz.ContainsKey(ord)) { structuralOnly++; continue; }
  1313	                var refMz = ((JArray)spectra[i]["mz"]).Select(x => (double)x).ToArray();
  1314	                var refInt = ((JArray)spectra[i]["intensity"]).Select(x => (double)x).ToArray();
  1315	                var aMz = ourMz[ord];
  1316	                var aInt = ourInt[ord];
  1317	
  1318	                // Only claim value-equality where the two m/z arrays correspond point-for-point.
  1319	                bool corresponds = refMz.Length == aMz.Count;
  1320	                for (int k = 0; corresponds && k < refMz.Length; k++)
  1321	                    if (refMz[k] != aMz[k]) corresponds = false;
  1322	
  1323	                if (!corresponds) { structuralOnly++; continue; }
  1324	
  1325	                compared++;
  1326	                for (int k = 0; k < refInt.Length; k++)
  1327	                {
  1328	                    // Both sides narrowed to f32: our archive stores f32, the mzML carries f64 that the
  1329	                    // writer would have narrowed identically.
  1330	                    Assert.That(aInt[k], Is.EqualTo((float)refInt[k]),
  1331	                        $"ordinal {ord} intensity[{k}] must equal the independent mzML intensity (f32)");
  1332	                }
  1333	            }
  1334	
  1335	            Assert.That(compared, Is.GreaterThan(0),
  1336	                "at least one emitted spectrum must have a bit-exact m/z correspondence to compare by value");
  1337	            TestContext.Out.WriteLine(
