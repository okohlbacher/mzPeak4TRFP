   481	        private byte[] BuildChromatogramMetadataFacet(int n)
   482	        {
   483	            var chromatogram = BuildChromatogramField();
   484	            var precursor = BuildPrecursorField();
   485	            var selectedIon = BuildSelectedIonField();
   486	            var schema = new ParquetSchema(chromatogram, precursor, selectedIon);
   487	
   488	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
   489	            var present = new[] { true };
   490	
   491	            AddScalar(cols, schema, "chromatogram/index", new ulong[] { 0UL }, present);
   492	            AddScalar(cols, schema, "chromatogram/id", new[] { "TIC" }, present);
   493	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1000465", "scan_polarity"),
   494	                new sbyte[] { 0 }, present);
   495	            CollectPrefix("MS:1000235");
   496	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1000626", "chromatogram_type"),
   497	                new[] { "MS:1000235" }, present);
   498	
   499	            var dprLeaf = Leaf(schema, "chromatogram/data_processing_ref");
   500	            var dprRows = new[] { MzPeakParquet.AtLevel(dprLeaf.MaxDefinitionLevel - 1, false) };
   501	            var (dprDef, _) = MzPeakParquet.NestedLevels(dprLeaf, dprRows);
   502	            cols[dprLeaf] = (new string[0], dprDef, null);
   503	
   504	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1003060", "number_of_data_points"),
   505	                new ulong[] { (ulong)n }, present);
   506	
   507	            AddEmptyList(cols, schema, "chromatogram/parameters");
   508	            AddEmptyAuxList(cols, schema, "chromatogram/auxiliary_arrays");
   509	            AddScalar(cols, schema, "chromatogram/number_of_auxiliary_arrays", new uint[] { 0u }, present);
   510	
   511	            AddNullPrecursor(cols, schema);
   512	            AddNullSelectedIon(cols, schema);
   513	
   514	            var custom = new Dictionary<string, string>
   515	            {
   516	                ["chromatogram_count"] = "1",
   517	                ["chromatogram_data_point_count"] = "0"
   518	            };
   519	
   520	            return WriteFacet(schema, custom, cols);
   521	        }
