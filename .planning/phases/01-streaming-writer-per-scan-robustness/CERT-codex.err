    66	        private static (int code, string stdout, string stderr) Run(string file, string args)
    67	        {
    68	            var psi = new ProcessStartInfo(file, args)
    69	            {
    70	                RedirectStandardOutput = true,
    71	                RedirectStandardError = true,
    72	                UseShellExecute = false
    73	            };
    74	            psi.EnvironmentVariables["DOTNET_ROLL_FORWARD"] = "LatestMajor";
    75	            psi.EnvironmentVariables["DOTNET_ROLL_FORWARD_TO_PRERELEASE"] = "1";
    76	            using (var p = Process.Start(psi))
    77	            {
    78	                var so = p.StandardOutput.ReadToEnd();
    79	                var se = p.StandardError.ReadToEnd();
    80	                p.WaitForExit();
    81	                return (p.ExitCode, so, se);
    82	            }
    83	        }
