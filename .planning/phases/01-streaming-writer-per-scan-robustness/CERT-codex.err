    67	                new[] { 1, 0, 1 }, null);
    68	
    69	            Assert.That(nameCol.DefinitionLevels, Is.EqualTo(new[] { 5, 5, 0, 2 }));
    70	            Assert.That(nameCol.RepetitionLevels, Is.EqualTo(new[] { 0, 1, 0, 0 }));
    71	            Assert.That(indexCol.DefinitionLevels, Is.EqualTo(new[] { 1, 0, 1 }));
    72	            Assert.That(indexCol.RepetitionLevels, Is.Null);
