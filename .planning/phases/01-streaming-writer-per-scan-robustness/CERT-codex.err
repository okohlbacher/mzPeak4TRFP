    23	                    new XicUnit()
    24	                    {
    25	                        Meta = new XicMeta()
    26	                        {
    27	                            MzStart = null,
    28	                            MzEnd = null,
    29	                            RtStart = null,
    30	                            RtEnd = null
    31	                        }
    32	                    }
    33	                }
    34	            };
    35	
    36	            XicParameters xicparams = new XicParameters();
