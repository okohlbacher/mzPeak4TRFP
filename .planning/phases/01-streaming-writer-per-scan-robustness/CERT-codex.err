   130	
   131	        // Test seam mirroring the per-scan commit ordering for the shared precursor-resolution map. A
   132	        // scan whose read/build fails NEVER calls Commit*, so the precursor-map entry is not written and
   133	        // a later child cannot resolve its parent through the skipped scan. Returns the assigned ordinal.
   134	        internal ulong CommitScanForTest(string filterKey, int scanNumber, ref ulong ordinal,
   135	            IDictionary<int, ulong> scanNumberToOrdinal)
   136	        {
   137	            var assigned = ordinal;
   138	            scanNumberToOrdinal[scanNumber] = assigned;
   139	            _precursorScanNumbers[filterKey] = scanNumber;
   140	            ordinal++;
   141	            return assigned;
   142	        }
   143	
   144	        // Resolve a child's parent scan number via the same shared map the writer uses, then map it to an
   145	        // emitted ordinal (null when the parent was skipped/filtered and never committed).
   146	        internal ulong? ResolveParentOrdinalForTest(string parentFilterKey,
   147	            IDictionary<int, ulong> scanNumberToOrdinal)
   148	        {
   149	            if (!_precursorScanNumbers.TryGetValue(parentFilterKey, out var parentScan)) return null;
   150	            if (parentScan <= 0) return null;
   151	            return scanNumberToOrdinal.TryGetValue(parentScan, out var ord) ? ord : (ulong?)null;
   152	        }
   153	
   154	        public override void Write(IRawDataPlus raw, int firstScanNumber, int lastScanNumber)
   155	        {
   156	            if (!raw.HasMsData)
   157	            {
   158	                throw new RawFileParserException("No MS data in RAW file, no output will be produced");
   159	            }
   160	
   161	            var instData = raw.GetInstrumentData();
   162	            _instrumentModel = instData.Model;
   163	            _instrumentSerial = instData.SerialNumber;
   164	            _creationDate = raw.CreationDate;
   165	            _sourceName = Path.GetFileName(ParseInput.RawFilePath);
   166	            _sourceLocation = "file://" + (Path.GetDirectoryName(Path.GetFullPath(ParseInput.RawFilePath)) ?? "");
   167	
   168	            var records = new List<Record>();
   169	            var scanNumberToOrdinal = new Dictionary<int, ulong>();
   170	            var peakSpectra = new HashSet<ulong>();
   171	
   172	            ulong ordinal = 0;
   173	
   174	            var dataFacet = new PointFacetStream(Cap);
   175	            var peaksFacet = new PointFacetStream(Cap);
   176	            var chromFacet = new ChromDataFacetStream(Cap);
   177	
   178	            try
   179	            {
   180	                for (var scanNumber = firstScanNumber; scanNumber <= lastScanNumber; scanNumber++)
   181	                {
   182	                    // Per-scan all-or-nothing staging: every read/build lands in locals first; nothing
   183	                    // touches shared/streaming state until the scan fully succeeds. A read/build failure
   184	                    // logs + NewError + skips, consuming no ordinal, no rows, no precursor-map entry.
   185	                    double[] stagedMz = null, stagedPeakMz = null;
   186	                    float[] stagedInten = null, stagedPeakInten = null;
   187	                    Record rec = null;
   188	                    string filterKey = null;
   189	                    bool stage;
   190	
   191	                    try
   192	                    {
   193	                        var scanFilter = raw.GetFilterForScanNumber(scanNumber);
   194	                        int level = (int)scanFilter.MSOrder;
   195	                        if (level > ParseInput.MaxLevel || !ParseInput.MsLevel.Contains(level)) continue;
   196	
   197	                        var scanEvent = raw.GetScanEventForScanNumber(scanNumber);
   198	                        var mzData = ReadMZData(raw, scanEvent, scanNumber, false, false, false);
   199	
   200	                        var (mz, inten) = OrderedPairs(mzData.masses, mzData.intensities);
   201	                        if (mz.Length == 0) continue;
   202	                        stagedMz = mz;
   203	                        stagedInten = inten;
   204	
   205	                        ulong? peakCount = null;
   206	                        if (scanEvent.ScanData == ScanDataType.Profile && Scan.FromFile(raw, scanNumber).HasCentroidStream)
   207	                        {
   208	                            var peakData = ReadMZData(raw, scanEvent, scanNumber, true, false, false);
   209	                            var (pMz, pInten) = OrderedPairs(peakData.masses, peakData.intensities);
   210	                            if (pMz.Length > 0)
   211	                            {
   212	                                stagedPeakMz = pMz;
   213	                                stagedPeakInten = pInten;
   214	                                peakCount = (ulong)pMz.Length;
   215	                            }
   216	                        }
   217	
   218	                        var scanStats = raw.GetScanStatsForScanNumber(scanNumber);
   219	                        var trailer = new ScanTrailer(raw.GetTrailerExtraInformation(scanNumber));
   220	
   221	                        // Mirror the mzML parent-derivation bookkeeping: map each scan's filter prefix to
   222	                        // its scan number so an MSn child can resolve its parent via the scan string.
   223	                        var filterMatch = level == 1
   224	                            ? null
   225	                            : (level == 2
   226	                                ? _filterStringIsolationMzPattern.Match(scanEvent.ToString())
   227	                                : _filterStringParentMzPattern.Match(scanEvent.ToString()));
   228	                        filterKey = level == 1 ? "" : (filterMatch != null && filterMatch.Success ? filterMatch.Groups[1].Value : "");
   229	
   230	                        rec = new Record
   231	                        {
   232	                            Ordinal = ordinal,
   233	                            ScanNumber = scanNumber,
   234	                            MsLevel = level,
   235	                            Id = ConstructSpectrumTitle((int)Device.MS, 1, scanNumber),
   236	                            Time = raw.RetentionTimeFromScanNumber(scanNumber),
   237	                            Polarity = scanFilter.Polarity == PolarityType.Negative ? (sbyte)-1 : (sbyte)1,
   238	                            Representation = mzData.isCentroided ? "MS:1000127" : "MS:1000128",
   239	                            SpectrumType = level == 1 ? "MS:1000579" : "MS:1000580",
   240	                            LowestMz = mz[0],
   241	                            HighestMz = mz[mz.Length - 1],
   242	                            BasePeakMz = mzData.basePeakMass ?? 0.0,
   243	                            BasePeakIntensity = (float)(mzData.basePeakIntensity ?? 0.0),
   244	                            TotalIonCurrent = (float)scanStats.TIC,
   245	                            DataPointCount = (ulong)mz.Length,
   246	                            PeakCount = peakCount,
   247	                            ScanStartTime = (float)raw.RetentionTimeFromScanNumber(scanNumber),
   248	                            FilterString = scanEvent.ToString(),
   249	                            IonInjectionTime = (float)(trailer.AsDouble("Ion Injection Time (ms):") ?? 0.0),
   250	                            InstrumentConfigRef = AnalyzerIndex(scanFilter.MassAnalyzer, scanFilter.IonizationMode),
   251	                            WindowLower = (float)scanStats.LowMass,
   252	                            WindowUpper = (float)scanStats.HighMass
   253	                        };
   254	
   255	                        if (level >= 2)
   256	                        {
   257	                            BuildPrecursor(raw, scanNumber, scanEvent, scanFilter, trailer, scanNumberToOrdinal,
   258	                                filterKey, rec);
   259	                        }
   260	
   261	                        stage = true;
   262	                    }
   263	                    catch (Exception ex)
   264	                    {
   265	                        Log.Error($"Scan #{scanNumber} cannot be processed because of the following exception: {ex.Message}");
   266	                        Log.Debug($"{ex.StackTrace}\n{ex.InnerException}");
   267	                        ParseInput.NewError();
   268	                        continue;
   269	                    }
   270	
   271	                    if (!stage) continue;
   272	
   273	                    // Commit block: scan fully succeeded. Apply ALL staged state atomically, including the
   274	                    // shared precursor-resolution map (S2) — a scan that failed above never reaches here,
   275	                    // so it cannot poison a later child's parent lookup. A write/flush/IO failure here is
   276	                    // FATAL (bytes may already be on disk) and must propagate, never be swallowed as a skip.
   277	                    dataFacet.Append(ordinal, stagedMz, stagedInten);
   278	                    if (stagedPeakMz != null)
   279	                    {
   280	                        peaksFacet.Append(ordinal, stagedPeakMz, stagedPeakInten);
   281	                        peakSpectra.Add(ordinal);
   282	                    }
   283	                    records.Add(rec);
   284	                    scanNumberToOrdinal[scanNumber] = ordinal;
   285	                    _precursorScanNumbers[filterKey] = scanNumber;
   286	                    ordinal++;
   287	                }
   288	
   289	                if (ordinal == 0)
   290	                {
   291	                    throw new RawFileParserException("No in-range spectrum to write");
   292	                }
   293	
   294	                // Device TIC over the whole run (minutes, one value per scan in scan order), paired with
   295	                // the per-scan (RT, ms_level) records. The device-trace value is the reference TIC; the
   296	                // summed ScanStatistics.TIC differs for MS1 and is used only when the trace is unavailable.
   297	                var chromTime = new List<double>();
   298	                var chromIntensity = new List<float>();
   299	                var chromMsLevel = new List<long>();
   300	                CaptureTic(raw, records, chromTime, chromIntensity, chromMsLevel);
   301	                for (int i = 0; i < chromTime.Count; i++)
   302	                    chromFacet.Append(chromTime[i], chromIntensity[i], chromMsLevel[i]);
   303	
   304	                var hasPeaks = peaksFacet.PointCount > 0;
   305	
   306	                // Chromatogram facets contribute their own CURIE prefixes; register them before the
   307	                // metadata facet so the generated cv_list — finalized inside the metadata facet — covers
   308	                // every prefix the archive uses.
   309	                RegisterChromDataPrefixes();
   310	
   311	                var dataMeta = PointFooter((int)ordinal, dataFacet.PointCount);
   312	                var peaksMeta = PointFooter(peakSpectra.Count, peaksFacet.PointCount);
   313	                var chromMeta = new Dictionary<string, string>
   314	                {
   315	                    ["chromatogram_data_point_count"] = "0",
   316	                    ["chromatogram_array_index"] = ChromatogramArrayIndex,
   317	                    ["chromatogram_tic_source"] = _chromFromDeviceTrace ? "device" : "summed"
   318	                };
   319	
   320	                dataFacet.Close(dataMeta);
   321	                peaksFacet.Close(peaksMeta);
   322	                chromFacet.Close(chromMeta);
   323	
   324	                var chromMetaBytes = BuildChromatogramMetadataFacet(records.Count);
   325	                var metaBytes = BuildMetadataFacet(records);
   326	                var indexBytes = BuildIndex(hasPeaks, true);
   327	
   328	                ConfigureWriter(".mzpeak");
   329	                try
   330	                {
   331	                    using (var zip = new ZipArchive(Writer.BaseStream, ZipArchiveMode.Create, true))
   332	                    {
   333	                        AddStored(zip, "mzpeak_index.json", indexBytes);
   334	                        AddStoredFromFile(zip, "spectra_data.parquet", dataFacet.TempPath);
   335	                        AddStored(zip, "spectra_metadata.parquet", metaBytes);
   336	                        if (hasPeaks) AddStoredFromFile(zip, "spectra_peaks.parquet", peaksFacet.TempPath);
   337	                        AddStored(zip, "chromatograms_metadata.parquet", chromMetaBytes);
   338	                        AddStoredFromFile(zip, "chromatograms_data.parquet", chromFacet.TempPath);
   339	                    }
   340	
   341	                    Writer.Flush();
   342	                }
   343	                finally
   344	                {
   345	                    Writer.Close();
   346	                }
   347	
   348	                Log.Info($"Wrote mzPeak archive with {ordinal} spectra ({dataFacet.PointCount} data points, " +
   349	                         $"{peaksFacet.PointCount} peak points, {chromFacet.PointCount} TIC points)");
   350	            }
   351	            finally
   352	            {
   353	                dataFacet.Dispose();
   354	                peaksFacet.Dispose();
   355	                chromFacet.Dispose();
   356	                TryDelete(dataFacet.TempPath);
   357	                TryDelete(peaksFacet.TempPath);
   358	                TryDelete(chromFacet.TempPath);
   359	            }
   360	        }
   361	
   362	        private static void TryDelete(string path)
   363	        {
   364	            try { if (path != null && File.Exists(path)) File.Delete(path); }
   365	            catch { }
   366	        }
