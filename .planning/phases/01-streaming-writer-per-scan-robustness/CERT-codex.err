   426	                        Is.EqualTo(new[] { "MS:1000133", "MS:1000045" }));
   427	                    var floats = o["row0_floats"].Select(x => x.Type == Newtonsoft.Json.Linq.JTokenType.Null ? (double?)null : (double)x).ToArray();
   428	                    Assert.That(floats, Is.EqualTo(new double?[] { null, 35.0 }));
   429	                    Assert.That((double)o["row0_iso_target"], Is.EqualTo(810.7).Within(0.05));
   430	                    Assert.That((float)o["row0_window_lower"], Is.EqualTo(200f));
   431	                }
   432	            }
   433	            finally
   434	            {
   435	                File.Delete(path);
   436	            }
   437	        }
   438	
   439	        // For a value/* sibling leaf never populated in any element, every element entry is one level
   440	        // below the present level (null inside present element) mirroring the accession's rep pattern.
   441	        private static int[] NullLeaf(ParquetSchema schema, string path, int[] siblingDef, int[] siblingRep)
   442	        {
   443	            var leaf = Leaf(schema, path);
   444	            int present = leaf.MaxDefinitionLevel;
   445	            var def = new int[siblingDef.Length];
   446	            for (int i = 0; i < siblingDef.Length; i++)
   447	            {
   448	                // mirror sibling: element-present sibling levels become leaf-null (present-1);
   449	                // empty/null list levels carry through unchanged.
   450	                def[i] = siblingDef[i] >= present ? present - 1 : siblingDef[i];
   451	            }
   452	            return def;
   453	        }
   454	
   455	        private static int[] UnitLevels(int[] accDef, int present)
   456	        {
   457	            // unit present only for the collision-energy element (2nd entry); first present element
   458	            // (CID) has no unit -> present-1. Empty/null entries carry through unchanged.
   459	            var def = (int[])accDef.Clone();
   460	            int seenPresent = 0;
   461	            for (int i = 0; i < def.Length; i++)
   462	            {
   463	                if (def[i] == present)
   464	                {
   465	                    seenPresent++;
   466	                    if (seenPresent == 1) def[i] = present - 1; // CID: no unit
   467	                }
   468	            }
   469	            return def;
   470	        }
   471	
   472	        private static string ResolvePython()
   473	        {
   474	            foreach (var cand in new[] { "python3", "python" })
   475	            {
   476	                try
   477	                {
   478	                    var psi = new ProcessStartInfo(cand, "-c \"import pyarrow\"")
   479	                    {
   480	                        RedirectStandardOutput = true,
   481	                        RedirectStandardError = true,
   482	                        UseShellExecute = false
   483	                    };
   484	                    using (var p = Process.Start(psi))
   485	                    {
   486	                        p.WaitForExit();
   487	                        if (p.ExitCode == 0) return cand;
   488	                    }
   489	                }
   490	                catch { }
   491	            }
   492	            return null;
   493	        }
   494	
   495	        private static string Quote(string s) => "\"" + s.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"";
   496	
   497	        [Test]
   498	        public void WrittenFile_ReportsZstdCompression()
   499	        {
   500	            var spectrum = new StructField("spectrum", new DataField<ulong>("index"));
   501	            var schema = new ParquetSchema(spectrum);
   502	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   503	            {
   504	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 0 }, new[] { 1 }, null)
   505	            };
   506	
   507	            var ms = new MemoryStream();
   508	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string>(),
   509	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   510	
   511	            ms.Position = 0;
   512	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   513	            {
   514	                var columns = reader.Metadata.RowGroups[0].Columns;
   515	                Assert.That(columns, Is.Not.Empty);
   516	                foreach (var c in columns)
   517	                    Assert.That(c.MetaData.Codec, Is.EqualTo(Parquet.Meta.CompressionCodec.ZSTD));
   518	
   519	                var rg = reader.OpenRowGroupReader(0);
   520	                var col = rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result;
   521	                Assert.That(col.Data, Is.EqualTo(new ulong[] { 0 }));
   522	            }
   523	        }
   524	
   525	        private static ParquetSchema PointSchema()
   526	        {
   527	            var point = new StructField("point",
   528	                new DataField<ulong>("spectrum_index"),
   529	                new DataField<double>("mz"),
   530	                new DataField<float>("intensity"));
   531	            return new ParquetSchema(point);
   532	        }
   533	
   534	        private static Dictionary<DataField, (Array, int[], int[])> PointSlice(ParquetSchema schema,
   535	            ulong[] index, double[] mz, float[] intensity)
   536	        {
   537	            return new Dictionary<DataField, (Array, int[], int[])>
   538	            {
   539	                [Leaf(schema, "point/spectrum_index")] = (index, null, null),
   540	                [Leaf(schema, "point/mz")] = (mz, null, null),
   541	                [Leaf(schema, "point/intensity")] = (intensity, null, null)
   542	            };
   543	        }
