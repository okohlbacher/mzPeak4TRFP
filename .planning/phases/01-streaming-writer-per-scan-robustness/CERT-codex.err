   339	        [Test]
   340	        public void TestIndexedMzML()
   341	        {
   342	            // Get temp path for writing the test mzML
   343	            var tempFilePath = Path.GetTempPath();
   344	
   345	            Console.WriteLine(tempFilePath);
   346	
   347	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
   348	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.IndexMzML);
   349	
   350	            RawFileParser.Parse(parseInput);
   351	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   352	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   353	
   354	            Assert.That(File.Exists(Path.Combine(tempFilePath, "small.mzML")));
   355	            // Deserialize the mzML file
   356	            using (var fs = new FileStream(Path.Combine(tempFilePath, "small.mzML"), FileMode.Open,
   357	                FileAccess.Read, FileShare.ReadWrite))
   358	            {
   359	                var xmlSerializer = new XmlSerializer(typeof(indexedmzML));
   360	                var testMzMl = (indexedmzML)xmlSerializer.Deserialize(fs);
   361	
   362	                Assert.That(testMzMl.mzML.run.spectrumList.count, Is.EqualTo("48"));
   363	                Assert.That(testMzMl.mzML.run.spectrumList.spectrum.Length, Is.EqualTo(48));
   364	
   365	                Assert.That(testMzMl.mzML.run.chromatogramList.count, Is.EqualTo("1"));
   366	                Assert.That(testMzMl.mzML.run.chromatogramList.chromatogram.Length, Is.EqualTo(1));
   367	
   368	                Assert.That(testMzMl.indexList.index.Length, Is.EqualTo(2));
   369	                Assert.That(testMzMl.indexList.index[0].name.ToString(), Is.EqualTo("spectrum"));
   370	                Assert.That(testMzMl.indexList.index[0].offset.Length, Is.EqualTo(48));
   371	                Assert.That(testMzMl.indexList.index[1].name.ToString(), Is.EqualTo("chromatogram"));
   372	                Assert.That(testMzMl.indexList.index[1].offset.Length, Is.EqualTo(1));
   373	            }
   374	
   375	            File.Delete(Path.Combine(tempFilePath, "small.mzML"));
   376	        }
