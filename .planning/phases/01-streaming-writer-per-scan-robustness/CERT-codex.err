   200	        [Test]
   201	        public void NestedLevels_Reproduces_CheatSheet_Levels()
   202	        {
   203	            var paramItem = new StructField("item",
   204	                new DataField<string>("name"), new DataField<double>("val", true));
   205	            var paramsList = new ListField("parameters", paramItem);
   206	            var mzRange = new StructField("mz_range",
   207	                new DataField<double>("lo"), new DataField<double>("hi"));
   208	            var spectrum = new StructField("spectrum",
   209	                new DataField<ulong>("index"), mzRange, paramsList);
   210	            var schema = new ParquetSchema(spectrum);
   211	
   212	            var indexLeaf = Leaf(schema, "spectrum/index");
   213	            var loLeaf = Leaf(schema, "spectrum/mz_range/lo");
   214	            var nameLeaf = Leaf(schema, "spectrum/parameters/list/item/name");
   215	            var valLeaf = Leaf(schema, "spectrum/parameters/list/item/val");
   216	
   217	            // top struct leaf: max-def 1 -> [1,0,1]
   218	            Assert.That(indexLeaf.MaxDefinitionLevel, Is.EqualTo(1));
   219	            var (idxDef, idxRep) = MzPeakParquet.NestedLevels(indexLeaf, new[]
   220	            {
   221	                MzPeakParquet.Present(indexLeaf), MzPeakParquet.Absent(), MzPeakParquet.Present(indexLeaf)
   222	            });
   223	            Assert.That(idxDef, Is.EqualTo(new[] { 1, 0, 1 }));
   224	            Assert.That(idxRep, Is.Null);
   225	
   226	            // nested struct-in-struct leaf: max-def 2 -> [2,0,2]
   227	            Assert.That(loLeaf.MaxDefinitionLevel, Is.EqualTo(2));
   228	            var (loDef, _) = MzPeakParquet.NestedLevels(loLeaf, new[]
   229	            {
   230	                MzPeakParquet.Present(loLeaf), MzPeakParquet.Absent(), MzPeakParquet.Present(loLeaf)
   231	            });
   232	            Assert.That(loDef, Is.EqualTo(new[] { 2, 0, 2 }));
   233	
   234	            // list-of-struct leaves: max-def 5; present-elem 5, leaf-null-in-elem 4, empty-list 2, null-list 0
   235	            Assert.That(nameLeaf.MaxDefinitionLevel, Is.EqualTo(5));
   236	            Assert.That(paramsList.MaxDefinitionLevel, Is.EqualTo(3));
   237	            // empty-list level for these leaves is the cheat-sheet 2 (= list MaxDef - 1)
   238	            Assert.That(MzPeakParquet.EmptyList(paramsList).Cells[0], Is.EqualTo(2));
   239	            // row0: 2 elements (both name present); row1: null list; row2: empty list
   240	            var (nDef, nRep) = MzPeakParquet.NestedLevels(nameLeaf, new[]
   241	            {
   242	                MzPeakParquet.ListOf(new[] { 5, 5 }, new[] { true, true }),
   243	                MzPeakParquet.NullList(),
   244	                MzPeakParquet.EmptyList(paramsList)
   245	            });
   246	            Assert.That(nDef, Is.EqualTo(new[] { 5, 5, 0, 2 }));
   247	            Assert.That(nRep, Is.EqualTo(new[] { 0, 1, 0, 0 }));
   248	
   249	            // val: row0 elem0 present (5), elem1 null (4); row1 null list; row2 empty list
   250	            var (vDef, vRep) = MzPeakParquet.NestedLevels(valLeaf, new[]
   251	            {
   252	                MzPeakParquet.ListOf(new[] { 5, 4 }, new[] { true, false }),
   253	                MzPeakParquet.NullList(),
   254	                MzPeakParquet.EmptyList(paramsList)
   255	            });
   256	            Assert.That(vDef, Is.EqualTo(new[] { 5, 4, 0, 2 }));
   257	            Assert.That(vRep, Is.EqualTo(new[] { 0, 1, 0, 0 }));
   258	        }
