   764	        [Test]
   765	        public void Metadata_CvList_Covers_Collected_Set_In_Index_And_Footer()
   766	        {
   767	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   768	            var dir = Convert(input, out var archive);
   769	            try
   770	            {
   771	                var metaBytes = ReadEntry(archive, "spectra_metadata.parquet");
   772	
   773	                var index = JObject.Parse(
   774	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
   775	                var metadata = (JObject)index["metadata"];
   776	                var idxCv = (JArray)metadata["cv_list"];
   777	                Assert.That(idxCv, Is.Not.Null.And.Not.Empty);
   778	
   779	                var footer = FooterKv(metaBytes);
   780	                Assert.That(footer.ContainsKey("cv_list"), "footer carries cv_list");
   781	
   782	                // Authoritative set: schema column CURIEs PLUS every accession/unit recursively gathered
   783	                // from the index metadata blocks AND the footer JSON blocks (PARAM lists, components, ...).
   784	                var collected = CollectAllCvPrefixes(metaBytes, metadata);
   785	                var footerBlocks = new JObject();
   786	                foreach (var key in new[]
   787	                    {
   788	                        "file_description", "instrument_configuration_list", "software_list",
   789	                        "data_processing_method_list", "run"
   790	                    })
   791	                {
   792	                    if (footer.TryGetValue(key, out var raw)) footerBlocks[key] = JToken.Parse(raw);
   793	                }
   794	                CollectCuriePrefixes(footerBlocks, collected);
   795	                Assert.That(collected, Is.Not.Empty, "metadata must use CV-named columns and params");
   796	
   797	                var idxIds = idxCv.Select(e => (string)e["id"]).ToHashSet();
   798	                Assert.That(idxIds, Is.EquivalentTo(collected),
   799	                    $"index cv_list {string.Join(",", idxIds.OrderBy(x => x))} must EQUAL collected " +
   800	                    $"{string.Join(",", collected.OrderBy(x => x))} -- no hard-coded extras, nothing missing");
   801	                foreach (var e in idxCv)
   802	                {
   803	                    Assert.That((string)e["id"], Is.Not.Null.And.Not.Empty);
   804	                    Assert.That((string)e["version"], Is.Not.Null.And.Not.Empty);
   805	                    Assert.That((string)e["uri"], Is.Not.Null.And.Not.Empty);
   806	                }
   807	
   808	                var footCv = JArray.Parse(footer["cv_list"]);
   809	                var footIds = footCv.Select(e => (string)e["id"]).ToHashSet();
   810	                Assert.That(footIds, Is.EquivalentTo(collected),
   811	                    "footer cv_list must EQUAL the collected CV-prefix set exactly");
   812	                Assert.That(footIds, Is.EquivalentTo(idxIds), "index and footer cv_list agree");
   813	            }
   814	            finally
   815	            {
   816	                Directory.Delete(dir, true);
   817	            }
   818	        }
