  1613	        [Test]
  1614	        public void BadScanFile_Converts_To_Completion_With_Skip_And_Parity()
  1615	        {
  1616	            var raw = Path.Combine(
  1617	                Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
  1618	                "Claude", "mzML2mzPeak", "data", "raw-replacements",
  1619	                "bruker-impact-sub__PXD076459", "S4_5foldGHRP.raw");
  1620	            if (!File.Exists(raw)) Assert.Ignore($"corpus bad-scan file not present: {raw}");
  1621	
  1622	            var dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
  1623	            Directory.CreateDirectory(dir);
  1624	            var input = new ParseInput(raw, null, dir, OutputFormat.MzPeak);
  1625	            try
  1626	            {
  1627	                // ROB-01 contract: an unreadable scan must NEVER abort the conversion with an unhandled
  1628	                // throw; it is logged and ParseInput.NewError()-counted instead. This corpus file is a
  1629	                // Finnigan RAW whose scan-event index is corrupt: every scan raises "Cannot get scan
  1630	                // event". The robustness path must absorb every one of them without crashing.
  1631	                Assert.DoesNotThrow(() => RawFileParser.Parse(input),
  1632	                    "bad scans must not abort the conversion with an unhandled exception");
  1633	                Assert.That(input.Errors, Is.GreaterThanOrEqualTo(1),
  1634	                    "each skipped scan is error-counted");
  1635	
  1636	                var archive = Path.Combine(dir, "S4_5foldGHRP.mzpeak");
  1637	                if (File.Exists(archive))
  1638	                {
  1639	                    // If any scan was readable, the produced archive must hold facet/metadata parity and
  1640	                    // dense ordinals despite the skips (ROB-02).
  1641	                    var data = ReadAllRowGroups(ReadEntry(archive, "spectra_data.parquet"));
  1642	                    var metaIdx = ReadMetadataIndices(ReadEntry(archive, "spectra_metadata.parquet"));
  1643	
  1644	                    int distinct = data.SpectrumIndex.Distinct().Count();
  1645	                    Assert.That(distinct, Is.EqualTo(data.SpectrumCount), "distinct spectrum_index == spectrum_count");
  1646	                    Assert.That(metaIdx.Length, Is.EqualTo(data.SpectrumCount), "metadata rows == spectrum_count");
  1647	                    Assert.That(metaIdx.OrderBy(x => x).ToArray(),
  1648	                        Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()),
  1649	                        "ordinals dense 0..N-1 despite the skips");
  1650	                }
  1651	                else
  1652	                {
  1653	                    // Every scan was unreadable -> graceful completion with no output is the correct
  1654	                    // degenerate behavior (the writer raises a clean "No in-range spectrum" rather than a
  1655	                    // corrupt partial archive). The no-abort + error-count assertions above are the gate.
  1656	                    Assert.That(input.Errors, Is.GreaterThan(25000),
  1657	                        "every scan in this corrupt file is skipped and counted");
  1658	                }
  1659	            }
  1660	            finally
  1661	            {
  1662	                Directory.Delete(dir, true);
  1663	            }
  1664	        }
