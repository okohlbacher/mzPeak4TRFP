   945	        [Test]
   946	        public void Chromatogram_Data_Facet_Shape_And_PerScan_Alignment()
   947	        {
   948	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   949	            var dir = Convert(input, out var archive);
   950	            try
   951	            {
   952	                using (var ms = new MemoryStream(ReadEntry(archive, "chromatograms_data.parquet")))
   953	                using (var reader = ParquetReader.CreateAsync(ms).Result)
   954	                {
   955	                    var schema = reader.Schema;
   956	                    Assert.That(Leaf(schema, "point/chromatogram_index").ClrType, Is.EqualTo(typeof(ulong)));
   957	                    Assert.That(Leaf(schema, "point/time").ClrType, Is.EqualTo(typeof(double)));
   958	                    Assert.That(Leaf(schema, "point/intensity").ClrType, Is.EqualTo(typeof(float)));
   959	                    Assert.That(Leaf(schema, "point/ms_level").ClrType, Is.EqualTo(typeof(long)));
   960	                }
   961	
   962	                var chrom = ReadChromFacet(ReadEntry(archive, "chromatograms_data.parquet"));
   963	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   964	                int n = data.SpectrumCount;
   965	
   966	                Assert.That(chrom.Time.Length, Is.EqualTo(n), "one TIC point per emitted scan");
   967	                Assert.That(chrom.TicSource, Is.EqualTo("device"),
   968	                    "default conversion must take the device-trace path, not the summed fallback");
   969	                Assert.That(chrom.ChromatogramIndex.All(x => x == 0UL), Is.True, "single chromatogram, index all 0");
   970	                var levels = chrom.MsLevel.Distinct().OrderBy(x => x).ToArray();
   971	                Assert.That(levels, Is.EqualTo(new long[] { 1, 2 }), "ms_level multiset {1,2}, never 0");
   972	
   973	                // Per-scan spectrum (time, ms_level) read from spectra_metadata, aligned by ordinal.
   974	                var snippet =
   975	                    "import pyarrow.parquet as pq, json\n" +
   976	                    "t = pq.read_table(r'{PARQUET}')\n" +
   977	                    "d = t.to_pylist()\n" +
   978	                    "out = {'time':[d[i]['spectrum']['time'] for i in range(len(d))],\n" +
   979	                    "       'lvl':[int(d[i]['spectrum']['MS_1000511_ms_level']) for i in range(len(d))]}\n" +
   980	                    "print(json.dumps(out))\n";
   981	                var o = PyArrowEntry(archive, "spectra_metadata.parquet", snippet);
   982	                var sTime = o["time"].Select(x => (double)x).ToArray();
   983	                var sLvl = o["lvl"].Select(x => (long)x).ToArray();
   984	
   985	                Assert.That(sTime.Length, Is.EqualTo(n));
   986	                for (int i = 0; i < n; i++)
   987	                {
   988	                    Assert.That(chrom.Time[i], Is.EqualTo(sTime[i]).Within(1e-6),
   989	                        $"TIC time[{i}] must equal spectrum time");
   990	                    Assert.That(chrom.MsLevel[i], Is.EqualTo(sLvl[i]),
   991	                        $"TIC ms_level[{i}] must equal spectrum ms_level");
   992	                }
   993	                for (int i = 1; i < n; i++)
   994	                    Assert.That(chrom.Time[i], Is.GreaterThanOrEqualTo(chrom.Time[i - 1]), "time non-decreasing");
   995	            }
   996	            finally
   997	            {
   998	                Directory.Delete(dir, true);
   999	            }
  1000	        }
