  1027	        private string Cv(string accession, string label, string unit = null)
  1028	        {
  1029	            CollectPrefix(accession);
  1030	            if (unit != null) CollectPrefix(unit);
  1031	            return MzPeakParquet.CvColumn(accession, label, unit);
  1032	        }
  1033	
  1034	        private void CollectPrefix(string curie)
  1035	        {
  1036	            if (string.IsNullOrEmpty(curie)) return;
  1037	            var i = curie.IndexOf(':');
  1038	            if (i > 0) _cvPrefixes.Add(curie.Substring(0, i));
  1039	        }
  1040	
  1041	        private static void AddScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1042	            string path, Array values, bool[] present)
  1043	        {
  1044	            var leaf = Leaf(schema, path);
  1045	            var rows = present.Select(p => p ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1046	            var (def, _r) = MzPeakParquet.NestedLevels(leaf, rows);
  1047	            cols[leaf] = (values, def, null);
  1048	        }
  1049	
  1050	        // A scalar leaf inside a top-level struct present only on the first M rows (the MSn count),
  1051	        // null on rows M..N-1. values has length M (one per MSn).
  1052	        private static void AddMsnScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1053	            string path, int n, Array values)
  1054	        {
  1055	            var leaf = Leaf(schema, path);
  1056	            int m = values.Length;
  1057	            var rows = Enumerable.Range(0, n)
  1058	                .Select(i => i < m ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1059	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1060	            cols[leaf] = (values, def, null);
  1061	        }
  1062	
  1063	        private static void AddMsnString(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1064	            string path, int n, string[] values)
  1065	        {
  1066	            var leaf = Leaf(schema, path);
  1067	            int m = values.Length;
  1068	            var rows = new List<MzPeakParquet.LeafRow>();
  1069	            var present = new List<string>();
  1070	            for (int i = 0; i < n; i++)
  1071	            {
  1072	                if (i >= m) rows.Add(MzPeakParquet.Absent());
  1073	                else if (values[i] != null) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i]); }
  1074	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
  1075	            }
  1076	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1077	            cols[leaf] = (present.ToArray(), def, null);
  1078	        }
  1079	
  1080	        private static void AddMsnPrecursorIndex(IDictionary<DataField, (Array, int[], int[])> cols,
  1081	            ParquetSchema schema, string path, int n, List<Record> msn)
  1082	        {
  1083	            var leaf = Leaf(schema, path);
  1084	            int m = msn.Count;
  1085	            var rows = new List<MzPeakParquet.LeafRow>();
  1086	            var present = new List<ulong>();
  1087	            for (int i = 0; i < n; i++)
  1088	            {
  1089	                if (i >= m) rows.Add(MzPeakParquet.Absent());
  1090	                else if (msn[i].PrecursorIndex.HasValue)
  1091	                { rows.Add(MzPeakParquet.Present(leaf)); present.Add(msn[i].PrecursorIndex.Value); }
  1092	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
  1093	            }
  1094	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1095	            cols[leaf] = (present.ToArray(), def, null);
  1096	        }
