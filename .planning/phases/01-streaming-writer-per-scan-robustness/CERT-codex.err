   162	        [Test]
   163	        public void SpectraData_Ascending_And_MultisetPreserved()
   164	        {
   165	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   166	            var dir = Convert(input, out var archive);
   167	            try
   168	            {
   169	                var facet = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   170	
   171	                Assert.That(facet.Mz.Length, Is.EqualTo(facet.PointCount));
   172	                Assert.That(facet.Mz.Length, Is.EqualTo(facet.SpectrumIndex.Length));
   173	                Assert.That(facet.Intensity.Length, Is.EqualTo(facet.PointCount));
   174	
   175	                for (int i = 1; i < facet.SpectrumIndex.Length; i++)
   176	                {
   177	                    if (facet.SpectrumIndex[i] == facet.SpectrumIndex[i - 1])
   178	                        Assert.That(facet.Mz[i], Is.GreaterThanOrEqualTo(facet.Mz[i - 1]),
   179	                            $"spectrum {facet.SpectrumIndex[i]} not non-decreasing at {i}");
   180	                }
   181	            }
   182	            finally
   183	            {
   184	                Directory.Delete(dir, true);
   185	            }
   186	        }
