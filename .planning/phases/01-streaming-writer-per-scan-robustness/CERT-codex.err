   417	        [Test]
   418	        public void TestParquetCentroid()
   419	        {
   420	            // Get temp path for writing the test output
   421	            var tempFilePath = Path.GetTempPath();
   422	
   423	            var testRawFile = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, @"Data/small.RAW");
   424	            var parseInput = new ParseInput(testRawFile, null, tempFilePath, OutputFormat.Parquet);
   425	
   426	            RawFileParser.Parse(parseInput);
   427	            Assert.That(parseInput.Errors, Is.EqualTo(0));
   428	            Assert.That(parseInput.Warnings, Is.EqualTo(0));
   429	
   430	            // Actual test
   431	            var parquetFilePath = Path.Combine(tempFilePath, "small.mzparquet");
   432	
   433	            Assert.That(File.Exists(parquetFilePath));
   434	            using (var parquetReader = ParquetReader.CreateAsync(parquetFilePath).Result)
   435	            {
   436	                var groupReader = parquetReader.OpenRowGroupReader(0);
   437	                var schema = parquetReader.Schema;
   438	                var scanColumn = groupReader.ReadColumnAsync(schema.FindDataField("scan")).Result;
   439	
   440	                Assert.That(scanColumn.NumValues, Is.EqualTo(48520));
   441	                Assert.That(scanColumn.Statistics.DistinctCount, Is.EqualTo(48));
   442	                Assert.That((from int p in scanColumn.Data where p == 22 select p).Count(), Is.EqualTo(1632));
   443	            }
   444	
   445	            File.Delete(parquetFilePath);
   446	        }
