   227	                catch (Exception ex)
   228	                {
   229	                    Log.Error($"Scan #{scanNumber} cannot be processed because of the following exception: {ex.Message}");
   230	                    Log.Debug($"{ex.StackTrace}\n{ex.InnerException}");
   231	                    ParseInput.NewError();
   232	                }
   233	            }
   234	
   235	            if (ordinal == 0)
   236	            {
   237	                throw new RawFileParserException("No in-range spectrum to write");
   238	            }
   239	
   240	            // Device TIC over the whole run (minutes, one value per scan in scan order), paired with
   241	            // the per-scan (RT, ms_level) records. The device-trace value is the reference TIC; the
   242	            // summed ScanStatistics.TIC differs for MS1 and is used only when the trace is unavailable.
   243	            var chromTime = new List<double>();
   244	            var chromIntensity = new List<float>();
   245	            var chromMsLevel = new List<long>();
   246	            CaptureTic(raw, records, chromTime, chromIntensity, chromMsLevel);
   247	
   248	            var hasPeaks = peaksIndex.Count > 0;
   249	            var dataBytes = BuildPointFacet(dataIndex, dataMz, dataIntensity, (int)ordinal);
   250	            var peaksBytes = hasPeaks
   251	                ? BuildPointFacet(peaksIndex, peaksMz, peaksIntensity, peakSpectra.Count)
   252	                : null;
   253	
   254	            // Chromatogram facets contribute their own CURIE prefixes (e.g. the chromatogram type and
   255	            // array-index terms); build them before the metadata facet so the generated cv_list — which
   256	            // is finalized inside the metadata facet — covers every prefix the archive actually uses.
   257	            var chromDataBytes = BuildChromatogramDataFacet(chromTime, chromIntensity, chromMsLevel);
   258	            var chromMetaBytes = BuildChromatogramMetadataFacet(records.Count);
   259	
   260	            var metaBytes = BuildMetadataFacet(records);
   261	            var indexBytes = BuildIndex(hasPeaks, true);
   262	
   263	            ConfigureWriter(".mzpeak");
   264	            try
   265	            {
   266	                using (var zip = new ZipArchive(Writer.BaseStream, ZipArchiveMode.Create, true))
   267	                {
   268	                    AddStored(zip, "mzpeak_index.json", indexBytes);
   269	                    AddStored(zip, "spectra_data.parquet", dataBytes);
   270	                    AddStored(zip, "spectra_metadata.parquet", metaBytes);
   271	                    if (hasPeaks) AddStored(zip, "spectra_peaks.parquet", peaksBytes);
   272	                    AddStored(zip, "chromatograms_metadata.parquet", chromMetaBytes);
   273	                    AddStored(zip, "chromatograms_data.parquet", chromDataBytes);
   274	                }
   275	
   276	                Writer.Flush();
   277	            }
   278	            finally
   279	            {
   280	                Writer.Close();
   281	            }
   282	
   283	            Log.Info($"Wrote mzPeak archive with {ordinal} spectra ({dataIndex.Count} data points, " +
   284	                     $"{peaksIndex.Count} peak points, {chromTime.Count} TIC points)");
   285	        }

