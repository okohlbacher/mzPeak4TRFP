   340	        [Test]
   341	        public void BitwiseMultiset_Chunked_Equals_Point()
   342	        {
   343	            var chunked = Convert(false, out var cdir);
   344	            var pointed = Convert(true, out var pdir);
   345	            try
   346	            {
   347	                // Decode chunked m/z with the null-aware delta decode, build per-spectrum BITWISE keys
   348	                // (DoubleToInt64Bits / SingleToInt32Bits), and compare the multisets to the point facet.
   349	                var decodeSnippet =
   350	                    "import pyarrow.parquet as pq, json, struct\n" +
   351	                    "from collections import defaultdict\n" +
   352	                    "def dd(start, arr):\n" +
   353	                    "    buf=[]; last=start\n" +
   354	                    "    if not arr: return [start]\n" +
   355	                    "    if arr[0] is None:\n" +
   356	                    "        if len(arr)>1 and arr[1] is None: buf.append(last)\n" +
   357	                    "        last=None\n" +
   358	                    "    else: buf.append(start)\n" +
   359	                    "    for it in arr:\n" +
   360	                    "        if it is not None:\n" +
   361	                    "            if last is not None: last=it+last; buf.append(last)\n" +
   362	                    "            else: buf.append(it); last=it\n" +
   363	                    "        else: buf.append(None); last=None\n" +
   364	                    "    return buf\n" +
   365	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   366	                    "si=t.field('spectrum_index').to_pylist(); cs=t.field('mz_chunk_start').to_pylist()\n" +
   367	                    "cv=t.field('mz_chunk_values').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   368	                    "d=defaultdict(list)\n" +
   369	                    "for i in range(len(si)):\n" +
   370	                    "    dmz=dd(cs[i], cv[i] if cv[i] is not None else [])\n" +
   371	                    "    for m,it in zip(dmz, inn[i]):\n" +
   372	                    "        if m is None or it is None: continue\n" +
   373	                    "        d[si[i]].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   374	                    "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   375	                var chunkKeys = PyArrow(chunked, "spectra_data.parquet", decodeSnippet);
   376	
   377	                var pointSnippet =
   378	                    "import pyarrow.parquet as pq, json, struct\n" +
   379	                    "from collections import defaultdict\n" +
   380	                    "t = pq.read_table(r'{PARQUET}').column('point').combine_chunks()\n" +
   381	                    "si=t.field('spectrum_index').to_pylist(); mz=t.field('mz').to_pylist(); inn=t.field('intensity').to_pylist()\n" +
   382	                    "d=defaultdict(list)\n" +
   383	                    "for s,m,it in zip(si,mz,inn):\n" +
   384	                    "    d[s].append([struct.unpack('<q',struct.pack('<d',float(m)))[0], struct.unpack('<i',struct.pack('<f',float(it)))[0]])\n" +
   385	                    "print(json.dumps({str(k):sorted(v) for k,v in d.items()}))\n";
   386	                var pointKeys = PyArrow(pointed, "spectra_data.parquet", pointSnippet);
   387	
   388	                Assert.That(chunkKeys.Properties().Select(p => p.Name).OrderBy(x => x),
   389	                    Is.EqualTo(pointKeys.Properties().Select(p => p.Name).OrderBy(x => x)),
   390	                    "same spectrum_index set");
   391	
   392	                int mzMismatch = 0, intMismatch = 0;
   393	                foreach (var prop in chunkKeys.Properties())
   394	                {
   395	                    var c = ((JArray)prop.Value).Select(a => ((long)a[0], (int)a[1])).OrderBy(x => x).ToArray();
   396	                    var p = ((JArray)pointKeys[prop.Name]).Select(a => ((long)a[0], (int)a[1])).OrderBy(x => x).ToArray();
   397	                    Assert.That(c.Length, Is.EqualTo(p.Length), $"spectrum {prop.Name} point count");
   398	                    var cMz = c.Select(x => x.Item1).ToArray(); var pMz = p.Select(x => x.Item1).ToArray();
   399	                    var cIn = c.Select(x => x.Item2).OrderBy(x => x).ToArray();
   400	                    var pIn = p.Select(x => x.Item2).OrderBy(x => x).ToArray();
   401	                    if (!cMz.SequenceEqual(pMz)) mzMismatch++;
   402	                    if (!cIn.SequenceEqual(pIn)) intMismatch++;
   403	                }
   404	                // Intensity is never delta-encoded -> must be bitwise-identical.
   405	                Assert.That(intMismatch, Is.EqualTo(0), "intensity is bitwise-identical chunked vs point");
   406	                // Empirical finding (recorded in SUMMARY): f64 delta encode+reconstruct is bit-exact on real
   407	                // Thermo m/z, so the m/z multiset matches bitwise with zero tolerance (exact / L1).
   408	                Assert.That(mzMismatch, Is.EqualTo(0),
   409	                    "m/z is BITWISE-identical chunked vs point (delta round-trip is bit-exact on Thermo m/z)");
   410	            }
   411	            finally { Directory.Delete(cdir, true); Directory.Delete(pdir, true); }
