   671	        private static Array EmptyArray(Type clr) => Array.CreateInstance(clr, 0);
   672	
   673	        private uint AnalyzerIndex(MassAnalyzerType analyzer, IonizationModeType ionization)
   674	        {
   675	            int idx = _analyzerOrder.IndexOf(analyzer);
   676	            if (idx < 0)
   677	            {
   678	                _analyzerOrder.Add(analyzer);
   679	                _ionizationOrder.Add(ionization);
   680	                idx = _analyzerOrder.Count - 1;
   681	            }
   682	            return (uint)idx;
   683	        }
   684	
   685	        private void BuildPrecursor(IRawDataPlus raw, int scanNumber, IScanEvent scanEvent,
   686	            IScanFilter scanFilter, ScanTrailer trailer, IDictionary<int, ulong> scanNumberToOrdinal,
   687	            string filterKey, Record rec)
   688	        {
   689	            rec.IsMsn = true;
   690	
   691	            // Parent scan via Master Scan Number trailer, falling back to the scan-string parent the
   692	            // mzML path derives. Map the parent scan number to its emitted ordinal; if the parent was
   693	            // filtered out / not emitted, keep the precursor entry but leave precursor_index null.
   694	            int parentScan;
   695	            var master = trailer.AsPositiveInt("Master Scan Number:");
   696	            if (master.HasValue) parentScan = master.Value;
   697	            else parentScan = GetParentFromScanString(filterKey);
   698	
   699	            if (parentScan > 0 && scanNumberToOrdinal.TryGetValue(parentScan, out var p))
   700	            {
   701	                rec.PrecursorIndex = p;
   702	                rec.PrecursorId = ConstructSpectrumTitle((int)Device.MS, 1, parentScan);
   703	            }
   704	
   705	            var reaction = GetReaction(scanEvent, scanNumber);
   706	            if (reaction == null) return;
   707	
   708	            double? isolationWidth = reaction.IsolationWidth;
   709	            if (isolationWidth < 0) isolationWidth = null;
   710	
   711	            rec.IsolationTarget = (float)reaction.PrecursorMass;
   712	            if (isolationWidth != null)
   713	            {
   714	                var offset = isolationWidth.Value / 2 + reaction.IsolationWidthOffset;
   715	                rec.IsolationLowerOffset = (float)(isolationWidth.Value - offset);
   716	                rec.IsolationUpperOffset = (float)offset;
   717	            }
   718	
   719	            if (OntologyMapping.DissociationTypes.TryGetValue(reaction.ActivationType, out var diss))
   720	            {
   721	                rec.ActivationParams.Add(new Param { Accession = diss.accession, Name = diss.name });
   722	            }
   723	
   724	            if (reaction.CollisionEnergyValid)
   725	            {
   726	                rec.ActivationParams.Add(new Param
   727	                {
   728	                    Accession = "MS:1000045",
   729	                    Name = "collision energy",
   730	                    Float = reaction.CollisionEnergy,
   731	                    Unit = "UO:0000266"
   732	                });
   733	            }
   734	
   735	            int? charge = trailer.AsPositiveInt("Charge State:");
   736	            double? monoisotopicMz = trailer.AsDouble("Monoisotopic M/Z:");
   737	            rec.SelectedIonMz = CalculateSelectedIonMz(reaction, monoisotopicMz, isolationWidth);
   738	            rec.ChargeState = charge;
   739	
   740	            // Selected-ion intensity is read FROM the parent spectrum, so it is only meaningful when
   741	            // the parent was actually emitted (a committed ordinal). A parent that was skipped/filtered
   742	            // out or whose read fails must never force this otherwise-readable child to fail: gate on
   743	            // the parent ordinal being known, and treat any parent-read error as "intensity unknown".
   744	            if (rec.SelectedIonMz > ZeroDelta && rec.PrecursorIndex.HasValue)
   745	            {
   746	                try
   747	                {
   748	                    rec.SelectedIonIntensity = (float)CalculatePrecursorPeakIntensity(raw, parentScan,
   749	                        reaction.PrecursorMass, isolationWidth,
   750	                        ParseInput.NoPeakPicking.Contains(rec.MsLevel - 1));
   751	                }
   752	                catch (Exception ex)
   753	                {
   754	                    Log.Warn($"Scan #{scanNumber}: parent #{parentScan} intensity unreadable, " +
   755	                             $"selected-ion intensity left null: {ex.Message}");
   756	                }
   757	            }
   758	        }
   759	
   760	        private static void AddStored(ZipArchive zip, string name, byte[] bytes)
   761	        {
   762	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   763	            using (var s = entry.Open())
   764	            {
   765	                s.Write(bytes, 0, bytes.Length);
   766	            }
   767	        }
   768	
   769	        // Streams a finished temp-file facet into a STORED zip entry via a 64 KB bounded CopyTo, never
   770	        // reading the whole facet into a byte[].
   771	        private static void AddStoredFromFile(ZipArchive zip, string name, string tempPath)
   772	        {
   773	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   774	            using (var es = entry.Open())
   775	            using (var src = File.OpenRead(tempPath))
   776	                src.CopyTo(es, 1 << 16);
   777	        }
