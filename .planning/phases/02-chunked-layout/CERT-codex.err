   375	out['rows'] = len(d)
   376	out['precursor_present'] = [r['precursor'] is not None and r['precursor']['source_index'] is not None for r in d]
   377	out['activation_present'] = [ (r['precursor'] is not None and r['precursor']['activation'] is not None) for r in d ]
