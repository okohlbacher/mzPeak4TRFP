   761	/// Find all positions which satisfy `is_zero_pair_mask` in the `column_index`th column in `batch`
   762	/// in `target_indices` columns.
   763	///
   764	/// # Panics
   765	/// If the array at `column_index` is a non-numeric or non-primitive array
   766	pub fn nullify_at_zero_pair(
   767	    batch: &RecordBatch,
   768	    column_index: usize,
   769	    target_indices: &[usize],
   770	) -> Result<RecordBatch, arrow::error::ArrowError> {
   771	    let (schema, mut cols, _row_count) = batch.clone().into_parts();
   772	
   773	    cols = nullify_at_zero_pair_arrays(cols, column_index, target_indices)?;
   774	
   775	    let schema: Vec<_> = schema
   776	        .fields()
   777	        .iter()
   778	        .map(|f| Arc::new(f.as_ref().clone().with_nullable(true)))
   779	        .collect();
   780	
   781	    RecordBatch::try_new(Arc::new(Schema::new(schema)), cols)
   782	}
