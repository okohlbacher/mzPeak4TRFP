   615	        // A present-but-empty list on a single-row facet (the list value is defined, no elements).
   616	        private void AddEmptyList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   617	            string listPath)
   618	        {
   619	            var list = (ListField)FindField(schema, listPath);
   620	            foreach (var leaf in schema.GetDataFields())
   621	            {
   622	                if (!leaf.Path.ToString().StartsWith(listPath + "/")) continue;
   623	                var rows = new[] { MzPeakParquet.EmptyList(list) };
   624	                var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   625	                cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   626	            }
   627	        }
   628	
   629	        // The auxiliary_arrays list is empty, but its element struct carries a non-nullable data leaf
   630	        // (data/list/item: uint8 not null); emit the same empty-list level for every descendant leaf.
   631	        private void AddEmptyAuxList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   632	            string listPath)
   633	        {
   634	            var list = (ListField)FindField(schema, listPath);
   635	            foreach (var leaf in schema.GetDataFields())
   636	            {
   637	                if (!leaf.Path.ToString().StartsWith(listPath + "/")) continue;
   638	                var rows = new[] { MzPeakParquet.EmptyList(list) };
   639	                var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   640	                cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   641	            }
   642	        }
   643	
   644	        private void AddNullPrecursor(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema)
   645	        {
   646	            foreach (var leaf in schema.GetDataFields())
   647	            {
   648	                if (!leaf.Path.ToString().StartsWith("precursor/")) continue;
   649	                AddNullLeaf(cols, leaf);
   650	            }
   651	        }
   652	
   653	        private void AddNullSelectedIon(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema)
   654	        {
   655	            foreach (var leaf in schema.GetDataFields())
   656	            {
   657	                if (!leaf.Path.ToString().StartsWith("selected_ion/")) continue;
   658	                AddNullLeaf(cols, leaf);
   659	            }
   660	        }
   661	
   662	        // A single all-null row for a leaf in a present-but-null top-level struct: definition level
   663	        // sits one below the leaf's own present level (the owning struct is null), no value slot.
   664	        private static void AddNullLeaf(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf)
   665	        {
   666	            var rows = new[] { MzPeakParquet.AtLevel(0, false) };
   667	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   668	            cols[leaf] = (EmptyArray(leaf.ClrType), def, rep);
   669	        }
