    49	        private static byte[] ReadEntry(string archive, string name)
    50	        {
    51	            using (var zip = ZipFile.OpenRead(archive))
    52	            {
    53	                var entry = zip.GetEntry(name);
    54	                if (entry == null) return null;
    55	                using (var s = entry.Open())
    56	                using (var ms = new MemoryStream())
    57	                {
    58	                    s.CopyTo(ms);
    59	                    return ms.ToArray();
    60	                }
    61	            }
    62	        }
    63	
    64	        private static Facet ReadPointFacet(byte[] bytes)
    65	        {
    66	            using (var ms = new MemoryStream(bytes))
    67	            using (var reader = ParquetReader.CreateAsync(ms).Result)
    68	            {
    69	                var schema = reader.Schema;
    70	                var rg = reader.OpenRowGroupReader(0);
    71	                var idx = rg.ReadColumnAsync(Leaf(schema, "point/spectrum_index")).Result.Data
    72	                    .Cast<ulong>().ToArray();
    73	                var mz = rg.ReadColumnAsync(Leaf(schema, "point/mz")).Result.Data
    74	                    .Cast<double>().ToArray();
    75	                var inten = rg.ReadColumnAsync(Leaf(schema, "point/intensity")).Result.Data
    76	                    .Cast<float>().ToArray();
    77	                var meta = reader.CustomMetadata;
    78	                return new Facet
    79	                {
    80	                    SpectrumIndex = idx,
    81	                    Mz = mz,
    82	                    Intensity = inten,
    83	                    SpectrumCount = int.Parse(meta["spectrum_count"]),
    84	                    PointCount = int.Parse(meta["spectrum_data_point_count"])
    85	                };
    86	            }
    87	        }
    88	
    89	        private static DataField Leaf(ParquetSchema schema, string path)
    90	        {
    91	            return schema.GetDataFields().First(d => d.Path.ToString() == path);
    92	        }
