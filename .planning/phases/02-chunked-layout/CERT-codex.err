   784	/// Delta-encode an Arrow array containing nulls. Nulls are encoded as null values, and treated as 0.0
   785	/// for the purposes of computing the next delta.
   786	///
   787	/// This is necessarily a copying operation
   788	pub fn null_delta_encode<T: ArrowPrimitiveType>(array: &PrimitiveArray<T>) -> PrimitiveArray<T>
   789	where
   790	    T::Native: Float,
   791	    PrimitiveArray<T>: From<Vec<Option<T::Native>>>,
   792	{
   793	    let mut buffer: Vec<Option<<T as ArrowPrimitiveType>::Native>> =
   794	        Vec::with_capacity(array.len());
   795	
   796	    if array.is_empty() {
   797	        return PrimitiveArray::from(buffer);
   798	    }
   799	
   800	    let mut it = array.iter();
   801	    let mut last = it.next().unwrap();
   802	    if last.is_none() {
   803	        buffer.push(last);
   804	    }
   805	    for item in it {
   806	        if let Some(val) = item {
   807	            if let Some(last_val) = last {
   808	                let delta = val - last_val;
   809	                buffer.push(Some(delta));
   810	                last = item;
   811	            } else {
   812	                buffer.push(item);
   813	                last = item;
   814	            }
   815	        } else {
   816	            buffer.push(item);
   817	            last = item;
   818	        }
   819	    }
   820	    PrimitiveArray::from(buffer)
   821	}
   822	
   823	/// Decode an Arrow array that was delta-encoded *with* nulls.
   824	///
   825	/// This is necessarily a copying operation.
   826	pub fn null_delta_decode<T: ArrowPrimitiveType>(
   827	    array: &PrimitiveArray<T>,
   828	    start: T::Native,
   829	) -> PrimitiveArray<T>
   830	where
   831	    T::Native: Float,
   832	    PrimitiveArray<T>: From<Vec<Option<T::Native>>>,
   833	{
   834	    let mut buffer: Vec<Option<<T as ArrowPrimitiveType>::Native>> =
   835	        Vec::with_capacity(array.len());
   836	    let mut last = Some(start);
   837	    if array.is_null(0) {
   838	        // If the buffer starts with two nulls, it means that the starting point of the chunk was
   839	        // a singleton peak at the chunk boundary, so we need to add it back
   840	        if array.len() > 1 && array.is_null(1) {
   841	            buffer.push(last);
   842	        }
   843	        // If the first delta is null, then the subsequent non-null point will have been encoded
   844	        // directly, not as a delta
   845	        last = None;
   846	    } else {
   847	        buffer.push(Some(start));
   848	    }
   849	
   850	    for item in array.iter() {
   851	        if let Some(val) = item {
   852	            if let Some(last_val) = last {
   853	                let delta = val + last_val;
   854	                buffer.push(Some(delta));
   855	                last = Some(delta);
   856	            } else {
   857	                buffer.push(item);
   858	                last = item;
   859	            }
   860	        } else {
   861	            buffer.push(item);
   862	            last = item;
   863	        }
   864	    }
   865	    PrimitiveArray::from(buffer)
   866	}
