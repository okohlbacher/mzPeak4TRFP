   168	        private static string RepoRoot()
   169	        {
   170	            var d = new DirectoryInfo(AppDomain.CurrentDomain.BaseDirectory);
   171	            while (d != null && !File.Exists(Path.Combine(d.FullName, ReferenceChunkedArchive)))
   172	                d = d.Parent;
   173	            return d?.FullName;
