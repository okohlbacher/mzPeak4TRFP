   176	        private static string TestRawFile =>
   177	            Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Data", "small.RAW");
   178	
   179	        private static string Convert(bool point, out string dir)
   180	        {
   181	            dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
   182	            Directory.CreateDirectory(dir);
   183	            var input = new ParseInput(TestRawFile, null, dir, OutputFormat.MzPeak)
   184	            {
   185	                MzPeakPointLayout = point
   186	            };
   187	            RawFileParser.Parse(input);
   188	            Assert.That(input.Errors, Is.EqualTo(0));
   189	            var archive = Path.Combine(dir, "small.mzpeak");
   190	            Assert.That(File.Exists(archive));
   191	            return archive;
   192	        }
