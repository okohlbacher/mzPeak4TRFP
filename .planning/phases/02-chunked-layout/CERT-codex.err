  1405	                    RedirectStandardError = true,
  1406	                    UseShellExecute = false
  1407	                };
  1408	                using (var p = Process.Start(psi))
  1409	                {
  1410	                    p.StandardOutput.ReadToEnd();
  1411	                    p.StandardError.ReadToEnd();
  1412	                    p.WaitForExit();
  1413	                }
  1414	
  1415	                Assert.That(File.Exists(jsonPath), "validator must emit a JSON report");
  1416	                var report = JObject.Parse(File.ReadAllText(jsonPath));
  1417	                var findings = (JArray)report["findings"];
  1418	
  1419	                var errors = findings.Where(f => (string)f["level"] == "error")
  1420	                    .Select(f => (string)f["ruleId"]).ToArray();
  1421	                var warnings = findings.Where(f => (string)f["level"] == "warning")
  1422	                    .Select(f => (string)f["ruleId"]).ToArray();
  1423	
  1424	                Assert.That(errors, Is.Empty, $"0 errors required; got {string.Join(",", errors)}");
  1425	                Assert.That(warnings, Is.Empty, $"0 warnings required; got {string.Join(",", warnings)}");
  1426	
  1427	                var chromRules = findings.Select(f => (string)f["ruleId"])
  1428	                    .Where(r => r != null && r.Contains("chromatogram")).ToArray();
  1429	                Assert.That(chromRules, Is.Empty,
  1430	                    $"no chromatogram-related finding: {string.Join(",", chromRules)}");
  1431	            }
  1432	            finally
  1433	            {
  1434	                if (File.Exists(jsonPath)) File.Delete(jsonPath);
  1435	                Directory.Delete(dir, true);
  1436	            }
  1437	        }
