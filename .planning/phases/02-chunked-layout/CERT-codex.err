    84	
    85	        // Reads both archives and emits a single JSON verdict. Decodes the reference chunk layout to
    86	        // absolute (m/z, intensity) pairs, builds TRFP's per-spectrum signal from its point layout, and
    87	        // compares the nonzero (m/z, intensity) multiset of every reference-profile spectrum. Centroid
    88	        // coverage is scoped to indices present in BOTH peaks facets (the reference centroids MS2 while
    89	        // TRFP keeps MS2 profile in spectra_data, so the centroid sets are disjoint here and the
    90	        // comparison is reported as skipped rather than dropped).
    91	        private const string CompareScript =
    92	            "import sys, json, zipfile, io, collections, struct\n" +
    93	            "import pyarrow.parquet as pq\n" +
    94	            "ref_path, trfp_path = sys.argv[1], sys.argv[2]\n" +
    95	            "def read(zpath, name):\n" +
    96	            "    z = zipfile.ZipFile(zpath)\n" +
    97	            "    return pq.read_table(io.BytesIO(z.read(name))).to_pylist() if name in z.namelist() else None\n" +
    98	            "ref_data = read(ref_path, 'spectra_data.parquet')\n" +
    99	            "ref = collections.defaultdict(list)\n" +
   100	            "for r in ref_data:\n" +
   101	            "    c = r['chunk']; si = c['spectrum_index']; mz = c['mz_chunk_start']\n" +
   102	            "    ref[si].append((mz, c['intensity'][0]))\n" +
   103	            "    for d, it in zip(c['mz_chunk_values'], c['intensity'][1:]):\n" +
   104	            "        mz += d; ref[si].append((mz, it))\n" +
   105	            "ref_profile_indices = sorted(ref.keys())\n" +
   106	            "ref_peaks = read(ref_path, 'spectra_peaks.parquet')\n" +
   107	            "refpk = collections.defaultdict(list)\n" +
   108	            "if ref_peaks:\n" +
   109	            "    for r in ref_peaks:\n" +
   110	            "        p = r['point']; refpk[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   111	            "trfp_data = read(trfp_path, 'spectra_data.parquet')\n" +
   112	            "trfp = collections.defaultdict(list)\n" +
   113	            "for r in trfp_data:\n" +
   114	            "    p = r['point']; trfp[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   115	            "trfp_peaks = read(trfp_path, 'spectra_peaks.parquet')\n" +
   116	            "trfppk = collections.defaultdict(list)\n" +
   117	            "if trfp_peaks:\n" +
   118	            "    for r in trfp_peaks:\n" +
   119	            "        p = r['point']; trfppk[p['spectrum_index']].append((p['mz'], p['intensity']))\n" +
   120	            "def meta_map(rows):\n" +
   121	            "    m = {}\n" +
   122	            "    for r in rows:\n" +
   123	            "        s = r['spectrum']; m[s['index']] = (s['MS_1000511_ms_level'], s.get('MS_1000465_scan_polarity'), s['time'])\n" +
   124	            "    return m\n" +
   125	            "rm = meta_map(read(ref_path, 'spectra_metadata.parquet'))\n" +
   126	            "tm = meta_map(read(trfp_path, 'spectra_metadata.parquet'))\n" +
   127	            "def nz(pairs):\n" +
   128	            "    c = collections.Counter()\n" +
   129	            "    for mz, it in pairs:\n" +
   130	            "        if it == 0: continue\n" +
   131	            "        c[(mz, struct.unpack('f', struct.pack('f', it))[0])] += 1\n" +
   132	            "    return c\n" +
   133	            "profile_ok = all(nz(ref[si]) == nz(trfp.get(si, [])) for si in ref_profile_indices)\n" +
   134	            "centroid_compared, centroid_skipped, centroid_ok = [], [], True\n" +
   135	            "for si in sorted(refpk.keys()):\n" +
   136	            "    if si in trfppk:\n" +
   137	            "        centroid_compared.append(si)\n" +
   138	            "        if nz(refpk[si]) != nz(trfppk[si]): centroid_ok = False\n" +
   139	            "    else:\n" +
   140	            "        centroid_skipped.append(si)\n" +
   141	            "out = {\n" +
   142	            "  'spectrum_count_ok': len(rm) == len(tm), 'ref_spectrum_count': len(rm), 'trfp_spectrum_count': len(tm),\n" +
   143	            "  'ms_level_ok': all(rm[i][0] == tm[i][0] for i in rm if i in tm),\n" +
   144	            "  'polarity_ok': all(rm[i][1] is None or tm.get(i,(None,None,None))[1] is None or rm[i][1]==tm[i][1] for i in rm),\n" +
   145	            "  'rt_ok': all(i in tm and abs(rm[i][2]-tm[i][2]) < 1e-3 for i in rm),\n" +
   146	            "  'profile_multiset_ok': profile_ok,\n" +
   147	            "  'ref_profile_indices': ref_profile_indices, 'ref_profile_count': len(ref_profile_indices),\n" +
   148	            "  'compared_indices': ref_profile_indices,\n" +
   149	            "  'centroid_indices_compared': centroid_compared, 'centroid_multiset_ok': centroid_ok,\n" +
   150	            "  'centroid_indices_skipped': centroid_skipped,\n" +
   151	            "}\n" +
   152	            "print(json.dumps(out))\n";
   153	
   154	        [Test]
   155	        public void Differential_Semantic_Equivalence_Vs_MzML2MzPeak()
   156	        {
   157	            var repoRoot = ResolveRepoRoot();
   158	            var dll = ResolveDll(repoRoot);
   159	            var m2m = ResolveMzml2Mzpeak();
   160	            var python = ResolvePython();
   161	
   162	            if (dll == null) Assert.Ignore("Release ThermoRawFileParser.dll not built");
   163	            if (m2m == null) Assert.Ignore("prebuilt mzml2mzpeak not available");
   164	            if (python == null) Assert.Ignore("python3.11/pyarrow not available");
   165	
   166	            var tmp = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
   167	            Directory.CreateDirectory(tmp);
   168	            var mzml = Path.Combine(tmp, "small.profile.mzML");
   169	            var refMzpeak = Path.Combine(tmp, "small.ref.mzpeak");
   170	            var trfpMzpeak = Path.Combine(tmp, "small.trfp.mzpeak");
   171	            var script = Path.Combine(tmp, "compare.py");
   172	
   173	            try
   174	            {
   175	                var s1 = Run("dotnet", $"\"{dll}\" -i \"{TestRawFile}\" -b \"{mzml}\" -f 1 -p");
   176	                Assert.That(s1.code, Is.EqualTo(0), $"RAW->profile mzML failed: {s1.stderr}");
   177	                Assert.That(File.Exists(mzml), "profile mzML must exist");
   178	
   179	                var s2 = Run(m2m, $"\"{mzml}\" \"{refMzpeak}\" --no-numpress");
   180	                Assert.That(s2.code, Is.EqualTo(0), $"mzML->ref mzpeak failed: {s2.stderr}");
   181	                Assert.That(File.Exists(refMzpeak), "reference mzpeak must exist");
   182	
   183	                var s3 = Run("dotnet", $"\"{dll}\" -i \"{TestRawFile}\" -b \"{trfpMzpeak}\" -f 4 --point");
   184	                Assert.That(s3.code, Is.EqualTo(0), $"RAW->trfp mzpeak failed: {s3.stderr}");
   185	                Assert.That(File.Exists(trfpMzpeak), "trfp mzpeak must exist");
   186	
   187	                File.WriteAllText(script, CompareScript);
   188	                var cmp = Run(python, $"\"{script}\" \"{refMzpeak}\" \"{trfpMzpeak}\"");
   189	                Assert.That(cmp.code, Is.EqualTo(0), $"comparison failed: {cmp.stderr}");
   190	
   191	                var o = JObject.Parse(cmp.stdout.Trim());
   192	
   193	                Assert.That((bool)o["spectrum_count_ok"], Is.True,
   194	                    $"spectrum count must agree ({o["ref_spectrum_count"]} vs {o["trfp_spectrum_count"]})");
   195	                Assert.That((bool)o["ms_level_ok"], Is.True, "per-index ms_level must agree");
   196	                Assert.That((bool)o["polarity_ok"], Is.True, "per-index polarity must agree");
   197	                Assert.That((bool)o["rt_ok"], Is.True, "per-index RT must agree within tolerance");
   198	                Assert.That((bool)o["profile_multiset_ok"], Is.True,
   199	                    "nonzero (m/z,intensity) multiset must match for every reference-profile spectrum");
   200	
   201	                Assert.That((int)o["ref_profile_count"], Is.EqualTo(14),
   202	                    "reference MS1-profile set is the 14 ms_level-1 spectra routed to spectra_data");
   203	                Assert.That((int)o["ref_profile_count"], Is.GreaterThan(0));
   204	
   205	                var refIdx = o["ref_profile_indices"].Select(x => (int)x).ToArray();
   206	                var cmpIdx = o["compared_indices"].Select(x => (int)x).ToArray();
   207	                Assert.That(cmpIdx, Is.EqualTo(refIdx),
   208	                    "the compared index set must equal the exact reference MS1-profile index set");
   209	
   210	                Assert.That((bool)o["centroid_multiset_ok"], Is.True,
   211	                    "reference-centroid spectra present in BOTH peaks facets must match (centroid coverage " +
   212	                    "is scoped to indices in both facets; the reference centroids MS2 while TRFP keeps MS2 " +
   213	                    "profile in spectra_data, so the disjoint set is reported as skipped, not dropped)");
   214	            }
   215	            finally
   216	            {
   217	                Directory.Delete(tmp, true);
   218	            }
   219	        }
   220	    }
   221	}

codex
The differential test does intentionally run TRFP with `--point`, so it still compares a point TRFP archive instead of trying to read chunked output as `r['point']`. I’m now validating whether the chunk implementation itself matches the Arrow reference and whether the docs state the chromatogram deviation honestly.
