  1267	
  1268	        // Re-exports the test RAW to a profile mzML in-process, decodes its binaryDataArrays in Python
  1269	        // (honoring each array's own 32/64-bit + zlib CV flags), and asserts that, for every emitted
  1270	        // spectrum with a bit-exact m/z correspondence, our f32-narrowed spectra_data intensities equal
  1271	        // the mzML intensities narrowed to f32. The mzML is an independent re-derivation of the RAW, so
  1272	        // matching intensities certify L2 value-equality beyond the differential suite's profile subset.
  1273	        private static void AssertIntensityMatchesIndependentMzml(string dir, string archive,
  1274	            Dictionary<ulong, List<double>> ourMz, Dictionary<ulong, List<float>> ourInt)
  1275	        {
  1276	            var python = ResolvePython();
  1277	            if (python == null) Assert.Ignore("python3 not available");
  1278	
  1279	            var mzml = Path.Combine(dir, "small.indep.profile.mzML");
  1280	            var mzmlInput = new ParseInput(TestRawFile, null, dir, OutputFormat.MzML)
  1281	            {
  1282	                NoPeakPicking = ParseInput.AllLevels
  1283	            };
  1284	            RawFileParser.Parse(mzmlInput);
  1285	            // TRFP names the mzML output after the RAW stem; relocate it to the deterministic path.
  1286	            var produced = Path.Combine(dir, "small.mzML");
  1287	            if (File.Exists(produced) && !File.Exists(mzml)) File.Move(produced, mzml);
  1288	            Assert.That(File.Exists(mzml), "independent profile mzML must exist");
  1289	
  1290	            // Decode the mzML into ordered per-spectrum (mz, intensity) f64 arrays. Index order in the
  1291	            // mzML matches our ordinal order (same scan-range filter, same source), so we compare by
  1292	            // position and only where the m/z arrays correspond exactly.
  1293	            var script = Path.Combine(dir, "decode_mzml.py");
  1294	            File.WriteAllText(script, DecodeMzmlScript);
  1295	            var psi = new ProcessStartInfo(python, $"\"{script}\" \"{mzml}\"")
  1296	            {
  1297	                RedirectStandardOutput = true,
  1298	                RedirectStandardError = true,
  1299	                UseShellExecute = false
  1300	            };
  1301	            string stdout, stderr;
  1302	            using (var proc = Process.Start(psi))
  1303	            {
  1304	                stdout = proc.StandardOutput.ReadToEnd();
  1305	                stderr = proc.StandardError.ReadToEnd();
  1306	                proc.WaitForExit();
  1307	                Assert.That(proc.ExitCode, Is.EqualTo(0), $"mzML decode failed: {stderr}");
  1308	            }
  1309	
  1310	            var spectra = (JArray)JObject.Parse(stdout.Trim())["spectra"];
  1311	            int compared = 0, structuralOnly = 0;
  1312	            for (int i = 0; i < spectra.Count; i++)
  1313	            {
  1314	                var ord = (ulong)i;
  1315	                if (!ourMz.ContainsKey(ord)) { structuralOnly++; continue; }
  1316	                var refMz = ((JArray)spectra[i]["mz"]).Select(x => (double)x).ToArray();
  1317	                var refInt = ((JArray)spectra[i]["intensity"]).Select(x => (double)x).ToArray();
  1318	                var aMz = ourMz[ord];
  1319	                var aInt = ourInt[ord];
  1320	
  1321	                // Only claim value-equality where the two m/z arrays correspond point-for-point.
  1322	                bool corresponds = refMz.Length == aMz.Count;
  1323	                for (int k = 0; corresponds && k < refMz.Length; k++)
  1324	                    if (refMz[k] != aMz[k]) corresponds = false;
  1325	
  1326	                if (!corresponds) { structuralOnly++; continue; }
  1327	
  1328	                compared++;
  1329	                for (int k = 0; k < refInt.Length; k++)
  1330	                {
  1331	                    // Both sides narrowed to f32: our archive stores f32, the mzML carries f64 that the
  1332	                    // writer would have narrowed identically.
  1333	                    Assert.That(aInt[k], Is.EqualTo((float)refInt[k]),
  1334	                        $"ordinal {ord} intensity[{k}] must equal the independent mzML intensity (f32)");
  1335	                }
  1336	            }
  1337	
  1338	            Assert.That(compared, Is.GreaterThan(0),
  1339	                "at least one emitted spectrum must have a bit-exact m/z correspondence to compare by value");
  1340	            TestContext.Out.WriteLine(
  1341	                $"independent intensity check: {compared} spectra value-equal, {structuralOnly} structural-only");
  1342	        }
  1343	
  1344	        // Standard-library mzML decoder: yields per-spectrum (mz, intensity) f64 arrays, decoding each
  1345	        // binaryDataArray per its own precision (32/64-bit float) and compression (zlib/none) CV flags.
  1346	        private const string DecodeMzmlScript =
  1347	            "import sys, json, base64, zlib, struct\n" +
  1348	            "import xml.etree.ElementTree as ET\n" +
  1349	            "path = sys.argv[1]\n" +
  1350	            "ns = {'m': 'http://psi.hupo.org/ms/mzml'}\n" +
  1351	            "tree = ET.parse(path); root = tree.getroot()\n" +
  1352	            "def localname(t):\n" +
  1353	            "    return t.rsplit('}', 1)[-1]\n" +
  1354	            "def decode_array(bda):\n" +
  1355	            "    accs = set()\n" +
  1356	            "    for cv in bda:\n" +
  1357	            "        if localname(cv.tag) == 'cvParam': accs.add(cv.get('accession'))\n" +
  1358	            "    bits = 64 if 'MS:1000523' in accs else (32 if 'MS:1000521' in accs else 64)\n" +
  1359	            "    zipped = 'MS:1000574' in accs\n" +
  1360	            "    is_mz = 'MS:1000514' in accs\n" +
  1361	            "    is_int = 'MS:1000515' in accs\n" +
  1362	            "    b64 = None\n" +
  1363	            "    for c in bda:\n" +
  1364	            "        if localname(c.tag) == 'binary': b64 = c.text or ''\n" +
  1365	            "    raw = base64.b64decode(b64) if b64 else b''\n" +
  1366	            "    if zipped and raw: raw = zlib.decompress(raw)\n" +
  1367	            "    fmt = ('<%dd' % (len(raw)//8)) if bits == 64 else ('<%df' % (len(raw)//4))\n" +
  1368	            "    vals = list(struct.unpack(fmt, raw)) if raw else []\n" +
  1369	            "    return is_mz, is_int, vals\n" +
  1370	            "spectra = []\n" +
  1371	            "for sp in root.iter():\n" +
  1372	            "    if localname(sp.tag) != 'spectrum': continue\n" +
  1373	            "    mz, inten = [], []\n" +
  1374	            "    for bda in sp.iter():\n" +
  1375	            "        if localname(bda.tag) != 'binaryDataArray': continue\n" +
  1376	            "        is_mz, is_int, vals = decode_array(bda)\n" +
  1377	            "        if is_mz: mz = vals\n" +
  1378	            "        elif is_int: inten = vals\n" +
  1379	            "    spectra.append({'mz': mz, 'intensity': inten})\n" +
  1380	            "print(json.dumps({'spectra': spectra}))\n";
  1381	
  1382	        [Test]
  1383	        public void Validator_Gate_Stays_Zero_Errors_With_Chromatograms()
  1384	        {
