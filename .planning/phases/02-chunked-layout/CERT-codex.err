    23	    public static class MzPeakParquet
    24	    {
    25	        public static StructField BuildParamField(string name)
    26	        {
    27	            var value = new StructField("value",
    28	                new DataField<long>("integer", true),
    29	                new DataField<double>("float", true),
    30	                new DataField<string>("string", true),
    31	                new DataField<bool>("boolean", true));
    32	
    33	            return new StructField(name,
