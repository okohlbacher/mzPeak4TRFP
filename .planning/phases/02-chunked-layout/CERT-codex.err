   425	        // single-row-group facet's metadata.
   426	        private static Dictionary<string, string> PointFooter(int spectrumCount, long pointCount) =>
   427	            new Dictionary<string, string>
   428	            {
   429	                ["spectrum_count"] = spectrumCount.ToString(),
   430	                ["spectrum_data_point_count"] = pointCount.ToString(),
   431	                ["spectrum_array_index"] = SpectrumArrayIndex
   432	            };
   433	
   434	        // Footer KV for the chunked spectra_data facet: same count keys as the point facet, with the chunk
   435	        // spectrum_array_index instead of the point one.
   436	        private static Dictionary<string, string> ChunkFooter(int spectrumCount, long pointCount) =>
   437	            new Dictionary<string, string>
   438	            {
   439	                ["spectrum_count"] = spectrumCount.ToString(),
   440	                ["spectrum_data_point_count"] = pointCount.ToString(),
   441	                ["spectrum_array_index"] = ChunkedSpectrumArrayIndex
   442	            };
   443	
   444	        // Returns the (mz,intensity) pairs in non-decreasing m/z order with the full multiset
   445	        // preserved. The Thermo SegmentedScan/CentroidStream are already ascending; a paired
   446	        // index sort is applied only when an ascending violation is detected, never dropping or
   447	        // merging equal-m/z points.
   448	        public static (double[] mz, float[] intensity) OrderedPairs(double[] masses, double[] intensities)
   449	        {
   450	            var n = masses?.Length ?? 0;
   451	            var mz = new double[n];
   452	            var inten = new float[n];
   453	            bool ascending = true;
   454	            for (int i = 0; i < n; i++)
   455	            {
   456	                mz[i] = masses[i];
   457	                inten[i] = (float)intensities[i];
   458	                if (i > 0 && masses[i] < masses[i - 1]) ascending = false;
   459	            }
   460	
   461	            if (ascending) return (mz, inten);
   462	
   463	            var order = new int[n];
   464	            for (int i = 0; i < n; i++) order[i] = i;
   465	            Array.Sort(order, (a, b) =>
   466	            {
   467	                int c = masses[a].CompareTo(masses[b]);
   468	                return c != 0 ? c : a.CompareTo(b);
   469	            });
   470	            var sortedMz = new double[n];
   471	            var sortedInten = new float[n];
   472	            for (int i = 0; i < n; i++)
   473	            {
   474	                sortedMz[i] = masses[order[i]];
   475	                sortedInten[i] = (float)intensities[order[i]];
   476	            }
   477	            return (sortedMz, sortedInten);
   478	        }
   479	
   480	        private void CaptureTic(IRawDataPlus raw, List<Record> records, List<double> time,
   481	            List<float> intensity, List<long> msLevel)
   482	        {
   483	            ChromatogramSignal[] trace;
   484	            try
   485	            {
   486	                raw.SelectInstrument(Device.MS, 1);
   487	                var settings = new ChromatogramTraceSettings(TraceType.TIC);
   488	                var data = raw.GetChromatogramData(new IChromatogramSettings[] { settings }, -1, -1);
   489	                trace = ChromatogramSignal.FromChromatogramData(data);
   490	            }
   491	            catch (Exception ex)
   492	            {
   493	                Log.Warn($"Device TIC trace unavailable, falling back to summed TIC: {ex.Message}");
   494	                trace = Array.Empty<ChromatogramSignal>();
   495	            }
   496	
   497	            if (trace.Length == 0)
   498	            {
   499	                foreach (var r in records)
   500	                {
   501	                    time.Add(r.Time);
   502	                    intensity.Add(r.TotalIonCurrent);
   503	                    msLevel.Add(r.MsLevel);
   504	                }
   505	                _chromFromDeviceTrace = false;
   506	                return;
   507	            }
   508	
   509	            var signal = trace[0];
   510	            if (signal.Times.Count == records.Count)
   511	            {
   512	                for (int i = 0; i < records.Count; i++)
   513	                {
   514	                    time.Add(signal.Times[i]);
   515	                    intensity.Add((float)signal.Intensities[i]);
   516	                    msLevel.Add(records[i].MsLevel);
   517	                }
   518	                _chromFromDeviceTrace = true;
   519	                return;
   520	            }

