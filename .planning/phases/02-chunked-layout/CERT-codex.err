   201	                    if (outputFile != null)
   202	                    {
   203	                        parameters.outputFileList.Add(Path.GetFullPath(outputFile));
   204	                    }
   205	                    else if (outputDirectory != null)
   206	                    {
   207	                        parameters.outputFileList.Add(Path.Combine(outputDirectory ?? throw new NoNullAllowedException("Output directory cannot be null"),
   208	                                                        Path.GetFileNameWithoutExtension(singleFile) + ".json"));
   209	                    }
   210	                    else
   211	                    {
   212	                        parameters.outputFileList.Add(Path.Combine(Path.GetDirectoryName(Path.GetFullPath(singleFile)),
   213	                                                        Path.GetFileNameWithoutExtension(singleFile) + ".json"));
   214	                    }
   215	                }
   216	                else
   217	                {
   218	                    if (outputFile != null)
   219	                    {
   220	                        throw new OptionException("Cannot use single output file to proceess a directory, use directory output instead", "-o, --output");
   221	                    }
   222	                    else if (outputDirectory != null)
   223	                    {
   224	                        outputDirectory = Path.GetFullPath(outputDirectory);
   225	                    }
   226	                    else
   227	                    {
   228	                        outputDirectory = Path.GetFullPath(fileDirectory);
   229	                    }
   230	
   231	                    var directoryInfo = new DirectoryInfo(Path.GetFullPath(fileDirectory));
   232	                    var files = directoryInfo.GetFiles("*", SearchOption.TopDirectoryOnly)
   233	                        .Where(f => f.Extension.ToLower() == ".raw").ToArray<FileInfo>();
   234	                    foreach (var file in files)
   235	                    {
   236	                        parameters.rawFileList.Add(file.FullName);
   237	                        parameters.outputFileList.Add(Path.Combine(outputDirectory ?? throw new NoNullAllowedException("Output directory cannot be null"),
   238	                                                    Path.GetFileNameWithoutExtension(file.Name) + ".json"));
   239	                    }
   240	                }
   241	
   242	                if (logFormatString != null)
   243	                {
   244	                    parameters.LogFormat = (LogFormat)ParseToEnum(typeof(LogFormat), logFormatString, "-l, --logging");
   245	                }
   246	
   247	                if (parameters.stdout) parameters.LogFormat = LogFormat.SILENT; //switch off logging in stdout
   248	            }
   249	            catch (OptionException optionException)
   250	            {
   251	                ShowHelp("Error - usage is:", optionException,
   252	                    optionSet);
   253	            }
   254	            catch (ArgumentNullException)
   255	            {
   256	                if (parameters.help)
   257	                {
   258	                    ShowHelp("usage is:", new OptionException(),
   259	                        optionSet);
   260	                }
   261	                else
   262	                {
   263	                    ShowHelp("Error - usage is:", new OptionException(),
   264	                        optionSet);
   265	                }
   266	            }
   267	
   268	            var exitCode = 1;
   269	            try
   270	            {
   271	                switch (parameters.LogFormat)
   272	                {
   273	                    case LogFormat.VERBOSE:
   274	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   275	                            Level.Debug;
   276	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   277	                            .RaiseConfigurationChanged(EventArgs.Empty);
   278	                        break;
   279	                    case LogFormat.SILENT:
   280	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   281	                            Level.Off;
   282	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   283	                            .RaiseConfigurationChanged(EventArgs.Empty);
   284	                        break;
   285	                    case LogFormat.WARNING:
   286	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   287	                            Level.Warn;
   288	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   289	                            .RaiseConfigurationChanged(EventArgs.Empty);
   290	                        break;
   291	                    case LogFormat.ERROR:
   292	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   293	                            Level.Error;
   294	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   295	                            .RaiseConfigurationChanged(EventArgs.Empty);
   296	                        break;
   297	                }
   298	
   299	                XicExecutor.Run(parameters);
   300	
   301	                Log.Info($"Processing completed {parameters.Errors} errors, {parameters.Warnings} warnings");
   302	
   303	                exitCode = parameters.Vigilant ? parameters.Errors + parameters.Warnings : parameters.Errors;
   304	            }
   305	            catch (Exception ex)
   306	            {
   307	                if (ex is RawFileParserException)
   308	                {
   309	                    Log.Error(ex.Message);
   310	                }
   311	                else
   312	                {
   313	                    Log.Error("An unexpected error occured:");
   314	                    Log.Error(ex.ToString());
   315	                }
   316	            }
   317	            finally
   318	            {
   319	                Environment.Exit(exitCode);
   320	            }
   321	        }
