   891	        /// <summary>
   892	        /// Show the help message
   893	        /// </summary>
   894	        /// <param name="message">the help message</param>
   895	        /// <param name="optionException">the option exception, can be null</param>
   896	        /// <param name="optionSet">the option set object</param>
   897	        private static void ShowHelp(string message, OptionException optionException, OptionSet optionSet)
   898	        {
   899	            if (optionException != null)
   900	            {
   901	                if (!optionException.OptionName.IsNullOrEmpty())
   902	                {
   903	                    Console.Error.Write(optionException.OptionName + ": ");
   904	                }
   905	
   906	                Console.Error.WriteLine(optionException.Message);
   907	            }
   908	
   909	            Console.Error.WriteLine(message);
   910	            optionSet.WriteOptionDescriptions(Console.Error);
   911	            Environment.Exit(-1);
   912	        }
