  1532	        private void AddScanWindows(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1533	            List<Record> records)
  1534	        {
  1535	            var lowerLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"));
  1536	            var upperLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"));
  1537	
  1538	            var lowerRows = new List<MzPeakParquet.LeafRow>();
  1539	            var upperRows = new List<MzPeakParquet.LeafRow>();
  1540	            var lowerVals = new List<float>();
  1541	            var upperVals = new List<float>();
  1542	
  1543	            for (int row = 0; row < records.Count; row++)
  1544	            {
  1545	                lowerRows.Add(MzPeakParquet.ListOf(new[] { lowerLeaf.MaxDefinitionLevel }, new[] { true }));
  1546	                upperRows.Add(MzPeakParquet.ListOf(new[] { upperLeaf.MaxDefinitionLevel }, new[] { true }));
  1547	                lowerVals.Add(records[row].WindowLower);
  1548	                upperVals.Add(records[row].WindowUpper);
  1549	            }
  1550	
  1551	            Emit(cols, lowerLeaf, lowerVals.ToArray(), lowerRows);
  1552	            Emit(cols, upperLeaf, upperVals.ToArray(), upperRows);
  1553	        }
  1554	
  1555	        private static Field FindField(ParquetSchema schema, string path)
  1556	        {
  1557	            var parts = path.Split('/');
  1558	            Field current = schema.Fields.First(f => f.Name == parts[0]);
  1559	            for (int i = 1; i < parts.Length; i++)
  1560	            {
  1561	                current = ((StructField)current).Fields.First(f => f.Name == parts[i]);
  1562	            }
  1563	            return current;
  1564	        }
  1565	
  1566	        private static byte[] WriteFacet(ParquetSchema schema, IReadOnlyDictionary<string, string> meta,
  1567	            IDictionary<DataField, (Array, int[], int[])> cols)
  1568	        {
  1569	            using (var ms = new MemoryStream())
  1570	            {
  1571	                MzPeakParquet.WriteAsync(ms, schema, meta, cols).GetAwaiter().GetResult();
  1572	                return ms.ToArray();
  1573	            }
  1574	        }
