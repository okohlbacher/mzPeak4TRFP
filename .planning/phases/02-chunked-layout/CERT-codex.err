    81	            Self::Basic { chunk_size: _ } => NO_COMPRESSION,
    82	            Self::Delta { chunk_size: _ } => DELTA_ENCODE,
    83	            Self::NumpressLinear { chunk_size: _ } => NUMPRESS_LINEAR,
    84	        }
    85	    }
