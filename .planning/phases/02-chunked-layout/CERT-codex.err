     1	//! Write layer surface.
     2	//!
     3	//! The write layer is the integration boundary between the Phase-2 read layer
     4	//! ([`crate::read`]) and the Phase-3 imaging-schema layer ([`crate::schema`]): it turns the
     5	//! stream of [`ImagingSpectrum`](crate::read::ImagingSpectrum) records into a valid imaging
     6	//! mzPeak archive by driving the reference `mzpeak_prototyping` writer. It owns three
     7	//! concerns:
     8	//!
     9	//!   1. [`spectrum`] — the genuinely-new mechanism: reconstructing an mzdata
    10	//!      `MultiLayerSpectrum` from an [`ImagingSpectrum`](crate::read::ImagingSpectrum), so
    11	//!      the coordinate columns serialize as real values (the writer reads `IMS:1000050/51/52`
    12	//!      from scan-event params at write-time — RESEARCH.md Pitfall 1) and profile/centroid
    13	//!      routing is driven verbatim by `signal_continuity`.
    14	//!   2. [`writer`] — the `ImagingWriter` wrapper that owns the configured
    15	//!      `MzPeakWriterType<File>`, registers the coordinate columns via
    16	//!      `add_spectrum_scan_field`, and maps metadata (Plan 02).
    17	//!   3. [`convert`] — the top-level `convert(reader → path)` orchestrator that drives the
    18	//!      streaming read→write loop (Plan 03).
    19	//!
    20	//! Declaring all three submodules up front means Plans 02 (`writer`) and 03 (`convert`)
    21	//! fill their bodies WITHOUT ever editing this file (mirrors `schema/mod.rs`).
    22	
    23	pub mod spectrum;
    24	pub mod writer;
    25	pub mod convert;
    26	pub mod image;
    27	pub mod mzml;
    28	pub mod reporter_quant;
    29	
    30	pub use spectrum::{to_mzdata, to_mzdata_canonical, CastNarrowing};
    31	pub use writer::{ImagingWriter, WriteError};
    32	pub use convert::{convert, convert_with, ConversionOutcome};
    33	pub use mzml::{
    34	    convert_mzml, convert_mzml_with, inspect_mzml, CentroidNonMonotonic, MzmlConvertError,
    35	    MzmlConvertReport,
    36	};
    37	
    38	use mzpeak_prototyping::chunk_series::ChunkingStrategy;
    39	use parquet::basic::{Compression, ZstdLevel};
    40	
    41	/// Output-size encoding knobs shared by the imaging and plain-mzML writers.
    42	///
    43	/// The defaults (`Default`/[`EncodingOptions::compact`]) target small files: **Numpress-linear**
    44	/// chunked m/z encoding + **zstd-19** + tuned Parquet row groups. Numpress-linear is *lossy on
    45	/// m/z* (bounded fixed-point error; intensity stays lossless), so it is the right default for
    46	/// plain proteomics mzML but trades away the imaging **L1 bit-for-bit** guarantee — callers that
    47	/// need exact imaging round-trips use [`EncodingOptions::lossless`] (`--no-numpress`: Delta
    48	/// chunking, still compact but exact). [`EncodingOptions::legacy`] reproduces the pre-tuning
    49	/// writer defaults (no chunking, writer-default zstd) and backs the library's [`convert`] so the
    50	/// existing L1 tests are byte-behaviour-unchanged.
    51	#[derive(Debug, Clone)]
    52	pub struct EncodingOptions {
    53	    /// m/z (+ chromatogram-time) chunked encoding. `None` = no chunking.
    54	    ///
    55	    /// This is the SINGLE SOURCE OF TRUTH for whether the m/z axis is encoded lossily: lossy-ness
    56	    /// is *derived* from this strategy via [`EncodingOptions::mz_is_lossy`], never tracked as an
    57	    /// independent flag that could drift from the strategy actually applied.
    58	    pub mz_chunking: Option<ChunkingStrategy>,
    59	    /// ZSTD level (1..=22); `None` = writer default (~3).
    60	    pub zstd_level: Option<i32>,
    61	    /// Parquet row-group size in rows; `None` = writer default. Larger groups compress better.
    62	    pub row_group_size: Option<usize>,
    63	}
    64	
    65	/// Default chunk window (m/z Th) for chunked encodings — mirrors the reference converter's 50.
    66	const CHUNK_SIZE: f64 = 50.0;
    67	/// Tuned Parquet row-group size (#4): larger groups let zstd see more context → better ratio.
    68	/// 2,000,000 rows balances ratio vs. writer memory for dense point columns.
    69	const TUNED_ROW_GROUP: usize = 2_000_000;
    70	/// Higher ZSTD level applied by both compact and lossless profiles.
    71	const HIGH_ZSTD: i32 = 19;
    72	
    73	impl EncodingOptions {
    74	    /// Compact, lossy-m/z default: Numpress-linear chunking + zstd-19 + tuned row groups.
    75	    pub fn compact() -> Self {
    76	        Self {
    77	            mz_chunking: Some(ChunkingStrategy::NumpressLinear { chunk_size: CHUNK_SIZE }),
    78	            zstd_level: Some(HIGH_ZSTD),
    79	            row_group_size: Some(TUNED_ROW_GROUP),
    80	        }
    81	    }
    82	
    83	    /// Lossless-but-compact (`--no-numpress`): Delta chunking (exact) + zstd-19 + tuned rows.
    84	    pub fn lossless() -> Self {
    85	        Self {
    86	            mz_chunking: Some(ChunkingStrategy::Delta { chunk_size: CHUNK_SIZE }),
    87	            zstd_level: Some(HIGH_ZSTD),
    88	            row_group_size: Some(TUNED_ROW_GROUP),
    89	        }
    90	    }
    91	
    92	    /// Pre-tuning writer defaults (no chunking, writer-default zstd) — back-compat for [`convert`].
    93	    pub fn legacy() -> Self {
    94	        Self {
    95	            mz_chunking: None,
    96	            zstd_level: None,
    97	            row_group_size: None,
    98	        }
    99	    }
   100	
   101	    /// Whether the m/z axis is encoded LOSSILY — derived solely from [`mz_chunking`], the single
   102	    /// source of truth (FIX-2). m/z is lossy iff Numpress-linear chunking is applied (bounded
   103	    /// fixed-point error). Delta chunking and "no chunking" are exact, so they are lossless. This
   104	    /// gates the `metadata.transform` L2 claim so it can never drift from the strategy actually
   105	    /// used.
   106	    ///
   107	    /// [`mz_chunking`]: EncodingOptions::mz_chunking
   108	    pub fn mz_is_lossy(&self) -> bool {
   109	        matches!(self.mz_chunking, Some(ChunkingStrategy::NumpressLinear { .. }))
   110	    }
   111	
   112	    /// The `parquet` [`Compression`] for `zstd_level` (falls back to writer default zstd if unset
   113	    /// or out of range).
   114	    pub fn compression(&self) -> Compression {
   115	        match self.zstd_level.and_then(|l| ZstdLevel::try_new(l).ok()) {
   116	            Some(level) => Compression::ZSTD(level),
   117	            None => Compression::ZSTD(ZstdLevel::default()),
   118	        }
   119	    }
   120	}
   121	
   122	impl Default for EncodingOptions {
   123	    fn default() -> Self {
   124	        Self::compact()
   125	    }
   126	}

