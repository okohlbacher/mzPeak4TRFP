    14	namespace ThermoRawFileParserTest
    15	{
    16	    [TestFixture]
    17	    public class MzPeakChunkTests
    18	    {
    19	        private static long MzBits(double v) => BitConverter.DoubleToInt64Bits(v);
    20	        private static int IntBits(float v) => BitConverter.SingleToInt32Bits(v);
    21	
    22	        // Encode + decode every window and concatenate; returns the reconstructed (mz,intensity) pairs
    23	        // dropping null pairs, mirroring the writer/reader contract.
    24	        private static List<(double mz, float inten)> RoundTrip(double[] mz, float[] inten, double width)
    25	        {
    26	            var outp = new List<(double, float)>();
    27	            foreach (var (s, e) in MzPeakChunkCodec.Chunk(mz, width))
    28	            {
    29	                var slice = new double?[e - s];
    30	                for (int i = s; i < e; i++) slice[i - s] = mz[i];
    31	                MzPeakChunkCodec.DeltaEncode(slice, out var start, out _, out var values);
    32	                var dmz = MzPeakChunkCodec.DeltaDecode(start, values);
    33	                for (int i = 0; i < dmz.Length; i++)
    34	                {
    35	                    if (!dmz[i].HasValue) continue;
    36	                    outp.Add((dmz[i].Value, inten[s + i]));
    37	                }
    38	            }
    39	            return outp;
    40	        }
    41	
    42	        [Test]
    43	        public void RoundTrip_Gapless_BitwiseExact()
    44	        {
    45	            var rnd = new Random(7);
    46	            int n = 5000;
    47	            var mz = new double[n];
    48	            var inten = new float[n];
    49	            double cur = 100.0;
    50	            for (int i = 0; i < n; i++)
    51	            {
    52	                cur += rnd.NextDouble() * 0.5;
    53	                mz[i] = cur;
    54	                inten[i] = (float)(rnd.NextDouble() * 1e6);
    55	            }
    56	
    57	            var rt = RoundTrip(mz, inten, 50.0);
    58	            Assert.That(rt.Count, Is.EqualTo(n), "no points lost");
    59	
    60	            var src = Enumerable.Range(0, n)
    61	                .Select(i => (MzBits(mz[i]), IntBits(inten[i])))
    62	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ToArray();
    63	            var got = rt
    64	                .Select(p => (MzBits(p.mz), IntBits(p.inten)))
    65	                .OrderBy(x => x.Item1).ThenBy(x => x.Item2).ToArray();
    66	            Assert.That(got, Is.EqualTo(src), "decoded multiset is BITWISE equal to input");
    67	        }
