   194	        private static byte[] ReadEntry(string archive, string name)
   195	        {
   196	            using (var zip = ZipFile.OpenRead(archive))
   197	            {
   198	                var entry = zip.GetEntry(name);
   199	                if (entry == null) return null;
   200	                using (var s = entry.Open())
   201	                using (var ms = new MemoryStream())
   202	                {
   203	                    s.CopyTo(ms);
   204	                    return ms.ToArray();
   205	                }
   206	            }
   207	        }
   208	
   209	        private static string ResolvePython()
   210	        {
   211	            foreach (var cand in new[] { "python3", "python" })
   212	            {
   213	                try
   214	                {
   215	                    var psi = new ProcessStartInfo(cand, "-c \"import pyarrow\"")
   216	                    { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   217	                    using (var p = Process.Start(psi)) { p.WaitForExit(); if (p.ExitCode == 0) return cand; }
   218	                }
   219	                catch { }
   220	            }
   221	            return null;
   222	        }
   223	
   224	        private static string ResolveValidator()
   225	        {
   226	            try
   227	            {
   228	                var psi = new ProcessStartInfo("mzpeak-validate", "--help")
   229	                { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   230	                using (var p = Process.Start(psi)) { p.WaitForExit(); return "mzpeak-validate"; }
   231	            }
   232	            catch { return null; }
   233	        }
   234	
   235	        // Runs a pyarrow snippet against a named parquet entry of an archive ({PARQUET} token) and returns
   236	        // the printed JSON object. Ignores when python/pyarrow is unavailable.
   237	        private static JObject PyArrow(string archive, string entry, string snippet)
   238	        {
   239	            var python = ResolvePython();
   240	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   241	
   242	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   243	            File.WriteAllBytes(path, ReadEntry(archive, entry));
   244	            try
   245	            {
   246	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   247	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   248	                { RedirectStandardOutput = true, RedirectStandardError = true, UseShellExecute = false };
   249	                using (var proc = Process.Start(psi))
   250	                {
   251	                    var stdout = proc.StandardOutput.ReadToEnd();
   252	                    var stderr = proc.StandardError.ReadToEnd();
   253	                    proc.WaitForExit();
   254	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   255	                    return JObject.Parse(stdout.Trim());
   256	                }
   257	            }
   258	            finally { File.Delete(path); }
   259	        }
