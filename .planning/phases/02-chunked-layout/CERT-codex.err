   370	        // Writes the metadata parquet to a temp file and runs a python pyarrow snippet that prints
   371	        // a single JSON object to stdout. The snippet sees the file path via the {PARQUET} token.
   372	        private static JObject PyArrowMetadata(string archive, string snippet)
   373	        {
