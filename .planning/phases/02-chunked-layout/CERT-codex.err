   589	        private StructField BuildChromatogramField()
   590	        {
   591	            return new StructField("chromatogram",
   592	                new DataField<ulong>("index", true),
   593	                new DataField<string>("id", true),
   594	                new DataField<sbyte>(Cv("MS:1000465", "scan_polarity"), true),
   595	                new DataField<string>(Cv("MS:1000626", "chromatogram_type"), true),
   596	                new DataField<string>("data_processing_ref", true),
   597	                new DataField<ulong>(Cv("MS:1003060", "number_of_data_points"), true),
   598	                new ListField("parameters", MzPeakParquet.BuildParamField("item")),
   599	                new ListField("auxiliary_arrays", BuildAuxArrayField("item")),
   600	                new DataField<uint>("number_of_auxiliary_arrays", true));
   601	        }
   602	
   603	        private StructField BuildAuxArrayField(string name)
   604	        {
   605	            return new StructField(name,
   606	                new ListField("data", new DataField<byte>("item")),
   607	                MzPeakParquet.BuildParamField("name"),
   608	                new DataField<string>("data_type", true),
   609	                new DataField<string>("compression", true),
   610	                new DataField<string>("unit", true),
   611	                new ListField("parameters", MzPeakParquet.BuildParamField("item")),
   612	                new DataField<string>("data_processing_ref", true));
   613	        }
