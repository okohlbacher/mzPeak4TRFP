    93	            ChunkingStrategy::NumpressLinear { chunk_size: _ } => {
    94	                let name = main_axis_name
    95	                    .clone()
    96	                    .with_format(BufferFormat::ChunkTransform)
    97	                    .with_transform(Some(BufferTransform::NumpressLinear));
    98	
    99	                let bytes = Field::new(
   100	                    name.to_string(),
   101	                    DataType::LargeList(Arc::new(Field::new("item", DataType::UInt8, false))),
   102	                    true,
   103	                )
   104	                .with_metadata(name.as_field_metadata());
