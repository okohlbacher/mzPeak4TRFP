   347	        private static string ResolvePython()
   348	        {
   349	            foreach (var cand in new[] { "python3", "python" })
   350	            {
   351	                try
   352	                {
   353	                    var psi = new ProcessStartInfo(cand, "-c \"import pyarrow\"")
   354	                    {
   355	                        RedirectStandardOutput = true,
   356	                        RedirectStandardError = true,
   357	                        UseShellExecute = false
   358	                    };
   359	                    using (var p = Process.Start(psi))
   360	                    {
   361	                        p.WaitForExit();
   362	                        if (p.ExitCode == 0) return cand;
   363	                    }
   364	                }
   365	                catch { }
   366	            }
   367	            return null;
   368	        }
