  1418	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
  1419	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1420	            string listPath, int n, List<List<Param>> perRow)
  1421	        {
  1422	            int m = perRow.Count;
  1423	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
  1424	            var padded = new List<List<Param>>();
  1425	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
  1426	            AddParamList(cols, schema, listPath, padded, structPresent);
  1427	        }
  1428	
  1429	        private void AddParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1430	            string listPath, List<List<Param>> perRow, bool[] structPresent)
  1431	        {
  1432	            var list = (ListField)FindField(schema, listPath);
  1433	            var accLeaf = Leaf(schema, listPath + "/list/item/accession");
  1434	            var nameLeaf = Leaf(schema, listPath + "/list/item/name");
  1435	            var unitLeaf = Leaf(schema, listPath + "/list/item/unit");
  1436	            var intLeaf = Leaf(schema, listPath + "/list/item/value/integer");
  1437	            var fltLeaf = Leaf(schema, listPath + "/list/item/value/float");
  1438	            var strLeaf = Leaf(schema, listPath + "/list/item/value/string");
  1439	            var boolLeaf = Leaf(schema, listPath + "/list/item/value/boolean");
  1440	
  1441	            var accRows = new List<MzPeakParquet.LeafRow>();
  1442	            var nameRows = new List<MzPeakParquet.LeafRow>();
  1443	            var unitRows = new List<MzPeakParquet.LeafRow>();
  1444	            var intRows = new List<MzPeakParquet.LeafRow>();
  1445	            var fltRows = new List<MzPeakParquet.LeafRow>();
  1446	            var strRows = new List<MzPeakParquet.LeafRow>();
  1447	            var boolRows = new List<MzPeakParquet.LeafRow>();
  1448	
  1449	            var accVals = new List<string>();
  1450	            var nameVals = new List<string>();
  1451	            var unitVals = new List<string>();
  1452	            var intVals = new List<long>();
  1453	            var fltVals = new List<double>();
  1454	            var strVals = new List<string>();
  1455	            var boolVals = new List<bool>();
  1456	
  1457	            for (int row = 0; row < perRow.Count; row++)
  1458	            {
  1459	                if (!structPresent[row])
  1460	                {
  1461	                    accRows.Add(MzPeakParquet.NullList()); nameRows.Add(MzPeakParquet.NullList());
  1462	                    unitRows.Add(MzPeakParquet.NullList()); intRows.Add(MzPeakParquet.NullList());
  1463	                    fltRows.Add(MzPeakParquet.NullList()); strRows.Add(MzPeakParquet.NullList());
  1464	                    boolRows.Add(MzPeakParquet.NullList());
  1465	                    continue;
  1466	                }
  1467	
  1468	                var items = perRow[row];
  1469	                if (items.Count == 0)
  1470	                {
  1471	                    accRows.Add(MzPeakParquet.EmptyList(list)); nameRows.Add(MzPeakParquet.EmptyList(list));
  1472	                    unitRows.Add(MzPeakParquet.EmptyList(list)); intRows.Add(MzPeakParquet.EmptyList(list));
  1473	                    fltRows.Add(MzPeakParquet.EmptyList(list)); strRows.Add(MzPeakParquet.EmptyList(list));
  1474	                    boolRows.Add(MzPeakParquet.EmptyList(list));
  1475	                    continue;
  1476	                }
  1477	
  1478	                foreach (var it in items) { CollectPrefix(it.Accession); CollectPrefix(it.Unit); }
  1479	                AddListLeaf(accRows, accVals, accLeaf, items, p => p.Accession);
  1480	                AddListLeaf(nameRows, nameVals, nameLeaf, items, p => p.Name);
  1481	                AddListLeaf(unitRows, unitVals, unitLeaf, items, p => p.Unit);
  1482	                AddListLeafNumStruct(intRows, intVals, intLeaf, items, p => p.Integer);
  1483	                AddListLeafNumStruct(fltRows, fltVals, fltLeaf, items, p => p.Float);
  1484	                AddListLeaf(strRows, strVals, strLeaf, items, p => p.String);
  1485	                AddListLeafNumStruct(boolRows, boolVals, boolLeaf, items, p => p.Boolean);
  1486	            }
  1487	
  1488	            Emit(cols, accLeaf, accVals.ToArray(), accRows);
  1489	            Emit(cols, nameLeaf, nameVals.ToArray(), nameRows);
  1490	            Emit(cols, unitLeaf, unitVals.ToArray(), unitRows);
  1491	            Emit(cols, intLeaf, intVals.ToArray(), intRows);
  1492	            Emit(cols, fltLeaf, fltVals.ToArray(), fltRows);
  1493	            Emit(cols, strLeaf, strVals.ToArray(), strRows);
  1494	            Emit(cols, boolLeaf, boolVals.ToArray(), boolRows);
  1495	        }
  1496	
  1497	        private static void AddListLeaf(List<MzPeakParquet.LeafRow> rows, List<string> vals, DataField leaf,
  1498	            List<Param> items, Func<Param, string> sel)
  1499	        {
  1500	            var levels = new int[items.Count];
  1501	            var has = new bool[items.Count];
  1502	            for (int i = 0; i < items.Count; i++)
  1503	            {
  1504	                var v = sel(items[i]);
  1505	                if (v != null) { vals.Add(v); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1506	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1507	            }
  1508	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1509	        }
  1510	
  1511	        private static void AddListLeafNumStruct<T>(List<MzPeakParquet.LeafRow> rows, List<T> vals, DataField leaf,
  1512	            List<Param> items, Func<Param, T?> sel) where T : struct
  1513	        {
  1514	            var levels = new int[items.Count];
  1515	            var has = new bool[items.Count];
  1516	            for (int i = 0; i < items.Count; i++)
  1517	            {
  1518	                var v = sel(items[i]);
  1519	                if (v.HasValue) { vals.Add(v.Value); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
  1520	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
  1521	            }
  1522	            rows.Add(MzPeakParquet.ListOf(levels, has));
  1523	        }
  1524	
  1525	        private static void Emit(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf,
  1526	            Array values, List<MzPeakParquet.LeafRow> rows)
  1527	        {
  1528	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
  1529	            cols[leaf] = (values, def, rep);
  1530	        }
