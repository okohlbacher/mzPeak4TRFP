   842	    /// Construct an Arrow schema from this chunk.
   843	    ///
   844	    /// This schema must hold for just *this* block of chunks. It will
   845	    /// be adapted by [`ChunkBuffers`](crate::writer::ChunkBuffers) to
   846	    /// the file-level schema.
   847	    pub fn to_schema(
   848	        &self,
   849	        buffer_context: BufferContext,
   850	        encodings: &[ChunkingStrategy],
   851	        include_time: bool,
   852	    ) -> Schema {
   853	        let base_name = self.chunk_axis.clone();
   854	        let mut bounds_name = base_name.clone();
   855	        bounds_name.dtype = BinaryDataArrayType::Float64;
   856	        let (start, end) = bounds_name.make_bounds_fields().unwrap();
   857	        let field_meta = base_name.as_field_metadata();
   858	        let chunk_encoding_meta = base_name
   859	            .clone()
   860	            .with_format(BufferFormat::ChunkEncoding)
   861	            .as_field_metadata();
   862	        let mut fields_of = vec![
   863	            buffer_context.index_field(),
   864	            start,
   865	            end,
   866	            Field::new(
   867	                base_name.to_string(),
   868	                DataType::LargeList(Arc::new(Field::new(
   869	                    "item",
   870	                    array_to_arrow_type(base_name.dtype),
   871	                    true,
   872	                ))),
   873	                true,
   874	            )
   875	            .with_metadata(field_meta)
   876	            .into(),
   877	            Field::new(
   878	                "chunk_encoding",
   879	                CURIEBuilder::default().as_struct_type(),
   880	                true,
   881	            )
   882	            .with_metadata(chunk_encoding_meta)
   883	            .into(),
   884	        ];
   885	
   886	        for buffer_name in self.arrays.keys().sorted() {
   887	            if let Ok(transform) = BufferTransformEncoder::try_from(buffer_name.transform) {
   888	                let f_of = transform.to_field(buffer_name);
   889	                fields_of.push(Arc::new(f_of));
   890	            } else {
   891	                let f_of = buffer_name.to_field();
   892	                let dtype = DataType::LargeList(Arc::new(Field::new(
   893	                    "item",
   894	                    f_of.data_type().clone(),
   895	                    true,
   896	                )));
   897	                fields_of.push(Arc::new((*f_of).clone().with_data_type(dtype)));
   898	            }
   899	        }
   900	
   901	        for enc in encodings.iter() {
