   785	        // The 6-field chunk struct of the reference spectra_data chunk layout. mz_chunk_values / intensity
   786	        // are nullable-item lists (the writer emits no nulls; the type stays null-aware for read parity).
   787	        private static StructField ChunkStructField() =>
   788	            new StructField("chunk",
   789	                new DataField<ulong>("spectrum_index"),
   790	                new DataField<double>("mz_chunk_start"),
   791	                new DataField<double>("mz_chunk_end"),
   792	                new ListField("mz_chunk_values", new DataField<double>("item", true)),
   793	                new DataField<string>("chunk_encoding"),
   794	                new ListField("intensity", new DataField<float>("item", true)));
