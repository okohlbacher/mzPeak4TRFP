   329	        // success. Any read/build failure throws and is handled by the caller as an error-counted skip, so
   330	        // a failed scan never commits an ordinal, rows, or a precursor-map entry.
   331	        private StagedScan StageScan(IRawDataPlus raw, int scanNumber, ulong ordinal,
   332	            IDictionary<int, ulong> scanNumberToOrdinal)
   333	        {
   334	            var scanFilter = raw.GetFilterForScanNumber(scanNumber);
   335	            int level = (int)scanFilter.MSOrder;
   336	            if (level > ParseInput.MaxLevel || !ParseInput.MsLevel.Contains(level)) return null;
   337	
   338	            var scanEvent = raw.GetScanEventForScanNumber(scanNumber);
   339	            var mzData = ReadMZData(raw, scanEvent, scanNumber, false, false, false);
   340	
   341	            var (mz, inten) = OrderedPairs(mzData.masses, mzData.intensities);
   342	            if (mz.Length == 0) return null;
   343	
   344	            double[] peakMz = null;
   345	            float[] peakInten = null;
   346	            ulong? peakCount = null;
   347	            if (scanEvent.ScanData == ScanDataType.Profile && Scan.FromFile(raw, scanNumber).HasCentroidStream)
   348	            {
   349	                var peakData = ReadMZData(raw, scanEvent, scanNumber, true, false, false);
   350	                var (pMz, pInten) = OrderedPairs(peakData.masses, peakData.intensities);
   351	                if (pMz.Length > 0)
   352	                {
   353	                    peakMz = pMz;
   354	                    peakInten = pInten;
   355	                    peakCount = (ulong)pMz.Length;
   356	                }
   357	            }
   358	
   359	            var scanStats = raw.GetScanStatsForScanNumber(scanNumber);
   360	            var trailer = new ScanTrailer(raw.GetTrailerExtraInformation(scanNumber));
   361	
   362	            // Mirror the mzML parent-derivation bookkeeping: map each scan's filter prefix to its scan
   363	            // number so an MSn child can resolve its parent via the scan string.
   364	            var filterMatch = level == 1
   365	                ? null
   366	                : (level == 2
   367	                    ? _filterStringIsolationMzPattern.Match(scanEvent.ToString())
   368	                    : _filterStringParentMzPattern.Match(scanEvent.ToString()));
   369	            var filterKey = level == 1 ? "" : (filterMatch != null && filterMatch.Success ? filterMatch.Groups[1].Value : "");
   370	
   371	            // Failure injection point: the filter key is staged but nothing has committed. A throw here is
   372	            // indistinguishable from a real post-key read failure and must leave no trace of this scan.
   373	            AfterFilterKeyStaged?.Invoke(scanNumber);
   374	
   375	            var rec = new Record
   376	            {
   377	                Ordinal = ordinal,
   378	                ScanNumber = scanNumber,
   379	                MsLevel = level,
   380	                Id = ConstructSpectrumTitle((int)Device.MS, 1, scanNumber),
   381	                Time = raw.RetentionTimeFromScanNumber(scanNumber),
   382	                Polarity = scanFilter.Polarity == PolarityType.Negative ? (sbyte)-1 : (sbyte)1,
   383	                Representation = mzData.isCentroided ? "MS:1000127" : "MS:1000128",
   384	                SpectrumType = level == 1 ? "MS:1000579" : "MS:1000580",
   385	                LowestMz = mz[0],
   386	                HighestMz = mz[mz.Length - 1],
   387	                BasePeakMz = mzData.basePeakMass ?? 0.0,
   388	                BasePeakIntensity = (float)(mzData.basePeakIntensity ?? 0.0),
   389	                TotalIonCurrent = (float)scanStats.TIC,
   390	                DataPointCount = (ulong)mz.Length,
   391	                PeakCount = peakCount,
   392	                ScanStartTime = (float)raw.RetentionTimeFromScanNumber(scanNumber),
   393	                FilterString = scanEvent.ToString(),
   394	                IonInjectionTime = (float)(trailer.AsDouble("Ion Injection Time (ms):") ?? 0.0),
   395	                InstrumentConfigRef = AnalyzerIndex(scanFilter.MassAnalyzer, scanFilter.IonizationMode),
   396	                WindowLower = (float)scanStats.LowMass,
   397	                WindowUpper = (float)scanStats.HighMass
   398	            };
   399	
   400	            if (level >= 2)
   401	            {
   402	                BeforeBuildPrecursor?.Invoke(scanNumber, scanNumberToOrdinal);
   403	                BuildPrecursor(raw, scanNumber, scanEvent, scanFilter, trailer, scanNumberToOrdinal,
   404	                    filterKey, rec);
   405	            }
   406	
   407	            return new StagedScan
   408	            {
   409	                Mz = mz,
   410	                Inten = inten,
   411	                PeakMz = peakMz,
   412	                PeakInten = peakInten,
   413	                Rec = rec,
   414	                FilterKey = filterKey
   415	            };
   416	        }
