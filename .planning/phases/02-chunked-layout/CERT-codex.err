   547	        private byte[] BuildChromatogramMetadataFacet(int n)
   548	        {
   549	            var chromatogram = BuildChromatogramField();
   550	            var precursor = BuildPrecursorField();
   551	            var selectedIon = BuildSelectedIonField();
   552	            var schema = new ParquetSchema(chromatogram, precursor, selectedIon);
   553	
   554	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
   555	            var present = new[] { true };
   556	
   557	            AddScalar(cols, schema, "chromatogram/index", new ulong[] { 0UL }, present);
   558	            AddScalar(cols, schema, "chromatogram/id", new[] { "TIC" }, present);
   559	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1000465", "scan_polarity"),
   560	                new sbyte[] { 0 }, present);
   561	            CollectPrefix("MS:1000235");
   562	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1000626", "chromatogram_type"),
   563	                new[] { "MS:1000235" }, present);
   564	
   565	            var dprLeaf = Leaf(schema, "chromatogram/data_processing_ref");
   566	            var dprRows = new[] { MzPeakParquet.AtLevel(dprLeaf.MaxDefinitionLevel - 1, false) };
   567	            var (dprDef, _) = MzPeakParquet.NestedLevels(dprLeaf, dprRows);
   568	            cols[dprLeaf] = (new string[0], dprDef, null);
   569	
   570	            AddScalar(cols, schema, "chromatogram/" + Cv("MS:1003060", "number_of_data_points"),
   571	                new ulong[] { (ulong)n }, present);
   572	
   573	            AddEmptyList(cols, schema, "chromatogram/parameters");
   574	            AddEmptyAuxList(cols, schema, "chromatogram/auxiliary_arrays");
   575	            AddScalar(cols, schema, "chromatogram/number_of_auxiliary_arrays", new uint[] { 0u }, present);
   576	
   577	            AddNullPrecursor(cols, schema);
   578	            AddNullSelectedIon(cols, schema);
   579	
   580	            var custom = new Dictionary<string, string>
   581	            {
   582	                ["chromatogram_count"] = "1",
   583	                ["chromatogram_data_point_count"] = "0"
   584	            };
   585	
   586	            return WriteFacet(schema, custom, cols);
   587	        }
