  1350	            ParquetSchema schema, string path, int n, List<Record> msn)
  1351	        {
  1352	            var leaf = Leaf(schema, path);
  1353	            int m = msn.Count;
  1354	            var rows = new List<MzPeakParquet.LeafRow>();
  1355	            var present = new List<ulong>();
  1356	            for (int i = 0; i < n; i++)
  1357	            {
  1358	                if (i >= m) rows.Add(MzPeakParquet.Absent());
  1359	                else if (msn[i].PrecursorIndex.HasValue)
  1360	                { rows.Add(MzPeakParquet.Present(leaf)); present.Add(msn[i].PrecursorIndex.Value); }
  1361	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
  1362	            }
  1363	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1364	            cols[leaf] = (present.ToArray(), def, null);
  1365	        }
