    60	/// Different methods for encoding chunks along a coordinate dimension
    61	#[derive(Clone, Copy, Debug, PartialEq)]
    62	pub enum ChunkingStrategy {
    63	    /// Values are encoded as-is without any transformation. While this doesn't have any compression
    64	    /// benefits, it provides compatibility for sparse data. The start and end values are included in
    65	    /// the encoded data.
    66	    Basic { chunk_size: f64 },
    67	    /// Values are stored as deltas w.r.t. previous values. The first value stored is w.r.t. to the chunk
    68	    /// starting value, but the starting value is not encoded in the chunk values array itself. Decoding
    69	    /// of the chunk values requires the chunk start value be read from the chunk metadata.
    70	    Delta { chunk_size: f64 },
    71	    /// Values are stored using MS-Numpress linear compression. The entire chunk is encoded in a byte buffer
    72	    /// which may not align with a multi-byte value type and must be stored in a dedicated byte array. The
    73	    /// start and end values are included in the encoded chunk as well as the chunk metadata.
    74	    NumpressLinear { chunk_size: f64 },
    75	}
