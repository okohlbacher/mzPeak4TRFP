   375	            if (python == null) Assert.Ignore("python3/pyarrow not available");
   376	
   377	            var path = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".parquet");
   378	            File.WriteAllBytes(path, ReadEntry(archive, "spectra_metadata.parquet"));
   379	            try
   380	            {
   381	                var code = snippet.Replace("{PARQUET}", path.Replace("\\", "\\\\"));
   382	                var psi = new ProcessStartInfo(python, "-c \"" + code.Replace("\\", "\\\\").Replace("\"", "\\\"") + "\"")
   383	                {
   384	                    RedirectStandardOutput = true,
   385	                    RedirectStandardError = true,
   386	                    UseShellExecute = false
   387	                };
   388	                using (var proc = Process.Start(psi))
   389	                {
   390	                    var stdout = proc.StandardOutput.ReadToEnd();
   391	                    var stderr = proc.StandardError.ReadToEnd();
   392	                    proc.WaitForExit();
   393	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow failed: {stderr}");
   394	                    return JObject.Parse(stdout.Trim());
   395	                }
   396	            }
   397	            finally
   398	            {
   399	                File.Delete(path);
   400	            }
   401	        }
