   119	        schema: &Schema,
   120	        visited: &mut HashSet<usize>,
   121	    ) {
   122	        match self {
   123	            ChunkingStrategy::Basic { chunk_size: _ } => {}
   124	            ChunkingStrategy::Delta { chunk_size: _ } => {}
   125	            ChunkingStrategy::NumpressLinear { chunk_size: _ } => {
   126	                let fields = self.extra_arrays(main_axis_name);
