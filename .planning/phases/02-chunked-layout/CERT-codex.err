  1303	        private void CollectPrefix(string curie)
  1304	        {
  1305	            if (string.IsNullOrEmpty(curie)) return;
  1306	            var i = curie.IndexOf(':');
  1307	            if (i > 0) _cvPrefixes.Add(curie.Substring(0, i));
