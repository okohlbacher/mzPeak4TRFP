   724	        [Test]
   725	        public void Metadata_NumberOfPeaks_Matches_PerOrdinal_Peaks_Facet()
   726	        {
   727	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   728	            var dir = Convert(input, out var archive);
   729	            try
   730	            {
   731	                var peaks = ReadPointFacet(ReadEntry(archive, "spectra_peaks.parquet"));
   732	                var perOrdinal = peaks.SpectrumIndex
   733	                    .GroupBy(x => x)
   734	                    .ToDictionary(g => g.Key, g => (long)g.Count());
   735	
   736	                var snippet =
   737	                    "import pyarrow.parquet as pq, json\n" +
   738	                    "t = pq.read_table(r'{PARQUET}')\n" +
   739	                    "d = t.to_pylist()\n" +
   740	                    "N = len(d)\n" +
   741	                    "out = {'npk': {str(i): d[i]['spectrum']['MS_1003059_number_of_peaks'] for i in range(N)}}\n" +
   742	                    "print(json.dumps(out))\n";
   743	                var o = PyArrowMetadata(archive, snippet);
   744	                var npk = (JObject)o["npk"];
   745	
   746	                foreach (var kv in npk)
   747	                {
   748	                    ulong ord = ulong.Parse(kv.Key);
   749	                    if (kv.Value.Type == JTokenType.Null)
   750	                    {
   751	                        Assert.That(perOrdinal.ContainsKey(ord), Is.False,
   752	                            $"ordinal {ord} has null number_of_peaks but peaks were written");
   753	                    }
   754	                    else
   755	                    {
   756	                        Assert.That(perOrdinal.TryGetValue(ord, out var cnt) && cnt == (long)kv.Value, Is.True,
   757	                            $"ordinal {ord} number_of_peaks must equal its spectra_peaks point count");
   758	                    }
   759	                }
   760	            }
   761	            finally
   762	            {
   763	                Directory.Delete(dir, true);
   764	            }
   765	        }
