   261	        [Test]
   262	        public void SchemaDiff_vs_Reference()
   263	        {
   264	            var root = RepoRoot();
   265	            if (root == null) Assert.Ignore("reference archive not found");
   266	            var archive = Convert(false, out var dir);
   267	            try
   268	            {
   269	                var refArchive = Path.Combine(root, ReferenceChunkedArchive);
   270	                var snippet =
   271	                    "import pyarrow.parquet as pq, json\n" +
   272	                    "f = pq.read_table(r'{PARQUET}').schema.field('chunk').type\n" +
   273	                    "out = {'names':[f.field(i).name for i in range(f.num_fields)],\n" +
   274	                    "       'mz_item':str(f.field(3).type.value_field.type),\n" +
   275	                    "       'int_item':str(f.field(5).type.value_field.type)}\n" +
   276	                    "print(json.dumps(out))\n";
   277	                var ours = PyArrow(archive, "spectra_data.parquet", snippet);
   278	                var refs = PyArrow(refArchive, "spectra_data.parquet", snippet);
   279	
   280	                Assert.That(ours["names"].Select(x => (string)x).ToArray(),
   281	                    Is.EqualTo(refs["names"].Select(x => (string)x).ToArray()),
   282	                    "chunk field names match the reference");
   283	                Assert.That((string)ours["mz_item"], Is.EqualTo("double"));
   284	                Assert.That((string)ours["int_item"], Is.EqualTo("float"));
   285	                Assert.That((string)refs["mz_item"], Is.EqualTo("double"));
   286	                Assert.That((string)refs["int_item"], Is.EqualTo("float"));
   287	
   288	                var encSnippet =
   289	                    "import pyarrow.parquet as pq, json\n" +
   290	                    "t = pq.read_table(r'{PARQUET}').column('chunk').combine_chunks()\n" +
   291	                    "print(json.dumps({'enc':sorted(set(t.field('chunk_encoding').to_pylist()))}))\n";
   292	                var ourEnc = PyArrow(archive, "spectra_data.parquet", encSnippet)["enc"].Select(x => (string)x).ToArray();
   293	                Assert.That(ourEnc, Is.EqualTo(new[] { "MS:1003089" }), "chunk_encoding is the reference delta CURIE");
   294	            }
   295	            finally { Directory.Delete(dir, true); }
   296	        }
