  1048	        // A chrom-data facet streamed to a seekable temp file. Bounded by scan count anyway; streamed for
  1049	        // uniformity with the point facets.
  1050	        private sealed class ChromDataFacetStream : IDisposable
  1051	        {
  1052	            public readonly string TempPath;
  1053	            private readonly ParquetSchema _schema;
  1054	            private readonly DataField _idx, _time, _int, _lvl;
  1055	            private readonly int _cap;
  1056	            private FileStream _sink;
  1057	            private MzPeakParquet.Handle _handle;
  1058	            private readonly List<ulong> _bIdx = new List<ulong>();
  1059	            private readonly List<double> _bTime = new List<double>();
  1060	            private readonly List<float> _bInt = new List<float>();
  1061	            private readonly List<long> _bLvl = new List<long>();
  1062	
  1063	            public long PointCount { get; private set; }
  1064	
  1065	            public ChromDataFacetStream(int cap)
  1066	            {
  1067	                _cap = cap;
  1068	                TempPath = Path.GetTempFileName();
  1069	                _schema = new ParquetSchema(ChromDataStructField());
  1070	                _idx = Leaf(_schema, "point/chromatogram_index");
  1071	                _time = Leaf(_schema, "point/time");
  1072	                _int = Leaf(_schema, "point/intensity");
  1073	                _lvl = Leaf(_schema, "point/ms_level");
  1074	                try
  1075	                {
  1076	                    _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
  1077	                    _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
  1078	                }
  1079	                catch
  1080	                {
  1081	                    _handle?.Dispose();
  1082	                    _sink?.Dispose();
  1083	                    TryDelete(TempPath);
  1084	                    throw;
  1085	                }
  1086	            }
  1087	
  1088	            public void Append(double time, float intensity, long msLevel)
  1089	            {
  1090	                _bIdx.Add(0UL); _bTime.Add(time); _bInt.Add(intensity); _bLvl.Add(msLevel);
  1091	                PointCount++;
  1092	                if (_bIdx.Count >= _cap) Flush();
  1093	            }
  1094	
  1095	            private void Flush()
  1096	            {
  1097	                if (_bIdx.Count == 0) return;
  1098	                var cols = new Dictionary<DataField, (Array, int[], int[])>
  1099	                {
  1100	                    [_idx] = (_bIdx.ToArray(), null, null),
  1101	                    [_time] = (_bTime.ToArray(), null, null),
  1102	                    [_int] = (_bInt.ToArray(), null, null),
  1103	                    [_lvl] = (_bLvl.ToArray(), null, null)
  1104	                };
  1105	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
  1106	                _bIdx.Clear(); _bTime.Clear(); _bInt.Clear(); _bLvl.Clear();
  1107	            }
  1108	
  1109	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
  1110	            {
  1111	                Flush();
  1112	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
  1113	                _handle = null;
  1114	                _sink.Dispose();
  1115	                _sink = null;
  1116	            }
  1117	
  1118	            public void Dispose()
  1119	            {
  1120	                _handle?.Dispose();
  1121	                _sink?.Dispose();
  1122	            }
  1123	        }
