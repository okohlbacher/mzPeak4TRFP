    41	pub fn delta_decode<T: Float + Pod + AddAssign>(
    42	    it: &[T],
    43	    start_value: T,
    44	    accumulator: &mut DataArray,
    45	) -> usize {
    46	    let mut state = start_value;
    47	    accumulator.push(state).unwrap();
    48	    for val in it.iter().copied() {
    49	        state += val;
    50	        accumulator.push(state).unwrap();
    51	    }
    52	    it.len() + 1
    53	}
