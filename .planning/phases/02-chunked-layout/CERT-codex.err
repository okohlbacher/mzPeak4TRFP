  1310	        private static void AddScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1311	            string path, Array values, bool[] present)
  1312	        {
  1313	            var leaf = Leaf(schema, path);
  1314	            var rows = present.Select(p => p ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1315	            var (def, _r) = MzPeakParquet.NestedLevels(leaf, rows);
  1316	            cols[leaf] = (values, def, null);
  1317	        }
  1318	
  1319	        // A scalar leaf inside a top-level struct present only on the first M rows (the MSn count),
  1320	        // null on rows M..N-1. values has length M (one per MSn).
  1321	        private static void AddMsnScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1322	            string path, int n, Array values)
  1323	        {
  1324	            var leaf = Leaf(schema, path);
  1325	            int m = values.Length;
  1326	            var rows = Enumerable.Range(0, n)
  1327	                .Select(i => i < m ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
  1328	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1329	            cols[leaf] = (values, def, null);
  1330	        }
  1331	
  1332	        private static void AddMsnString(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
  1333	            string path, int n, string[] values)
  1334	        {
  1335	            var leaf = Leaf(schema, path);
  1336	            int m = values.Length;
  1337	            var rows = new List<MzPeakParquet.LeafRow>();
  1338	            var present = new List<string>();
  1339	            for (int i = 0; i < n; i++)
  1340	            {
  1341	                if (i >= m) rows.Add(MzPeakParquet.Absent());
  1342	                else if (values[i] != null) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i]); }
  1343	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
  1344	            }
  1345	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
  1346	            cols[leaf] = (present.ToArray(), def, null);
  1347	        }
