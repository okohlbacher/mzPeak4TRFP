   807	
   808	        // The spectra_data facet contract shared by the point and chunk layouts: append a scan's
   809	        // (mz,intensity) arrays, expose the running data-point count and temp path, and close with the
   810	        // footer KV. The Write() path selects the implementation by the layout flag.
   811	        private interface ISpectraDataFacet : IDisposable
   812	        {
   813	            string TempPath { get; }
   814	            long PointCount { get; }
   815	            void Append(ulong ordinal, double[] mz, float[] intensity);
   816	            void Close(IReadOnlyDictionary<string, string> finalMetadata);
   817	        }
   818	
   819	        // A point-facet (spectra_data / spectra_peaks) streamed to a seekable temp file in bounded row
   820	        // groups. Staging buffers accumulate per scan and flush at the cap; the final residual buffer is
   821	        // flushed by Close, which also attaches the footer KV before disposing the writer.
   822	        private sealed class PointFacetStream : IDisposable, ISpectraDataFacet
   823	        {
   824	            public string TempPath { get; }
   825	            private readonly ParquetSchema _schema;
   826	            private readonly DataField _idx, _mz, _int;
   827	            private readonly int _cap;
   828	            private FileStream _sink;
   829	            private MzPeakParquet.Handle _handle;
   830	            private readonly List<ulong> _bIdx = new List<ulong>();
   831	            private readonly List<double> _bMz = new List<double>();
   832	            private readonly List<float> _bInt = new List<float>();
   833	
   834	            public long PointCount { get; private set; }
   835	
   836	            public PointFacetStream(int cap)
   837	            {
   838	                _cap = cap;
   839	                TempPath = Path.GetTempFileName();
   840	                _schema = new ParquetSchema(PointStructField());
   841	                _idx = Leaf(_schema, "point/spectrum_index");
   842	                _mz = Leaf(_schema, "point/mz");
   843	                _int = Leaf(_schema, "point/intensity");
   844	                try
   845	                {
   846	                    _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
   847	                    _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
   848	                }
   849	                catch
   850	                {
   851	                    // Self-clean a partially-opened facet: the caller never receives a reference to dispose,
   852	                    // so release the sink and delete the temp file here before the exception propagates.
   853	                    _handle?.Dispose();
   854	                    _sink?.Dispose();
   855	                    TryDelete(TempPath);
   856	                    throw;
   857	                }
   858	            }
   859	
   860	            // The cap is a HARD upper bound on the in-memory buffer: a single scan's points are split
   861	            // across as many row groups as needed (a scan MAY span row groups in the point layout),
   862	            // filling the remaining capacity, flushing at the cap, then continuing with the same ordinal.
   863	            public void Append(ulong ordinal, double[] mz, float[] intensity)
   864	            {
   865	                int i = 0;
   866	                while (i < mz.Length)
   867	                {
   868	                    int room = _cap - _bIdx.Count;
   869	                    int take = Math.Min(room, mz.Length - i);
   870	                    for (int j = 0; j < take; j++, i++)
   871	                    {
   872	                        _bIdx.Add(ordinal); _bMz.Add(mz[i]); _bInt.Add(intensity[i]);
   873	                    }
   874	                    if (_bIdx.Count >= _cap) Flush();
   875	                }
   876	                PointCount += mz.Length;
   877	            }
   878	
   879	            private void Flush()
   880	            {
   881	                if (_bIdx.Count == 0) return;
   882	                var cols = new Dictionary<DataField, (Array, int[], int[])>
   883	                {
   884	                    [_idx] = (_bIdx.ToArray(), null, null),
   885	                    [_mz] = (_bMz.ToArray(), null, null),
   886	                    [_int] = (_bInt.ToArray(), null, null)
   887	                };
   888	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
   889	                _bIdx.Clear(); _bMz.Clear(); _bInt.Clear();
   890	            }
   891	
   892	            // Finalize order: flush residual buffer -> CloseAsync(final KV) disposes the writer -> dispose
   893	            // the temp FileStream. After this returns the temp file is fully on disk.
   894	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
   895	            {
   896	                Flush();
   897	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
   898	                _handle = null;
   899	                _sink.Dispose();
   900	                _sink = null;
   901	            }
   902	
   903	            public void Dispose()
   904	            {
   905	                _handle?.Dispose();
   906	                _sink?.Dispose();
   907	            }
   908	        }
   909	
   910	        // A chunked spectra_data facet streamed to a seekable temp file. One chunk struct row per
   911	        // non-empty m/z window per scan: scalar spectrum_index/start/end/encoding plus the two
   912	        // nullable-item lists (mz_chunk_values delta-encoded, intensity verbatim). The row-group cap counts
   913	        // chunk ROWS, not points; a scan contributes as many rows as it has windows.
   914	        private sealed class ChunkFacetStream : IDisposable, ISpectraDataFacet
   915	        {
   916	            public string TempPath { get; }
   917	            private readonly ParquetSchema _schema;
   918	            private readonly DataField _idx, _start, _end, _enc, _mzItem, _intItem;
   919	            private readonly int _cap;
   920	            private readonly double _chunkSize;
   921	            private FileStream _sink;
   922	            private MzPeakParquet.Handle _handle;
   923	
   924	            private readonly List<ulong> _bIdx = new List<ulong>();
   925	            private readonly List<double> _bStart = new List<double>();
   926	            private readonly List<double> _bEnd = new List<double>();
   927	            private readonly List<string> _bEnc = new List<string>();
   928	            private readonly List<MzPeakParquet.LeafRow> _mzRows = new List<MzPeakParquet.LeafRow>();
   929	            private readonly List<double> _mzVals = new List<double>();
   930	            private readonly List<MzPeakParquet.LeafRow> _intRows = new List<MzPeakParquet.LeafRow>();
   931	            private readonly List<float> _intVals = new List<float>();
   932	
   933	            public long PointCount { get; private set; }
   934	
   935	            public ChunkFacetStream(int cap, double chunkSize)
   936	            {
   937	                _cap = cap;
   938	                _chunkSize = chunkSize;
   939	                TempPath = Path.GetTempFileName();
   940	                _schema = new ParquetSchema(ChunkStructField());
   941	                _idx = Leaf(_schema, "chunk/spectrum_index");
   942	                _start = Leaf(_schema, "chunk/mz_chunk_start");
   943	                _end = Leaf(_schema, "chunk/mz_chunk_end");
   944	                _enc = Leaf(_schema, "chunk/chunk_encoding");
   945	                _mzItem = Leaf(_schema, "chunk/mz_chunk_values/list/item");
   946	                _intItem = Leaf(_schema, "chunk/intensity/list/item");
   947	                try
   948	                {
   949	                    _sink = new FileStream(TempPath, FileMode.Create, FileAccess.Write);
   950	                    _handle = MzPeakParquet.OpenAsync(_sink, _schema, null).GetAwaiter().GetResult();
   951	                }
   952	                catch
   953	                {
   954	                    _handle?.Dispose();
   955	                    _sink?.Dispose();
   956	                    TryDelete(TempPath);
   957	                    throw;
   958	                }
   959	            }
   960	
   961	            // Builds one chunk row per non-empty window. Empty scans contribute no row.
   962	            public void Append(ulong ordinal, double[] mz, float[] intensity)
   963	            {
   964	                foreach (var (s, e) in MzPeakChunkCodec.Chunk(mz, _chunkSize))
   965	                {
   966	                    var slice = new double?[e - s];
   967	                    for (int i = s; i < e; i++) slice[i - s] = mz[i];
   968	                    MzPeakChunkCodec.DeltaEncode(slice, out var start, out var end, out var values);
   969	
   970	                    _bIdx.Add(ordinal);
   971	                    _bStart.Add(start);
   972	                    _bEnd.Add(end);
   973	                    _bEnc.Add(ChunkEncodingCurie);
   974	
   975	                    if (values.Length == 0)
   976	                    {
   977	                        _mzRows.Add(MzPeakParquet.EmptyList((ListField)FindField(_schema, "chunk/mz_chunk_values")));
   978	                    }
   979	                    else
   980	                    {
   981	                        var levels = new int[values.Length];
   982	                        var has = new bool[values.Length];
   983	                        for (int i = 0; i < values.Length; i++)
   984	                        {
   985	                            levels[i] = _mzItem.MaxDefinitionLevel; has[i] = true;
   986	                            _mzVals.Add(values[i].Value);
   987	                        }
   988	                        _mzRows.Add(MzPeakParquet.ListOf(levels, has));
   989	                    }
   990	
   991	                    int k = e - s;
   992	                    var iLevels = new int[k];
   993	                    var iHas = new bool[k];
   994	                    for (int i = 0; i < k; i++)
   995	                    {
   996	                        iLevels[i] = _intItem.MaxDefinitionLevel; iHas[i] = true;
   997	                        _intVals.Add(intensity[s + i]);
   998	                    }
   999	                    _intRows.Add(MzPeakParquet.ListOf(iLevels, iHas));
  1000	
  1001	                    PointCount += k;
  1002	                    if (_bIdx.Count >= _cap) Flush();
  1003	                }
  1004	            }
  1005	
  1006	            private void Flush()
  1007	            {
  1008	                if (_bIdx.Count == 0) return;
  1009	                var present = _bIdx.Select(_ => true).ToArray();
  1010	                var (idxDef, _i) = MzPeakParquet.NestedLevels(_idx, present.Select(_ => MzPeakParquet.Present(_idx)).ToArray());
  1011	                var (startDef, _s) = MzPeakParquet.NestedLevels(_start, present.Select(_ => MzPeakParquet.Present(_start)).ToArray());
  1012	                var (endDef, _e) = MzPeakParquet.NestedLevels(_end, present.Select(_ => MzPeakParquet.Present(_end)).ToArray());
  1013	                var (encDef, _c) = MzPeakParquet.NestedLevels(_enc, present.Select(_ => MzPeakParquet.Present(_enc)).ToArray());
  1014	                var (mzDef, mzRep) = MzPeakParquet.NestedLevels(_mzItem, _mzRows);
  1015	                var (intDef, intRep) = MzPeakParquet.NestedLevels(_intItem, _intRows);
  1016	
  1017	                var cols = new Dictionary<DataField, (Array, int[], int[])>
  1018	                {
  1019	                    [_idx] = (_bIdx.ToArray(), idxDef, null),
  1020	                    [_start] = (_bStart.ToArray(), startDef, null),
  1021	                    [_end] = (_bEnd.ToArray(), endDef, null),
  1022	                    [_enc] = (_bEnc.ToArray(), encDef, null),
  1023	                    [_mzItem] = (_mzVals.ToArray(), mzDef, mzRep),
  1024	                    [_intItem] = (_intVals.ToArray(), intDef, intRep)
  1025	                };
  1026	                _handle.WriteRowGroupAsync(_schema, cols).GetAwaiter().GetResult();
  1027	
  1028	                _bIdx.Clear(); _bStart.Clear(); _bEnd.Clear(); _bEnc.Clear();
  1029	                _mzRows.Clear(); _mzVals.Clear(); _intRows.Clear(); _intVals.Clear();
  1030	            }
  1031	
  1032	            public void Close(IReadOnlyDictionary<string, string> finalMetadata)
  1033	            {
  1034	                Flush();
  1035	                _handle.CloseAsync(finalMetadata).GetAwaiter().GetResult();
  1036	                _handle = null;
  1037	                _sink.Dispose();
  1038	                _sink = null;
  1039	            }
