   298	        [Test]
   299	        public void Footer_ArrayIndex_Lock()
   300	        {
   301	            var root = RepoRoot();
   302	            if (root == null) Assert.Ignore("reference archive not found");
   303	            var chunked = Convert(false, out var cdir);
   304	            var pointed = Convert(true, out var pdir);
   305	            try
   306	            {
   307	                var footerSnippet =
   308	                    "import pyarrow.parquet as pq, json\n" +
   309	                    "m = pq.read_metadata(r'{PARQUET}').metadata\n" +
   310	                    "print(m[b'spectrum_array_index'].decode())\n";
   311	
   312	                var ours = PyArrow(chunked, "spectra_data.parquet", footerSnippet);
   313	                Assert.That((string)ours["prefix"], Is.EqualTo("chunk"));
   314	                var entries = (JArray)ours["entries"];
   315	                Assert.That(entries.Select(e => (string)e["buffer_format"]).ToArray(),
   316	                    Is.EqualTo(new[] { "chunk_start", "chunk_end", "chunk_values", "chunk_encoding", "chunk_secondary" }));
   317	
   318	                var refArchive = Path.Combine(root, ReferenceChunkedArchive);
   319	                var refFooter = PyArrow(refArchive, "spectra_data.parquet", footerSnippet);
   320	                var refEntries = (JArray)refFooter["entries"];
   321	                var refTransforms = refEntries.Select(e => (string)e["transform"]).ToArray();
   322	                Assert.That(entries.Select(e => (string)e["transform"]).ToArray(), Is.EqualTo(refTransforms),
   323	                    "transform CURIEs match the reference footer verbatim");
   324	
   325	                // m/z entries carry sorting_rank 0; the intensity entry omits it.
   326	                for (int i = 0; i < 4; i++)
   327	                    Assert.That((int)entries[i]["sorting_rank"], Is.EqualTo(0), $"m/z entry {i} sorting_rank 0");
   328	                Assert.That(entries[4]["sorting_rank"].Type, Is.EqualTo(JTokenType.Null),
   329	                    "intensity entry omits sorting_rank");
   330	
   331	                var pointFooter = PyArrow(pointed, "spectra_data.parquet", footerSnippet);
   332	                Assert.That((string)pointFooter["prefix"], Is.EqualTo("point"),
   333	                    "--point mode retains the v1 point array_index");
   334	                Assert.That(((JArray)pointFooter["entries"]).Select(e => (string)e["buffer_format"]).ToArray(),
   335	                    Is.EqualTo(new[] { "point", "point" }));
   336	            }
   337	            finally { Directory.Delete(cdir, true); Directory.Delete(pdir, true); }
   338	        }
