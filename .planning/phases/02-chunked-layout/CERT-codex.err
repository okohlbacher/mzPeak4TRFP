   359	#[derive(Debug, Clone, Copy, PartialEq, Eq)]
   360	pub struct BufferTransformEncoder(BufferTransform);
   361	
   362	impl TryFrom<Option<BufferTransform>> for BufferTransformEncoder {
   363	    type Error = <Self as TryFrom<BufferTransform>>::Error;
   364	
   365	    fn try_from(value: Option<BufferTransform>) -> Result<Self, Self::Error> {
   366	        match value {
   367	            Some(value) => value.try_into(),
   368	            None => Err(format!("Cannot convert from empty")),
   369	        }
   370	    }
   371	}
   372	
   373	impl TryFrom<BufferTransform> for BufferTransformEncoder {
   374	    type Error = String;
   375	
   376	    fn try_from(value: BufferTransform) -> Result<Self, Self::Error> {
   377	        match value {
   378	            BufferTransform::NumpressLinear
   379	            | BufferTransform::NumpressSLOF
   380	            | BufferTransform::NumpressPIC => Ok(Self(value)),
   381	            BufferTransform::NullInterpolate | BufferTransform::NullZero => {
   382	                Err(format!("{value:?} does not have an encoder"))
   383	            }
   384	        }
   385	    }
   386	}
   387	
   388	impl BufferTransformEncoder {
   389	    pub fn to_buffer_name(&self, buffer_name: &BufferName) -> BufferName {
   390	        match self.0 {
   391	            BufferTransform::NumpressLinear => todo!(),
   392	            BufferTransform::NumpressSLOF | BufferTransform::NumpressPIC => buffer_name
   393	                .clone()
   394	                .with_format(BufferFormat::ChunkTransform)
   395	                .with_transform(Some(self.0)),
   396	            _ => unimplemented!("{:?} does not have a buffer name", self.0),
   397	        }
   398	    }
   399	
   400	    pub fn to_field(&self, buffer_name: &BufferName) -> Field {
   401	        let buffer_name = self.to_buffer_name(buffer_name);
   402	        match self.0 {
   403	            BufferTransform::NumpressLinear => todo!(),
   404	            BufferTransform::NumpressSLOF | BufferTransform::NumpressPIC => {
   405	                let meta = buffer_name.as_field_metadata();
   406	                let bytes = Field::new(
   407	                    buffer_name.to_string(),
   408	                    DataType::LargeList(Arc::new(Field::new("item", DataType::UInt8, false))),
   409	                    true,
   410	                )
   411	                .with_metadata(meta);
   412	                bytes
   413	            }
   414	            _ => unimplemented!("{:?} does not have a field conversion", self.0),
   415	        }
   416	    }
   417	
   418	    pub fn visit_builder(
   419	        &self,
   420	        buffer_name: &BufferName,
   421	        chunk: &ArrowArrayChunk,
   422	        chunk_builder: &mut StructBuilder,
   423	        schema: &Schema,
   424	        visited: &mut HashSet<usize>,
   425	    ) {
   426	        // The buffer name's array is already the name of the field we want, we don't want to
   427	        // use the full buffer name formatting again
   428	        let f = self.to_field(buffer_name);
   429	        let q = f.name();
   430	        let idx = schema.fields().iter().position(|p| p.name() == q).unwrap();
   431	
   432	        if visited.contains(&idx) {
   433	            return;
   434	        }
   435	        visited.insert(idx);
   436	        let b: &mut LargeListBuilder<Box<dyn ArrayBuilder>> =
   437	            chunk_builder.field_builder(idx).unwrap();
   438	
   439	        if let Some(chunk_segment) = chunk.arrays.get(buffer_name) {
   440	            let inner = b
   441	                .values()
   442	                .as_any_mut()
   443	                .downcast_mut::<UInt8Builder>()
   444	                .unwrap();
   445	            let bytes: &UInt8Array = chunk_segment.as_primitive();
   446	            inner.extend(bytes);
   447	            b.append(true);
   448	        } else {
   449	            b.append_null();
   450	        }
   451	    }
   452	
   453	    pub fn encode_arrow(
   454	        &self,
   455	        _buffer_name: &BufferName,
   456	        chunk_segment: &impl AsArray,
   457	    ) -> ArrayRef {
   458	        match self.0 {
   459	            BufferTransform::NumpressLinear => todo!(),
   460	            BufferTransform::NumpressPIC => {
   461	                let mut bytes = Vec::new();
   462	                if let Some(vals) = chunk_segment.as_primitive_opt::<Float32Type>() {
   463	                    let vals = vals.values();
   464	                    numpress_rs::encode_pic(&vals, &mut bytes).unwrap();
   465	                } else if let Some(vals) = chunk_segment.as_primitive_opt::<Float64Type>() {
   466	                    let vals = vals.values();
   467	                    numpress_rs::encode_pic(&vals, &mut bytes).unwrap();
   468	                } else {
   469	                    todo!()
   470	                }
   471	                Arc::new(UInt8Array::from(bytes))
   472	            }
   473	            BufferTransform::NumpressSLOF => {
   474	                let mut bytes = Vec::new();
   475	                if let Some(vals) = chunk_segment.as_primitive_opt::<Float32Type>() {
   476	                    let vals = vals.values();
   477	                    let fp = numpress_rs::optimal_slof_fixed_point(&vals);
   478	                    numpress_rs::encode_slof(&vals, &mut bytes, fp).unwrap();
   479	                } else if let Some(vals) = chunk_segment.as_primitive_opt::<Float64Type>() {
   480	                    let vals = vals.values();
   481	                    let fp = numpress_rs::optimal_slof_fixed_point(&vals);
   482	                    numpress_rs::encode_slof(&vals, &mut bytes, fp).unwrap();
   483	                } else {
   484	                    todo!()
   485	                }
   486	                let bytes = UInt8Array::from(bytes);
   487	                Arc::new(bytes)
   488	            }
   489	            _ => unimplemented!("{:?} does not have an encoder", self.0),
   490	        }
   491	    }
   492	}
   493	
   494	#[derive(Debug, Clone, Copy, PartialEq, Eq)]
   495	pub struct BufferTransformDecoder(BufferTransform);
   496	
   497	impl BufferTransformDecoder {
   498	    pub fn decode(&self, buffer_name: &BufferName, array: &impl AsArray) -> ArrayRef {
   499	        macro_rules! decoder {
   500	            ($decoder:path) => {
   501	                let data: &UInt8Array = array.as_primitive();
   502	                match buffer_name.dtype {
   503	                    BinaryDataArrayType::Float64 => {
   504	                        let mut acc: Vec<f64> = Vec::new();
   505	                        $decoder(data.values(), &mut acc).unwrap();
   506	                        return Arc::new(Float64Array::from(acc));
   507	                    }
   508	                    BinaryDataArrayType::Float32 => {
   509	                        let mut acc: Vec<f64> = Vec::new();
   510	                        $decoder(data.values(), &mut acc).unwrap();
   511	                        return Arc::new(Float32Array::from_iter_values(
   512	                            acc.into_iter().map(|v| v as f32),
   513	                        ));
   514	                    }
   515	                    BinaryDataArrayType::Int32 => {
   516	                        let mut acc: Vec<f64> = Vec::new();
   517	                        $decoder(data.values(), &mut acc).unwrap();
   518	                        return Arc::new(Int32Array::from_iter_values(
   519	                            acc.into_iter().map(|v| v as i32),
   520	                        ));
   521	                    }
   522	                    BinaryDataArrayType::Int64 => {
   523	                        let mut acc: Vec<f64> = Vec::new();
   524	                        $decoder(data.values(), &mut acc).unwrap();
   525	                        return Arc::new(Int64Array::from_iter_values(
   526	                            acc.into_iter().map(|v| v as i64),
   527	                        ));
   528	                    }
   529	                    _ => panic!("Cannot decode {:?} into {:?}", self.0, buffer_name.dtype),
   530	                }
   531	            };
   532	        }
   533	        match self.0 {
   534	            BufferTransform::NumpressLinear => todo!(),
   535	            BufferTransform::NumpressSLOF => {
   536	                decoder!(numpress_rs::decode_slof);
   537	            }
   538	            BufferTransform::NumpressPIC => {
   539	                decoder!(numpress_rs::decode_pic);
   540	            }
   541	            _ => unimplemented!("{:?} does not have a decoder", self.0),
   542	        }
   543	    }
   544	}
   545	
   546	impl TryFrom<Option<BufferTransform>> for BufferTransformDecoder {
   547	    type Error = <Self as TryFrom<BufferTransform>>::Error;
   548	
   549	    fn try_from(value: Option<BufferTransform>) -> Result<Self, Self::Error> {
   550	        match value {
   551	            Some(value) => value.try_into(),
   552	            None => Err(format!("Cannot convert from empty")),
   553	        }
   554	    }
   555	}
   556	
   557	impl TryFrom<BufferTransform> for BufferTransformDecoder {
   558	    type Error = String;
   559	
   560	    fn try_from(value: BufferTransform) -> Result<Self, Self::Error> {
   561	        match value {
   562	            BufferTransform::NumpressLinear
   563	            | BufferTransform::NumpressSLOF
   564	            | BufferTransform::NumpressPIC => Ok(Self(value)),
   565	            BufferTransform::NullInterpolate | BufferTransform::NullZero => {
   566	                Err(format!("{value:?} does not have a decoder"))
   567	            }
   568	        }
   569	    }
   570	}
