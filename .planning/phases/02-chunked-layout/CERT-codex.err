   808	                    optionSet);
   809	            }
   810	            catch (ArgumentNullException)
   811	            {
   812	                if (help)
   813	                {
   814	                    ShowHelp("usage is:", new OptionException(),
   815	                        optionSet);
   816	                }
   817	                else
   818	                {
   819	                    ShowHelp("Error - usage is:", new OptionException(),
   820	                        optionSet);
   821	                }
   822	            }
   823	
   824	            var exitCode = 1;
   825	            try
   826	            {
   827	                switch (parseInput.LogFormat)
   828	                {
   829	                    case LogFormat.VERBOSE:
   830	                        ((log4net.Repository.Hierarchy.Hierarchy) LogManager.GetRepository()).Root.Level =
   831	                            Level.Debug;
   832	                        ((log4net.Repository.Hierarchy.Hierarchy) LogManager.GetRepository())
   833	                            .RaiseConfigurationChanged(EventArgs.Empty);
   834	                        break;
   835	                    case LogFormat.SILENT:
   836	                        ((log4net.Repository.Hierarchy.Hierarchy) LogManager.GetRepository()).Root.Level =
   837	                            Level.Off;
   838	                        ((log4net.Repository.Hierarchy.Hierarchy) LogManager.GetRepository())
   839	                            .RaiseConfigurationChanged(EventArgs.Empty);
   840	                        break;
   841	                    case LogFormat.WARNING:
   842	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   843	                            Level.Warn;
   844	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   845	                            .RaiseConfigurationChanged(EventArgs.Empty);
   846	                        break;
   847	                    case LogFormat.ERROR:
   848	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository()).Root.Level =
   849	                            Level.Error;
   850	                        ((log4net.Repository.Hierarchy.Hierarchy)LogManager.GetRepository())
   851	                            .RaiseConfigurationChanged(EventArgs.Empty);
   852	                        break;
   853	                }
   854	
   855	                RawFileParser.Parse(parseInput);
   856	
   857	                Log.Info($"Processing completed {parseInput.Errors} errors, {parseInput.Warnings} warnings");
   858	
   859	                exitCode = parseInput.Vigilant ? parseInput.Errors + parseInput.Warnings: parseInput.Errors;
   860	            }
   861	            catch (UnauthorizedAccessException ex)
   862	            {
   863	                Log.Error(!ex.Message.IsNullOrEmpty()
   864	                    ? ex.Message
   865	                    : "Attempting to write to an unauthorized location.");
   866	            }
   867	            catch (Amazon.S3.AmazonS3Exception ex)
   868	            {
   869	                Log.Error(!ex.Message.IsNullOrEmpty()
   870	                    ? "An Amazon S3 exception occured: " + ex.Message
   871	                    : "An Amazon S3 exception occured: " + ex);
   872	            }
   873	            catch (Exception ex)
   874	            {
   875	                if (ex is RawFileParserException)
   876	                {
   877	                    Log.Error(ex.Message);
   878	                }
   879	                else
   880	                {
   881	                    Log.Error("An unexpected error occured:");
   882	                    Log.Error(ex.ToString());
   883	                }
   884	            }
   885	            finally
   886	            {
   887	                Environment.Exit(exitCode);
   888	            }
   889	        }
