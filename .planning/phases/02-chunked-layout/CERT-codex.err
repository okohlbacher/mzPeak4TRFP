    34	        private static string Convert(ParseInput parseInput, out string archive)
    35	        {
    36	            var dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
    37	            Directory.CreateDirectory(dir);
    38	            parseInput.OutputDirectory = dir;
    39	            // These fixtures assert the v1 point spectra_data layout, which is now the --point opt-in
    40	            // (chunked is the default); force point so the v1 invariants stay under test.
    41	            parseInput.MzPeakPointLayout = true;
    42	            RawFileParser.Parse(parseInput);
    43	            Assert.That(parseInput.Errors, Is.EqualTo(0));
    44	            archive = Path.Combine(dir, "small.mzpeak");
    45	            Assert.That(File.Exists(archive));
    46	            return dir;
    47	        }
