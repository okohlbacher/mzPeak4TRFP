   875	
   876	        private static string ResolveValidator()
   877	        {
   878	            foreach (var cand in new[] { "mzpeak-validate" })
   879	            {
   880	                try
   881	                {
   882	                    var psi = new ProcessStartInfo(cand, "--help")
   883	                    {
   884	                        RedirectStandardOutput = true,
   885	                        RedirectStandardError = true,
   886	                        UseShellExecute = false
   887	                    };
   888	                    using (var p = Process.Start(psi))
   889	                    {
   890	                        p.WaitForExit();
   891	                        return cand;
   892	                    }
   893	                }
