   703	/// Construct a boolean mask marking all positions where two consecutive values were zero
   704	pub fn is_zero_pair_mask<T: ArrowPrimitiveType>(array: &PrimitiveArray<T>) -> BooleanArray
   705	where
   706	    T::Native: Zero + PartialEq,
   707	{
   708	    let z = T::Native::zero();
   709	    let n = array.len();
   710	    let n1 = n.saturating_sub(1);
   711	    let mut was_zero = false;
   712	    let mut acc = Vec::new();
   713	    for (i, v) in array.iter().enumerate() {
   714	        if let Some(v) = v {
   715	            if v == z {
   716	                if was_zero || (i < n1 && array.value(i + 1) == z) {
   717	                    acc.push(true);
   718	                } else {
   719	                    acc.push(false)
   720	                }
   721	                was_zero = true;
   722	            } else {
   723	                acc.push(false);
   724	                was_zero = false;
   725	            }
   726	        } else {
   727	            acc.push(false);
   728	            was_zero = false;
   729	        }
   730	    }
   731	    assert_eq!(acc.len(), n);
   732	    acc.into()
   733	}
   734	
   735	pub fn nullify_at_zero_pair_arrays(
   736	    mut batch: Vec<ArrayRef>,
   737	    column_index: usize,
   738	    target_indices: &[usize]
   739	) -> Result<Vec<ArrayRef>, arrow::error::ArrowError> {
   740	    let target_array = &batch[column_index];
   741	    let mask = match target_array.data_type() {
   742	        DataType::Float32 => is_zero_pair_mask(target_array.as_primitive::<Float32Type>()),
   743	        DataType::Float64 => is_zero_pair_mask(target_array.as_primitive::<Float64Type>()),
   744	        DataType::Int32 => is_zero_pair_mask(target_array.as_primitive::<Int32Type>()),
   745	        DataType::Int64 => is_zero_pair_mask(target_array.as_primitive::<Int64Type>()),
   746	        DataType::UInt32 => is_zero_pair_mask(target_array.as_primitive::<UInt32Type>()),
   747	        DataType::UInt64 => is_zero_pair_mask(target_array.as_primitive::<UInt64Type>()),
   748	        _ => panic!("Unsupported data type {:?}", target_array.data_type()),
   749	    };
   750	
   751	    for (i, col) in batch.iter_mut().enumerate() {
   752	        if !target_indices.contains(&i) {
   753	            continue;
   754	        }
   755	        *col = nullif(col, &mask)?;
   756	    }
   757	
   758	    Ok(batch)
   759	}
