  1702	        [Test]
  1703	        public void FailedParent_DoesNotPoison_LaterChild_PrecursorResolution()
  1704	        {
  1705	            // Part A — staging isolation: a post-key read failure on an MS1 must consume no ordinal and no
  1706	            // precursor-map entry. Skip scan 8 (an MS1) through the real Write loop and assert the output
  1707	            // stays dense and every precursor_index still points at a real emitted ordinal.
  1708	            var dirA = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
  1709	            Directory.CreateDirectory(dirA);
  1710	            try
  1711	            {
  1712	                var archive = WriteWithInjection(dirA, failScan: 8, dropParentBeforeChild: null);
  1713	
  1714	                var data = ReadAllRowGroups(ReadEntry(archive, "spectra_data.parquet"));
  1715	                var metaIdx = ReadMetadataIndices(ReadEntry(archive, "spectra_metadata.parquet"));
  1716	
  1717	                Assert.That(data.SpectrumCount, Is.EqualTo(metaIdx.Length),
  1718	                    "metadata rows == data spectrum_count after the skip");
  1719	                Assert.That(metaIdx.OrderBy(x => x).ToArray(),
  1720	                    Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()),
  1721	                    "ordinals dense 0..N-1 despite the skipped scan");
  1722	                Assert.That(data.SpectrumCount, Is.EqualTo(V1SpectrumCount - 1),
  1723	                    "exactly one scan was skipped");
  1724	
  1725	                var (pre, _) = ReadMsnChildMaps(ReadEntry(archive, "spectra_metadata.parquet"));
  1726	                foreach (var v in pre.Values.Where(v => v.HasValue))
  1727	                    Assert.That(v.Value, Is.LessThan((ulong)data.SpectrumCount),
  1728	                        "no precursor_index may dangle past the emitted set");
  1729	            }
  1730	            finally
  1731	            {
  1732	                Directory.Delete(dirA, true);
  1733	            }
  1734	
  1735	            // Part B — the C1 isolation guard: drive the real Write loop so that, at the moment an MSn child
  1736	            // builds its precursor, its resolved parent has a positive scan number but no emitted ordinal
  1737	            // (read-but-not-committed). The child must end with NO precursor_index and NO selected-ion
  1738	            // intensity — it must not read intensity through the absent parent. Before the C1 fix the
  1739	            // intensity was computed from the parent's scan regardless, and this fails.
  1740	            const int childScan = 3; // the first MSn child in small.RAW
  1741	            var dirB = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
  1742	            Directory.CreateDirectory(dirB);
  1743	            try
  1744	            {
  1745	                var archive = WriteWithInjection(dirB, failScan: null, dropParentBeforeChild: childScan);
  1746	                var (pre, si) = ReadMsnChildMaps(ReadEntry(archive, "spectra_metadata.parquet"));
  1747	
  1748	                // childScan is the third scan; with all scans emitted its ordinal is childScan-1.
  1749	                ulong childOrdinal = (ulong)(childScan - 1);
  1750	                Assert.That(pre.ContainsKey(childOrdinal), Is.True, "the targeted child must be present");
  1751	                Assert.That(pre[childOrdinal], Is.Null,
  1752	                    "a child whose parent was not emitted must have a null precursor_index");
  1753	                Assert.That(si[childOrdinal], Is.Null,
  1754	                    "a child with no emitted parent must not read a selected-ion intensity through it");
  1755	
  1756	                // The universal C1 invariant across all children: intensity present implies parent present.
  1757	                foreach (var child in si.Keys)
  1758	                {
  1759	                    bool parentPresent = pre.TryGetValue(child, out var p) && p.HasValue;
  1760	                    if (si[child] != null)
  1761	                        Assert.That(parentPresent, Is.True,
  1762	                            "selected-ion intensity may only exist when the parent was emitted");
  1763	                }
  1764	            }
  1765	            finally
  1766	            {
  1767	                Directory.Delete(dirB, true);
  1768	            }
  1769	        }
  1770	
  1771	        [Test]
  1772	        public void BadScanFile_Converts_To_Completion_With_Skip_And_Parity()
  1773	        {
  1774	            var raw = Path.Combine(
  1775	                Environment.GetFolderPath(Environment.SpecialFolder.UserProfile),
  1776	                "Claude", "mzML2mzPeak", "data", "raw-replacements",
  1777	                "bruker-impact-sub__PXD076459", "S4_5foldGHRP.raw");
  1778	            if (!File.Exists(raw)) Assert.Ignore($"corpus bad-scan file not present: {raw}");
  1779	
  1780	            var dir = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
  1781	            Directory.CreateDirectory(dir);
  1782	            var input = new ParseInput(raw, null, dir, OutputFormat.MzPeak);
  1783	            try
  1784	            {
  1785	                // An unreadable scan must NEVER abort the conversion with an unhandled throw; it is logged
  1786	                // and ParseInput.NewError()-counted instead. This corpus file is a Finnigan RAW whose
  1787	                // scan-event index is corrupt: every scan raises "Cannot get scan event". The conversion
  1788	                // must absorb every one of them without crashing.
  1789	                Assert.DoesNotThrow(() => RawFileParser.Parse(input),
  1790	                    "bad scans must not abort the conversion with an unhandled exception");
  1791	                Assert.That(input.Errors, Is.GreaterThanOrEqualTo(1),
  1792	                    "each skipped scan is error-counted");
  1793	
  1794	                var archive = Path.Combine(dir, "S4_5foldGHRP.mzpeak");
  1795	                if (File.Exists(archive))
  1796	                {
  1797	                    // If any scan was readable, the produced archive must hold facet/metadata parity and
  1798	                    // dense ordinals despite the skips.
  1799	                    var data = ReadAllRowGroups(ReadEntry(archive, "spectra_data.parquet"));
  1800	                    var metaIdx = ReadMetadataIndices(ReadEntry(archive, "spectra_metadata.parquet"));
  1801	
  1802	                    int distinct = data.SpectrumIndex.Distinct().Count();
  1803	                    Assert.That(distinct, Is.EqualTo(data.SpectrumCount), "distinct spectrum_index == spectrum_count");
  1804	                    Assert.That(metaIdx.Length, Is.EqualTo(data.SpectrumCount), "metadata rows == spectrum_count");
  1805	                    Assert.That(metaIdx.OrderBy(x => x).ToArray(),
  1806	                        Is.EqualTo(Enumerable.Range(0, data.SpectrumCount).Select(i => (ulong)i).ToArray()),
  1807	                        "ordinals dense 0..N-1 despite the skips");
  1808	                }
  1809	                else
  1810	                {
  1811	                    // Every scan was unreadable -> graceful completion with no output is the correct
  1812	                    // degenerate behavior (the writer raises a clean "No in-range spectrum" rather than a
  1813	                    // corrupt partial archive). The no-abort + error-count assertions above are the gate.
  1814	                    Assert.That(input.Errors, Is.GreaterThan(25000),
  1815	                        "every scan in this corrupt file is skipped and counted");
  1816	                }
  1817	            }
  1818	            finally
  1819	            {
  1820	                Directory.Delete(dir, true);
  1821	            }
  1822	        }
