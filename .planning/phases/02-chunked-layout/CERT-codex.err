   438	
   439	        // For a value/* sibling leaf never populated in any element, every element entry is one level
   440	        // below the present level (null inside present element) mirroring the accession's rep pattern.
   441	        private static int[] NullLeaf(ParquetSchema schema, string path, int[] siblingDef, int[] siblingRep)
   442	        {
   443	            var leaf = Leaf(schema, path);
   444	            int present = leaf.MaxDefinitionLevel;
   445	            var def = new int[siblingDef.Length];
   446	            for (int i = 0; i < siblingDef.Length; i++)
   447	            {
   448	                // mirror sibling: element-present sibling levels become leaf-null (present-1);
   449	                // empty/null list levels carry through unchanged.
   450	                def[i] = siblingDef[i] >= present ? present - 1 : siblingDef[i];
   451	            }
   452	            return def;
   453	        }
   454	
   455	        private static int[] UnitLevels(int[] accDef, int present)
   456	        {
   457	            // unit present only for the collision-energy element (2nd entry); first present element
   458	            // (CID) has no unit -> present-1. Empty/null entries carry through unchanged.
   459	            var def = (int[])accDef.Clone();
   460	            int seenPresent = 0;
   461	            for (int i = 0; i < def.Length; i++)
   462	            {
   463	                if (def[i] == present)
   464	                {
   465	                    seenPresent++;
   466	                    if (seenPresent == 1) def[i] = present - 1; // CID: no unit
   467	                }
   468	            }
   469	            return def;
   470	        }
