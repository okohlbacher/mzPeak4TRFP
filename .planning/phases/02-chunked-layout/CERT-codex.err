   379	out['activation_lens'] = [ (None if (r['precursor'] is None or r['precursor']['activation'] is None or r['precursor']['activation']['parameters'] is None) else len(r['precursor']['activation']['parameters'])) for r in d ]
   380	out['scan_window_lens'] = [ (None if (r['scan'] is None or r['scan']['scan_windows'] is None) else len(r['scan']['scan_windows'])) for r in d ]
   381	p0 = d[0]['precursor']['activation']['parameters']
   382	out['row0_accessions'] = [e['accession'] for e in p0]
   383	out['row0_floats'] = [ (None if e['value']['float'] is None else e['value']['float']) for e in p0 ]
   384	out['row0_iso_target'] = round(d[0]['precursor']['isolation_window']['target'], 1)
   385	out['row0_window_lower'] = d[0]['scan']['scan_windows'][0]['lower']
   386	print(json.dumps(out))
   387	";
   388	                var psi = new ProcessStartInfo(python, "-c " + Quote(py))
   389	                {
   390	                    RedirectStandardOutput = true,
   391	                    RedirectStandardError = true,
   392	                    UseShellExecute = false
   393	                };
   394	                using (var proc = Process.Start(psi))
   395	                {
   396	                    var stdout = proc.StandardOutput.ReadToEnd();
   397	                    var stderr = proc.StandardError.ReadToEnd();
   398	                    proc.WaitForExit();
   399	                    Assert.That(proc.ExitCode, Is.EqualTo(0), $"pyarrow read failed: {stderr}");
   400	
   401	                    var o = Newtonsoft.Json.Linq.JObject.Parse(stdout.Trim());
   402	                    Assert.That((int)o["rows"], Is.EqualTo(4));
   403	                    Assert.That(o["precursor_present"].Select(x => (bool)x).ToArray(),
   404	                        Is.EqualTo(new[] { true, true, true, false }));
   405	                    // null list and empty list distinguished: row1 empty (0), rows 2&3 null (None)
   406	                    var actLens = o["activation_lens"].Select(x => x.Type == Newtonsoft.Json.Linq.JTokenType.Null ? (int?)null : (int)x).ToArray();
   407	                    Assert.That(actLens, Is.EqualTo(new int?[] { 2, 0, null, null }));
   408	
   409	                    // LEVEL-AWARE null list (H1): row2 has activation PRESENT with a null parameters list,
   410	                    // row3 has the whole precursor (hence activation) absent. These two must be encoded at
   411	                    // DIFFERENT definition levels so a reader can tell present-struct-null-list from
   412	                    // absent-struct -- not collapsed to a flat def=0.
   413	                    var actPresent = o["activation_present"].Select(x => (bool)x).ToArray();
   414	                    var paramsNull = o["params_null"].Select(x => (bool)x).ToArray();
   415	                    Assert.That(actPresent, Is.EqualTo(new[] { true, true, true, false }),
   416	                        "row2 activation present with null params; row3 activation absent (precursor null)");
   417	                    Assert.That(paramsNull, Is.EqualTo(new[] { false, false, true, true }),
   418	                        "parameters list null on rows 2 (struct-present) and 3 (struct-absent)");
   419	                    Assert.That(actPresent[2] && paramsNull[2], Is.True,
   420	                        "activation != null && parameters == null is distinguishable from activation == null");

