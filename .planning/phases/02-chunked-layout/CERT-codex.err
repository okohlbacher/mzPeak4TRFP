   914	        private static string GetValidEnumLevels(Type enumType)
   915	        {
   916	            List<string> output = new List<string>();
   917	            foreach (int v in Enum.GetValues(enumType))
   918	            {
   919	                output.Add(String.Format("{0} ({1})", Enum.GetName(enumType, v), v));
   920	            }
   921	
   922	            return String.Join("\n", output);
   923	        }
   924	
   925	        private static int ParseToEnum(Type enumType, string formatString, string keyName)
   926	        {
   927	            if (int.TryParse(formatString, out var formatInt)) //can be parsed as int
   928	            {
   929	                if (Enum.IsDefined(enumType, formatInt))
   930	                {
   931	                    return formatInt;
   932	                }
   933	                else
   934	                {
   935	                    throw new OptionException(
   936	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   937	                    keyName);
   938	                }
   939	
   940	            }
   941	            else //try parse as a string
   942	            {
   943	                try
   944	                {
   945	                    return (int)Enum.Parse(enumType, formatString, true);
   946	                }
   947	
   948	                catch (Exception)
   949	                {
   950	                    throw new OptionException(
   951	                    String.Format("unknown format value, the following values recognized (case insensitive)\n{0}", GetValidEnumLevels(enumType)),
   952	                    keyName);
   953	                }
   954	            }
   955	        }
   956	
   957	        private static HashSet<int> ParseMsLevel(string inputString)
   958	        {
   959	            try
   960	            {
   961	                var levelIterator = new NumberIterator(inputString, 1, 10);
   962	                return new HashSet<int>(levelIterator.IterateScans());
   963	            }
   964	            catch (Exception ex)
   965	            {
   966	                throw new OptionException($"Cannot parse MS level from {inputString} - {ex.Message}", "msLevel");
   967	            }
   968	        }
   969	    }
