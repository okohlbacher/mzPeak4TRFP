   117	        [Test]
   118	        public void RefNull_NoneAbsoluteDelta_DecodesLikeReference()
   119	        {
   120	            // Reproduces refs/mzPeak/small.chunked.mzpeak row 1 (spectrum 0): a leading null, then an
   121	            // absolute restart, then consecutive deltas. The leading (null,null) pair is dropped.
   122	            double start = 252.96545361882283;
   123	            var values = new double?[]
   124	            {
   125	                null,
   126	                252.96545361882283,
   127	                0.00038742706865946275,
   128	                0.00038742825540794,
   129	                0.00038742944209957386,
   130	                0.00038743062887647284
   131	            };
   132	            var inten = new float?[] { null, 1328.245849609375f, 3272.78173828125f, 4725.3662109375f,
   133	                4891.2607421875f, 3677.263671875f };
   134	
   135	            var dmz = MzPeakChunkCodec.DeltaDecode(start, values);
   136	            var pairs = new List<(double, float)>();
   137	            for (int i = 0; i < dmz.Length; i++)
   138	                if (dmz[i].HasValue && inten[i].HasValue) pairs.Add((dmz[i].Value, inten[i].Value));
   139	
   140	            Assert.That(pairs.Count, Is.EqualTo(5), "the leading (null,null) pair is dropped");
   141	            Assert.That(MzBits(pairs[0].Item1), Is.EqualTo(MzBits(252.96545361882283)),
   142	                "post-null value is an absolute restart");
   143	            Assert.That(MzBits(pairs[1].Item1),
   144	                Is.EqualTo(MzBits(252.96545361882283 + 0.00038742706865946275)),
   145	                "subsequent deltas apply cumulatively");
   146	            Assert.That(pairs[0].Item2, Is.EqualTo(1328.245849609375f));
   147	            Assert.That(pairs[1].Item2, Is.EqualTo(3272.78173828125f));
   148	        }
