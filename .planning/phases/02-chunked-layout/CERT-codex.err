   497	        [Test]
   498	        public void WrittenFile_ReportsZstdCompression()
   499	        {
   500	            var spectrum = new StructField("spectrum", new DataField<ulong>("index"));
   501	            var schema = new ParquetSchema(spectrum);
   502	            var cols = new Dictionary<DataField, (Array, int[], int[])>
   503	            {
   504	                [Leaf(schema, "spectrum/index")] = (new ulong[] { 0 }, new[] { 1 }, null)
   505	            };
   506	
   507	            var ms = new MemoryStream();
   508	            MzPeakParquet.WriteAsync(ms, schema, new Dictionary<string, string>(),
   509	                cols.ToDictionary(kv => kv.Key, kv => kv.Value)).GetAwaiter().GetResult();
   510	
   511	            ms.Position = 0;
   512	            using (var reader = ParquetReader.CreateAsync(ms).Result)
   513	            {
   514	                var columns = reader.Metadata.RowGroups[0].Columns;
   515	                Assert.That(columns, Is.Not.Empty);
   516	                foreach (var c in columns)
   517	                    Assert.That(c.MetaData.Codec, Is.EqualTo(Parquet.Meta.CompressionCodec.ZSTD));
   518	
   519	                var rg = reader.OpenRowGroupReader(0);
   520	                var col = rg.ReadColumnAsync(Leaf(schema, "spectrum/index")).Result;
   521	                Assert.That(col.Data, Is.EqualTo(new ulong[] { 0 }));
   522	            }
