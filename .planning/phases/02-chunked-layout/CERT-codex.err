   868	/// Partition a sorted numerical array into segments spanning no more than `width` units.
   869	///
   870	/// This operation is null-aware, so sparse arrays can be partitioned.
   871	pub fn null_chunk_every_k<T: ArrowPrimitiveType>(
   872	    array: &PrimitiveArray<T>,
   873	    width: T::Native,
   874	) -> Vec<SimpleInterval<usize>>
   875	where
   876	    T::Native: Float,
   877	{
   878	    let n = array.len();
   879	    let start = array.iter().find_map(|v| v);
   880	    if start.is_none() {
   881	        return vec![SimpleInterval::new(0, n)];
   882	    }
   883	
   884	    let mut chunks = Vec::new();
   885	    let mut offset = 0;
   886	    let mut threshold = start.unwrap() + width;
   887	    let mut i = 0;
   888	    while i < n {
   889	        if array.is_valid(i) {
   890	            let v = array.value(i);
   891	            if v > threshold {
   892	                // If the next value is null, then skip ahead an extra step.
   893	                // Nulls are supposed to be paired.
   894	                if (i + 1 < n) && array.is_null(i + 1) {
   895	                    while (i + 1 < n) && array.is_null(i + 1) {
   896	                        i += 1;
   897	                    }
   898	                    i = i.min(array.len());
   899	                }
   900	
   901	                // We don't want to create a chunk of length 1, especially not if it is a null
   902	                // point.
   903	                if i - offset != 1 {
   904	                    chunks.push(SimpleInterval::new(offset, i));
   905	                    offset = i;
   906	                }
   907	                while threshold < v {
   908	                    threshold = threshold + width;
   909	                }
   910	            }
   911	        } else if ((i + 1) < n) && (array.is_valid(i + 1)) {
   912	            i += 1;
   913	            let v = array.value(i);
   914	            if v > threshold {
   915	                i -= 1;
   916	                chunks.push(SimpleInterval::new(offset, i));
   917	                offset = i;
   918	                while threshold < v {
   919	                    threshold = threshold + width;
   920	                }

