   306	        [Test]
   307	        public void Peaks_Routes_Only_Profile_Scans_With_CentroidStream_NoDuplication()
   308	        {
   309	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   310	            var dir = Convert(input, out var archive);
   311	            try
   312	            {
   313	                var peaksBytes = ReadEntry(archive, "spectra_peaks.parquet");
   314	                Assert.That(peaksBytes, Is.Not.Null, "small.RAW must produce spectra_peaks.parquet");
   315	
   316	                var indexJson = JObject.Parse(
   317	                    System.Text.Encoding.UTF8.GetString(ReadEntry(archive, "mzpeak_index.json")));
   318	                var peaksEntry = ((JArray)indexJson["files"])
   319	                    .FirstOrDefault(f => (string)f["name"] == "spectra_peaks.parquet");
   320	                Assert.That(peaksEntry, Is.Not.Null, "index must list spectra_peaks when the facet is written");
   321	                Assert.That((string)peaksEntry["data_kind"], Is.EqualTo("peaks"));
   322	
   323	                var data = ReadPointFacet(ReadEntry(archive, "spectra_data.parquet"));
   324	                var peaks = ReadPointFacet(peaksBytes);
   325	
   326	                Assert.That(peaks.Mz.Length, Is.EqualTo(peaks.PointCount));
   327	                var peakSpectra = peaks.SpectrumIndex.Distinct().ToHashSet();
   328	                Assert.That(peakSpectra.Count, Is.EqualTo(peaks.SpectrumCount),
   329	                    "spectra_peaks must carry one ordinal per qualifying scan, no duplication");
   330	                Assert.That(peakSpectra.Count, Is.GreaterThan(0), "small.RAW has profile scans with a centroid stream");
   331	
   332	                var dataSpectra = data.SpectrumIndex.Distinct().ToHashSet();
   333	                Assert.That(peakSpectra.IsSubsetOf(dataSpectra) && !peakSpectra.SetEquals(dataSpectra), Is.True,
   334	                    "peaks ordinals must be a strict subset of spectra_data ordinals (centroid-only scans absent)");
   335	
   336	                int qualifying = CountProfileWithCentroidStreamScans();
   337	                Assert.That(peakSpectra.Count, Is.LessThanOrEqualTo(qualifying),
   338	                    "no scan outside the profile+centroid-stream set may appear in spectra_peaks");
   339	                Assert.That(qualifying, Is.GreaterThan(0));
   340	            }
   341	            finally
   342	            {
   343	                Directory.Delete(dir, true);
   344	            }
   345	        }
