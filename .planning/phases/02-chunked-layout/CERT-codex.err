   340	        [Test]
   341	        public void BitwiseMultiset_Chunked_Equals_Point()
   342	        {
   343	            var chunked = Convert(false, out var cdir);
   344	            var pointed = Convert(true, out var pdir);
   345	            try
   346	            {
   347	                // Decode chunked m/z with the null-aware delta decode, build per-spectrum BITWISE keys
   348	                // (DoubleToInt64Bits / SingleToInt32Bits), and compare the multisets to the point facet.
   349	                var decodeSnippet =
   350	                    "import pyarrow.parquet as pq, json, struct\n" +
   351	                    "from collections import defaultdict\n" +
