  1125	        private byte[] BuildMetadataFacet(List<Record> records)
  1126	        {
  1127	            int n = records.Count;
  1128	
  1129	            var spectrum = BuildSpectrumField();
  1130	            var scan = BuildScanField();
  1131	            var precursor = BuildPrecursorField();
  1132	            var selectedIon = BuildSelectedIonField();
  1133	            var schema = new ParquetSchema(spectrum, scan, precursor, selectedIon);
  1134	
  1135	            var cols = new Dictionary<DataField, (Array, int[], int[])>();
  1136	            var presentAll = records.Select(_ => true).ToArray();
  1137	
  1138	            // precursor / selected_ion are independent tables: the k-th MSn (ascending ordinal) sits
  1139	            // at row k, null-padded on rows M..N-1.
  1140	            var msnRecords = records.Where(r => r.IsMsn).OrderBy(r => r.Ordinal).ToList();
  1141	
  1142	            // spectrum facet (present on all N rows)
  1143	            AddScalar(cols, schema, "spectrum/index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1144	            AddScalar(cols, schema, "spectrum/id", records.Select(r => r.Id).ToArray(), presentAll);
  1145	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000511", "ms_level"),
  1146	                records.Select(r => (byte)r.MsLevel).ToArray(), presentAll);
  1147	            AddScalar(cols, schema, "spectrum/time", records.Select(r => r.Time).ToArray(), presentAll);
  1148	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000465", "scan_polarity"),
  1149	                records.Select(r => r.Polarity).ToArray(), presentAll);
  1150	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000525", "spectrum_representation"),
  1151	                records.Select(r => r.Representation).ToArray(), presentAll);
  1152	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000559", "spectrum_type"),
  1153	                records.Select(r => r.SpectrumType).ToArray(), presentAll);
  1154	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"),
  1155	                records.Select(r => r.LowestMz).ToArray(), presentAll);
  1156	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000527", "highest_observed_mz", "MS:1000040"),
  1157	                records.Select(r => r.HighestMz).ToArray(), presentAll);
  1158	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1003060", "number_of_data_points"),
  1159	                records.Select(r => r.DataPointCount).ToArray(), presentAll);
  1160	
  1161	            // number_of_peaks: present only where peaks were written (leaf-null otherwise).
  1162	            var npkLeaf = Leaf(schema, "spectrum/" + Cv("MS:1003059", "number_of_peaks"));
  1163	            var npkRows = records.Select(r => r.PeakCount.HasValue
  1164	                ? MzPeakParquet.Present(npkLeaf)
  1165	                : MzPeakParquet.AtLevel(npkLeaf.MaxDefinitionLevel - 1, false)).ToArray();
  1166	            var (npkDef, _) = MzPeakParquet.NestedLevels(npkLeaf, npkRows);
  1167	            cols[npkLeaf] = (records.Where(r => r.PeakCount.HasValue).Select(r => r.PeakCount.Value).ToArray(), npkDef, null);
  1168	
  1169	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000504", "base_peak_mz", "MS:1000040"),
  1170	                records.Select(r => r.BasePeakMz).ToArray(), presentAll);
  1171	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000505", "base_peak_intensity", "MS:1000131"),
  1172	                records.Select(r => r.BasePeakIntensity).ToArray(), presentAll);
  1173	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000285", "total_ion_current", "MS:1000131"),
  1174	                records.Select(r => r.TotalIonCurrent).ToArray(), presentAll);
  1175	
  1176	            AddParamList(cols, schema, "spectrum/parameters", records.Select(r => r.SpectrumParams).ToList(), presentAll);
  1177	
  1178	            // scan facet (present on all N rows)
  1179	            AddScalar(cols, schema, "scan/source_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1180	            AddScalar(cols, schema, "scan/scan_index", records.Select(r => r.Ordinal).ToArray(), presentAll);
  1181	            AddScalar(cols, schema, "scan/" + Cv("MS:1000016", "scan_start_time", "UO:0000031"),
  1182	                records.Select(r => r.ScanStartTime).ToArray(), presentAll);
  1183	            AddScalar(cols, schema, "scan/" + Cv("MS:1000512", "filter_string"),
  1184	                records.Select(r => r.FilterString).ToArray(), presentAll);
  1185	            AddScalar(cols, schema, "scan/" + Cv("MS:1000927", "ion_injection_time", "UO:0000028"),
  1186	                records.Select(r => r.IonInjectionTime).ToArray(), presentAll);
  1187	            AddScalar(cols, schema, "scan/instrument_configuration_ref",
  1188	                records.Select(r => r.InstrumentConfigRef).ToArray(), presentAll);
  1189	            AddScanWindows(cols, schema, records);
  1190	
  1191	            // precursor facet (present on rows 0..M-1, null on M..N-1)
  1192	            AddMsnScalar(cols, schema, "precursor/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
  1193	            AddMsnPrecursorIndex(cols, schema, "precursor/precursor_index", n, msnRecords);
  1194	            AddMsnString(cols, schema, "precursor/precursor_id", n, msnRecords.Select(r => r.PrecursorId).ToArray());
  1195	            AddMsnScalar(cols, schema, "precursor/isolation_window/" + Cv("MS:1000827", "isolation_window_target_mz"),
  1196	                n, msnRecords.Select(r => r.IsolationTarget).ToArray());
  1197	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"),
  1198	                n, msnRecords.Select(r => r.IsolationLowerOffset).ToArray());
  1199	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"),
  1200	                n, msnRecords.Select(r => r.IsolationUpperOffset).ToArray());
  1201	            AddMsnParamList(cols, schema, "precursor/isolation_window/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
  1202	            AddMsnParamList(cols, schema, "precursor/activation/parameters", n, msnRecords.Select(r => r.ActivationParams).ToList());
  1203	
  1204	            // selected_ion facet (present on rows 0..M-1, null on M..N-1)
  1205	            AddMsnScalar(cols, schema, "selected_ion/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
  1206	            AddMsnPrecursorIndex(cols, schema, "selected_ion/precursor_index", n, msnRecords);
  1207	            AddMsnScalar(cols, schema, "selected_ion/" + Cv("MS:1000744", "selected_ion_mz", "MS:1000040"),
  1208	                n, msnRecords.Select(r => r.SelectedIonMz).ToArray());
  1209	            AddMsnNullableInt(cols, schema, "selected_ion/" + Cv("MS:1000041", "charge_state"),
  1210	                n, msnRecords.Select(r => r.ChargeState).ToArray());
  1211	            AddMsnNullableFloat(cols, schema, "selected_ion/" + Cv("MS:1000042", "intensity", "MS:1000131"),
  1212	                n, msnRecords.Select(r => r.SelectedIonIntensity).ToArray());
  1213	
  1214	            // Ion-mobility columns exist to match the ground-truth struct shape; the Thermo RAW path
  1215	            // carries no per-selected-ion mobility value, so they stay leaf-null on every MSn row.
  1216	            AddMsnNullableDouble(cols, schema, "selected_ion/ion_mobility_value", n, msnRecords.Select(_ => (double?)null).ToArray());
  1217	            AddMsnString(cols, schema, "selected_ion/ion_mobility_type", n, msnRecords.Select(_ => (string)null).ToArray());
  1218	            AddMsnParamList(cols, schema, "selected_ion/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
  1219	
  1220	            var custom = new Dictionary<string, string>
  1221	            {
  1222	                ["spectrum_count"] = n.ToString(),
  1223	                ["spectrum_data_point_count"] = "0",
  1224	                ["spectrum_array_index"] = SpectrumArrayIndex
  1225	            };
  1226	            AddMetadataBlocks(custom, records);
  1227	
  1228	            return WriteFacet(schema, custom, cols);
  1229	        }
