   899	        [Test]
   900	        public void Validator_Gate_ScanError_And_CvList_Absent_NoNewError()
   901	        {
   902	            var validator = ResolveValidator();
   903	            if (validator == null) Assert.Ignore("mzpeak-validate not available");
   904	
   905	            var input = new ParseInput(TestRawFile, null, null, OutputFormat.MzPeak);
   906	            var dir = Convert(input, out var archive);
   907	            var jsonPath = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName() + ".json");
   908	            try
   909	            {
   910	                var psi = new ProcessStartInfo(validator, $"\"{archive}\" --json \"{jsonPath}\"")
   911	                {
   912	                    RedirectStandardOutput = true,
   913	                    RedirectStandardError = true,
   914	                    UseShellExecute = false
   915	                };
   916	                using (var p = Process.Start(psi))
   917	                {
   918	                    p.StandardOutput.ReadToEnd();
   919	                    p.StandardError.ReadToEnd();
   920	                    p.WaitForExit();
   921	                }
   922	
   923	                Assert.That(File.Exists(jsonPath), "validator must emit a JSON report");
   924	                var report = JObject.Parse(File.ReadAllText(jsonPath));
   925	                var errorIds = ((JArray)report["findings"])
   926	                    .Where(f => (string)f["level"] == "error")
   927	                    .Select(f => (string)f["ruleId"])
   928	                    .ToHashSet();
   929	
   930	                // The pre-existing reference-archive failures; our writer introduces none of them.
   931	                var allowlist = new HashSet<string> { "index_schema_valid", "cv_list_declared" };
   932	
   933	                Assert.That(errorIds, Does.Not.Contain("columns_spectra_metadata"),
   934	                    "scan-facet error must be cleared");
   935	                Assert.That(errorIds, Does.Not.Contain("cv_list_declared"),
   936	                    "cv_list_declared must be cleared by the generated cv_list");
   937	                var newErrors = errorIds.Except(allowlist).ToArray();
   938	                Assert.That(newErrors, Is.Empty,
   939	                    $"no new ERROR id beyond the pre-existing allowlist: {string.Join(",", newErrors)}");
   940	            }
   941	            finally
   942	            {
   943	                if (File.Exists(jsonPath)) File.Delete(jsonPath);
   944	                Directory.Delete(dir, true);
   945	            }
   946	        }
