                            let it = fill_nulls_for(it, model);
                            accumulator.push(start_value as f32).unwrap();
                            accumulator.extend(&it).unwrap();
                        } else {
                            accumulator.push(start_value as f32).unwrap();
                            accumulator.extend(it.values()).unwrap();
                        }
