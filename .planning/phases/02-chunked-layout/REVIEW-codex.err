                            accumulator.push(start_value as f64).unwrap();
                            accumulator.extend(&it).unwrap();
                        } else {
                            accumulator.push(start_value).unwrap();
                            accumulator.extend(it.values()).unwrap();
                        }
                    } else {
                        accumulator.push(start_value).unwrap();
                        accumulator.extend(it.values()).unwrap();
