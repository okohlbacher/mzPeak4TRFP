   566	
   567	        private string Cv(string accession, string label, string unit = null)
   568	        {
   569	            CollectPrefix(accession);
   570	            if (unit != null) CollectPrefix(unit);
   571	            return MzPeakParquet.CvColumn(accession, label, unit);
   572	        }
   573	
   574	        private void CollectPrefix(string curie)
   575	        {
   576	            if (string.IsNullOrEmpty(curie)) return;
   577	            var i = curie.IndexOf(':');
   578	            if (i > 0) _cvPrefixes.Add(curie.Substring(0, i));
   579	        }
   580	
   581	        private static void AddScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   582	            string path, Array values, bool[] present, int[] _)
   583	        {
   584	            var leaf = Leaf(schema, path);
   585	            var rows = present.Select(p => p ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
   586	            var (def, _r) = MzPeakParquet.NestedLevels(leaf, rows);
   587	            cols[leaf] = (values, def, null);
   588	        }
   589	
   590	        // A scalar leaf inside a top-level struct present only on the first M rows (the MSn count),
   591	        // null on rows M..N-1. values has length M (one per MSn).
   592	        private static void AddMsnScalar(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   593	            string path, int n, Array values)
   594	        {
   595	            var leaf = Leaf(schema, path);
   596	            int m = values.Length;
   597	            var rows = Enumerable.Range(0, n)
   598	                .Select(i => i < m ? MzPeakParquet.Present(leaf) : MzPeakParquet.Absent()).ToArray();
   599	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   600	            cols[leaf] = (values, def, null);
   601	        }
   602	
   603	        private static void AddMsnString(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   604	            string path, int n, string[] values)
   605	        {
   606	            var leaf = Leaf(schema, path);
   607	            int m = values.Length;
   608	            var rows = new List<MzPeakParquet.LeafRow>();
   609	            var present = new List<string>();
   610	            for (int i = 0; i < n; i++)
   611	            {
   612	                if (i >= m) rows.Add(MzPeakParquet.Absent());
   613	                else if (values[i] != null) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i]); }
   614	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
   615	            }
   616	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   617	            cols[leaf] = (present.ToArray(), def, null);
   618	        }
   619	
   620	        private static void AddMsnPrecursorIndex(IDictionary<DataField, (Array, int[], int[])> cols,
   621	            ParquetSchema schema, string path, int n, List<Record> msn)
   622	        {
   623	            var leaf = Leaf(schema, path);
   624	            int m = msn.Count;
   625	            var rows = new List<MzPeakParquet.LeafRow>();
   626	            var present = new List<ulong>();
   627	            for (int i = 0; i < n; i++)
   628	            {
   629	                if (i >= m) rows.Add(MzPeakParquet.Absent());
   630	                else if (msn[i].PrecursorIndex.HasValue)
   631	                { rows.Add(MzPeakParquet.Present(leaf)); present.Add(msn[i].PrecursorIndex.Value); }
   632	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
   633	            }
   634	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   635	            cols[leaf] = (present.ToArray(), def, null);
   636	        }
   637	
   638	        private static void AddMsnNullableFloat(IDictionary<DataField, (Array, int[], int[])> cols,
   639	            ParquetSchema schema, string path, int n, float?[] values)
   640	        {
   641	            var leaf = Leaf(schema, path);
   642	            int m = values.Length;
   643	            var rows = new List<MzPeakParquet.LeafRow>();
   644	            var present = new List<float>();
   645	            for (int i = 0; i < n; i++)
   646	            {
   647	                if (i >= m) rows.Add(MzPeakParquet.Absent());
   648	                else if (values[i].HasValue) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i].Value); }
   649	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
   650	            }
   651	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   652	            cols[leaf] = (present.ToArray(), def, null);
   653	        }
