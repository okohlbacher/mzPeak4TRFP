                Assert.That((string)m["version"], Is.Not.Null.And.Not.Empty);

                var ics = (JArray)m["instrument_configuration_list"];
                Assert.That(ics.Count, Is.EqualTo(2), "small.RAW yields two distinct analyzers");
                foreach (var ic in ics)
