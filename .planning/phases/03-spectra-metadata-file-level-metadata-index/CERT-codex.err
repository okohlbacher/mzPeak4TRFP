   369	        private static void AddStored(ZipArchive zip, string name, byte[] bytes)
   370	        {
   371	            var entry = zip.CreateEntry(name, CompressionLevel.NoCompression);
   372	            using (var s = entry.Open())
   373	            {
   374	                s.Write(bytes, 0, bytes.Length);
   375	            }
   430	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000525", "spectrum_representation"),
   431	                records.Select(r => r.Representation).ToArray(), presentAll, null);
   432	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000559", "spectrum_type"),
   433	                records.Select(r => r.SpectrumType).ToArray(), presentAll, null);
   434	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"),
   435	                records.Select(r => r.LowestMz).ToArray(), presentAll, null);
   436	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000527", "highest_observed_mz", "MS:1000040"),
   437	                records.Select(r => r.HighestMz).ToArray(), presentAll, null);
   438	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1003060", "number_of_data_points"),
   439	                records.Select(r => r.DataPointCount).ToArray(), presentAll, null);
   440	
   441	            // number_of_peaks: present only where peaks were written (leaf-null otherwise).
   442	            var npkLeaf = Leaf(schema, "spectrum/" + Cv("MS:1003059", "number_of_peaks"));
   443	            var npkRows = records.Select(r => r.PeakCount.HasValue
   444	                ? MzPeakParquet.Present(npkLeaf)
   445	                : MzPeakParquet.AtLevel(npkLeaf.MaxDefinitionLevel - 1, false)).ToArray();
   446	            var (npkDef, _) = MzPeakParquet.NestedLevels(npkLeaf, npkRows);
   447	            cols[npkLeaf] = (records.Where(r => r.PeakCount.HasValue).Select(r => r.PeakCount.Value).ToArray(), npkDef, null);
   448	
   449	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000504", "base_peak_mz", "MS:1000040"),
   450	                records.Select(r => r.BasePeakMz).ToArray(), presentAll, null);
   451	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000505", "base_peak_intensity", "MS:1000131"),
   452	                records.Select(r => r.BasePeakIntensity).ToArray(), presentAll, null);
   453	            AddScalar(cols, schema, "spectrum/" + Cv("MS:1000285", "total_ion_current", "MS:1000131"),
   454	                records.Select(r => r.TotalIonCurrent).ToArray(), presentAll, null);
   455	
   456	            AddParamList(cols, schema, "spectrum/parameters", records.Select(r => r.SpectrumParams).ToList(), presentAll);
   457	
   458	            // scan facet (present on all N rows)
   459	            AddScalar(cols, schema, "scan/source_index", records.Select(r => r.Ordinal).ToArray(), presentAll, null);
   460	            AddScalar(cols, schema, "scan/scan_index", records.Select(r => r.Ordinal).ToArray(), presentAll, null);
   461	            AddScalar(cols, schema, "scan/" + Cv("MS:1000016", "scan_start_time", "UO:0000031"),
   462	                records.Select(r => r.ScanStartTime).ToArray(), presentAll, null);
   463	            AddScalar(cols, schema, "scan/" + Cv("MS:1000512", "filter_string"),
   464	                records.Select(r => r.FilterString).ToArray(), presentAll, null);
   465	            AddScalar(cols, schema, "scan/" + Cv("MS:1000927", "ion_injection_time", "UO:0000028"),
   466	                records.Select(r => r.IonInjectionTime).ToArray(), presentAll, null);
   467	            AddScalar(cols, schema, "scan/instrument_configuration_ref",
   468	                records.Select(r => r.InstrumentConfigRef).ToArray(), presentAll, null);
   469	            AddScanWindows(cols, schema, records, presentAll);
   470	
   471	            // precursor facet (present on rows 0..M-1, null on M..N-1)
   472	            AddMsnScalar(cols, schema, "precursor/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   473	            AddMsnPrecursorIndex(cols, schema, "precursor/precursor_index", n, msnRecords);
   474	            AddMsnString(cols, schema, "precursor/precursor_id", n, msnRecords.Select(r => r.PrecursorId).ToArray());
   475	            AddMsnScalar(cols, schema, "precursor/isolation_window/" + Cv("MS:1000827", "isolation_window_target_mz"),
   476	                n, msnRecords.Select(r => r.IsolationTarget).ToArray());
   477	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"),
   478	                n, msnRecords.Select(r => r.IsolationLowerOffset).ToArray());
   479	            AddMsnNullableFloat(cols, schema, "precursor/isolation_window/" + Cv("MS:1000829", "isolation_window_upper_offset", "MS:1000040"),
   480	                n, msnRecords.Select(r => r.IsolationUpperOffset).ToArray());
   481	            AddMsnParamList(cols, schema, "precursor/isolation_window/parameters", n, msnRecords.Select(_ => new List<Param>()).ToList());
   482	            AddMsnParamList(cols, schema, "precursor/activation/parameters", n, msnRecords.Select(r => r.ActivationParams).ToList());
   483	
   484	            // selected_ion facet (present on rows 0..M-1, null on M..N-1)
   485	            AddMsnScalar(cols, schema, "selected_ion/source_index", n, msnRecords.Select(r => r.Ordinal).ToArray());
   486	            AddMsnPrecursorIndex(cols, schema, "selected_ion/precursor_index", n, msnRecords);
   487	            AddMsnScalar(cols, schema, "selected_ion/" + Cv("MS:1000744", "selected_ion_mz", "MS:1000040"),
   488	                n, msnRecords.Select(r => r.SelectedIonMz).ToArray());
   489	            AddMsnNullableInt(cols, schema, "selected_ion/" + Cv("MS:1000041", "charge_state"),
   490	                n, msnRecords.Select(r => r.ChargeState).ToArray());
   491	            AddMsnNullableFloat(cols, schema, "selected_ion/" + Cv("MS:1000042", "intensity", "MS:1000131"),
   492	                n, msnRecords.Select(r => r.SelectedIonIntensity).ToArray());
   493	
   494	            var custom = new Dictionary<string, string>
   495	            {
   496	                ["spectrum_count"] = n.ToString(),
   497	                ["spectrum_data_point_count"] = "0",
   498	                ["spectrum_array_index"] = SpectrumArrayIndex
   499	            };
   500	            AddMetadataBlocks(custom, records);
   501	
   502	            return WriteFacet(schema, custom, cols);
   503	        }
   504	
   505	        private StructField BuildSpectrumField()
   506	        {
   507	            return new StructField("spectrum",
   508	                new DataField<ulong>("index", true),
   509	                new DataField<string>("id", true),
   510	                new DataField<byte>(Cv("MS:1000511", "ms_level"), true),
   511	                new DataField<double>("time", true),
   512	                new DataField<sbyte>(Cv("MS:1000465", "scan_polarity"), true),
   513	                new DataField<string>(Cv("MS:1000525", "spectrum_representation"), true),
   514	                new DataField<string>(Cv("MS:1000559", "spectrum_type"), true),
   515	                new DataField<double>(Cv("MS:1000528", "lowest_observed_mz", "MS:1000040"), true),
   516	                new DataField<double>(Cv("MS:1000527", "highest_observed_mz", "MS:1000040"), true),
   517	                new DataField<ulong>(Cv("MS:1003060", "number_of_data_points"), true),
   518	                new DataField<ulong>(Cv("MS:1003059", "number_of_peaks"), true),
   519	                new DataField<double>(Cv("MS:1000504", "base_peak_mz", "MS:1000040"), true),
   520	                new DataField<float>(Cv("MS:1000505", "base_peak_intensity", "MS:1000131"), true),
   521	                new DataField<float>(Cv("MS:1000285", "total_ion_current", "MS:1000131"), true),
   522	                new ListField("parameters", MzPeakParquet.BuildParamField("item")));
   523	        }
   524	
   525	        private StructField BuildScanField()
   526	        {
   527	            var window = new StructField("item",
   528	                new DataField<float>(Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"), true),
   529	                new DataField<float>(Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"), true));
   530	            return new StructField("scan",
   531	                new DataField<ulong>("source_index", true),
   532	                new DataField<ulong>("scan_index", true),
   533	                new DataField<float>(Cv("MS:1000016", "scan_start_time", "UO:0000031"), true),
   534	                new DataField<string>(Cv("MS:1000512", "filter_string"), true),
   535	                new DataField<float>(Cv("MS:1000927", "ion_injection_time", "UO:0000028"), true),
   536	                new DataField<uint>("instrument_configuration_ref", true),
