   306	        private void BuildPrecursor(IRawDataPlus raw, int scanNumber, IScanEvent scanEvent,
   307	            IScanFilter scanFilter, ScanTrailer trailer, IDictionary<int, ulong> scanNumberToOrdinal,
   308	            string filterKey, Record rec)
   309	        {
   310	            rec.IsMsn = true;
   311	
   312	            // Parent scan via Master Scan Number trailer, falling back to the scan-string parent the
   313	            // mzML path derives. Map the parent scan number to its emitted ordinal; if the parent was
   314	            // filtered out / not emitted, keep the precursor entry but leave precursor_index null.
   315	            int parentScan;
   316	            var master = trailer.AsPositiveInt("Master Scan Number:");
   317	            if (master.HasValue) parentScan = master.Value;
   318	            else parentScan = GetParentFromScanString(filterKey);
   319	
   320	            if (parentScan > 0 && scanNumberToOrdinal.TryGetValue(parentScan, out var p))
   321	            {
   322	                rec.PrecursorIndex = p;
   323	                rec.PrecursorId = ConstructSpectrumTitle((int)Device.MS, 1, parentScan);
   324	            }
   325	
   326	            var reaction = GetReaction(scanEvent, scanNumber);
   327	            if (reaction == null) return;
   328	
   329	            double? isolationWidth = reaction.IsolationWidth;
   330	            if (isolationWidth < 0) isolationWidth = null;
   331	
   332	            rec.IsolationTarget = (float)reaction.PrecursorMass;
   333	            if (isolationWidth != null)
   334	            {
   335	                var offset = isolationWidth.Value / 2 + reaction.IsolationWidthOffset;
   336	                rec.IsolationLowerOffset = (float)(isolationWidth.Value - offset);
   337	                rec.IsolationUpperOffset = (float)offset;
   338	            }
   339	
   340	            if (OntologyMapping.DissociationTypes.TryGetValue(reaction.ActivationType, out var diss))
   341	            {
   342	                rec.ActivationParams.Add(new Param { Accession = diss.accession, Name = diss.name });
   343	            }
   344	
   345	            if (reaction.CollisionEnergyValid)
   346	            {
   347	                rec.ActivationParams.Add(new Param
   348	                {
   349	                    Accession = "MS:1000045",
   350	                    Name = "collision energy",
   351	                    Float = reaction.CollisionEnergy,
   352	                    Unit = "UO:0000266"
   353	                });
   354	            }
   355	
   356	            int? charge = trailer.AsPositiveInt("Charge State:");
   357	            double? monoisotopicMz = trailer.AsDouble("Monoisotopic M/Z:");
   358	            rec.SelectedIonMz = CalculateSelectedIonMz(reaction, monoisotopicMz, isolationWidth);
   359	            rec.ChargeState = charge;
   360	
   361	            if (rec.SelectedIonMz > ZeroDelta && parentScan > 0)
   362	            {
   363	                rec.SelectedIonIntensity = (float)CalculatePrecursorPeakIntensity(raw, parentScan,
   364	                    reaction.PrecursorMass, isolationWidth,
   365	                    ParseInput.NoPeakPicking.Contains(rec.MsLevel - 1));
   366	            }
   367	        }
