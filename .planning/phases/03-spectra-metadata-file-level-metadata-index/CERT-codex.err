   914	                {
   915	                    CvParam(model.accession, model.name, model.value),
   916	                    CvParam("MS:1000529", "instrument serial number", _instrumentSerial)
   917	                };
   918	                var components = new JArray
   919	                {
   920	                    Component("ionsource", 1, ionization),
   921	                    Component("analyzer", 2, analyzer),
   922	                    Component("detector", 3, detector)
   923	                };
   924	                list.Add(new JObject
   925	                {
   926	                    ["id"] = i,
   927	                    ["software_reference"] = "ThermoRawFileParser",
   928	                    ["parameters"] = configParams,
   929	                    ["components"] = components
   930	                });
