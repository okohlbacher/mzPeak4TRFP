   135	        public static LeafRow EmptyList(ListField list) =>
   136	            new LeafRow(true, new[] { list.MaxDefinitionLevel - 1 }, new[] { false });
   137	
   138	        // A null list (the owning list field is null). Def-level 0.
   139	        public static LeafRow NullList() => new LeafRow(true, System.Array.Empty<int>(), System.Array.Empty<bool>());
   140	
   141	        public static async Task WriteAsync(Stream output, ParquetSchema schema,
   142	            IReadOnlyDictionary<string, string> customMetadata,
   143	            IDictionary<DataField, (Array defined, int[] defLevels, int[] repLevels)> columns)
