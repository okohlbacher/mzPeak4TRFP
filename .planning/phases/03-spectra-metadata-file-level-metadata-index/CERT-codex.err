  1024	
  1025	        // A controlled-value PARAM (accession + name, no value). Records the CV prefix so the
  1026	        // generated cv_list stays exhaustive.
  1027	        private JObject CvParam(string accession, string name, string value)
  1028	        {
  1029	            CollectPrefix(accession);
  1030	            return JParam(name, accession, string.IsNullOrEmpty(value) ? null : value, null);
  1031	        }
  1032	
  1033	        // A PARAM object matching the param.json schema (name required; accession/value/unit nullable).
  1034	        private JObject JParam(string name, string accession, object value, string unit)
  1035	        {
  1036	            CollectPrefix(unit);
  1037	            return new JObject
  1038	            {
  1039	                ["name"] = name,
  1040	                ["accession"] = accession == null ? JValue.CreateNull() : new JValue(accession),
  1041	                ["value"] = value == null ? JValue.CreateNull() : JToken.FromObject(value),
  1042	                ["unit"] = unit == null ? JValue.CreateNull() : new JValue(unit)
  1043	            };
  1044	        }
  1045	
  1046	        private byte[] BuildIndex(bool hasPeaks)
  1047	        {
  1048	            var files = new JArray
  1049	            {
  1050	                new JObject
  1051	                {
  1052	                    ["name"] = "spectra_data.parquet",
  1053	                    ["entity_type"] = "spectrum",
  1054	                    ["data_kind"] = "data arrays"
  1055	                },
  1056	                new JObject
  1057	                {
  1058	                    ["name"] = "spectra_metadata.parquet",
  1059	                    ["entity_type"] = "spectrum",
  1060	                    ["data_kind"] = "metadata"
  1061	                }
  1062	            };
  1063	
  1064	            if (hasPeaks)
  1065	            {
  1066	                files.Add(new JObject
  1067	                {
  1068	                    ["name"] = "spectra_peaks.parquet",
  1069	                    ["entity_type"] = "spectrum",
  1070	                    ["data_kind"] = "peaks"
  1071	                });
  1072	            }
  1073	
  1074	            var metadata = _metadataBlocks != null
  1075	                ? (JObject)_metadataBlocks.DeepClone()
  1076	                : new JObject { ["version"] = MzPeakVersion };
  1077	
  1078	            var index = new JObject
  1079	            {
  1080	                ["version"] = MzPeakVersion,
  1081	                ["files"] = files,
  1082	                ["metadata"] = metadata
  1083	            };
  1084	
  1085	            return new UTF8Encoding(false).GetBytes(index.ToString());
  1086	        }
  1087	
  1088	        private static DataField Leaf(ParquetSchema schema, string path)
  1089	        {
  1090	            foreach (var d in schema.GetDataFields())
  1091	                if (d.Path.ToString() == path) return d;
  1092	            throw new RawFileParserException($"Leaf not found: {path}");
  1093	        }
  1094	    }
  1095	}

