   540	        private StructField BuildPrecursorField()
   541	        {
   542	            var isolationWindow = new StructField("isolation_window",
   543	                new DataField<float>(Cv("MS:1000827", "isolation_window_target_mz"), true),
   544	                new DataField<float>(Cv("MS:1000828", "isolation_window_lower_offset", "MS:1000040"), true),
