   655	        private static void AddMsnNullableInt(IDictionary<DataField, (Array, int[], int[])> cols,
   656	            ParquetSchema schema, string path, int n, int?[] values)
   657	        {
   658	            var leaf = Leaf(schema, path);
   659	            int m = values.Length;
   660	            var rows = new List<MzPeakParquet.LeafRow>();
   661	            var present = new List<int>();
   662	            for (int i = 0; i < n; i++)
   663	            {
   664	                if (i >= m) rows.Add(MzPeakParquet.Absent());
   665	                else if (values[i].HasValue) { rows.Add(MzPeakParquet.Present(leaf)); present.Add(values[i].Value); }
   666	                else rows.Add(MzPeakParquet.AtLevel(leaf.MaxDefinitionLevel - 1, false));
   667	            }
   668	            var (def, _) = MzPeakParquet.NestedLevels(leaf, rows);
   669	            cols[leaf] = (present.ToArray(), def, null);
   670	        }
   671	
   672	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
   673	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   674	            string listPath, int n, List<List<Param>> perRow)
   675	        {
   676	            int m = perRow.Count;
   677	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
   678	            var padded = new List<List<Param>>();
   679	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
   680	            AddParamList(cols, schema, listPath, padded, structPresent);
   681	        }
   682	
   683	        private void AddParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   684	            string listPath, List<List<Param>> perRow, bool[] structPresent)
   685	        {
   686	            var list = (ListField)FindField(schema, listPath);
   687	            var accLeaf = Leaf(schema, listPath + "/list/item/accession");
   688	            var nameLeaf = Leaf(schema, listPath + "/list/item/name");
   689	            var unitLeaf = Leaf(schema, listPath + "/list/item/unit");
   690	            var intLeaf = Leaf(schema, listPath + "/list/item/value/integer");
   691	            var fltLeaf = Leaf(schema, listPath + "/list/item/value/float");
   692	            var strLeaf = Leaf(schema, listPath + "/list/item/value/string");
   693	            var boolLeaf = Leaf(schema, listPath + "/list/item/value/boolean");
   694	
   695	            var accRows = new List<MzPeakParquet.LeafRow>();
   696	            var nameRows = new List<MzPeakParquet.LeafRow>();
   697	            var unitRows = new List<MzPeakParquet.LeafRow>();
   698	            var intRows = new List<MzPeakParquet.LeafRow>();
   699	            var fltRows = new List<MzPeakParquet.LeafRow>();
   700	            var strRows = new List<MzPeakParquet.LeafRow>();
   760	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
   761	            }
   762	            rows.Add(MzPeakParquet.ListOf(levels, has));
   763	        }
   764	
   765	        private static void AddListLeafNumStruct<T>(List<MzPeakParquet.LeafRow> rows, List<T> vals, DataField leaf,
   766	            List<Param> items, Func<Param, T?> sel) where T : struct
   767	        {
   768	            var levels = new int[items.Count];
   769	            var has = new bool[items.Count];
   770	            for (int i = 0; i < items.Count; i++)
   771	            {
   772	                var v = sel(items[i]);
   773	                if (v.HasValue) { vals.Add(v.Value); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
   774	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }
   775	            }
   776	            rows.Add(MzPeakParquet.ListOf(levels, has));
   777	        }
   778	
   779	        private static void Emit(IDictionary<DataField, (Array, int[], int[])> cols, DataField leaf,
   780	            Array values, List<MzPeakParquet.LeafRow> rows)
   781	        {
   782	            var (def, rep) = MzPeakParquet.NestedLevels(leaf, rows);
   783	            cols[leaf] = (values, def, rep);
   784	        }
   785	
   786	        private void AddScanWindows(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   787	            List<Record> records, bool[] present)
   788	        {
   789	            var lowerLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000501", "scan_window_lower_limit", "MS:1000040"));
   790	            var upperLeaf = Leaf(schema, "scan/scan_windows/list/item/" + Cv("MS:1000500", "scan_window_upper_limit", "MS:1000040"));
   791	
   792	            var lowerRows = new List<MzPeakParquet.LeafRow>();
   793	            var upperRows = new List<MzPeakParquet.LeafRow>();
   794	            var lowerVals = new List<float>();
   795	            var upperVals = new List<float>();
   796	
   797	            for (int row = 0; row < records.Count; row++)
   798	            {
   799	                lowerRows.Add(MzPeakParquet.ListOf(new[] { lowerLeaf.MaxDefinitionLevel }, new[] { true }));
   800	                upperRows.Add(MzPeakParquet.ListOf(new[] { upperLeaf.MaxDefinitionLevel }, new[] { true }));
   801	                lowerVals.Add(records[row].WindowLower);
   802	                upperVals.Add(records[row].WindowUpper);
   803	            }
   804	
   805	            Emit(cols, lowerLeaf, lowerVals.ToArray(), lowerRows);
   806	            Emit(cols, upperLeaf, upperVals.ToArray(), upperRows);
   807	        }
   808	
   809	        private static Field FindField(ParquetSchema schema, string path)
   810	        {
   811	            var parts = path.Split('/');
   812	            Field current = schema.Fields.First(f => f.Name == parts[0]);
   813	            for (int i = 1; i < parts.Length; i++)
   814	            {
   815	                current = ((StructField)current).Fields.First(f => f.Name == parts[i]);
   816	            }
   817	            return current;
   818	        }
   819	
   820	        private static byte[] WriteFacet(ParquetSchema schema, IReadOnlyDictionary<string, string> meta,
   821	            IDictionary<DataField, (Array, int[], int[])> cols)
   822	        {
   823	            using (var ms = new MemoryStream())
   824	            {
   825	                MzPeakParquet.WriteAsync(ms, schema, meta, cols).GetAwaiter().GetResult();
   826	                return ms.ToArray();
   827	            }
   828	        }
   829	
   830	        // File-level metadata blocks shared verbatim between the parquet footer KV and the index
   831	        // metadata{}. Built once after all CV-named columns/params are emitted so the generated
   832	        // cv_list covers exactly the collected CV-prefix set.
   833	        private JObject _metadataBlocks;
   834	
   835	        private void AddMetadataBlocks(IDictionary<string, string> custom, List<Record> records)
   836	        {
   837	            var instruments = BuildInstrumentConfigurations();
   838	            var software = BuildSoftwareList();
   839	            var dataProcessing = BuildDataProcessingList();
   840	            var fileDescription = BuildFileDescription(records);
   841	            var run = BuildRun();
   842	
   843	            // cv_list is generated LAST: every accession/unit routed through Cv() or a param helper
   844	            // has been recorded in _cvPrefixes by this point.
   845	            var cvList = BuildCvList();
   846	
   847	            _metadataBlocks = new JObject
   848	            {
   849	                ["version"] = MzPeakVersion,
   850	                ["cv_list"] = cvList,
   851	                ["file_description"] = fileDescription,
   852	                ["instrument_configuration_list"] = instruments,
   853	                ["software_list"] = software,
   854	                ["data_processing_method_list"] = dataProcessing,
   855	                ["run"] = run,
   856	                ["sample_list"] = new JArray(),
   857	                ["scan_settings_list"] = new JArray()
   858	            };
   859	
   860	            var enc = new UTF8Encoding(false);
   861	            custom["cv_list"] = Compact(cvList);
   862	            custom["file_description"] = Compact(fileDescription);
   863	            custom["instrument_configuration_list"] = Compact(instruments);
   864	            custom["software_list"] = Compact(software);
   865	            custom["data_processing_method_list"] = Compact(dataProcessing);
   866	            custom["run"] = Compact(run);
   867	            custom["sample_list"] = "[]";
   868	            custom["scan_settings_list"] = "[]";
   869	        }
   870	
   871	        private static string Compact(JToken token) =>
   872	            token.ToString(Newtonsoft.Json.Formatting.None);
   873	
   874	        private JArray BuildCvList()
   875	        {
   876	            var defs = new Dictionary<string, (string version, string fullName, string uri)>
   877	            {
   878	                ["MS"] = (MsCvVersion, "PSI-MS controlled vocabulary",
   879	                    "https://raw.githubusercontent.com/HUPO-PSI/psi-ms-CV/master/psi-ms.obo"),
   880	                ["UO"] = (UoCvVersion, "Unit Ontology", "http://purl.obolibrary.org/obo/uo.obo")
   881	            };
   882	
   883	            var list = new JArray();
   884	            foreach (var prefix in _cvPrefixes.OrderBy(p => p))
