   672	        // PARAM list inside a top-level struct present only on the first M rows. perRow has length M.
   673	        private void AddMsnParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   674	            string listPath, int n, List<List<Param>> perRow)
   675	        {
   676	            int m = perRow.Count;
   677	            var structPresent = Enumerable.Range(0, n).Select(i => i < m).ToArray();
   678	            var padded = new List<List<Param>>();
   679	            for (int i = 0; i < n; i++) padded.Add(i < m ? perRow[i] : new List<Param>());
   680	            AddParamList(cols, schema, listPath, padded, structPresent);
   681	        }
   682	
   683	        private void AddParamList(IDictionary<DataField, (Array, int[], int[])> cols, ParquetSchema schema,
   684	            string listPath, List<List<Param>> perRow, bool[] structPresent)
   685	        {
   686	            var list = (ListField)FindField(schema, listPath);
   687	            var accLeaf = Leaf(schema, listPath + "/list/item/accession");
   688	            var nameLeaf = Leaf(schema, listPath + "/list/item/name");
   689	            var unitLeaf = Leaf(schema, listPath + "/list/item/unit");
   690	            var intLeaf = Leaf(schema, listPath + "/list/item/value/integer");
   691	            var fltLeaf = Leaf(schema, listPath + "/list/item/value/float");
   692	            var strLeaf = Leaf(schema, listPath + "/list/item/value/string");
   693	            var boolLeaf = Leaf(schema, listPath + "/list/item/value/boolean");
   694	
   695	            var accRows = new List<MzPeakParquet.LeafRow>();
   696	            var nameRows = new List<MzPeakParquet.LeafRow>();
   697	            var unitRows = new List<MzPeakParquet.LeafRow>();
   698	            var intRows = new List<MzPeakParquet.LeafRow>();
   699	            var fltRows = new List<MzPeakParquet.LeafRow>();
   700	            var strRows = new List<MzPeakParquet.LeafRow>();
   701	            var boolRows = new List<MzPeakParquet.LeafRow>();
   702	
   703	            var accVals = new List<string>();
   704	            var nameVals = new List<string>();
   705	            var unitVals = new List<string>();
   706	            var intVals = new List<long>();
   707	            var fltVals = new List<double>();
   708	            var strVals = new List<string>();
   709	            var boolVals = new List<bool>();
   710	
   711	            for (int row = 0; row < perRow.Count; row++)
   712	            {
   713	                if (!structPresent[row])
   714	                {
   715	                    accRows.Add(MzPeakParquet.NullList()); nameRows.Add(MzPeakParquet.NullList());
   716	                    unitRows.Add(MzPeakParquet.NullList()); intRows.Add(MzPeakParquet.NullList());
   717	                    fltRows.Add(MzPeakParquet.NullList()); strRows.Add(MzPeakParquet.NullList());
   718	                    boolRows.Add(MzPeakParquet.NullList());
   719	                    continue;
   720	                }
   721	
   722	                var items = perRow[row];
   723	                if (items.Count == 0)
   724	                {
   725	                    accRows.Add(MzPeakParquet.EmptyList(list)); nameRows.Add(MzPeakParquet.EmptyList(list));
   726	                    unitRows.Add(MzPeakParquet.EmptyList(list)); intRows.Add(MzPeakParquet.EmptyList(list));
   727	                    fltRows.Add(MzPeakParquet.EmptyList(list)); strRows.Add(MzPeakParquet.EmptyList(list));
   728	                    boolRows.Add(MzPeakParquet.EmptyList(list));
   729	                    continue;
   730	                }
   731	
   732	                foreach (var it in items) { CollectPrefix(it.Accession); CollectPrefix(it.Unit); }
   733	                AddListLeaf(accRows, accVals, accLeaf, items, p => p.Accession);
   734	                AddListLeaf(nameRows, nameVals, nameLeaf, items, p => p.Name);
   735	                AddListLeaf(unitRows, unitVals, unitLeaf, items, p => p.Unit);
   736	                AddListLeafNumStruct(intRows, intVals, intLeaf, items, p => p.Integer);
   737	                AddListLeafNumStruct(fltRows, fltVals, fltLeaf, items, p => p.Float);
   738	                AddListLeaf(strRows, strVals, strLeaf, items, p => p.String);
   739	                AddListLeafNumStruct(boolRows, boolVals, boolLeaf, items, p => p.Boolean);
   740	            }
   741	
   742	            Emit(cols, accLeaf, accVals.ToArray(), accRows);
   743	            Emit(cols, nameLeaf, nameVals.ToArray(), nameRows);
   744	            Emit(cols, unitLeaf, unitVals.ToArray(), unitRows);
   745	            Emit(cols, intLeaf, intVals.ToArray(), intRows);
   746	            Emit(cols, fltLeaf, fltVals.ToArray(), fltRows);
   747	            Emit(cols, strLeaf, strVals.ToArray(), strRows);
   748	            Emit(cols, boolLeaf, boolVals.ToArray(), boolRows);
   749	        }
   750	
   751	        private static void AddListLeaf(List<MzPeakParquet.LeafRow> rows, List<string> vals, DataField leaf,
   752	            List<Param> items, Func<Param, string> sel)
   753	        {
   754	            var levels = new int[items.Count];
   755	            var has = new bool[items.Count];
   756	            for (int i = 0; i < items.Count; i++)
   757	            {
   758	                var v = sel(items[i]);
   759	                if (v != null) { vals.Add(v); levels[i] = leaf.MaxDefinitionLevel; has[i] = true; }
   760	                else { levels[i] = leaf.MaxDefinitionLevel - 1; has[i] = false; }

