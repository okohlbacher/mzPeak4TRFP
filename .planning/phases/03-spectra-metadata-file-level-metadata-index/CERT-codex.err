  1016	                ["id"] = Path.GetFileNameWithoutExtension(_sourceName),
  1017	                ["default_instrument_id"] = 0,
  1018	                ["default_data_processing_id"] = "trfp_conversion",
  1019	                ["default_source_file_id"] = "RAW1",
  1020	                ["start_time"] = _creationDate.ToUniversalTime()
  1021	                    .ToString("yyyy-MM-ddTHH:mm:ssZ", CultureInfo.InvariantCulture)
  1022	            };
